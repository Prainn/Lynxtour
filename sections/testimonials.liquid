<div class="testimonials-section">
  <div class="header-container">
    {% if section.settings.main_title != blank %}
      <div class="test-header">
        <h2 class="test-main-title">{{ section.settings.main_title }}</h2>
        <div class="title-underline"></div>
      </div>
    {% endif %}

    <div class="test-slider-relative">
      <button class="slider-nav prev" onclick="scrollSlider(-1)">&#10094;</button>
      <button class="slider-nav next" onclick="scrollSlider(1)">&#10095;</button>

      <div class="test-grid-scroll" id="TestimonialSlider">
        {%- for block in section.blocks -%}
          <div class="test-card" {{ block.shopify_attributes }}>
            <div class="quote-icon">&ldquo;</div>
            <div class="test-rating">
              {% for i in (1..5) %}
                <span class="star {% if i <= block.settings.rating %}filled{% endif %}">&#9733;</span>
              {% endfor %}
            </div>

            <div class="test-content">
              <p class="test-text" id="text-{{ block.id }}">{{ block.settings.text }}</p>
              <button class="see-more-btn" onclick="toggleText('{{ block.id }}')">See More</button>
            </div>

            <div class="test-trip-meta">
              <span class="trip-type">{{ block.settings.trip_type }}</span>
              <span class="trip-date">{{ block.settings.travel_date }}</span>
            </div>

            <div class="test-author">
              <div class="author-avatar">
                {% if block.settings.author_image != blank %}
                  <img src="{{ block.settings.author_image | img_url: '100x100', crop: 'center' }}">
                {% endif %}
              </div>
              <div class="author-info">
                <h4 class="author-name">{{ block.settings.author_name }}</h4>
                <p class="author-meta">{{ block.settings.author_meta }}</p>
              </div>
            </div>
          </div>
        {%- endfor -%}
      </div>
    </div>
  </div>
</div>

<script>
// 鎺у埗宸﹀彸婊戝姩鍔熻兘
function scrollSlider(direction) {
  const slider = document.getElementById('TestimonialSlider');
  const scrollAmount = slider.offsetWidth * 0.8; // 姣忔婊戝姩 80% 鐨勫搴?
  slider.scrollBy({
    left: direction * scrollAmount,
    behavior: 'smooth'
  });
}

// 鎺у埗鏂囧瓧灞曞紑
function toggleText(id) {
  const textElement = document.getElementById('text-' + id);
  const btnElement = textElement.nextElementSibling;
  if (textElement.classList.contains('expanded')) {
    textElement.classList.remove('expanded');
    btnElement.innerText = 'See More';
  } else {
    textElement.classList.add('expanded');
    btnElement.innerText = 'See Less';
  }
}
</script>

<style>
  .testimonials-section { background-color: #0a0a0a; padding: 80px 0; overflow: hidden; }
  .header-container { max-width: 1400px; margin: 0 auto; padding: 0 40px; }
  .test-header { text-align: center; margin-bottom: 50px; }
  .test-main-title { color: #fff; font-size: 24px; letter-spacing: 0.3em; text-transform: uppercase; font-weight: 300; }
  .title-underline { width: 40px; height: 1px; background: #fbbf24; margin: 15px auto; opacity: 0.6; }

  /* 婊戝姩瀹瑰櫒鍖呰鍣?*/
  .test-slider-relative { position: relative; display: flex; align-items: center; }

  /* 鏍稿績婊戝姩鍖哄煙 */
  .test-grid-scroll {
    display: flex;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
    gap: 20px;
    padding: 20px 0;
    scrollbar-width: none; /* Firefox 闅愯棌婊氬姩鏉?*/
  }
  .test-grid-scroll::-webkit-scrollbar { display: none; /* Chrome 闅愯棌婊氬姩鏉?*/ }

  /* 鍗＄墖灏哄璋冩暣 */
  .test-card {
    flex: 0 0 380px;
    scroll-snap-align: start;
    background: #111;
    padding: 40px;
    border: 1px solid #1a1a1a;
    position: relative;
    box-sizing: border-box;
  }

  /* 瀵艰埅鎸夐挳鏍峰紡 */
  .slider-nav {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    background: rgba(251, 191, 36, 0.1);
    border: 1px solid rgba(251, 191, 36, 0.3);
    color: #fbbf24;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    cursor: pointer;
    z-index: 10;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s;
  }
  .slider-nav:hover { background: #fbbf24; color: #000; }
  .slider-nav.prev { left: -50px; }
  .slider-nav.next { right: -50px; }

  .test-rating { color: #fbbf24; margin-bottom: 15px; font-size: 12px; }
  .test-text {
    color: #a8a29e; font-size: 14px; line-height: 1.8; font-style: italic;
    display: -webkit-box; -webkit-line-clamp: 4; -webkit-box-orient: vertical; overflow: hidden;
  }
  .test-text.expanded { -webkit-line-clamp: initial; display: block; }
  .see-more-btn { background: none; border: none; color: #fbbf24; font-size: 11px; cursor: pointer; margin: 10px 0 20px; text-transform: uppercase; }

  .test-trip-meta { display: flex; justify-content: space-between; border-top: 1px solid #1a1a1a; padding-top: 15px; margin-top: auto; }
  .trip-type, .trip-date { color: #57534e; font-size: 10px; text-transform: uppercase; }

  .test-author { display: flex; align-items: center; margin-top: 20px; }
  .author-avatar { width: 40px; height: 40px; border-radius: 50%; overflow: hidden; background: #222; margin-right: 12px; }
  .author-avatar img { width: 100%; height: 100%; object-fit: cover; }
  .author-name { color: #fff; font-size: 14px; margin: 0; }
  .author-meta { color: #57534e; font-size: 10px; margin: 0; }

  @media (max-width: 767px) {
    .testimonials-section { padding: 56px 0; }
    .test-header { margin-bottom: 28px; }
    .test-main-title { font-size: 20px; letter-spacing: 0.18em; }
    .test-grid-scroll { gap: 14px; padding: 12px 0 4px; scroll-padding-inline: 20px; }
    .test-card { flex: 0 0 calc(100vw - 40px); padding: 24px 20px; }
    .test-text { font-size: 13px; line-height: 1.75; }
    .see-more-btn { min-height: 44px; padding: 10px 0; margin: 6px 0 16px; font-size: 10px; }
    .test-trip-meta { gap: 10px; flex-wrap: wrap; }
    .test-author { margin-top: 16px; }
    .slider-nav { display: none; }
    .header-container { padding: 0 20px; }
  }

  @media (max-width: 430px) {
    .test-card { flex-basis: calc(100vw - 24px); padding: 22px 16px; }
    .header-container { padding: 0 12px; }
    .test-grid-scroll { scroll-padding-inline: 12px; }
  }
</style>

{% schema %}
{
  "name": "Testimonials Nav",
  "settings": [
    { "type": "text", "id": "main_title", "label": "Heading", "default": "GUEST REFLECTIONS" }
  ],
  "blocks": [
    {
      "type": "quote",
      "name": "Testimonial",
      "settings": [
        { "type": "range", "id": "rating", "min": 1, "max": 5, "step": 1, "label": "Rating", "default": 5 },
        { "type": "textarea", "id": "text", "label": "Content" },
        { "type": "text", "id": "trip_type", "label": "Trip Type" },
        { "type": "text", "id": "travel_date", "label": "Travel Date" },
        { "type": "text", "id": "author_name", "label": "Guest Name" },
        { "type": "text", "id": "author_meta", "label": "Guest Meta", "default": "VERIFIED EXPLORER" },
        { "type": "image_picker", "id": "author_image", "label": "Avatar" }
      ]
    }
  ],
  "presets": [
    { "name": "Testimonials Nav" }
  ]
}
{% endschema %}
