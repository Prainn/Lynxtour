</script>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "How many days should I plan for a private Yunnan tour from Malaysia?",
      "acceptedAnswer": {
        "@type": "Answer",
