<div class="luxury-collection-wrapper" id="CollectionProductGrid">

  <header class="coll-hero-compact">
    <div class="hero-bg">
      {% if collection.image %}
        <img src="{{ collection.image | img_url: '2000x' }}" alt="{{ collection.title | escape }} - Lynxtour" class="hero-img">
      {% else %}
        <div class="hero-placeholder"></div>
      {% endif %}
      <div class="hero-overlay"></div>
    </div>

    <div class="hero-text-container">
      <div class="hero-content">
        <div class="subtitle-wrap">
          <span class="coll-subtitle">
            {% if collection.handle == 'yunnan-private-day-trips' %}
              PRIVATE DAY TOURS ACROSS YUNNAN
            {% else %}
              SHORT PRIVATE JOURNEYS, DEEPER LOCAL DISCOVERY
            {% endif %}
          </span>
          <div class="subtitle-line"></div>
        </div>

        <h1 class="coll-title">
          {% if collection.handle == 'yunnan-private-day-trips' %}
            Yunnan Private Day Trips
          {% else %}
            {{ collection.title }}
          {% endif %}
        </h1>

        {% if collection.description != blank %}
          <div class="coll-desc-wrap">
            <div class="coll-desc">{{ collection.description | strip_html }}</div>
          </div>
        {% elsif collection.handle == 'yunnan-private-day-trips' %}
          <div class="coll-desc-wrap">
            <div class="coll-desc">
              Private day trips across Yunnan with flexible pacing and local-led experiences, suitable for travelers based in Kunming, Dali, Lijiang, or Shangri-La.
            </div>
          </div>
        {% endif %}
      </div>
    </div>
  </header>

  <div class="coll-container">
    <div class="coll-meta-bar">
      <div class="meta-left">
        <span class="meta-number">{{ collection.products_count }}</span>
        <span class="meta-label">Selected Experiences</span>
      </div>
      <div class="meta-divider"></div>
      <div class="meta-right">
        <span class="meta-location">
          {% if collection.handle == 'yunnan-private-day-trips' %}
            KUNMING • DALI • LIJIANG • SHANGRI-LA
          {% else %}
            Kunming, Yunnan
          {% endif %}
        </span>
      </div>
    </div>

    {% paginate collection.products by 12 %}

      {% if collection.handle == 'yunnan-private-day-trips' and paginate.current_page == 1 %}
        <section class="seo-copy seo-copy-top">
          <div class="seo-copy-inner">
            <p class="seo-eyebrow">YUNNAN PRIVATE DAY TRIPS</p>
            <h2>Curated Private Day Tours Across Yunnan</h2>
            <p>
              This collection brings together private day tours in Yunnan designed for flexible pacing, local-led experiences, and smooth logistics. Some day trips start from Kunming, while others start from Dali, Lijiang, or Shangri-La depending on the route, making it easier to choose experiences that match where you are based.
            </p>
          </div>
        </section>
      {% endif %}

      <div class="compact-grid">
        {% for product in collection.products %}
          {% liquid
            assign adult_variant_keywords = 'solo journey|double share|three person private group|adult|adult pricing|2 guests|3 guests|two guests|three guests|private tour' | split: '|'
            assign excluded_keywords = 'children pricing|child|children|kid|kids|infant|baby|toddler|single room supplement|room supplement|single supplement|supplement|add-on|addon|upgrade|custom|extra bed|surcharge|鍎跨|灏忕|濠村効' | split: '|'

            assign collection_display_price = blank
            assign valid_main_variant_count = 0
            assign found_adult_variant = false

            for variant in product.variants
              assign variant_title = variant.title | downcase | strip
              assign is_adult_variant = false

              for keyword in adult_variant_keywords
                if variant_title contains keyword
                  assign is_adult_variant = true
                  break
                endif
              endfor

              if is_adult_variant
                assign found_adult_variant = true
                assign valid_main_variant_count = valid_main_variant_count | plus: 1

                if collection_display_price == blank or variant.price < collection_display_price
                  assign collection_display_price = variant.price
                endif
              endif
            endfor

            if found_adult_variant == false
              assign valid_main_variant_count = 0
              assign collection_display_price = blank

              for variant in product.variants
                assign variant_title = variant.title | downcase | strip
                assign is_excluded = false

                for keyword in excluded_keywords
                  if variant_title contains keyword
                    assign is_excluded = true
                    break
                  endif
                endfor

                unless is_excluded
                  assign valid_main_variant_count = valid_main_variant_count | plus: 1

                  if collection_display_price == blank or variant.price < collection_display_price
                    assign collection_display_price = variant.price
                  endif
                endunless
              endfor
            endif

            if collection_display_price == blank
              assign collection_display_price = product.price
            endif

            assign show_from_prefix = false
            if valid_main_variant_count > 1
              assign show_from_prefix = true
            endif
          %}

          <div class="grid-item reveal-item">
            <a href="{{ product.url }}" class="card-link">
              <div class="card-visual">
                {% if product.featured_image %}
                  <img src="{{ product.featured_image | img_url: '800x1000', crop: 'center' }}" alt="{{ product.title | escape }}" loading="lazy">
                {% else %}
                  <div class="card-img-placeholder"></div>
                {% endif %}

                <div class="card-overlay">
                  <div class="card-btn">EXPLORE</div>
                </div>

                {% if product.tags contains 'Route' %}
                  <div class="route-indicator"><span class="dot-pulse"></span>PRIVATE</div>
                {% endif %}
              </div>

              <div class="card-content">
                <div class="card-header">
                  <h3 class="product-title">{{ product.title }}</h3>
                  <div class="product-price">
                    {% if show_from_prefix %}
                      <span class="price-prefix">From </span>
                    {% endif %}
                    {{ collection_display_price | money_with_currency }}
                  </div>
                </div>
                <div class="product-info-row">
                  <span class="product-type">{{ product.type | default: 'Experience' }}</span>
                </div>
              </div>
            </a>
          </div>
        {% endfor %}
      </div>

      {% if paginate.pages > 1 %}
        <div class="luxury-pagination">
          {{ paginate | default_pagination }}
        </div>
      {% endif %}

      {% if collection.handle == 'yunnan-private-day-trips' and paginate.current_page == 1 %}
        <section class="seo-copy seo-copy-bottom">
          <div class="seo-copy-inner">
            <div class="seo-block">
              <h2>Why Choose a Private Day Trip in Yunnan?</h2>
              <p>
                Private day tours in Yunnan offer a more personal way to explore without switching hotels every night. Compared with fixed group formats, private trips give you better control over timing, pacing, and daily focus, with local support that adapts to your interests and travel style.
              </p>
            </div>

            <div class="seo-block">
              <h2>Day Trip Ideas in Kunming, Dali, Lijiang, and Shangri-La</h2>
              <p>
                Across Yunnan, day trips can focus on old towns, mountain scenery, lakeside landscapes, cultural heritage, food discovery, or lighter nature walks. Whether you are planning Kunming day trips, Dali day trips, Lijiang day trips, or Shangri-La day trips, this collection helps you compare routes in one place.
              </p>
            </div>

            <div class="seo-block">
              <h2>Who Are Yunnan Day Trips Best For?</h2>
              <p>
                Yunnan private day trips work especially well for travelers on shorter schedules, families with children, senior travelers, and anyone who prefers more comfort and flexibility than a shared group format. They are also a strong option if you want to add one well-planned local experience before or after a longer Yunnan itinerary. With private transport and a more focused route, even a single day can feel efficient, relaxed, and rewarding.
              </p>
            </div>

            <div class="seo-block">
              <h2>Best Time for Day Trips in Yunnan</h2>
              <p>
                Yunnan works well year-round, with spring and autumn often preferred for balanced weather and visibility. Summer brings greener landscapes, while winter can be crisp and photogenic in many areas. A private format makes it easier to adjust route timing by season, weather, and energy level.
              </p>
            </div>

            <div class="seo-block">
              <h2>Related Collections</h2>
              <div class="seo-links">
                <a href="/collections/yunnan-private-tours">Yunnan Private Tours</a>
                <a href="/collections/dali-private-tours">Dali Private Tours</a>
                <a href="/collections/lijiang-private-tours">Lijiang Private Tours</a>
                <a href="/collections/shangri-la-private-tours">Shangri-La Private Tours</a>
                <a href="/blogs/travel-guides">Yunnan Travel Guides</a>
              </div>
            </div>

            <div class="seo-block faq-block">
              <h2>Frequently Asked Questions</h2>

              <details class="faq-item">
                <summary>Are your Yunnan private day trips customizable?</summary>
                <div class="faq-answer">
                  Yes. Many private day trips can be adjusted based on your schedule, interests, pickup location, and preferred pace.
                </div>
              </details>

              <details class="faq-item">
                <summary>Where do these Yunnan day trips depart from?</summary>
                <div class="faq-answer">
                  Departure city depends on the route. Some day trips start from Kunming, while others start from Dali, Lijiang, or Shangri-La. Please check each product page for exact departure details.
                </div>
              </details>

              <details class="faq-item">
                <summary>Are private day trips suitable for families?</summary>
                <div class="faq-answer">
                  Yes. Private day trips are often a better fit for families because the pace is more flexible and the day can be planned more comfortably around your group.
                </div>
              </details>

              <details class="faq-item">
                <summary>What is usually included in a Yunnan private day trip?</summary>
                <div class="faq-answer">
                  Inclusions vary by route, but private transport, a planned itinerary, and local travel support are commonly part of the experience.
                </div>
              </details>

              <details class="faq-item">
                <summary>How long are Yunnan private day trips?</summary>
                <div class="faq-answer">
                  Most are designed as full-day experiences, though exact timing depends on distance, route design, and the attractions included.
                </div>
              </details>

              <details class="faq-item">
                <summary>Can I combine a day trip with a longer Yunnan itinerary?</summary>
                <div class="faq-answer">
                  Yes. A private day trip can work well as a standalone local experience or as an extension before or after a longer Yunnan private tour.
                </div>
              </details>
            </div>
          </div>
        </section>

        <script type="application/ld+json">
        {
          "@context": "https://schema.org",
          "@type": "FAQPage",
          "mainEntity": [
            {
              "@type": "Question",
              "name": "Are your Yunnan private day trips customizable?",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "Yes. Many private day trips can be adjusted based on your schedule, interests, pickup location, and preferred pace."
              }
            },
            {
              "@type": "Question",
