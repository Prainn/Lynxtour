{% assign seo_variant = product.selected_or_first_available_variant %}
{% assign seo_currency = cart.currency.iso_code | default: shop.currency %}
{% assign seo_collection = product.collections.first %}
{% assign seo_crumb_name = 'Products' %}
{% assign seo_crumb_url = shop.url | append: '/collections/all' %}
{% if seo_collection %}
  {% assign seo_crumb_name = seo_collection.title %}
  {% assign seo_crumb_url = shop.url | append: seo_collection.url %}
{% endif %}
{% assign seo_availability = 'https://schema.org/OutOfStock' %}
{% if seo_variant and seo_variant.available %}
  {% assign seo_availability = 'https://schema.org/InStock' %}
{% endif %}
{% assign seo_image_obj = product.featured_image | default: product.images.first %}
{% assign seo_image_url = '' %}
{% if seo_image_obj %}
  {% assign seo_image_url = seo_image_obj | image_url: width: 1200 | prepend: 'https:' %}
{% endif %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Product",
      "@id": "{{ shop.url }}{{ product.url }}#product",
      "url": "{{ shop.url }}{{ product.url }}",
      "name": {{ product.title | strip | json }},
      "description": {{ product.description | strip_html | strip_newlines | truncate: 500 | json }},
      "image": [{% if seo_image_url != '' %}{{ seo_image_url | json }}{% endif %}],
      "sku": {{ seo_variant.sku | json }},
      "offers": {
        "@type": "Offer",
        "url": "{{ shop.url }}{{ product.url }}",
        "priceCurrency": {{ seo_currency | json }},
        "price": {{ seo_variant.price | default: product.price | divided_by: 100.0 | round: 2 }},
        "availability": "{{ seo_availability }}"
      }
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "name": "Home",
          "item": "{{ shop.url }}/"
        },
        {
          "@type": "ListItem",
          "position": 2,
          "name": {{ seo_crumb_name | json }},
          "item": {{ seo_crumb_url | json }}
        },
        {
          "@type": "ListItem",
          "position": 3,
          "name": {{ product.title | strip | json }},
          "item": "{{ shop.url }}{{ product.url }}"
        }
      ]
    }
  ]
}
</script>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr@4.6.13/dist/flatpickr.min.css">

<style>
  :root {
    --gold: #d4b106;
    --dark-bg: #1a1a1a;
    --dark-card: #242424;
    --text-white: #ffffff;
    --text-gray: #a0a0a0;
    --border-color: #333333;
    --header-safe-height: 120px;
    --sidebar-sticky-top: calc(var(--header-safe-height) + 20px);
  }

  .ota-wrapper{
    background: var(--dark-bg);
    color: var(--text-white);
    font-family: "PingFang SC", sans-serif;
    padding-top: calc(var(--header-safe-height) + 20px);
    position: relative;
    z-index: 1;
  }

  .ota-container{
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    gap: 30px;
    align-items: flex-start;
  }

  .ota-main-config{
    flex: 2;
    background: var(--dark-card);
    border-radius: 16px;
    padding: 40px;
    border: 1px solid var(--border-color);
    box-shadow: 0 10px 30px rgba(0,0,0,0.3);
  }

  .ota-header{ display:flex; justify-content:space-between; align-items:center; margin-bottom:30px; }
  .ota-section-title{ font-size:24px; font-weight:300; letter-spacing:2px; margin:0; }

  .ota-page-heading{
  margin-bottom: 26px;
}

.ota-page-kicker{
  margin: 0 0 8px;
  color: var(--gold);
  font-size: 12px;
  font-weight: 700;
  letter-spacing: 0.14em;
  text-transform: uppercase;
}

.ota-page-title{
  margin: 0;
  color: #fff;
  font-size: 34px;
  line-height: 1.2;
  font-weight: 800;
  letter-spacing: 0.01em;
}

.ota-sidebar-title{
  margin: 0;
  font-size: 16px;
  font-weight: 700;
  letter-spacing: 1px;
}

@media (max-width: 768px){
  .ota-page-heading{
    margin-bottom: 20px;
  }

  .ota-page-title{
    font-size: 26px;
    line-height: 1.25;
  }
}

@media (max-width: 430px){
  .ota-page-title{
    font-size: 22px;
  }
}

  .ota-reset{
    background: transparent;
    color: var(--gold);
    border: 1px solid var(--gold);
    padding: 4px 14px;
    border-radius: 20px;
    cursor: pointer;
    font-size: 12px;
    transition: .2s;
  }
  .ota-reset:hover{ background: rgba(212,177,6,0.10); }

  .ota-group{ margin-bottom: 32px; }
  .ota-label{ color: var(--gold); font-size:14px; margin-bottom:12px; display:block; letter-spacing:1px; font-weight:600; }
  .ota-subhint{ margin: 8px 0 0; color:#888; font-size:12px; line-height:1.6; }

  .ota-date-box{ position: relative; z-index: 20; }
  .ota-date-input{
    width: 100%;
    background: #0c0a09;
    color: #fff;
    border: 1px solid var(--border-color);
    padding: 14px 50px 14px 16px;
    border-radius: 10px;
    outline: none;
    cursor: pointer;
    font-size: 15px;
    transition: .2s;
  }
  .ota-date-input:focus{ border-color: var(--gold); box-shadow: 0 0 0 3px rgba(212,177,6,0.10); }
  .ota-date-btn{
    position:absolute;
    right:8px;
    top:50%;
    transform:translateY(-50%);
    width:36px;height:36px;
    border:0;
    background: transparent;
    color: var(--gold);
    pointer-events: auto;
    cursor: pointer;
  }

  .ota-tag-container{ display:flex; gap:12px; flex-wrap:wrap; }
  .ota-tag{
    border: 1px solid var(--border-color);
    padding: 10px 18px;
    border-radius: 10px;
    font-size: 13px;
    color: var(--text-gray);
    cursor: pointer;
    transition: .2s;
    user-select: none;
  }
  .ota-tag.active{
    border-color: var(--gold);
    color: var(--gold);
    background: rgba(212,177,6,0.08);
    box-shadow: 0 0 15px rgba(212,177,6,0.10);
  }
  .ota-tag.disabled{ opacity: .4; cursor: not-allowed; border-style:dashed; }

  .ota-item-row{
    display:flex;
    justify-content:space-between;
    align-items:center;
    padding: 16px 0;
    border-bottom: 1px solid #333;
  }
  .ota-item-row:last-child{ border-bottom: none; }

  .ota-item-name{ font-size: 15px; color:#e5e5e5; }
  .item-desc-tag{ font-size: 11px; color:#888; margin-top: 6px; line-height:1.4; }

  .ota-item-action{ display:flex; align-items:center; gap: 15px; }
  .ota-item-price{ color: var(--gold); font-weight: 800; font-size: 16px; }

  .ota-stepper{
    display:flex;
    align-items:center;
    background:#000;
    border-radius: 10px;
    border: 1px solid var(--border-color);
    overflow:hidden;
  }
  .ota-stepper button{
    width: 34px; height: 34px;
    border:0;
    background: transparent;
    color: var(--gold);
    cursor: pointer;
    font-size: 18px;
    display:flex;
    align-items:center;
    justify-content:center;
  }
  .ota-stepper button:disabled{ color:#444; cursor: not-allowed; }
  .ota-stepper input{
    width: 42px;
    border: 0;
    background: transparent;
    color:#fff;
    text-align:center;
    font-size: 14px;
    -moz-appearance: textfield;
  }

  .ota-footer{
    display:flex;
    justify-content:space-between;
    align-items:flex-start;
    margin-top: 20px;
    border-top: 1px solid var(--border-color);
    padding-top: 26px;
    gap: 20px;
  }
  .ota-total-price{
    font-size: 32px;
    color: var(--gold);
    font-weight: 900;
    line-height: 1;
  }
  .ota-hint{ margin: 6px 0 0; color:#666; font-size:12px; }

  .ota-btns-area{ display:flex; flex-direction:column; gap: 12px; flex: 1; }

  .ota-btns{ display:flex; gap: 12px; justify-content:flex-end; }
  .ota-btn-cart, .ota-btn-buy{
    padding: 14px 24px;
    border-radius: 10px;
    cursor: pointer;
    font-weight: 800;
    transition: .2s;
    font-size: 14px;
    position: relative;
    white-space: nowrap;
  }
  .ota-btn-cart{ background: transparent; border:1px solid var(--gold); color: var(--gold); }
  .ota-btn-cart:hover{ background: rgba(212,177,6,0.10); }
  .ota-btn-buy{ background: var(--gold); color:#000; border:0; }
  .ota-btn-buy:hover{ filter: brightness(1.07); }

  .js-submit:disabled{ opacity: .7; cursor: wait; }
  .js-submit.loading{ color: transparent !important; }
  .js-submit.loading::after{
    content:"";
    position:absolute;
    left:50%;
    top:50%;
    width:18px;height:18px;
    margin:-9px;
    border:2px solid rgba(0,0,0,0.25);
    border-top-color: currentColor;
    border-radius: 50%;
    animation: ota-spin .8s infinite linear;
  }
  .ota-btn-cart.loading::after{ border-color: rgba(212,177,6,0.25); border-top-color: var(--gold); }
  @keyframes ota-spin{ to{ transform: rotate(360deg); } }

  /* Sidebar */
  .ota-sidebar{
    flex: 1;
    position: sticky;
    top: var(--sidebar-sticky-top);
    z-index: 10;
  }
  .sidebar-sticky-card{
    background: var(--dark-card);
    border-radius: 16px;
    border: 1px solid var(--border-color);
    max-height: calc(100vh - var(--sidebar-sticky-top) - 20px);
    overflow: hidden;
    display:flex;
    flex-direction:column;
  }
  .sidebar-head{
    padding: 16px 20px;
    border-bottom: 1px solid #333;
    flex-shrink:0;
  }
  .sidebar-head h3{ margin:0; font-size:16px; font-weight:700; letter-spacing:1px; }
  .sidebar-content-wrapper{ padding: 0 20px 20px; overflow-y:auto; -webkit-overflow-scrolling: touch; }
  .sidebar-labels{ padding: 15px 0 10px; position: sticky; top: 0; background: var(--dark-card); z-index: 4; }
  .s-tag{
    background: #333;
    color:#eee;
    padding: 4px 10px;
    border-radius: 6px;
    font-size: 11px;
    margin: 0 6px 6px 0;
    display:inline-block;
    border: 1px solid #444;
  }

  .accordion-item{ border:1px solid #333; border-radius:12px; margin-bottom:10px; background:#1c1c1c; overflow:hidden; }
  .accordion-header{ padding:14px; display:flex; justify-content:space-between; align-items:center; cursor:pointer; background:#222; transition:.2s; user-select:none; }
  .accordion-header:hover{ background:#2a2a2a; }
  .day-icon{ color: var(--gold); font-size:12px; font-weight:900; text-transform:uppercase; }
  .arrow-icon{ font-size:10px; color:#666; transition:.2s; }
  .accordion-item.active .arrow-icon{ transform: rotate(180deg); color: var(--gold); }
  .accordion-content{ display:none; padding:15px; border-top:1px solid #333; background:#181818; }
  .accordion-item.active .accordion-content{ display:block; }
  .day-text-content{ font-size:13px; line-height:1.8; color:#ccc; margin-bottom:12px; }
  .day-gallery{ display:grid; grid-template-columns: 1fr 1fr; gap:10px; }
  .day-img{ width:100%; border-radius:10px; border:1px solid #333; transition:.2s; }
  .day-img:hover{ filter: brightness(1.08); transform: scale(1.01); }

  /* Custom View */
  .custom-tour-view{
    display:none;
    text-align:center;
    padding: 40px 20px;
    background: rgba(255,255,255,0.05);
    border-radius: 12px;
    border: 1px dashed var(--gold);
  }
  .custom-icon{ font-size:30px; margin-bottom: 15px; display:block; }
  .custom-title{ font-size:18px; color:#fff; margin:0 0 10px; }
  .custom-desc{ font-size:13px; color:#aaa; margin:0 0 25px; line-height:1.7; }
  .btn-contact-custom{
    background: var(--gold);
    color:#000;
    padding: 12px 30px;
    border:0;
    border-radius: 10px;
    font-weight: 900;
    cursor: pointer;
    text-decoration:none;
    display:inline-block;
    margin: 6px 6px 0;
  }

  @media (max-width: 990px){
    .ota-container{ flex-direction:column; padding: 0 15px; }
    .ota-main-config{ padding: 24px; }
    .ota-sidebar{ position: static; width:100%; margin-top: 20px; }
    .sidebar-sticky-card{ max-height: none; overflow: visible; }
    .ota-footer{ flex-direction:column; }
    .ota-btns{ justify-content: stretch; }
    .ota-btn-cart, .ota-btn-buy{ width: 100%; }
  }

  .ota-wrapper{
    padding-top: calc(var(--header-safe-height, 160px) + 20px) !important;
  }

  /* =========================
     Flatpickr — minimal + stable theme
     ========================= */
  .flatpickr-calendar{
    background: #111 !important;
    border: 1px solid #333 !important;
    border-radius: 12px !important;
    box-shadow: 0 12px 26px rgba(0,0,0,0.55) !important;
    overflow: visible !important;
  }
  .flatpickr-months{
    display: flex !important;
    align-items: center !important;
    position: relative !important;
    height: 48px !important;
    padding: 8px 36px 0 !important;
    background: #111 !important;
    overflow: visible !important;
  }
  .flatpickr-current-month{
    position: static !important;
    display: flex !important;
    align-items: center !important;
    justify-content: center !important;
    width: 100% !important;
    height: 32px !important;
    line-height: 32px !important;
    padding: 0 !important;
    opacity: 1 !important;
    visibility: visible !important;
    color: #fff !important;
  }
  .flatpickr-monthDropdown-months{
    background: transparent !important;
    border: 0 !important;
    color: #fff !important;
    font-size: 14px !important;
    font-weight: 800 !important;
    height: 32px !important;
    line-height: 32px !important;
    padding: 0 8px !important;
    margin: 0 !important;
    -webkit-appearance: menulist !important;
    appearance: menulist !important;
  }
  .flatpickr-current-month .numInputWrapper{
    width: 70px !important;
    height: 32px !important;
  }
  .flatpickr-current-month input.cur-year{
    background: transparent !important;
    border: 0 !important;
    color: var(--gold) !important;
    font-size: 14px !important;
    font-weight: 900 !important;
    height: 32px !important;
    line-height: 32px !important;
    padding: 0 !important;
    opacity: 1 !important;
    visibility: visible !important;
  }
  .flatpickr-prev-month,
  .flatpickr-next-month{
    top: 8px !important;
    height: 32px !important;
    display: flex !important;
    align-items: center !important;
    z-index: 20 !important;
  }
  .flatpickr-prev-month svg,
  .flatpickr-next-month svg{
    fill: var(--gold) !important;
  }
  .flatpickr-weekdays{
    background: #111 !important;
    height: 28px !important;
    display: flex !important;
    align-items: center !important;
  }
  span.flatpickr-weekday{
    color: #888 !important;
    font-size: 12px !important;
    font-weight: 600 !important;
  }
  .flatpickr-innerContainer,
  .flatpickr-days,
  .dayContainer{
    background: #111 !important;
  }
  .flatpickr-day{
    color: #fff !important;
    background: transparent !important;
    border-color: transparent !important;
    border-radius: 8px !important;
    display: flex !important;
    flex-direction: column !important;
    justify-content: flex-start !important;
    align-items: center !important;
    padding-top: 6px !important;
    height: 60px !important;
    line-height: 1 !important;
  }
  .flatpickr-day:hover{
    background: #2a2a2a !important;
    color: var(--gold) !important;
  }
  .flatpickr-day.selected,
  .flatpickr-day.startRange,
  .flatpickr-day.endRange{
    background: var(--gold) !important;
    color: #000 !important;
    border-color: var(--gold) !important;
    font-weight: 900 !important;
  }
  .flatpickr-day.today{
    border-color: var(--gold) !important;
  }
  .flatpickr-day.prevMonthDay,
  .flatpickr-day.nextMonthDay{
    color: #555 !important;
  }
  .flatpickr-day.flatpickr-disabled,
  .flatpickr-day.disabled{
    color: #333 !important;
  }
  .day-price{
    font-size: 10px;
    color: var(--gold);
    margin-top: 5px;
    font-weight: 500;
    transform: scale(0.92);
  }
  .flatpickr-day.selected .day-price{
    color: #000 !important;
    font-weight: 900;
  }
  .flatpickr-calendar{
    color-scheme: dark;
  }
  .flatpickr-monthDropdown-months{
    background: #111 !important;
    color: #fff !important;
    border: 1px solid #333 !important;
    border-radius: 10px !important;
    padding: 0 10px !important;
  }
  .flatpickr-monthDropdown-months option{
    background: #111 !important;
    color: #fff !important;
  }
  .flatpickr-monthDropdown-months option:checked{
    background: #222 !important;
    color: var(--gold) !important;
  }
  .ota-date-box{ position: relative; }
  .ota-date-btn{
    pointer-events: auto !important;
    cursor: pointer;
    z-index: 5;
  }
  .ota-date-input{
    position: relative;
    z-index: 1;
  }
  .flatpickr-calendar{
    z-index: 999999 !important;
  }
  .accordion-content{
    padding: 8px 15px 15px; 
  }
  .day-gallery{
    margin-top: 12px;
    display: grid;
    gap: 10px;
  }
  .day-img-wrap{
    position: relative;
    overflow: hidden;
    border-radius: 12px;
    border: 1px solid rgba(255,255,255,0.10);
    background: #111;
  }
  .day-img{
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transform: scale(1.001);
  }
  .day-gallery--1{
    grid-template-columns: 1fr;
  }
  .day-gallery--1 .day-img-wrap{
    height: 220px;
  }
  .day-gallery--2{
    grid-template-columns: 1fr 1fr;
  }
  .day-gallery--2 .day-img-wrap{
    height: 160px;
  }
  .day-gallery--3{
    grid-template-columns: 1.35fr 1fr;
    grid-auto-rows: 120px; 
  }
  .day-gallery--3 .day-img-wrap:first-child{
    grid-row: span 2;      
  }
  .day-img-wrap.is-more::after{
    content: attr(data-more);
    position: absolute;
    right: 10px;
    bottom: 10px;
    padding: 6px 10px;
    border-radius: 999px;
    font-size: 12px;
    font-weight: 900;
    color: #fff;
    background: rgba(0,0,0,0.55);
    border: 1px solid rgba(255,255,255,0.18);
    backdrop-filter: blur(6px);
  }
  @media (max-width: 990px){
    .day-gallery--1 .day-img-wrap{ height: 180px; }
    .day-gallery--2 .day-img-wrap{ height: 140px; }
    .day-gallery--3{ grid-auto-rows: 105px; }
  }

  :root{
    --tl-meal:  #F6C945; 
    --tl-car:   #8C7CFF; 
    --tl-spot:  #39D98A; 
    --tl-hotel: #58B6FF; 
    --tl-flight:#FF6B8A; 
    --tl-train: #6FE3FF; 
    --tl-hike:  #B6E36F; 
    --tl-free:  #D4B106; 
  }
  .tl-item{ --tl-accent: var(--tl-spot); }
  .tl-item[data-type="meal"]  { --tl-accent: var(--tl-meal); }
  .tl-item[data-type="car"]   { --tl-accent: var(--tl-car); }
  .tl-item[data-type="spot"]  { --tl-accent: var(--tl-spot); }
  .tl-item[data-type="hotel"] { --tl-accent: var(--tl-hotel); }
  .tl-item[data-type="flight"]{ --tl-accent: var(--tl-flight); }
  .tl-item[data-type="train"] { --tl-accent: var(--tl-train); }
  .tl-item[data-type="hike"]  { --tl-accent: var(--tl-hike); }
  .tl-item[data-type="free"]  { --tl-accent: var(--tl-free); }
  .tl-dot{
    color: var(--tl-accent);
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.12);
  }
  .tl-item[data-type="meal"]  .tl-dot{ background: rgba(246,201,69,0.18); border-color: rgba(246,201,69,0.35); }
  .tl-item[data-type="car"]   .tl-dot{ background: rgba(140,124,255,0.18); border-color: rgba(140,124,255,0.35); }
  .tl-item[data-type="spot"]  .tl-dot{ background: rgba(57,217,138,0.16); border-color: rgba(57,217,138,0.32); }
  .tl-item[data-type="hotel"] .tl-dot{ background: rgba(88,182,255,0.16); border-color: rgba(88,182,255,0.32); }
  .tl-item[data-type="flight"] .tl-dot{ background: rgba(255,107,138,0.16); border-color: rgba(255,107,138,0.32); }
  .tl-item[data-type="train"] .tl-dot{ background: rgba(111,227,255,0.14); border-color: rgba(111,227,255,0.28); }
  .tl-item[data-type="hike"]  .tl-dot{ background: rgba(182,227,111,0.14); border-color: rgba(182,227,111,0.28); }
  .tl-item[data-type="free"]  .tl-dot{ background: rgba(212,177,6,0.12);  border-color: rgba(212,177,6,0.28); }

  .tl-dot{
    width: 28px;
    height: 28px;
    border-radius: 999px;
    display:flex;
    align-items:center;
    justify-content:center;
    color: var(--tl-accent);
    background: transparent;
    border: 1px solid rgba(255,255,255,0.12);
  }
  .tl-ico{ width:16px; height:16px; display:block; }
  .day-timeline::before{
    background: rgba(255,255,255,0.10);
  }
  .ota-wrapper[data-dot-style="outline"] .tl-dot{
    background: transparent !important;
    border: 1px solid rgba(255,255,255,0.18) !important;
    box-shadow: none !important;
    color: var(--tl-accent) !important;
  }
  .day-timeline{
    padding-left: 0 !important;
  }
  .day-timeline::before{
    left: 14px !important; 
  }
  .tl-item{
    position: relative !important;
    display: grid !important;
    grid-template-columns: 32px 1fr !important; 
    column-gap: 12px !important;
    padding: 10px 0 18px !important;
  }
  .tl-dot{
    position: relative !important;
    left: auto !important;
    top: auto !important;
    margin-top: 2px !important; 
  }
  .tl-head{
    align-items: center !important;
  }
  .day-gallery .day-img{
    height: 100% !important;
    width: 100% !important;
    object-fit: cover !important;
  }
  .day-img-wrap{
    overflow: hidden;
    border-radius: 12px;
    border: 1px solid rgba(255,255,255,0.10);
    background: #111;
  }
  .day-gallery--1 .day-img-wrap{ height: 260px; }   
  .day-gallery--2 .day-img-wrap{ height: 180px; }   
  .day-gallery--3{ grid-auto-rows: 140px; }         
  .day-gallery--3 .day-img-wrap:first-child{ grid-row: span 2; } 

  @media (max-width: 990px){
    .day-gallery--1 .day-img-wrap{ height: 200px; }
    .day-gallery--2 .day-img-wrap{ height: 150px; }
    .day-gallery--3{ grid-auto-rows: 115px; }
  }

  /* ========= Info buttons + popup ========= */
  .ota-info-actions{
    display: flex;
    gap: 12px;
    margin-bottom: 2px;
  }

  .ota-info-btn{
    flex: 1;
    min-width: 0;
    padding: 12px 16px;
    border-radius: 10px;
    cursor: pointer;
    font-weight: 700;
    font-size: 13px;
    border: 1px solid rgba(212,177,6,0.35);
    background: rgba(212,177,6,0.06);
    color: var(--gold);
    transition: .2s;
  }

  .ota-info-btn:hover{
    background: rgba(212,177,6,0.12);
    border-color: var(--gold);
  }

  .ota-popup[hidden]{
    display: none !important;
  }

  .ota-popup{
    position: fixed;
    inset: 0;
    z-index: 999999;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 20px;
  }

  .ota-popup__backdrop{
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,0.58);
    backdrop-filter: blur(3px);
  }

  .ota-popup__card{
    position: relative;
    z-index: 1;
    width: min(560px, calc(100vw - 30px));
    max-height: min(78vh, 720px);
    overflow: hidden;
    background: #1f1f1f;
    border: 1px solid var(--border-color);
    border-radius: 16px;
    box-shadow: 0 20px 50px rgba(0,0,0,0.45);
  }

  .ota-popup__head{
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 18px 20px;
    border-bottom: 1px solid rgba(255,255,255,0.08);
  }

  .ota-popup__title{
    margin: 0;
    font-size: 18px;
    font-weight: 800;
    color: var(--gold);
    letter-spacing: .5px;
  }

  .ota-popup__close{
    width: 34px;
    height: 34px;
    border: 0;
    border-radius: 999px;
    background: rgba(255,255,255,0.06);
    color: #fff;
    cursor: pointer;
    font-size: 16px;
    line-height: 1;
  }

  .ota-popup__close:hover{
    background: rgba(255,255,255,0.12);
  }

  .ota-popup__body{
    padding: 18px 20px 22px;
    overflow-y: auto;
    max-height: calc(78vh - 72px);
  }

  .ota-popup-copy{
    color: #cfcfcf;
    font-size: 13px;
    line-height: 1.9;
  }

  @media (max-width: 990px){
    .ota-info-actions{
      flex-direction: column;
    }

    .ota-popup{
      padding: 14px;
    }

    .ota-popup__card{
      width: 100%;
    }
  }
</style>


<div class="ota-wrapper" data-dot-style="outline">
  <div class="ota-container">

    <div class="ota-main-config">
  <div class="ota-page-heading">
    <p class="ota-page-kicker">Lynxtour Private Tour</p>
    <h1 class="ota-page-title">{{ product.title }}</h1>
  </div>

  <div class="ota-header">
    <h2 class="ota-section-title">Choose booking options</h2>
    <button type="button" class="ota-reset js-reset">Reset selections</button>
  </div>

      <div class="ota-group">
        <label class="ota-label">Travel date</label>
        <div class="ota-date-box">
          <input type="text" id="TravelDate" class="ota-date-input" value="{{ 'now' | date: '%Y-%m-%d' }}" readonly placeholder="Select a date">
          <button type="button" class="ota-date-btn" aria-label="Choose date">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
              <path d="M7 2v3M17 2v3M3.5 9h17" stroke-linecap="round"/>
              <path d="M6.5 6h11c2 0 3 1 3 3v10c0 2-1 3-3 3h-11c-2 0-3-1-3-3V9c0-2 1-3 3-3Z" stroke-linejoin="round"/>
            </svg>
          </button>
        </div>
        <p class="ota-subhint">Please select your departure date. It will be submitted with the order.</p>
      </div>

      <div class="ota-group">
        <label class="ota-label">Package type</label>
        <div class="ota-tag-container" id="PackageTabs">
          <div class="ota-tag active" data-type="luxury">Wild Luxury Private Tour</div>
          <div class="ota-tag" data-type="value">Best-Value Private Tour</div>
          <div class="ota-tag" data-type="economy">Economy Private Tour</div>
          <div class="ota-tag" data-type="custom">Custom Tour</div>
        </div>
      </div>

      <div id="StandardBookingView">
        <div class="ota-group">
          <label class="ota-label">Quantity</label>
          <p class="ota-subhint"></p>

          <div class="ota-item-list">
            {% for variant in product.variants %}
              {%- assign pkg_label = variant.option1 | strip -%}
              {%- assign pkg_lc = pkg_label | downcase -%}

              {%- assign pkg_type = 'economy' -%}

              {%- if pkg_lc contains 'luxury' or pkg_label contains '野奢' -%}
                {%- assign pkg_type = 'luxury' -%}
              {%- elsif pkg_lc contains 'best-value' or pkg_lc contains 'best value' or pkg_lc contains 'value' or pkg_label contains '性价比' -%}
                {%- assign pkg_type = 'value' -%}
              {%- elsif pkg_lc contains 'economy' or pkg_label contains '经济' -%}
                {%- assign pkg_type = 'economy' -%}
              {%- endif -%}

              {%- assign desc_text = 'Includes: Standard services' -%}
              {%- if pkg_lc contains 'luxury' -%}
                {%- assign desc_text = 'Includes: Selected 5-star luxury hotels, comfortable business-class vehicle, premium concierge service' -%}
              {%- elsif pkg_lc contains 'value' -%}
                {%- assign desc_text = 'Includes: Selected 4-star value hotels, comfortable business-class vehicle, attentive concierge service' -%}
              {%- elsif pkg_lc contains 'economy' -%}
                {%- assign desc_text = 'Includes: Selected 3-star hotels, economy vehicle, basic services' -%}
              {%- endif -%}

              {%- assign option2_downcase = variant.option2 | downcase -%}
              {%- if option2_downcase contains 'single room supplement' -%}
                {%- assign desc_text = 'Note: For children sharing a bed (no extra bed). If an extra bed is required, please book as an adult.' -%}
              {%- endif -%}

              {%- assign min_qty = 1 -%}
              {%- assign opt2_lc = variant.option2 | downcase -%}

              {%- if opt2_lc contains '两人' or opt2_lc contains '2' or opt2_lc contains '2-person' -%}
                {%- assign min_qty = 2 -%}
              {%- elsif opt2_lc contains '三到四' or opt2_lc contains '3-4' or opt2_lc contains '3-4人' -%}
                {%- assign min_qty = 3 -%}
              {%- elsif opt2_lc contains '五' or opt2_lc contains '5-10' or opt2_lc contains '5-10人' or opt2_lc contains '5人' -%}
                {%- assign min_qty = 5 -%}
              {%- endif -%}

              <div class="ota-item-row"
                data-variant-id="{{ variant.id }}"
                data-base-price="{{ variant.price }}"
                data-package="{{ pkg_type }}"
                data-min-qty="{{ min_qty }}"
                style="{% if pkg_type != 'luxury' %}display:none;{% endif %}">
                <div class="ota-item-info">
                  <span class="ota-item-name">{{ variant.option2 }}</span>
                  <div class="item-desc-tag">{{ desc_text }}</div>
                </div>

                <div class="ota-item-action">
                  <span class="ota-item-price money">{{ variant.price | money }}</span>

                  <div class="ota-stepper">
                    <button type="button" class="js-qty" data-delta="-1" aria-label="减少" disabled>-</button>
                    <input type="number" value="0" min="0" readonly inputmode="numeric">
                    <button type="button" class="js-qty" data-delta="1" aria-label="增加">+</button>
                  </div>
                </div>
              </div>
            {% endfor %}
          </div>
        </div>
      </div>

      <div id="CustomTourView" class="custom-tour-view">
        <span class="custom-icon">✨</span>
        <h3 class="custom-title">Bespoke custom itinerary</h3>
        <p class="custom-desc">
          If the preset routes don’t fit your needs, our travel designers can tailor a trip just for you.<br>
          Including route planning, hotel upgrades, and special activity arrangements.
        </p>
        <a href="/pages/contact-us" class="btn-contact-custom">Contact a travel advisor</a>
        <a href="tel:0871-63218099" class="btn-contact-custom">Call hotline 0871-63218099</a>
        <a href="https://wa.me/13211685553" target="_blank" class="btn-contact-custom">Message on WhatsApp</a>
      </div>

      <div class="ota-footer">
        <div class="ota-total-box">
          <div class="ota-total-price money" id="FinalGrandTotal">
            {{ 0 | money }}
          </div>
          <p class="ota-hint">Luxury Experience Design</p>
        </div>

        <div class="ota-btns-area">
          <div class="ota-info-actions">
            <button type="button" class="ota-info-btn" data-modal="children">
              Children pricing
            </button>
            <button type="button" class="ota-info-btn" data-modal="group">
              Tour service standards
            </button>
          </div>

          <div class="ota-btns">
            <button type="button" class="ota-btn-cart js-submit" data-type="cart">Add to booking list</button>
            <button type="button" class="ota-btn-buy js-submit" data-type="buy">Book now</button>
          </div>

          <div class="ota-popup" id="OtaInfoPopup" hidden>
            <div class="ota-popup__backdrop"></div>

            <div class="ota-popup__card" role="dialog" aria-modal="true" aria-labelledby="OtaInfoPopupTitle">
              <div class="ota-popup__head">
                <h3 class="ota-popup__title" id="OtaInfoPopupTitle"></h3>
                <button type="button" class="ota-popup__close" aria-label="Close">✕</button>
              </div>
              <div class="ota-popup__body" id="OtaInfoPopupBody"></div>
            </div>

            <div class="ota-popup-source" data-popup-key="children" hidden>
              <div class="ota-popup-copy">
                Most attractions in Yunnan charge child tickets by height (1.2m–1.4m). Pricing rules for children under 12:<br><br>
                1) Children who require their own bed are charged at the adult rate;<br>
                2) Children without a bed: subtract the “single room supplement” from the tour price;<br>
                3) If the child’s height does not meet the attraction’s ticketing rule, the difference will be refunded based on the actual situation before the group departs;<br>
                4) Age 12 and above is charged at the adult rate.
              </div>
            </div>

            <div class="ota-popup-source" data-popup-key="group" hidden>
  <div class="ota-popup-copy">
    <strong>Small-Group Private Tour - Service Standards</strong><br><br>

    <strong>I. What's Included</strong><br><br>

    <strong>Transportation</strong><br>
    Exclusive private vehicle service throughout the itinerary. Vehicle type will be arranged according to group size, such as a 5-seat SUV, 7-seat business MPV, or 9-seat Mercedes van. Vehicle usage, fuel, tolls, parking fees, and empty return transfer charges are included.<br><br>

    <strong>Accommodation</strong><br>
    Hotels listed in the itinerary or accommodations of the same category, including breakfast, based on double occupancy in a standard room.<br><br>

    <strong>Meals</strong><br>
    Meals specifically indicated in the itinerary are included. Beverages and alcoholic drinks are not included.<br><br>

    <strong>Admission Tickets & Experiences</strong><br>
    First-entry admission tickets to the attractions listed in the itinerary, required in-park transportation, and featured experience activities specifically included in the itinerary.<br><br>

    <strong>Driver Service</strong><br>
    Professional driver-guide service, including the driver's accommodation and meal allowance. The driver will escort guests to scenic areas but will not accompany guests inside the attractions.<br><br>

    <strong>Insurance</strong><br>
    Travel agency liability insurance is included. Guests are strongly advised to purchase personal travel accident insurance separately.<br><br>

    <strong>Transfers</strong><br>
    Airport or railway station pick-up on the first day, and drop-off service on the last day of the itinerary.<br><br>

    <strong>II. What's Not Included</strong><br><br>

    <strong>Intercity Transportation</strong><br>
    Round-trip airfare, train tickets, or other transportation between the departure city and destination.<br><br>

    <strong>Single Room Supplement</strong><br>
    Additional charges apply if one guest occupies a room alone.<br><br>

    <strong>Personal Expenses</strong><br>
    Personal expenses not specified in the itinerary, such as beverages, souvenirs, shopping, and hotel incidentals.<br><br>

    <strong>Optional Activities</strong><br>
    Optional self-paid activities and any secondary in-park expenses not expressly included in the itinerary.<br><br>

    <strong>Unspecified Meals</strong><br>
    Meals not clearly marked as included in the itinerary.<br><br>

    <strong>Tips</strong><br>
    Tips for the driver or guide are not included. Any gratuity is voluntary and at the guest's discretion.<br><br>

    <strong>Force Majeure Costs</strong><br>
    Additional expenses caused by force majeure events such as transportation delays, strikes, severe weather, flight cancellations, or schedule changes.<br><br>

    <strong>Personal Travel Accident Insurance</strong><br>
    Not included in the tour price. Guests may purchase it independently or request the travel agency to arrange it at additional cost.<br><br>

    <strong>III. Important Notes</strong><br><br>

    <strong>Booking & Contract</strong><br>
    1. Guests must sign an official electronic travel contract with a licensed travel agency.<br>
    2. Payment should be made to the travel agency's official corporate account, and proof of payment should be retained.<br>
    3. Guests are advised to book at least 30 days in advance, especially during peak seasons or for one-way routes.<br>
    4. If the number of travelers decreases for personal reasons, any costs already incurred by the travel agency will be borne by the guest.<br><br>

    <strong>Itinerary Adjustments</strong><br>
    1. The travel agency may adjust the sequence of the itinerary due to weather, traffic, or temporary attraction closures, provided that no sightseeing items are omitted and service standards are not reduced.<br>
    2. Any request to add attractions or change the route during the trip must be agreed with the driver or guide. Additional charges may apply for overtime or excess mileage.<br>
    3. For airport or railway transfers, guests with similar arrival or departure times may be arranged on a shared transfer basis.<br><br>

    <strong>Safety</strong><br>
    1. Guests with heart disease, hypertension, respiratory illness, or other conditions unsuitable for long-distance or high-altitude travel must inform the travel agency at the time of booking.<br>
    2. For high-risk activities such as horseback riding, hiking, diving, or skiing, guests should understand the safety requirements, arrange suitable insurance, and participate within their own limits.<br>
    3. Guests may not leave the group without authorization. If a guest leaves the group for personal reasons, any unused services will be regarded as voluntarily forfeited, and any incurred costs will not be refunded.<br>
    4. Guests must carry valid identification documents during the trip. Children should carry a household registration booklet or birth certificate. Preferential admission documents should also be carried if applicable.<br><br>

    <strong>Accommodation & Meals</strong><br>
    1. Hotel check-in is generally after 14:00, and check-out is before 12:00.<br>
    2. If late check-out is required on the final day, any related cost shall be borne by the guest.<br>
    3. If the number of travelers is odd or a private room is requested, a single room supplement will apply. If room sharing is accepted, the travel agency will try to coordinate arrangements.<br>
    4. Meal standards for included meals are listed in the itinerary. Meals not included may be chosen independently based on the guest's own preference and budget.<br><br>

    <strong>Service & Complaints</strong><br>
    1. If any issue arises during the trip, guests should contact the travel agency's 24-hour emergency contact immediately. We are committed to responding within 3 minutes and resolving issues efficiently.<br>
    2. Any complaint should be raised on-site as soon as possible for prompt resolution. Written complaints after the trip must be submitted within 7 days, and the signed Guest Feedback Form will serve as the basis for review.<br>
    3. Services will be provided strictly in accordance with the contract, with no hidden charges and no compulsory spending. We are committed to quality service, standardized safety management, and in-depth travel experiences.
  </div>
</div>
          </div>
        </div>
      </div>
    </div>

    <aside class="ota-sidebar">
      <div class="sidebar-sticky-card">
        <div class="sidebar-head">
  <h2 class="ota-sidebar-title">Itinerary details</h2>
</div>

        <div class="sidebar-content-wrapper">
          <div class="sidebar-labels">
            {% if product.metafields.custom.service_tags.value != blank %}
              {% assign tags = product.metafields.custom.service_tags.value | split: ',' %}
              {% for tag in tags %}<span class="s-tag">{{ tag }}</span>{% endfor %}
            {% else %}
              <span class="s-tag">尊享私家团</span><span class="s-tag">金牌管家服务</span><span class="s-tag">极致野奢</span>
            {% endif %}
          </div>

          <div class="itinerary-preview">
            {% assign days = product.metafields.custom.itinerary_days.value %}

            {% if days != blank %}
              <div class="ota-accordion">
                {% for d in days %}
                  <div class="accordion-item {% if forloop.first %}active{% endif %}">
                    <div class="accordion-header" role="button" tabindex="0">
                      <div class="header-left"><span class="day-icon">Day {{ d.day_number }}</span></div>
                      <span class="arrow-icon">▼</span>
                    </div>

                    <div class="accordion-content">
                      <div class="day-timeline">
                        {% assign items = d.items.value %}
                        {% for it in items %}
                          <div class="tl-item" data-type="{{ it.type }}">
                            <div class="tl-dot" aria-hidden="true">
                              {% assign t = it.type | downcase %}
                              {% case t %}

                                {% when 'meal' %}
                                  <svg class="tl-ico" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                                    <path d="M8 3v7a3 3 0 0 1-3 3H4" stroke-linecap="round"/>
                                    <path d="M4 3v10" stroke-linecap="round"/>
                                    <path d="M14 3v8a3 3 0 0 0 3 3h1V3" stroke-linecap="round"/>
                                  </svg>

                                {% when 'car' %}
                                  <svg class="tl-ico" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                                    <path d="M3 13l1-4a3 3 0 0 1 3-2h10a3 3 0 0 1 3 2l1 4" stroke-linejoin="round"/>
                                    <path d="M5 13h14v5a2 2 0 0 1-2 2h-1" stroke-linejoin="round"/>
                                    <circle cx="7" cy="18" r="1.2"/><circle cx="17" cy="18" r="1.2"/>
                                  </svg>

                                {% when 'spot' %}
                                  <svg class="tl-ico" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                                    <path d="M12 21s6-4.5 6-10a6 6 0 1 0-12 0c0 5.5 6 10 6 10Z" stroke-linejoin="round"/>
                                    <path d="M12 11.5V8.2" stroke-linecap="round"/>
                                  </svg>

                                {% when 'hotel' %}
                                  <svg class="tl-ico" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                                    <path d="M3 11h18" stroke-linecap="round"/>
                                    <path d="M5 11V7a2 2 0 0 1 2-2h3v6" stroke-linejoin="round"/>
                                    <path d="M14 11V7a2 2 0 0 1 2-2h3v6" stroke-linejoin="round"/>
                                    <path d="M4 20v-5a2 2 0 0 1 2-2h12a2 2 0 0 1 2 2v5" stroke-linejoin="round"/>
                                  </svg>

                                {% when 'flight' %}
                                  <svg class="tl-ico" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                                    <path d="M2 16l20-6-20-6 6 6-6 6Z" stroke-linejoin="round"/>
                                    <path d="M8 10h6" stroke-linecap="round"/>
                                  </svg>

                                {% when 'train' %}
                                  <svg class="tl-ico" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                                    <path d="M7 3h10a3 3 0 0 1 3 3v9a3 3 0 0 1-3 3H7a3 3 0 0 1-3-3V6a3 3 0 0 1 3-3Z" stroke-linejoin="round"/>
                                    <path d="M7 21l2-3M17 21l-2-3" stroke-linecap="round"/>
                                    <circle cx="8" cy="14" r="1.2"/><circle cx="16" cy="14" r="1.2"/>
                                  </svg>

                                {% when 'hike' %}
                                  <svg class="tl-ico" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                                    <path d="M14 5a2 2 0 1 1-4 0a2 2 0 0 1 4 0Z"/>
                                    <path d="M8 21l2-7 3 2 2 5" stroke-linecap="round" stroke-linejoin="round"/>
                                    <path d="M10 14l-2-3 3-2 3 2" stroke-linejoin="round"/>
                                    <path d="M16 10l2-2" stroke-linecap="round"/>
                                  </svg>

                                {% when 'free' %}
                                  <svg class="tl-ico" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                                    <path d="M5 21V4" stroke-linecap="round"/>
                                    <path d="M5 4c6 0 6 4 12 4v9c-6 0-6-4-12-4" stroke-linejoin="round"/>
                                  </svg>

                                {% else %}
                                  <svg class="tl-ico" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                                    <path d="M12 21s6-4.5 6-10a6 6 0 1 0-12 0c0 5.5 6 10 6 10Z" stroke-linejoin="round"/>
                                  </svg>

                              {% endcase %}
                            </div>

                            <div>
                              <div class="tl-head">
                                <div class="tl-title">{{ it.title }}</div>
                                {% if it.time != blank %}<div class="tl-time">{{ it.time }}</div>{% endif %}
                              </div>

                              {% if it.duration != blank or it.tag != blank %}
                                <div class="tl-meta">
                                  {% if it.duration != blank %}<span class="tl-meta-item">🕒 {{ it.duration }}</span>{% endif %}
                                  {% if it.tag != blank %}<span class="tl-meta-item tl-tag">🏳️ {{ it.tag }}</span>{% endif %}
                                </div>
                              {% endif %}

                              {% if it.desc != blank %}
                                <div class="tl-desc">{{ it.desc | newline_to_br }}</div>
                              {% endif %}

                              {% assign imgs = it.images.value %}
                              {% if imgs != blank %}
                                {% assign img_count = imgs.size %}
                                {% assign extra = img_count | minus: 3 %}

                                <div class="day-gallery {% if img_count == 1 %}day-gallery--1{% elsif img_count == 2 %}day-gallery--2{% else %}day-gallery--3{% endif %}">
                                  {% for img in imgs limit: 3 %}
                                    {% assign is_more = false %}
                                    {% if forloop.index == 3 and extra > 0 %}
                                      {% assign is_more = true %}
                                    {% endif %}

                                    <div class="day-img-wrap {% if is_more %}is-more{% endif %}" {% if is_more %}data-more="+{{ extra }}"{% endif %}>
                                      {% if img.preview_image %}
                                        <img
                                          class="day-img"
                                          loading="lazy"
                                          alt="{{ it.title | escape }}"
                                          src="{{ img.preview_image | image_url: width: 1000 }}"
                                        >
                                      {% else %}
                                        <a class="day-file-link" href="{{ img | file_url }}" target="_blank" rel="noopener">View image</a>
                                      {% endif %}
                                    </div>
                                  {% endfor %}
                                </div>
                              {% endif %}
                            </div>
                          </div>
                        {% endfor %}
                      </div>
                    </div>
                  </div>
                {% endfor %}
              </div>
            {% else %}
              <div style="padding:12px;color:#aaa;">custom.itinerary_days is not configured.</div>
            {% endif %}
          </div>
        </div>
      </div>
    </aside>

  </div>
</div>


<script src="https://cdn.jsdelivr.net/npm/flatpickr@4.6.13/dist/flatpickr.min.js"></script>

<script>
document.addEventListener('DOMContentLoaded', () => {
  const root = document.querySelector('.ota-wrapper');
  if (!root) return;

  const rows = Array.from(root.querySelectorAll('.ota-item-row'));
  const totalEl = document.getElementById('FinalGrandTotal');
  const dateInput = document.getElementById('TravelDate');
  const bookingView = document.getElementById('StandardBookingView');
  const customView = document.getElementById('CustomTourView');
  const footer = root.querySelector('.ota-footer');
  const infoPopup = root.querySelector('#OtaInfoPopup');
  const infoPopupTitle = root.querySelector('#OtaInfoPopupTitle');
  const infoPopupBody = root.querySelector('#OtaInfoPopupBody');

  const MONEY_FORMAT = {{ shop.money_format | json }};
  const rawPrices = {{ product.metafields.custom.calendar_prices.value | json }};
  const priceMap = rawPrices && typeof rawPrices === 'object' ? rawPrices : {};
  const CURRENCY_SYMBOL = {{ cart.currency.symbol | json }};

  let currentPackageType = 'luxury';

  const getElTarget = (e) => (e.target instanceof Element ? e.target : e.target?.parentElement);

  const formatMoney = (cents) => {
    if (window.Shopify && typeof Shopify.formatMoney === 'function') {
      return Shopify.formatMoney(cents, MONEY_FORMAT);
    }
    return (cents / 100).toFixed(0);
  };

  const getRowQty = (row) => Number(row.querySelector('input')?.value || 0);

  const setRowQty = (row, qty) => {
    const input = row.querySelector('input');
    if (!input) return;
    const val = Math.max(0, qty);
    input.value = val;

    const minusBtn = row.querySelector('[data-delta="-1"]');
    if (minusBtn) minusBtn.disabled = val <= 0;
  };

  const getRowPriceCents = (row) => Number(row.dataset.basePrice || 0);

  const isRowVisible = (row) => window.getComputedStyle(row).display !== 'none';

  const openInfoPopup = (key) => {
    if (!infoPopup || !infoPopupTitle || !infoPopupBody) return;

    const source = root.querySelector(`.ota-popup-source[data-popup-key="${key}"]`);
    if (!source) return;

    const titleMap = {
      children: 'Children pricing',
      group: 'Tour service standards'
    };

    infoPopupTitle.textContent = titleMap[key] || 'Details';
    infoPopupBody.innerHTML = source.innerHTML;
    infoPopup.hidden = false;
    document.body.style.overflow = 'hidden';
  };

  const closeInfoPopup = () => {
    if (!infoPopup || !infoPopupBody) return;
    infoPopup.hidden = true;
    infoPopupBody.innerHTML = '';
    document.body.style.overflow = '';
  };

  const updateTotal = () => {
    let totalCents = 0;
    rows.forEach(r => {
      if (!isRowVisible(r)) return;
      totalCents += getRowPriceCents(r) * getRowQty(r);
    });

    if (totalEl) {
      if (window.Shopify && typeof Shopify.formatMoney === 'function') {
        totalEl.innerHTML = Shopify.formatMoney(totalCents, MONEY_FORMAT);
      } else {
        totalEl.innerHTML = CURRENCY_SYMBOL + (totalCents / 100).toLocaleString('en-US');
      }
    }
  };

  const switchPackage = (type) => {
    currentPackageType = type;

    root.querySelectorAll('.ota-tag').forEach(t => {
      t.classList.toggle('active', t.dataset.type === type);
    });

    if (type === 'custom') {
      if (bookingView) bookingView.style.display = 'none';
      if (customView) customView.style.display = 'block';
      if (footer) footer.style.display = 'none';
      return;
    }

    if (bookingView) bookingView.style.display = 'block';
    if (customView) customView.style.display = 'none';
    if (footer) footer.style.display = 'flex';

    rows.forEach(row => {
      const show = row.dataset.package === type;
      row.style.display = show ? 'flex' : 'none';
      if (!show) setRowQty(row, 0);
    });

    updateTotal();
  };

  root.addEventListener('click', async (e) => {
    const target = getElTarget(e);
    if (!target) return;

    const tag = target.closest('.ota-tag');
    if (tag) {
      if (tag.classList.contains('disabled') && !tag.classList.contains('active')) return;
      switchPackage(tag.dataset.type);
      return;
    }

    const qtyBtn = target.closest('.js-qty');
    if (qtyBtn) {
      e.preventDefault();
      const row = qtyBtn.closest('.ota-item-row');
      const delta = Number(qtyBtn.dataset.delta || 0);
      const minQty = parseInt(row.dataset.minQty || 1);
      const currentQty = getRowQty(row);

      let newQty = 0;

      if (delta > 0) {
        if (currentQty === 0) {
          newQty = minQty;
        } else {
          newQty = currentQty + 1;
        }
      } else {
        if (currentQty <= minQty) {
          newQty = 0;
        } else {
          newQty = currentQty - 1;
        }
      }

      setRowQty(row, newQty);
      updateTotal();
      return;
    }

    if (target.closest('.js-reset')) {
      rows.forEach(r => setRowQty(r, 0));
      updateTotal();
      return;
    }

    const infoBtn = target.closest('.ota-info-btn');
    if (infoBtn) {
      e.preventDefault();
      openInfoPopup(infoBtn.dataset.modal);
      return;
    }

    if (target.closest('.ota-popup__close') || target.closest('.ota-popup__backdrop')) {
      e.preventDefault();
      closeInfoPopup();
      return;
    }

    const accordionHeader = target.closest('.accordion-header');
    if (accordionHeader) {
      e.preventDefault();
      const item = accordionHeader.closest('.accordion-item');
      const isActive = item.classList.contains('active');
      root.querySelectorAll('.accordion-item').forEach(i => i.classList.remove('active'));
      if (!isActive) item.classList.add('active');
      return;
    }

    const submitBtn = target.closest('.js-submit');
    if (submitBtn) {
      if (currentPackageType === 'custom') return;

      const items = rows
        .filter(r => isRowVisible(r))
        .map(r => ({
          id: r.dataset.variantId,
          quantity: getRowQty(r),
          properties: {
            'Departure date': dateInput ? dateInput.value : '',
            'Package type': currentPackageType
          }
        }))
        .filter(i => i.quantity > 0);

      if (items.length === 0) return alert('Please add at least one booking quantity.');
      if (dateInput && !dateInput.value) {
        alert('请选择您的出发日期');
        dateInput._flatpickr?.open();
        return;
      }

      const actionType = submitBtn.dataset.type;

      try {
        submitBtn.classList.add('loading');
        submitBtn.disabled = true;

        const res = await fetch(window.Shopify.routes.root + 'cart/add.js', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ items })
        });

        if (!res.ok) throw new Error('Failed to add to cart');

        window.location.href = actionType === 'cart' ? '/cart' : '/checkout';
      } catch (err) {
        console.error(err);
        alert('Failed to add. Please try again.');
        submitBtn.classList.remove('loading');
        submitBtn.disabled = false;
      }
    }
  });

  (function () {
    function bootCalendar() {
      const root = document.querySelector('.ota-wrapper');
      if (!root) return;

      const dateInput = root.querySelector('#TravelDate');
      if (!dateInput) return;

      if (dateInput._flatpickr) return;

      const start = () => {
        if (dateInput._flatpickr) return;

        window.flatpickr(dateInput, {
          dateFormat: 'Y-m-d',
          minDate: 'today',
          disableMobile: true,
          monthSelectorType: 'dropdown',
          locale: 'en',

          onDayCreate(dObj, dStr, fp, dayElem) {
            const dateKey = fp.formatDate(dayElem.dateObj, 'Y-m-d');
            const price = priceMap?.[dateKey];
            if (price == null) return;

            const sp = document.createElement('span');
            sp.className = 'day-price';
            sp.textContent = `${CURRENCY_SYMBOL}${price}`;
            dayElem.appendChild(sp);
          }
        });

        const open = (ev) => {
          ev.preventDefault();
          ev.stopPropagation();
          dateInput._flatpickr?.open();
        };

        const dateBox = root.querySelector('.ota-date-box');
        const dateBtn = root.querySelector('.ota-date-btn');
        ['pointerdown', 'click'].forEach((evt) => {
          dateInput.addEventListener(evt, open, { capture: true });
          dateBtn && dateBtn.addEventListener(evt, open, { capture: true });
          dateBox && dateBox.addEventListener(evt, open, { capture: true });
        });
      };

      if (typeof window.flatpickr === 'function') {
        start();
      } else {
        const t0 = Date.now();
        const timer = setInterval(() => {
          if (typeof window.flatpickr === 'function') {
            clearInterval(timer);
            start();
          } else if (Date.now() - t0 > 3000) {
            clearInterval(timer);
            console.warn('[OTA] flatpickr not loaded (check CSP / CDN / network).');
          }
        }, 50);
      }
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', bootCalendar);
    } else {
      bootCalendar();
    }
    window.addEventListener('pageshow', bootCalendar);
    document.addEventListener('shopify:section:load', bootCalendar);
  })();

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && infoPopup && !infoPopup.hidden) {
      closeInfoPopup();
    }
  });

  updateTotal();

  function pickHeaderEl() {
    return (
      document.querySelector('#shopify-section-header') ||
      document.querySelector('.shopify-section-header') ||
      document.querySelector('.section-header') ||
      document.querySelector('.header-wrapper') ||
      document.querySelector('#site-header') ||
      document.querySelector('header')
    );
  }

  function pickAnnouncementEl() {
    return (
      document.querySelector('.announcement-bar') ||
      document.querySelector('.utility-bar') ||
      document.querySelector('[data-section-type="announcement-bar"]')
    );
  }

  function updateHeaderSafeHeight() {
    const headerEl = pickHeaderEl();
    const annEl = pickAnnouncementEl();

    const headerH = headerEl ? headerEl.getBoundingClientRect().height : 0;
    const annH = annEl ? annEl.getBoundingClientRect().height : 0;

    const total = Math.ceil(headerH + annH);
    if (total > 0) {
      document.documentElement.style.setProperty('--header-safe-height', `${total}px`);
    }
  }

  updateHeaderSafeHeight();
  window.addEventListener('resize', updateHeaderSafeHeight);

  const headerEl = pickHeaderEl();
  const annEl = pickAnnouncementEl();
  if (window.ResizeObserver) {
    const ro = new ResizeObserver(updateHeaderSafeHeight);
    if (headerEl) ro.observe(headerEl);
    if (annEl) ro.observe(annEl);
  }

  function removeLeadingBr(el) {
    while (el.firstChild) {
      const n = el.firstChild;

      if (n.nodeType === 1 && n.tagName === 'BR') {
        el.removeChild(n);
        continue;
      }

      if (n.nodeType === 3 && !n.textContent.replace(/\u00A0/g, '').trim()) {
        el.removeChild(n);
        continue;
      }

      break;
    }
  }

  root.querySelectorAll('.day-text-content').forEach(removeLeadingBr);
});
</script>