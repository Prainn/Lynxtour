<header class="site-header-wrapper" id="site-header">
  {%- if section.settings.show_slogan -%}
    <div class="slogan-bar-wrapper" id="slogan-node">
      <div class="relative overflow-hidden bg-stone-950">
        <div class="absolute inset-0 bg-gradient-to-r from-amber-900/10 via-transparent to-amber-900/10"></div>
        <div class="relative py-2 text-center">
          <p class="text-[10px] md:text-xs font-medium tracking-[0.3em] uppercase italic text-amber-500/90 font-sans m-0">
            {{ section.settings.slogan_text }}
          </p>
        </div>
      </div>
    </div>
  {%- endif -%}

  <nav class="main-nav-bar" id="nav-node">
    <div class="header-container flex-layout">
      <div class="header-left">
        <a href="/" class="logo-wrapper">
          <span class="logo-cn">{{ section.settings.logo_text_cn }}</span>
          <span class="logo-en">{{ section.settings.logo_text_en }}</span>
        </a>
      </div>

      <div class="header-right">
        <div class="desktop-nav">
          {%- assign nav_menu = linklists[section.settings.main_menu] -%}
          {%- for link in nav_menu.links -%}
            <div class="nav-group">
              <a href="{{ link.url }}" class="nav-item">
                {{ link.title }}{%- if link.links != blank -%}<span class="caret"></span>{%- endif -%}
              </a>
              {%- if link.links != blank -%}
                <div class="dropdown-menu">
                  {%- for childlink in link.links -%}
                    <a href="{{ childlink.url }}" class="dropdown-link">{{ childlink.title }}</a>
                  {%- endfor -%}
                </div>
              {%- endif -%}
            </div>
          {%- endfor -%}
        </div>

        <button id="menu-toggle" class="mobile-toggle" aria-label="Menu">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M4 8h16M4 16h16"/>
          </svg>
        </button>
      </div>
    </div>
  </nav>
</header>

<style>
  :root {
    --amber-500: #fbbf24;
    --slogan-h: 36px;
  }

  /* 基础布局 */
  .site-header-wrapper { width: 100%; z-index: 9999; position: relative; }
  .slogan-bar-wrapper { background: #0c0a09; height: var(--slogan-h); position: relative; z-index: 1001; }

  /* 导航栏固定逻辑 */
  .main-nav-bar {
    position: fixed;
    top: var(--slogan-h);
    left: 0;
    width: 100%;
    background: transparent;
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    z-index: 1000;
  }

  /* 滚动吸顶后的状态 */
  .main-nav-bar.is-stuck {
    top: 0;
    background: rgba(12, 10, 9, 0.95);
    backdrop-filter: blur(15px);
    box-shadow: 0 10px 30px rgba(0,0,0,0.5);
  }

  /* 容器排版 */
  .header-container { max-width: 1400px; margin: 0 auto; padding: 0 40px; }
  .flex-layout { display: flex; justify-content: space-between; align-items: center; height: 80px; transition: height 0.3s; }
  .main-nav-bar.is-stuck .flex-layout { height: 65px; }

  /* 桌面端导航 */
  .desktop-nav { display: flex; gap: 35px; align-items: center; }
  .nav-group { position: relative; }
  .nav-item { color: #fff; text-decoration: none; font-size: 13px; letter-spacing: 2px; text-transform: uppercase; font-weight: 500; }
  .caret { border-top: 4px solid currentColor; border-left: 4px solid transparent; border-right: 4px solid transparent; margin-left: 6px; }

  /* 二级菜单悬浮 */
  .dropdown-menu {
    position: absolute; top: 100%; left: 50%; transform: translateX(-50%) translateY(10px);
    background: #0c0a09; border: 1px solid rgba(251,191,36,0.2); 
    min-width: 180px; padding: 12px 0; opacity: 0; visibility: hidden; transition: 0.3s;
  }
  .nav-group:hover .dropdown-menu { opacity: 1; visibility: visible; transform: translateX(-50%) translateY(0); }
  .dropdown-link { display: block; padding: 8px 20px; color: #a8a29e; text-decoration: none; font-size: 12px; }
  .dropdown-link:hover { color: var(--amber-500); background: rgba(255,255,255,0.05); }

  /* 移动端开关 - 核心：桌面端隐藏 */
  .mobile-toggle { 
    display: none; /* 默认隐藏（网页端不出现） */
    background: none; border: none; color: #fff; cursor: pointer; padding: 5px;
  }

  /* Logo 样式 */
  .logo-wrapper { display: flex; flex-direction: column; text-decoration: none; }
  .logo-cn { color: var(--amber-500); font-size: 22px; font-weight: 700; letter-spacing: 2px; }
  .logo-en { color: #d6d3d1; font-size: 10px; opacity: 0.7; letter-spacing: 1px; }

  /* 移动端适配 */
  @media (max-width: 990px) {
    .desktop-nav { display: none; } /* 隐藏桌面菜单 */
    .mobile-toggle { display: block; } /* 仅在手机端显示开关 */
    .header-container { padding: 0 20px; }
    .flex-layout { height: 70px; }
  }
</style>

<script>
document.addEventListener('DOMContentLoaded', function() {
  const nav = document.getElementById('nav-node');
  const slogan = document.getElementById('slogan-node');
  
  const handleScroll = () => {
    const sloganHeight = slogan ? slogan.offsetHeight : 0;
    if (window.scrollY > sloganHeight) {
      nav.classList.add('is-stuck');
    } else {
      nav.classList.remove('is-stuck');
    }
  };

  window.addEventListener('scroll', handleScroll);
  handleScroll(); // 初始化执行一次
});
</script>

{% schema %}
{
  "name": "Header Clean Version",
  "settings": [
    { "type": "checkbox", "id": "show_slogan", "label": "显示标语", "default": true },
    { "type": "text", "id": "slogan_text", "label": "标语文字", "default": "探索云之南 · 定制奢华之旅" },
    { "type": "text", "id": "logo_text_cn", "label": "中文名", "default": "云之旅" },
    { "type": "text", "id": "logo_text_en", "label": "英文名", "default": "CLOUD TRAVEL" },
    { "type": "link_list", "id": "main_menu", "label": "主菜单", "default": "main-menu" }
  ]
}
{% endschema %}