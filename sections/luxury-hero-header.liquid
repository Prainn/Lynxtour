            {%- assign mega_top_btn = section.settings.mega_default_btn -%}

            {%- assign mega_side_label = section.settings.mega_default_side_label -%}
            {%- assign mega_side_title = section.settings.mega_default_side_title -%}
            {%- assign mega_side_text = section.settings.mega_default_side_text -%}
