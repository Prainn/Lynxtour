          {%- when 'top attractions' -%}
            {%- assign mobile_parent_link = section.settings.mega_attractions_side_link | default: link.url -%}
          {%- when 'tours' -%}
            {%- assign mobile_parent_link = section.settings.mega_tours_side_link | default: link.url -%}
          {%- when 'travel services' -%}
            {%- assign mobile_parent_link = section.settings.mega_services_side_link | default: link.url -%}
          {%- when 'travel guide' -%}
            {%- assign mobile_parent_link = section.settings.mega_guide_side_link | default: link.url -%}
          {%- when 'support' -%}
            {%- assign mobile_parent_link = section.settings.mega_support_side_link | default: link.url -%}
          {%- else -%}
            {%- assign mobile_parent_link = section.settings.mega_default_side_link | default: link.url -%}
        {%- endcase -%}

        <div class="drawer-item">
          <a href="{{ mobile_parent_link }}" class="drawer-link">{{ link.title }}</a>

          {%- if link.links != blank -%}
            <div class="drawer-sub">
              {%- for childlink in link.links -%}
                <a href="{{ childlink.url }}" class="drawer-sub-link">{{ childlink.title }}</a>
              {%- endfor -%}
            </div>
          {%- endif -%}
        </div>
      {%- endfor -%}

      <!-- 移动端语言选择器 -->
      {%- if localization.available_languages.size > 1 -%}
        <div class="mobile-lang-switch">
          {%- form 'localization', id: 'MobileLanguageForm' -%}
            <p class="drawer-sub-link" style="margin-bottom:8px; opacity:0.5; font-size:12px;">Language / 语言</p>
            <div class="lang-selector-wrap mobile-wrap">
              <select name="locale_code" class="lang-select mobile-select" onchange="this.form.submit()">
                {%- for language in localization.available_languages -%}
                  <option value="{{ language.iso_code }}" {% if language.iso_code == localization.language.iso_code %}selected{% endif %}>
                    {{ language.endonym_name | capitalize }}
                  </option>
                {%- endfor -%}
              </select>
            </div>
          {%- endform -%}
        </div>
      {%- endif -%}

      <!-- 移动端客户账户 -->
      {%- if shop.customer_accounts_enabled -%}
        <div class="mobile-account-switch">
          <p class="drawer-sub-link" style="margin-bottom:8px; opacity:0.5; font-size:12px;">Account</p>
          {%- if customer -%}
            <a href="{{ routes.account_url }}" class="drawer-link" style="font-size: 16px; display: flex; align-items: center; gap: 8px;">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>
              {{ customer.first_name | default: 'My Account' }}
            </a>
            <a href="{{ routes.account_logout_url }}" class="drawer-sub-link">Log out</a>
          {%- else -%}
            <a href="{{ routes.account_login_url }}" class="drawer-link" style="font-size: 16px; display: flex; align-items: center; gap: 8px;">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>
              Sign in
            </a>
          {%- endif -%}
        </div>
      {%- endif -%}
    </div>
  </div>
</div>

<!-- 3. Hero 主视觉区域 -->
{%- assign hero_alt = section.settings.main_title | append: ' - ' | append: section.settings.sub_title -%}

<div class="hero-section" id="Hero-{{ section.id }}">
  <div class="hero-bg-container" data-align="{{ section.settings.bg_alignment }}">
    {% if section.settings.hero_image != blank %}
      {{
        section.settings.hero_image
        | image_url: width: 2200
        | image_tag:
          class: 'hero-bg-image',
          widths: '480,768,960,1200,1600,2200',
          sizes: '100vw',
          loading: 'eager',
          fetchpriority: 'high',
          alt: hero_alt
      }}
    {% endif %}
  </div>

  <div class="hero-overlay"></div>

  <div class="hero-content">
    {% if section.settings.hero_eyebrow != blank %}
      <p class="hero-eyebrow">{{ section.settings.hero_eyebrow }}</p>
    {% endif %}

    <h1 class="hero-title">{{ section.settings.main_title }}</h1>

    {% if section.settings.sub_title != blank %}
      <p class="hero-subtitle">{{ section.settings.sub_title }}</p>
    {% endif %}

    {% if section.settings.brand_intro != blank %}
      <p class="hero-brand-intro">{{ section.settings.brand_intro }}</p>
    {% endif %}

    <div class="hero-button-wrapper">
      {% if section.settings.button_text != blank %}
        <a href="{{ section.settings.button_link }}" class="hero-btn hero-btn-primary">
          {{ section.settings.button_text }}
          <span class="btn-pulse"></span>
        </a>
      {% endif %}

      {% if section.settings.button_text_2 != blank %}
        <a href="{{ section.settings.button_link_2 }}" class="hero-btn hero-btn-secondary">
          <span class="btn-text">{{ section.settings.button_text_2 }}</span>
        </a>
      {% endif %}
    </div>
  </div>

  <div class="scroll-guide" aria-hidden="true">
    <div class="mouse"><div class="wheel"></div></div>
    <span class="scroll-text">SCROLL TO EXPLORE</span>
  </div>
</div>

