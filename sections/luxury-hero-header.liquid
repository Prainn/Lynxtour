                {%- assign mega_top_title = section.settings.mega_tours_title -%}
                {%- assign mega_top_text = section.settings.mega_tours_text -%}
                {%- assign mega_top_btn = section.settings.mega_tours_btn -%}

                {%- assign mega_side_label = section.settings.mega_tours_side_label -%}
                {%- assign mega_side_title = section.settings.mega_tours_side_title -%}
                {%- assign mega_side_text = section.settings.mega_tours_side_text -%}
