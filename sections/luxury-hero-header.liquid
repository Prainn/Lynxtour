<style>
  :root {
    --brand-color: {{ section.settings.btn_color }};
    --brand-light: #fef3c7;
    --slogan-h: {% if section.settings.show_slogan %}36px{% else %}0px{% endif %};
  }

  /* --- 导航基础 --- */
  .main-nav-bar {
    position: absolute;
    top: var(--slogan-h);
    left: 0;
    width: 100%;
    background: transparent;
    transition: 0.35s ease;
    z-index: 1000;
  }

  .main-nav-bar.is-stuck {
    position: fixed;
    top: 0;
    background: rgba(12, 10, 9, 0.92);
    backdrop-filter: blur(12px);
    border-bottom: none;
  }

  .header-container {
    max-width: 1480px;
    margin: 0 auto;
    padding: 0 28px;
  }

  .flex-layout {
    display: flex;
    justify-content: space-between;
    align-items: center;
    height: 86px;
    gap: 18px;
  }

  /* --- Logo 区域 --- */
  .header-left {
    flex: 0 0 auto;
  }

  .logo-wrapper {
    display: flex;
    align-items: center;
    gap: 14px;
    text-decoration: none;
  }

  .header-logo-image {
    height: {{ section.settings.logo_height }}px;
    width: auto;
    object-fit: contain;
  }

  .logo-text-group {
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .logo-cn {
    color: var(--brand-color);
    font-size: 20px;
    font-weight: 700;
    line-height: 1.15;
  }

  .logo-en {
    color: #d6d3d1;
    font-size: 9px;
    opacity: 0.78;
    letter-spacing: 1.4px;
    line-height: 1.2;
  }

  /* --- 右侧区域 --- */
  .header-right {
    flex: 1 1 auto;
    min-width: 0;
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 16px;
  }

  /* --- 桌面菜单 --- */
  .desktop-nav {
    display: flex;
    align-items: center;
    gap: clamp(14px, 1.3vw, 24px);
    min-width: 0;
  }

  .nav-group {
    position: relative;
  }

  .nav-item {
    color: #fff;
    text-decoration: none;
    font-size: 12px;
    letter-spacing: 1.2px;
    text-transform: uppercase;
    font-weight: 500;
    padding: 28px 0;
    display: inline-flex;
    align-items: center;
    white-space: nowrap;
    transition: color 0.25s ease;
    position: relative;
  }

  .nav-item::after {
    content: "";
    position: absolute;
    left: 0;
    bottom: 16px;
    width: 100%;
    height: 1px;
    background: var(--brand-color);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.25s ease;
    opacity: 0.9;
  }

  .nav-item:hover,
  .nav-group:hover > .nav-item {
    color: var(--brand-color);
  }

  .nav-item:hover::after,
  .nav-group:hover > .nav-item::after {
    transform: scaleX(1);
  }

  .caret {
    border-top: 4px solid currentColor;
    border-left: 4px solid transparent;
    border-right: 4px solid transparent;
    margin-left: 6px;
    opacity: 0.65;
    display: inline-block;
    vertical-align: middle;
  }

  /* --- 语言选择器 --- */
  .desktop-lang-switch {
    display: flex;
    align-items: center;
    margin-left: 4px;
    padding-left: 14px;
    border-left: 1px solid rgba(255,255,255,0.12);
    height: 28px;
    flex: 0 0 auto;
  }

  .lang-selector-wrap {
    position: relative;
    display: flex;
    align-items: center;
  }

  .lang-icon {
    color: var(--brand-color);
    font-size: 14px;
    margin-right: 6px;
    pointer-events: none;
    opacity: 0.88;
  }

  .lang-select {
    appearance: none;
    -webkit-appearance: none;
    background: transparent;
    color: #ccc;
    border: 1px solid transparent;
    border-radius: 4px;
    padding: 4px 16px 4px 2px;
    font-size: 11px;
    cursor: pointer;
    transition: 0.25s ease;
    outline: none;
    font-family: inherit;
    letter-spacing: 0.06em;
    background-image: url("data:image/svg+xml;charset=UTF-8,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='%23fbbf24' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'%3e%3cpolyline points='6 9 12 15 18 9'%3e%3c/polyline%3e%3c/svg%3e");
    background-repeat: no-repeat;
    background-position: right center;
    background-size: 11px;
  }

  .lang-select:hover {
    color: var(--brand-color);
  }

  .lang-select option {
    background: #0c0a09;
    color: #fff;
    padding: 10px;
  }

  /* --- 账户 --- */
  .desktop-account-switch {
    display: flex;
    align-items: center;
    margin-left: 0;
    padding-left: 14px;
    border-left: 1px solid rgba(255,255,255,0.12);
    height: 28px;
    flex: 0 0 auto;
  }

  .account-link {
    display: flex;
    align-items: center;
    gap: 6px;
    color: #ccc;
    text-decoration: none;
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    transition: 0.25s ease;
    white-space: nowrap;
  }

  .account-link:hover {
    color: var(--brand-color);
  }

  .account-icon {
    color: var(--brand-color);
    display: flex;
  }

  /* --- 移动端菜单按钮 --- */
  .mobile-toggle {
    display: none;
    background: none;
    border: none;
    padding: 8px;
    cursor: pointer;
    z-index: 1001;
  }

  .hamburger-icon {
    display: flex;
    flex-direction: column;
    gap: 5px;
    width: 22px;
  }

  .hamburger-icon span {
    display: block;
    width: 100%;
    height: 2px;
    background-color: #fff;
    transition: 0.3s;
  }

  /* --- 移动端侧边抽屉 --- */
  .mobile-drawer {
    position: fixed;
    inset: 0;
    z-index: 2000;
    visibility: hidden;
    pointer-events: none;
  }

  .mobile-drawer.is-active {
    visibility: visible;
    pointer-events: auto;
  }

  .drawer-overlay {
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,0.8);
    opacity: 0;
    transition: 0.4s;
  }

  .mobile-drawer.is-active .drawer-overlay {
    opacity: 1;
  }

  .drawer-content {
    position: absolute;
    top: 0;
    right: 0;
    width: 80%;
    max-width: 320px;
    height: 100%;
    background: #0c0a09;
    transform: translateX(100%);
    transition: transform 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
    padding: 20px 30px;
    display: flex;
    flex-direction: column;
    border-left: 1px solid rgba(255,255,255,0.1);
  }

  .mobile-drawer.is-active .drawer-content {
    transform: translateX(0);
  }

  .drawer-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 30px;
    padding-bottom: 15px;
    border-bottom: 1px solid rgba(255,255,255,0.1);
  }

  .close-btn {
    background: none;
    border: none;
    font-size: 32px;
    color: #fff;
    cursor: pointer;
    line-height: 1;
  }

  .drawer-menu-list {
    overflow-y: auto;
    flex: 1;
  }

  .drawer-item {
    margin-bottom: 20px;
  }

  .drawer-link {
    color: #fff;
    text-decoration: none;
    font-size: 18px;
    font-weight: 500;
    display: block;
    margin-bottom: 8px;
    letter-spacing: 1px;
  }

  .drawer-sub {
    padding-left: 15px;
    border-left: 1px solid var(--brand-color);
  }

  .drawer-sub-link {
    color: #9ca3af;
    text-decoration: none;
    font-size: 14px;
    display: block;
    padding: 6px 0;
    transition: 0.2s;
  }

  .drawer-sub-link:hover {
    color: var(--brand-color);
  }

  .mobile-lang-switch {
    margin-top: 40px;
    padding-top: 20px;
    border-top: 1px solid rgba(255,255,255,0.1);
  }

  .mobile-select {
    width: 100%;
    text-align: left;
    padding: 12px;
    font-size: 14px;
    border: 1px solid rgba(255,255,255,0.15);
    background-position: right 10px center;
  }

  .mobile-account-switch {
    margin-top: 20px;
    padding-top: 20px;
    border-top: 1px solid rgba(255,255,255,0.1);
  }

  /* --- 标语栏 --- */
  .slogan-bar-wrapper {
    background: #0c0a09;
    height: var(--slogan-h);
    position: relative;
    overflow: hidden;
  }

  .slogan-gradient {
    position: absolute;
    inset: 0;
    background: linear-gradient(to right, rgba(120,53,15,0) 0%, rgba(251,191,36,0.15) 50%, rgba(120,53,15,0) 100%);
    animation: goldShimmer 7s infinite linear;
  }

  @keyframes goldShimmer {
    0% { transform: translateX(-100%); }
    100% { transform: translateX(100%); }
  }

  .slogan-content {
    position: relative;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 2;
  }

  .slogan-text {
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--brand-color);
    margin: 0;
  }

  /* --- Hero --- */
  .hero-section {
    position: relative;
    width: 100%;
    min-height: 100svh;
    height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    color: #ffffff;
    overflow: hidden;
    background: #1c1917;
    margin-top: calc(var(--slogan-h) * -1);
  }

  .hero-bg-container {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hero-bg-image {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
    transform: scale(1.02);
  }

  .hero-bg-container[data-align="left"] .hero-bg-image {
    object-position: left center;
  }

  .hero-bg-container[data-align="center"] .hero-bg-image {
    object-position: center center;
  }

  .hero-bg-container[data-align="right"] .hero-bg-image {
    object-position: right center;
  }

  @keyframes heroZoom {
    0% { transform: scale(1.02); }
    100% { transform: scale(1.08); }
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, rgba(0,0,0,0.2), rgba(0,0,0,0.6));
    z-index: 1;
  }

  .hero-content {
    position: relative;
    z-index: 2;
    padding: 0 24px;
    width: 100%;
    max-width: 1000px;
    margin: 0 auto;
  }

  .hero-eyebrow {
    margin: 0 auto 16px;
    color: var(--brand-color);
    font-size: clamp(0.72rem, 1.5vw, 0.9rem);
    letter-spacing: 0.38em;
    text-transform: uppercase;
    font-weight: 600;
  }

  .hero-title {
    font-size: clamp(2.6rem, 8vw, 5.5rem);
    font-weight: 800;
    margin: 0 auto 18px;
    text-transform: uppercase;
    line-height: 1.1;
  }

  .hero-subtitle {
    color: var(--brand-color);
    font-size: clamp(0.9rem, 2.5vw, 1.2rem);
    letter-spacing: 0.32em;
    text-transform: uppercase;
    margin: 0 auto 24px;
    display: inline-block;
  }

  .hero-brand-intro {
    max-width: 820px;
    margin: 0 auto;
    color: rgba(255,255,255,0.84);
    font-size: clamp(0.98rem, 1.8vw, 1.12rem);
    line-height: 1.9;
    letter-spacing: 0.01em;
  }

  .hero-button-wrapper {
    display: flex;
    gap: 30px;
    justify-content: center;
    align-items: center;
    flex-wrap: wrap;
    margin-top: 34px;
  }

  .hero-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 18px 50px;
    text-decoration: none;
    font-size: 0.95rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    border-radius: 60px;
    position: relative;
    transition: all 0.6s cubic-bezier(0.165, 0.84, 0.44, 1);
    min-width: 200px;
    overflow: hidden;
    white-space: nowrap;
  }

  .hero-btn-primary {
    background-color: var(--brand-color);
    color: {{ section.settings.btn_text_color }};
    border: none;
  }

  .hero-btn-primary:hover {
    transform: translateY(-5px);
    background-color: #ffffff;
    color: #1c1917;
    box-shadow: 0 10px 25px rgba(255,255,255,0.2);
  }

  .hero-btn-secondary {
    background: rgba(255, 255, 255, 0.05);
    color: #ffffff;
    border: 1px solid rgba(255, 255, 255, 0.3);
    backdrop-filter: blur(5px);
  }

  .hero-btn-secondary:hover {
    transform: translateY(-5px);
    border-color: var(--brand-color);
    color: var(--brand-color);
    background: rgba(0,0,0,0.3);
  }

  .scroll-guide {
    position: absolute;
    bottom: 40px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 5;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
    opacity: 0.8;
  }

  .mouse {
    width: 26px;
    height: 42px;
    border: 2px solid rgba(255,255,255,0.6);
    border-radius: 20px;
    position: relative;
  }

  .wheel {
    width: 4px;
    height: 8px;
    background: #fff;
    border-radius: 2px;
    position: absolute;
    top: 8px;
    left: 50%;
    transform: translateX(-50%);
    animation: scrollWheel 2s infinite;
  }

  .scroll-text {
    font-size: 10px;
    letter-spacing: 2px;
    color: rgba(255,255,255,0.6);
  }

  @keyframes scrollWheel {
    0% { opacity: 1; top: 8px; }
    100% { opacity: 0; top: 24px; }
  }

  @media (min-width: 991px) and (prefers-reduced-motion: no-preference) {
    .hero-bg-image {
      animation: heroZoom 18s infinite alternate cubic-bezier(0.445, 0.05, 0.55, 0.95);
    }
  }

  @media (min-width: 1181px) {
    /* --- 普通下拉 --- */
    .dropdown-menu {
      position: absolute;
      top: calc(100% - 6px);
      left: 50%;
      transform: translateX(-50%) translateY(12px);
      background: rgba(12, 10, 9, 0.98);
      min-width: 220px;
      padding: 10px;
      opacity: 0;
      visibility: hidden;
      transition: all 0.28s ease;
      box-shadow: 0 20px 45px rgba(0,0,0,0.55);
      border: 1px solid rgba(255,255,255,0.07);
      border-radius: 16px;
      z-index: 1100;
    }

    .nav-group:hover .dropdown-menu {
      opacity: 1;
      visibility: visible;
      transform: translateX(-50%) translateY(0);
    }

    .dropdown-link {
      display: block;
      padding: 11px 14px;
      color: #d1d5db;
      text-decoration: none;
      font-size: 12px;
      letter-spacing: 0.06em;
      border-radius: 10px;
      transition: 0.22s ease;
      white-space: nowrap;
    }

    .dropdown-link:hover {
      color: #111;
      background: linear-gradient(90deg, var(--brand-color) 0%, var(--brand-light) 100%);
    }

    /* --- Mega menu --- */
    .nav-group-mega {
      position: static;
    }

    .mega-menu {
      position: absolute;
      left: 50%;
      transform: translateX(-50%) translateY(14px);
      top: calc(100% - 6px);
      width: min(1120px, calc(100vw - 56px));
      opacity: 0;
      visibility: hidden;
      transition: all 0.28s ease;
      z-index: 1150;
    }

    .nav-group-mega:hover .mega-menu {
      opacity: 1;
      visibility: visible;
      transform: translateX(-50%) translateY(0);
    }

    .mega-menu-inner {
      display: grid;
      grid-template-columns: minmax(0, 1.75fr) minmax(250px, 320px);
      gap: 22px;
      background: rgba(12, 10, 9, 0.98);
      border: 1px solid rgba(255,255,255,0.07);
      border-radius: 24px;
      box-shadow: 0 28px 60px rgba(0,0,0,0.58);
      padding: 22px;
    }

    .mega-menu-main {
      min-width: 0;
    }

    .mega-menu-top {
      margin-bottom: 18px;
    }

    .mega-eyebrow {
      display: inline-block;
      font-size: 10px;
      letter-spacing: 0.28em;
      text-transform: uppercase;
      color: var(--brand-color);
      margin-bottom: 10px;
    }

    .mega-title {
      margin: 0 0 10px;
      color: #fff;
      font-size: 24px;
      font-weight: 700;
      letter-spacing: 0.02em;
    }

    .mega-intro {
      margin: 0;
      color: #b8b4ae;
      font-size: 13px;
      line-height: 1.8;
      max-width: 620px;
    }

    .mega-dest-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 14px;
    }

    .mega-dest-card {
      position: relative;
      display: flex;
      flex-direction: column;
      gap: 8px;
      min-height: 132px;
      padding: 18px 18px 20px;
      border-radius: 18px;
      text-decoration: none;
      color: #ece7e1;
      background: rgba(255,255,255,0.03);
      border: 1px solid rgba(255,255,255,0.06);
      transition: 0.24s ease;
    }

    .mega-dest-card:hover {
      transform: translateY(-3px);
      border-color: rgba(251,191,36,0.24);
      background: rgba(251,191,36,0.07);
    }

    .mega-dest-kicker {
      font-size: 10px;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--brand-color);
      opacity: 0.9;
    }

    .mega-dest-title {
      font-size: 18px;
      font-weight: 700;
      color: #fff;
      line-height: 1.25;
    }

    .mega-dest-desc {
      font-size: 12px;
      line-height: 1.75;
      color: #b8b4ae;
      max-width: 92%;
    }

    .mega-dest-arrow {
      position: absolute;
      right: 16px;
      top: 16px;
      font-size: 14px;
      color: var(--brand-color);
      opacity: 0.85;
    }

    .mega-spot-grid {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 12px;
    }

    .mega-spot-card {
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      min-height: 98px;
      padding: 16px;
      border-radius: 16px;
      text-decoration: none;
      color: #ece7e1;
      background: rgba(255,255,255,0.03);
      border: 1px solid rgba(255,255,255,0.06);
      transition: 0.22s ease;
    }

    .mega-spot-card:hover {
      transform: translateY(-2px);
      border-color: rgba(251,191,36,0.24);
      background: rgba(251,191,36,0.06);
    }

    .mega-spot-type {
      font-size: 10px;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--brand-color);
      opacity: 0.9;
    }

    .mega-spot-title {
      font-size: 13px;
      line-height: 1.5;
      color: #fff;
      font-weight: 600;
    }

    .mega-tour-list {
      display: flex;
      flex-direction: column;
      gap: 10px;
    }

    .mega-tour-row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 16px;
      min-height: 70px;
      padding: 16px 18px;
      border-radius: 16px;
      text-decoration: none;
      color: #ece7e1;
      background: rgba(255,255,255,0.03);
      border: 1px solid rgba(255,255,255,0.06);
      transition: 0.22s ease;
    }

    .mega-tour-row:hover {
      transform: translateY(-2px);
      border-color: rgba(251,191,36,0.24);
      background: rgba(251,191,36,0.06);
    }

    .mega-tour-copy {
      display: flex;
      flex-direction: column;
      gap: 6px;
      min-width: 0;
    }

    .mega-tour-title {
      color: #fff;
      font-size: 14px;
      font-weight: 700;
      line-height: 1.35;
    }

    .mega-tour-desc {
      color: #b8b4ae;
      font-size: 12px;
      line-height: 1.65;
    }

    .mega-tour-arrow {
      flex: 0 0 auto;
      font-size: 14px;
      color: var(--brand-color);
      opacity: 0.85;
    }

    .mega-links-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 12px;
    }

    .mega-link-card {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      min-height: 62px;
      padding: 16px 18px;
      border-radius: 16px;
      text-decoration: none;
      color: #ece7e1;
      background: rgba(255,255,255,0.03);
      border: 1px solid rgba(255,255,255,0.06);
      transition: 0.22s ease;
    }

    .mega-link-card:hover {
      transform: translateY(-2px);
      border-color: rgba(251,191,36,0.22);
      background: rgba(251,191,36,0.07);
      color: var(--brand-color);
    }

    .mega-link-title {
      font-size: 13px;
      letter-spacing: 0.02em;
      line-height: 1.45;
    }

    .mega-link-arrow {
      font-size: 14px;
      opacity: 0.8;
      flex: 0 0 auto;
    }

    .mega-menu-side {
      min-width: 0;
    }

    .mega-side-card {
      height: 100%;
      border-radius: 20px;
      padding: 22px 20px;
      background:
        radial-gradient(circle at top right, rgba(251,191,36,0.12), transparent 35%),
        rgba(255,255,255,0.03);
      border: 1px solid rgba(255,255,255,0.06);
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      min-height: 100%;
    }

    .mega-side-label {
      display: inline-block;
      color: var(--brand-color);
      font-size: 10px;
      letter-spacing: 0.28em;
      text-transform: uppercase;
      margin-bottom: 14px;
    }

    .mega-side-title {
      margin: 0 0 12px;
      color: #fff;
      font-size: 22px;
      line-height: 1.2;
      font-weight: 700;
    }

    .mega-side-text {
      margin: 0 0 20px;
      color: #b8b4ae;
      font-size: 13px;
      line-height: 1.8;
    }

    .mega-side-btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 44px;
      padding: 0 18px;
      border-radius: 999px;
      text-decoration: none;
      color: #111;
      background: linear-gradient(90deg, var(--brand-color) 0%, var(--brand-light) 100%);
      font-size: 12px;
      font-weight: 700;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      transition: 0.22s ease;
      align-self: flex-start;
    }

    .mega-side-btn:hover {
      transform: translateY(-2px);
      filter: brightness(1.03);
    }
  }

  @media (max-width: 1440px) {
    .header-container {
      padding: 0 24px;
    }

    .desktop-nav {
      gap: 18px;
    }

    .mega-menu {
      width: min(1040px, calc(100vw - 48px));
    }
  }

  @media (max-width: 1320px) {
    .nav-item {
      font-size: 11px;
      letter-spacing: 1px;
    }

    .desktop-nav {
      gap: 14px;
    }

    .header-right {
      gap: 12px;
    }

    .desktop-lang-switch,
    .desktop-account-switch {
      padding-left: 10px;
      margin-left: 0;
    }

    .mega-menu {
      width: min(980px, calc(100vw - 42px));
    }

    .mega-menu-inner {
      grid-template-columns: minmax(0, 1.55fr) minmax(220px, 280px);
    }
  }

  @media (max-width: 1180px) {
    .desktop-nav,
    .desktop-lang-switch,
    .desktop-account-switch {
      display: none;
    }

    .mobile-toggle {
      display: block;
    }

    .header-container {
      padding: 0 22px;
    }

    .flex-layout {
      height: 80px;
    }

    .main-nav-bar.is-stuck {
      backdrop-filter: none;
      background: rgba(12, 10, 9, 0.96);
    }
  }

  @media (max-width: 990px) {
    .hero-btn {
      width: 100%;
      min-width: 0;
      white-space: normal;
      padding: 16px 24px;
      line-height: 1.45;
      letter-spacing: 0.16em;
    }

    .hero-content {
      padding: 0 20px;
    }

    .hero-eyebrow {
      letter-spacing: 0.26em;
      margin-bottom: 14px;
    }

    .hero-brand-intro {
      max-width: 92%;
      font-size: 14px;
      line-height: 1.8;
    }

    .logo-cn {
      font-size: 18px;
    }

    .logo-en {
      font-size: 9px;
    }

    .hero-bg-image,
    .slogan-gradient,
    .wheel {
      animation: none !important;
      transform: none !important;
    }

    .hero-btn-secondary {
      backdrop-filter: none;
    }

    .scroll-guide {
      display: none;
    }
  }

  @media (max-width: 430px) {
    .hero-button-wrapper {
      gap: 14px;
      margin-top: 28px;
    }

    .hero-btn {
      padding: 15px 18px;
      font-size: 0.88rem;
      letter-spacing: 0.12em;
      border-radius: 24px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-bg-image,
    .slogan-gradient,
    .wheel {
      animation: none !important;
      transform: none !important;
    }

    .nav-item,
    .nav-item::after,
    .hero-btn,
    .drawer-content,
    .drawer-overlay {
      transition: none !important;
    }
  }
</style>

<script>
document.addEventListener('DOMContentLoaded', function() {
  const toggle = document.getElementById('menu-toggle');
  const drawer = document.getElementById('mobile-drawer');
  const close = document.getElementById('drawer-close');
  const overlay = document.getElementById('drawer-overlay');
  const nav = document.getElementById('nav-node');
  const slogan = document.getElementById('slogan-node');

  const openMenu = () => {
    if (drawer) drawer.classList.add('is-active');
    document.body.style.overflow = 'hidden';
  };

  const closeMenu = () => {
    if (drawer) drawer.classList.remove('is-active');
    document.body.style.overflow = '';
  };

  if (toggle) toggle.addEventListener('click', openMenu);
  if (close) close.addEventListener('click', closeMenu);
  if (overlay) overlay.addEventListener('click', closeMenu);

  let ticking = false;

  const updateNav = () => {
    const sloganHeight = slogan ? slogan.offsetHeight : 0;
    if (nav) {
      if (window.scrollY > Math.max(sloganHeight, 10)) {
        nav.classList.add('is-stuck');
      } else {
        nav.classList.remove('is-stuck');
      }
    }
    ticking = false;
  };

  const onScroll = () => {
    if (!ticking) {
      ticking = true;
      requestAnimationFrame(updateNav);
    }
  };

  window.addEventListener('scroll', onScroll, { passive: true });
  updateNav();
});
</script>

<!-- 1. 顶部 Header 区域 -->
<header class="site-header-wrapper" id="site-header">
