                              {%- for childlink in link.links -%}
                                {%- assign child_title = childlink.title | downcase -%}
                                {%- assign child_desc = 'Discover a distinct side of Yunnan through scenery, culture, and slower travel.' -%}

                                {%- if child_title contains 'kunming' -%}
                                  {%- assign child_desc = 'The gateway to Yunnan, known for spring weather, lakes, and easy day trips.' -%}
                                {%- elsif child_title contains 'dali' -%}
                                  {%- assign child_desc = 'A graceful lakeside destination shaped by Erhai, Bai heritage, and slower rhythms.' -%}
                                {%- elsif child_title contains 'lijiang' -%}
                                  {%- assign child_desc = 'Snow mountain views, old-town atmosphere, and one of Yunnan’s strongest identities.' -%}
                                {%- elsif child_title contains 'shangri-la' -%}
                                  {%- assign child_desc = 'Tibetan culture, monasteries, alpine landscapes, and the spirit of the high plateau.' -%}
                                {%- elsif child_title contains 'xishuangbanna' -%}
                                  {%- assign child_desc = 'A tropical and warmer side of Yunnan, rich in rainforest mood and Dai culture.' -%}
                                {%- endif -%}

                                <a href="{{ childlink.url }}" class="mega-dest-card">
                                  <span class="mega-dest-kicker">Destination</span>
                                  <span class="mega-dest-title">{{ childlink.title }}</span>
