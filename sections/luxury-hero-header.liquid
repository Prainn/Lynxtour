                {%- assign mega_side_title = section.settings.mega_support_side_title -%}
                {%- assign mega_side_text = section.settings.mega_support_side_text -%}
                {%- assign mega_side_btn = section.settings.mega_support_side_btn -%}
                {%- assign mega_side_link = section.settings.mega_support_side_link -%}
            {%- endcase -%}

            <div class="nav-group {% if is_mega and link.links != blank %}nav-group-mega{% endif %}">
