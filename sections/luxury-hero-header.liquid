                {%- assign mega_top_btn = section.settings.mega_destinations_btn -%}

                {%- assign mega_side_label = section.settings.mega_destinations_side_label -%}
                {%- assign mega_side_title = section.settings.mega_destinations_side_title -%}
                {%- assign mega_side_text = section.settings.mega_destinations_side_text -%}
                {%- assign mega_side_btn = section.settings.mega_destinations_side_btn -%}
                {%- assign mega_side_link = section.settings.mega_destinations_side_link -%}

              {%- when 'top attractions' -%}
                {%- assign mega_top_label = section.settings.mega_attractions_label -%}
                {%- assign mega_top_title = section.settings.mega_attractions_title -%}
