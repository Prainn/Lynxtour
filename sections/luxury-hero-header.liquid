                {%- assign mega_top_btn = section.settings.mega_services_btn -%}

                {%- assign mega_side_label = section.settings.mega_services_side_label -%}
                {%- assign mega_side_title = section.settings.mega_services_side_title -%}
                {%- assign mega_side_text = section.settings.mega_services_side_text -%}
                {%- assign mega_side_btn = section.settings.mega_services_side_btn -%}
                {%- assign mega_side_link = section.settings.mega_services_side_link -%}

              {%- when 'travel guide' -%}
