                                {%- if child_title contains 'lake' -%}
                                  {%- assign spot_type = 'Lake View' -%}
                                {%- elsif child_title contains 'mountain' or child_title contains 'snow' -%}
                                  {%- assign spot_type = 'Mountain' -%}
                                {%- elsif child_title contains 'old town' or child_title contains 'city' -%}
                                  {%- assign spot_type = 'Historic Area' -%}
                                {%- elsif child_title contains 'forest' -%}
                                  {%- assign spot_type = 'Natural Wonder' -%}
