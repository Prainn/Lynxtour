                                {%- elsif child_title contains 'luxury' -%}
                                  {%- assign tour_desc = 'Refined journeys with elevated stays, slower pacing, and signature experiences.' -%}
                                {%- elsif child_title contains 'day trip' -%}
                                  {%- assign tour_desc = 'Short private experiences designed for easy exploration from a single base.' -%}
                                {%- elsif child_title contains 'private' -%}
                                  {%- assign tour_desc = 'Flexible private travel with comfort, depth, and personalized pacing.' -%}
