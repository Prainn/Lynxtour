<div class="brand-features-section">
  <div class="header-container" style="max-width: 1200px; margin: 0 auto; padding: 0 20px;">
    
    {% if section.settings.main_title != blank %}
      <div class="brand-header">
        <h2 class="brand-main-title">{{ section.settings.main_title }}</h2>
        <div class="title-underline"></div>
      </div>
    {% endif %}

    {% assign has_intro_modules = false %}
    {% if section.settings.intro_heading_1 != blank and section.settings.intro_body_1 != blank %}
      {% assign has_intro_modules = true %}
    {% endif %}
    {% if section.settings.intro_heading_2 != blank and section.settings.intro_body_2 != blank %}
      {% assign has_intro_modules = true %}
    {% endif %}

    {% if has_intro_modules %}
      <div class="brand-intro-modules">
        {% if section.settings.intro_heading_1 != blank and section.settings.intro_body_1 != blank %}
          <article class="brand-intro-module">
            <h3 class="brand-intro-title">{{ section.settings.intro_heading_1 }}</h3>
            <p class="brand-intro-body">{{ section.settings.intro_body_1 }}</p>
          </article>
        {% endif %}
        {% if section.settings.intro_heading_2 != blank and section.settings.intro_body_2 != blank %}
          <article class="brand-intro-module">
            <h3 class="brand-intro-title">{{ section.settings.intro_heading_2 }}</h3>
            <p class="brand-intro-body">{{ section.settings.intro_body_2 }}</p>
          </article>
        {% endif %}
      </div>

      <div class="brand-link-list">
        {% if section.settings.link_label_1 != blank and section.settings.link_url_1 != blank %}<a href="{{ section.settings.link_url_1 }}" class="brand-link-chip">{{ section.settings.link_label_1 }}</a>{% endif %}
        {% if section.settings.link_label_2 != blank and section.settings.link_url_2 != blank %}<a href="{{ section.settings.link_url_2 }}" class="brand-link-chip">{{ section.settings.link_label_2 }}</a>{% endif %}
        {% if section.settings.link_label_3 != blank and section.settings.link_url_3 != blank %}<a href="{{ section.settings.link_url_3 }}" class="brand-link-chip">{{ section.settings.link_label_3 }}</a>{% endif %}
        {% if section.settings.link_label_4 != blank and section.settings.link_url_4 != blank %}<a href="{{ section.settings.link_url_4 }}" class="brand-link-chip">{{ section.settings.link_label_4 }}</a>{% endif %}
      </div>
    {% endif %}

    <div class="brand-grid">
      {% for block in section.blocks %}
        <div class="brand-item" {{ block.shopify_attributes }}>
          <div class="brand-icon">
            {% if block.settings.feature_image != blank %}
              <img src="{{ block.settings.feature_image | image_url: width: 120 }}" 
                   alt="{{ block.settings.item_title }}"
                   loading="lazy">
            {% elsif block.settings.custom_svg != blank %}
              {{ block.settings.custom_svg }}
            {% else %}
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1">
                <path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"></path>
              </svg>
            {% endif %}
          </div>
          <h3 class="brand-item-title">{{ block.settings.item_title }}</h3>
          <p class="brand-item-desc">{{ block.settings.item_desc }}</p>
        </div>
      {% endfor %}
    </div>
  </div>
  
  <div class="section-bottom-gradient"></div>
</div>

<style>
  .brand-features-section {
    position: relative;
    /* 确保与你的其他 Section 颜色严格一致，通常是 #0a0a0a 或 #000000 */
    background-color: #0a0a0a; 
    padding: 120px 0 160px 0; /* 增加底部内边距，留给渐变空间 */
    overflow: hidden;
  }

  /* 底部渐变效果：从背景色平滑过渡到全透明 */
  .section-bottom-gradient {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 150px;
    background: linear-gradient(to bottom, transparent, rgba(10, 10, 10, 0.8), #0a0a0a);
    pointer-events: none;
  }

  .brand-header {
    text-align: center;
    margin-bottom: 90px;
    position: relative;
    z-index: 2;
  }

  .brand-main-title {
    color: #fff;
    font-size: clamp(1.5rem, 3.5vw, 2.2rem);
    font-weight: 300;
    letter-spacing: 0.4em;
    text-transform: uppercase;
    margin-bottom: 20px;
    opacity: 0.9;
  }

  .title-underline {
    width: 30px;
    height: 1px;
    background: #fbbf24;
    margin: 0 auto;
    opacity: 0.5;
  }

  .brand-grid {
    display: grid;
    grid-template-columns: repeat({{ section.settings.columns_desktop }}, 1fr);
    gap: 60px;
    position: relative;
    z-index: 2;
  }

  .brand-intro-modules {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 22px;
    margin: 0 auto 32px;
    max-width: 1100px;
    position: relative;
    z-index: 2;
  }

  .brand-intro-module {
    border: 1px solid rgba(255,255,255,0.08);
    background: rgba(255,255,255,0.02);
    padding: 28px 26px;
  }

  .brand-intro-title {
    color: #fff;
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(1.8rem, 3vw, 2.4rem);
    font-style: italic;
    font-weight: 400;
    margin: 0 0 14px;
  }

  .brand-intro-body {
    color: #cfcfcf;
    font-size: 15px;
    line-height: 1.85;
    margin: 0;
  }

  .brand-link-list {
    display: flex;
    flex-wrap: wrap;
    gap: 12px 14px;
    justify-content: center;
    margin: 0 auto 48px;
    max-width: 1100px;
    position: relative;
    z-index: 2;
  }

  .brand-link-chip {
    color: #e7d6bf;
    text-decoration: none;
    border: 1px solid rgba(231,214,191,0.24);
    padding: 10px 14px;
    transition: 0.2s ease;
  }

  .brand-link-chip:hover {
    color: #fff;
    border-color: rgba(255,255,255,0.4);
    background: rgba(255,255,255,0.03);
  }

  .brand-item {
    text-align: center;
    padding: 20px;
    transition: all 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .brand-item:hover {
    transform: translateY(-15px);
  }

  .brand-icon {
    width: {{ section.settings.icon_size }}px;
    height: {{ section.settings.icon_size }}px;
    margin: 0 auto 35px;
    color: #fbbf24;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0.85;
    transition: opacity 0.3s ease;
  }

  .brand-item:hover .brand-icon {
    opacity: 1;
  }

  .brand-icon img, .brand-icon svg {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .brand-item-title {
    color: #fff;
    font-size: 18px;
    font-weight: 400;
    margin-bottom: 18px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
  }

  .brand-item-desc {
    color: #8c8c8c;
    font-size: 14px;
    line-height: 1.8;
    font-weight: 300;
    max-width: 280px;
    margin: 0 auto;
    letter-spacing: 0.02em;
  }

  @media (max-width: 1024px) {
    .brand-grid { grid-template-columns: repeat(2, 1fr); gap: 40px; }
  }

  @media (max-width: 767px) {
    .brand-features-section { padding: 80px 0 100px 0; }
    .brand-intro-modules { grid-template-columns: 1fr; margin-bottom: 24px; }
    .brand-intro-module { padding: 22px 20px; }
    .brand-link-list { justify-content: flex-start; margin-bottom: 36px; }
    .brand-grid { grid-template-columns: 1fr; }
    .brand-main-title { letter-spacing: 0.25em; font-size: 1.5rem; }
    .brand-item { margin-bottom: 30px; }
    .section-bottom-gradient { height: 80px; }
  }
</style>

{% schema %}
{
  "name": "Brand Features",
  "settings": [
    {
      "type": "text",
      "id": "main_title",
      "label": "英文大标题",
      "default": "THE ART OF CURATED TRAVEL"
    },
    {
      "type": "text",
      "id": "intro_heading_1",
      "label": "Intro heading 1",
      "default": ""
    },
    {
      "type": "textarea",
      "id": "intro_body_1",
      "label": "Intro body 1",
      "default": ""
    },
    {
      "type": "text",
      "id": "intro_heading_2",
      "label": "Intro heading 2",
      "default": ""
    },
    {
      "type": "textarea",
      "id": "intro_body_2",
      "label": "Intro body 2",
      "default": ""
    },
    {
      "type": "text",
      "id": "link_label_1",
      "label": "Link label 1",
      "default": ""
    },
    {
      "type": "url",
      "id": "link_url_1",
      "label": "Link URL 1"
    },
    {
      "type": "text",
      "id": "link_label_2",
      "label": "Link label 2",
      "default": ""
    },
    {
      "type": "url",
      "id": "link_url_2",
      "label": "Link URL 2"
    },
    {
      "type": "text",
      "id": "link_label_3",
      "label": "Link label 3",
      "default": ""
    },
    {
      "type": "url",
      "id": "link_url_3",
      "label": "Link URL 3"
    },
    {
      "type": "text",
      "id": "link_label_4",
      "label": "Link label 4",
      "default": ""
    },
    {
      "type": "url",
      "id": "link_url_4",
      "label": "Link URL 4"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 2,
      "max": 4,
      "step": 1,
      "label": "桌面端每行数量",
      "default": 3
    },
    {
      "type": "range",
      "id": "icon_size",
      "min": 40,
      "max": 120,
      "step": 10,
      "unit": "px",
      "label": "图标大小",
      "default": 60
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "特色项",
      "settings": [
        { "type": "image_picker", "id": "feature_image", "label": "图标图片" },
        { "type": "html", "id": "custom_svg", "label": "或者：SVG 代码" },
        { "type": "text", "id": "item_title", "label": "项标题", "default": "BESPOKE JOURNEYS" },
        { "type": "textarea", "id": "item_desc", "label": "项描述", "default": "Handcrafting every detail." }
      ]
    }
  ],
  "presets": [
    {
      "name": "Brand Features",
      "blocks": [
        { "type": "feature", "settings": { "item_title": "BESPOKE JOURNEYS" } },
        { "type": "feature", "settings": { "item_title": "EXPERT CURATORS" } },
        { "type": "feature", "settings": { "item_title": "WILD-LUXURY ESCAPES" } }
      ]
    }
  ]
}
{% endschema %}
