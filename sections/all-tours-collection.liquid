<section class="luxury-collection-wrapper" id="CollectionProductGrid-{{ section.id }}">
  <!-- 1) HERO -->
  <header class="coll-hero-compact">
    <div class="hero-bg">
      {% if collection.image %}
        <img src="{{ collection.image | image_url: width: 2400 }}" alt="{{ collection.title | escape }} - Lynxtour" class="hero-img">
      {% else %}
        <div class="hero-placeholder"></div>
      {% endif %}
      <div class="hero-overlay"></div>
    </div>

    <div class="hero-text-container">
      <div class="hero-content">
        <div class="subtitle-wrap">
          <span class="coll-subtitle">
            {% if collection.handle == 'yunnan-private-tours' %}
              PRIVATE JOURNEYS ACROSS YUNNAN
            {% else %}
              {{ section.settings.subtitle_text }}
            {% endif %}
          </span>
          <div class="subtitle-line"></div>
        </div>

        <h1 class="coll-title">
          {% if collection.handle == 'yunnan-private-tours' %}
            Yunnan Private Tours
          {% else %}
            {{ collection.title }}
          {% endif %}
        </h1>

        {% if collection.description != blank %}
          <div class="coll-desc-wrap">
            <div class="coll-desc">
              {{ collection.description | strip_html | truncatewords: 26 }}
            </div>
          </div>
        {% elsif collection.handle == 'yunnan-private-tours' %}
          <div class="coll-desc-wrap">
            <div class="coll-desc">
              Explore Yunnan with fully private tours tailored to your pace, interests, and travel dates. Discover Kunming, Dali, Lijiang, and Shangri-La with flexible itineraries and local support.
            </div>
          </div>
        {% endif %}
      </div>
    </div>
  </header>

  <!-- 2) LIST -->
  <div class="coll-container">
    <div class="coll-meta-bar">
      <div class="meta-left">
        <span class="meta-number">{{ collection.products_count }}</span>
        <span class="meta-label">Selected Experiences</span>
      </div>
      <div class="meta-divider"></div>
      <div class="meta-right">
        <span class="meta-location">
          {% if collection.handle == 'yunnan-private-tours' %}
            KUNMING · DALI · LIJIANG · SHANGRI-LA
          {% else %}
            {{ section.settings.location_text }}
          {% endif %}
        </span>
      </div>
    </div>

    {% paginate collection.products by section.settings.page_size %}

      {% if collection.handle == 'yunnan-private-tours' and paginate.current_page == 1 %}
        <section class="seo-copy seo-copy-top">
          <div class="seo-copy-inner">
            <p class="seo-eyebrow">PRIVATE YUNNAN ITINERARIES</p>
            <h2>Custom Yunnan Private Tours Designed Around Your Pace</h2>
            <p>
              Our Yunnan private tours are designed for travelers who want flexibility, comfort, and a deeper experience of Southwest China. From Kunming and Dali to Lijiang and Shangri-La, each journey can be tailored to your interests, travel rhythm, and preferred level of comfort. Whether you are planning a scenic cultural escape, a luxury honeymoon, or a multi-city family trip, this collection brings together our most rewarding private tour options in Yunnan.
            </p>
          </div>
        </section>

        <section class="seo-copy seo-copy-cta">
          <div class="seo-copy-inner">
            <div class="seo-block seo-cta-block">
              <h2>Not Sure Which Yunnan Route Fits You?</h2>
              <p>
                Tell us your travel dates, pace, and interests, and we’ll suggest a suitable Yunnan private itinerary based on your route, comfort level, and travel style.
              </p>
              <div class="seo-links seo-links-cta">
                <a href="/pages/contact-us">Plan a Custom Yunnan Trip</a>
                <a href="https://api.whatsapp.com/send/?phone=8613211685553&text&type=phone_number&app_absent=0" target="_blank" rel="noopener">Chat on WhatsApp</a>
              </div>
            </div>
          </div>
        </section>
      {% endif %}

      <div class="compact-grid" data-cols="{{ section.settings.desktop_cols }}">
        {% for product in collection.products %}
          {% liquid
  assign excluded_keywords = 'single room supplement|room supplement|single supplement|supplement|add-on|addon|upgrade|custom|extra bed|surcharge' | split: '|'
  assign child_keywords = 'child|children|kid|kids|infant|baby|toddler|儿童|小童|婴儿' | split: '|'

  assign collection_display_price = blank
  assign valid_main_variant_count = 0

  assign fallback_display_price = blank
  assign fallback_valid_variant_count = 0

  for variant in product.variants
    assign variant_title = variant.title | downcase | strip
    assign is_excluded = false
    assign is_child_variant = false

    for keyword in excluded_keywords
      if variant_title contains keyword
        assign is_excluded = true
        break
      endif
    endfor

    unless is_excluded
      assign fallback_valid_variant_count = fallback_valid_variant_count | plus: 1

      if fallback_display_price == blank or variant.price < fallback_display_price
        assign fallback_display_price = variant.price
      endif

      for child_keyword in child_keywords
        if variant_title contains child_keyword
          assign is_child_variant = true
          break
        endif
      endfor

      unless is_child_variant
        assign valid_main_variant_count = valid_main_variant_count | plus: 1

        if collection_display_price == blank or variant.price < collection_display_price
          assign collection_display_price = variant.price
        endif
      endunless
    endunless
  endfor

  if collection_display_price == blank
    assign collection_display_price = fallback_display_price
    assign valid_main_variant_count = fallback_valid_variant_count
  endif

  if collection_display_price == blank
    assign collection_display_price = product.price
  endif

  assign show_from_prefix = false
  if valid_main_variant_count > 1
    assign show_from_prefix = true
  endif
%}

          <div class="grid-item reveal-item">
            <a href="{{ product.url }}" class="card-link">
              <div class="card-visual">
                {% if product.featured_image %}
                  <img
                    src="{{ product.featured_image | image_url: width: 1200 }}"
                    alt="{{ product.title | escape }}"
                    loading="lazy"
                  >
                {% else %}
                  <div class="card-img-placeholder"></div>
                {% endif %}

                <div class="card-overlay">
                  <div class="card-btn">EXPLORE</div>
                </div>

                {% if product.tags contains section.settings.badge_tag %}
                  <div class="route-indicator"><span class="dot-pulse"></span>{{ section.settings.badge_text }}</div>
                {% endif %}
              </div>

              <div class="card-content">
                <div class="card-header">
                  <h3 class="product-title">{{ product.title }}</h3>
                  <div class="product-price">
                    {% if show_from_prefix %}
                      <span class="price-prefix">From </span>
                    {% endif %}
                    {{ collection_display_price | money_with_currency }}
                  </div>
                </div>
                <div class="product-info-row">
                  <span class="product-type">{{ product.type | default: 'Experience' }}</span>
                  {% if product.metafields.custom.duration != blank %}
                    <span class="sep">·</span>
                    <span class="product-duration">{{ product.metafields.custom.duration.value }}</span>
                  {% endif %}
                  {% if product.metafields.custom.start_city != blank %}
                    <span class="sep">·</span>
                    <span class="product-start">{{ product.metafields.custom.start_city.value }}</span>
                  {% endif %}
                </div>
              </div>
            </a>
          </div>
        {% endfor %}
      </div>

      {% if paginate.pages > 1 %}
        <div class="luxury-pagination">
          {{ paginate | default_pagination }}
        </div>
      {% endif %}

      {% if collection.handle == 'yunnan-private-tours' and paginate.current_page == 1 %}
        <section class="seo-copy seo-copy-bottom">
          <div class="seo-copy-inner">
            <div class="seo-block">
              <h2>How to Choose the Right Yunnan Private Tour</h2>
              <p>
                The best Yunnan private tour depends on your available travel time, preferred pace, and the kind of experience you want. Some travelers choose a classic first-time route linking Kunming, Dali, Lijiang, and Shangri-La, while others prefer a deeper journey with slower pacing, extra nature stops, or luxury stays. This collection is designed to help you compare different route lengths and choose a private itinerary that fits your travel style.
              </p>
            </div>

            <div class="seo-block">
              <h2>Best Yunnan Itinerary Lengths: 6, 8, or 10 Days</h2>
              <p>
                A 6-day Yunnan itinerary works well for first-time visitors who want to see the region’s essential highlights within a shorter schedule. An 8-day route is often the most balanced option, giving you enough time for Kunming, Dali, Lijiang, and Shangri-La without rushing too much. A 10-day or longer Yunnan private tour is better for travelers who want deeper pacing or additional destinations such as Lugu Lake, Tengchong, Yuanyang, or Xishuangbanna.
              </p>
            </div>

            <div class="seo-block">
              <h2>Who These Private Tours Are Best For</h2>
              <p>
                Yunnan private tours are especially suitable for couples, families, senior travelers, photographers, honeymoon trips, and travelers who want flexible pacing instead of fixed group schedules. They also work well for visitors who want private transfers, smoother route planning across multiple cities, and more control over hotel style, sightseeing rhythm, and altitude comfort.
              </p>
            </div>

            <div class="seo-block">
              <h2>Where to Start Your Yunnan Route</h2>
              <p>
                Many travelers begin in Kunming because of its stronger transport access and easy arrival pace, but some private routes can also start from Dali or Lijiang depending on your flights and overall plan. Choosing the right starting point helps reduce backtracking and makes your Yunnan itinerary more comfortable, especially for shorter trips or multi-city journeys.
              </p>
            </div>

            <div class="seo-block seo-cta-block">
              <h2>Need Help Comparing Yunnan Routes?</h2>
              <p>
                If you are not sure which itinerary length or route order fits your dates, we can recommend a more suitable private trip based on your pace, interests, and preferred level of comfort.
              </p>
              <div class="seo-links seo-links-cta">
                <a href="/pages/bespoke-custom-travel">Ask for a Custom Itinerary</a>
                <a href="https://api.whatsapp.com/send/?phone=8613211685553&text&type=phone_number&app_absent=0" target="_blank" rel="noopener">Chat on WhatsApp</a>
              </div>
            </div>

            <div class="seo-block">
              <h2>Explore Related Routes and Travel Planning</h2>
              <div class="seo-links">
                <a href="/pages/dali">Dali Private Tours &amp; Travel Guide</a>
                <a href="/pages/lijiang">Lijiang Private Tours &amp; Travel Guide</a>
                <a href="/pages/shangri-la">Shangri-La Private Tours &amp; Travel Guide</a>
                <a href="/blogs/travel-guides">Yunnan Travel Guides</a>
                <a href="/pages/contact-us">Plan a Custom Yunnan Itinerary</a>
              </div>
            </div>

            <div class="seo-block faq-block">
              <h2>Frequently Asked Questions</h2>

              <details class="faq-item">
                <summary>Are your Yunnan private tours customizable?</summary>
                <div class="faq-answer">
                  Yes. Our Yunnan private tours can be adjusted based on your travel dates, preferred pace, hotel style, destinations, and trip length.
                </div>
              </details>

              <details class="faq-item">
                <summary>Which destinations are usually included in a Yunnan private tour?</summary>
                <div class="faq-answer">
                  The most popular route usually includes Kunming, Dali, Lijiang, and Shangri-La. Some itineraries may also include Tiger Leaping Gorge, Yuanyang, Tengchong, or Xishuangbanna.
                </div>
              </details>

              <details class="faq-item">
                <summary>How many days do I need for a Yunnan tour?</summary>
                <div class="faq-answer">
                  A shorter Yunnan private tour can work in 4 to 6 days, while a more comfortable multi-city journey usually takes 7 to 10 days or longer.
                </div>
              </details>

              <details class="faq-item">
                <summary>Is Yunnan suitable for family or senior travel?</summary>
                <div class="faq-answer">
                  Yes. A private tour is often the most comfortable choice for families and senior travelers because the pace, transport, and daily schedule can be planned more flexibly.
                </div>
              </details>

              <details class="faq-item">
                <summary>Can I start my Yunnan tour from Kunming, Dali, or Lijiang?</summary>
                <div class="faq-answer">
                  Yes. Depending on flight access and your route plan, your private tour can begin in Kunming, Dali, Lijiang, or another suitable gateway city.
                </div>
              </details>

              <details class="faq-item">
                <summary>Do private tours in Yunnan include airport pickup?</summary>
                <div class="faq-answer">
                  Most custom itineraries can include airport or railway station pickup as part of the travel arrangement, depending on your route and service plan.
                </div>
              </details>

              <details class="faq-item">
                <summary>Can you help me choose the best Yunnan itinerary for my dates?</summary>
                <div class="faq-answer">
                  Yes. If you tell us your travel dates, starting city, and interests, we can recommend a more suitable Yunnan route and pacing plan for your trip.
                </div>
              </details>

              <details class="faq-item">
                <summary>Can I contact you before booking to discuss route ideas?</summary>
                <div class="faq-answer">
                  Absolutely. You can contact us before booking to discuss route ideas, trip length, hotel style, or private transfer preferences through our contact page or WhatsApp.
                </div>
              </details>
            </div>
          </div>
        </section>

        <script type="application/ld+json">
        {
          "@context": "https://schema.org",
          "@type": "FAQPage",
          "mainEntity": [
            {
