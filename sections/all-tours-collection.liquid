      {% endif %}

    {% endpaginate %}
  </div>
</section>

<style>
  /* ===== Scope to this section only ===== */
  #CollectionProductGrid-{{ section.id }}{
    background-color: #050505;
    color: #fff;
    overflow: hidden;
    --header-safe: var(--page-first-copy-offset, 114px);
  }

  /* --- HERO SECTION --- */
  #CollectionProductGrid-{{ section.id }} .coll-hero-compact{
    height: calc({{ section.settings.hero_height_vh }}vh + var(--header-safe));
    min-height: calc({{ section.settings.hero_min_height }}px + var(--header-safe));
    padding-top: var(--header-safe);
    box-sizing: border-box;
    position: relative;
    display:flex;
    align-items:center;
    justify-content:center;
  }

  #CollectionProductGrid-{{ section.id }} .hero-bg{
    position:absolute;
    inset:0;
    z-index:1;
  }

  #CollectionProductGrid-{{ section.id }} .hero-img{
    width:100%;
    height:100%;
    object-fit:cover;
    filter: brightness({{ section.settings.hero_brightness | divided_by: 100.0 }});
  }

  #CollectionProductGrid-{{ section.id }} .hero-placeholder{
    background:#111;
    width:100%;
    height:100%;
  }

  #CollectionProductGrid-{{ section.id }} .hero-overlay{
    position:absolute;
    inset:0;
    background: linear-gradient(to bottom, rgba(5,5,5,0) 0%, rgba(5,5,5,0.92) 100%);
    z-index:2;
  }

  #CollectionProductGrid-{{ section.id }} .hero-text-container{
    position:relative;
    z-index:10;
    text-align:center;
    width:100%;
    padding: 0 18px 56px;
  }

  #CollectionProductGrid-{{ section.id }} .hero-content{
    max-width: 920px;
    margin: 0 auto;
  }

  #CollectionProductGrid-{{ section.id }} .coll-subtitle{
    color:#c4b5a6;
    font-size:8px;
    letter-spacing:0.6em;
    text-transform:uppercase;
  }

  #CollectionProductGrid-{{ section.id }} .subtitle-line{
    width:35px;
    height:1px;
    background:#c4b5a6;
    opacity:1;
    margin: 12px auto 0;
  }

  #CollectionProductGrid-{{ section.id }} .coll-title{
    font-family:'Cormorant Garamond', serif;
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight:300;
    font-style:italic;
    margin: 10px 0;
    color:#fff;
  }

  #CollectionProductGrid-{{ section.id }} .coll-desc{
    display: -webkit-box;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 3;
    overflow: hidden;
    text-wrap: balance;
    font-size:13px;
    color:#9a9a9a;
    max-width: 560px;
    margin: 0 auto;
    line-height: 1.7;
  }

  /* --- CONTAINER --- */
  #CollectionProductGrid-{{ section.id }} .coll-container{
    max-width: 1400px;
    margin: 0 auto;
    padding: 40px 60px 100px;
  }

  /* --- META BAR --- */
  #CollectionProductGrid-{{ section.id }} .coll-meta-bar{
    display:flex;
    align-items:center;
    justify-content:center;
    gap:30px;
    margin-bottom: 42px;
    padding: 20px 0;
    border-top: 1px solid rgba(196,181,166,0.15);
    border-bottom: 1px solid rgba(196,181,166,0.15);
  }

  #CollectionProductGrid-{{ section.id }} .meta-left,
  #CollectionProductGrid-{{ section.id }} .meta-right{
    display:flex;
    align-items:baseline;
    gap:8px;
  }

  #CollectionProductGrid-{{ section.id }} .meta-number{
    font-family:'Cormorant Garamond', serif;
    font-size:24px;
    font-style:italic;
    color:#c4b5a6;
  }

  #CollectionProductGrid-{{ section.id }} .meta-label{
    font-size:9px;
    text-transform:uppercase;
    letter-spacing:0.3em;
    color:#666;
  }

  #CollectionProductGrid-{{ section.id }} .meta-location{
    font-size:10px;
    letter-spacing:0.4em;
    text-transform:uppercase;
    color:#888;
    font-weight:300;
  }

  #CollectionProductGrid-{{ section.id }} .meta-divider{
    width:1px;
    height:20px;
    background: linear-gradient(to bottom, transparent, #c4b5a6, transparent);
    opacity:0.6;
  }

  /* --- SEO COPY --- */
  #CollectionProductGrid-{{ section.id }} .seo-copy{
    margin: 0 auto 54px;
  }

  #CollectionProductGrid-{{ section.id }} .seo-copy-bottom{
    margin: 72px auto 0;
  }

  #CollectionProductGrid-{{ section.id }} .seo-copy-cta{
    margin: 0 auto 42px;
  }

  #CollectionProductGrid-{{ section.id }} .seo-copy-inner{
    max-width: 980px;
    margin: 0 auto;
  }

  #CollectionProductGrid-{{ section.id }} .seo-eyebrow{
    margin: 0 0 12px;
    font-size: 10px;
    letter-spacing: 0.34em;
    text-transform: uppercase;
    color: #b6a28e;
  }

  #CollectionProductGrid-{{ section.id }} .seo-block{
    margin-bottom: 34px;
    padding-bottom: 0;
  }

  #CollectionProductGrid-{{ section.id }} .seo-copy h2{
    margin: 0 0 14px;
    font-family:'Cormorant Garamond', serif;
    font-size: clamp(1.8rem, 3vw, 2.6rem);
    font-style: italic;
    font-weight: 300;
    line-height: 1.15;
    color: #fff;
  }

  #CollectionProductGrid-{{ section.id }} .seo-copy p{
    margin: 0;
    font-size: 15px;
    line-height: 1.95;
    color: #a4a4a4;
  }

  #CollectionProductGrid-{{ section.id }} .seo-links{
    display:flex;
    flex-wrap:wrap;
    gap:12px 14px;
    margin-top: 10px;
  }

  #CollectionProductGrid-{{ section.id }} .seo-links a{
    color:#d4c2ae;
    text-decoration:none;
    border-bottom:1px solid rgba(212,194,174,0.35);
    padding-bottom:2px;
    transition: .25s ease;
  }

  #CollectionProductGrid-{{ section.id }} .seo-links a:hover{
    color:#fff;
    border-color: rgba(255,255,255,0.6);
  }

  #CollectionProductGrid-{{ section.id }} .seo-cta-block{
    padding: 26px 28px;
    border: 1px solid rgba(196,181,166,0.16);
    background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));
  }

  #CollectionProductGrid-{{ section.id }} .seo-links-cta{
    margin-top: 18px;
  }

  #CollectionProductGrid-{{ section.id }} .seo-links-cta a{
    display:inline-flex;
    align-items:center;
    justify-content:center;
    min-height: 42px;
    padding: 0 16px;
    border: 1px solid rgba(212,194,174,0.35);
    background: rgba(255,255,255,0.02);
    border-bottom: none;
  }

  #CollectionProductGrid-{{ section.id }} .seo-links-cta a:hover{
    background: rgba(255,255,255,0.04);
  }

  /* --- FAQ --- */
  #CollectionProductGrid-{{ section.id }} .faq-block{
    margin-top: 10px;
  }

  #CollectionProductGrid-{{ section.id }} .faq-item{
    border-top: 1px solid rgba(255,255,255,0.08);
  }

  #CollectionProductGrid-{{ section.id }} .faq-item:last-child{
    border-bottom: 1px solid rgba(255,255,255,0.08);
  }

  #CollectionProductGrid-{{ section.id }} .faq-item summary{
    list-style: none;
    cursor: pointer;
    padding: 18px 36px 18px 0;
    position: relative;
    font-size: 15px;
    line-height: 1.7;
    color: #efefef;
  }

  #CollectionProductGrid-{{ section.id }} .faq-item summary::-webkit-details-marker{
    display:none;
  }

  #CollectionProductGrid-{{ section.id }} .faq-item summary::after{
    content:'+';
    position:absolute;
    right:0;
    top:50%;
    transform: translateY(-50%);
    font-size: 22px;
    line-height: 1;
    color:#bda995;
    transition: .25s ease;
  }

  #CollectionProductGrid-{{ section.id }} .faq-item[open] summary::after{
    content:'−';
  }

  #CollectionProductGrid-{{ section.id }} .faq-answer{
    padding: 0 0 18px;
    font-size: 14px;
    line-height: 1.9;
    color:#9d9d9d;
  }

  /* --- GRID --- */
  #CollectionProductGrid-{{ section.id }} .compact-grid{
    display:grid;
    grid-template-columns: repeat({{ section.settings.desktop_cols }}, 1fr);
    gap: 50px 40px;
  }

  /* --- REVEAL ANIMATION --- */
  #CollectionProductGrid-{{ section.id }} .reveal-item{
    opacity:0;
    transform: translateY(30px);
