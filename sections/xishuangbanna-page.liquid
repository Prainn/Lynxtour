<style>
  .xb-wrapper {
    background-color: #06110d;
    color: #fff;
    padding: 60px 0;
    overflow: hidden;
    font-family: 'Montserrat', sans-serif;
  }

  .xb-container {
    max-width: 1300px;
    margin: 0 auto;
    padding: 0 40px;
  }

  .xb-header {
    text-align: center;
    padding: 140px 20px 120px;
    max-width: 1000px;
    margin: 0 auto;
    position: relative;
  }

  .xb-subtitle {
    color: #d6b25e;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.7em;
    text-transform: uppercase;
    display: block;
    margin-bottom: 30px;
    opacity: 0.9;
  }

  .xb-main-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(3.2rem, 8vw, 5.5rem);
    font-weight: 300;
    line-height: 1.1;
    margin-bottom: 45px;
    letter-spacing: 0.08em;
    color: #ffffff;
    font-style: italic;
  }

  .xb-header::after {
    content: "";
    display: block;
    width: 1px;
    height: 80px;
    background: linear-gradient(to bottom, #d6b25e, transparent);
    margin: 0 auto 45px;
  }

  .xb-intro-text {
    max-width: 750px;
    margin: 0 auto;
    color: #e5e5e5;
    line-height: 2.1;
    font-size: 16px;
    font-weight: 300;
    letter-spacing: 0.05em;
  }

  .xb-header-actions {
    display: flex;
    justify-content: center;
    gap: 14px;
    flex-wrap: wrap;
    margin-top: 34px;
  }

  .xb-top-btn {
    min-width: 210px;
    padding: 14px 22px;
    text-decoration: none;
    font-size: 11px;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    transition: 0.3s ease;
    border: 1px solid transparent;
  }

  .xb-top-btn.primary {
    background: #d6b25e;
    color: #111;
    border-color: #d6b25e;
  }

  .xb-top-btn.primary:hover {
    background: #e5c06d;
    border-color: #e5c06d;
  }

  .xb-top-btn.whatsapp,
  .xb-top-btn.secondary {
    background: transparent;
    color: #fff;
    border-color: rgba(255,255,255,0.18);
  }

  .xb-top-btn.whatsapp:hover,
  .xb-top-btn.secondary:hover {
    border-color: rgba(214,178,94,0.5);
    color: #d6b25e;
  }

  .xb-section-eyebrow {
    display: block;
    color: #d6b25e;
    font-size: 10px;
    letter-spacing: 0.35em;
    text-transform: uppercase;
    margin-bottom: 14px;
  }

  .xb-section-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(2rem, 4vw, 3.2rem);
    font-style: italic;
    font-weight: 300;
    line-height: 1.15;
    margin: 0 0 18px;
    color: #fff;
  }

  .xb-section-intro {
    max-width: 760px;
    margin: 0 auto;
    color: #cfcac4;
    font-size: 14px;
    line-height: 1.9;
    letter-spacing: 0.02em;
    text-align: center;
  }

  .xb-info-section,
  .xb-route-section,
  .xb-related-section,
  .xb-cta-section,
  .xb-faq-section {
    padding: 0 0 120px;
    text-align: center;
  }

  .xb-info-grid,
  .xb-route-grid {
    margin-top: 48px;
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 24px;
  }

  .xb-info-card,
  .xb-route-card {
    background: rgba(255,255,255,0.02);
    border: 1px solid rgba(214,178,94,0.14);
    padding: 30px 28px;
    text-align: left;
    min-height: 100%;
  }

  .xb-info-tag,
  .xb-route-tag {
    display: block;
    color: #d6b25e;
    font-size: 10px;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    margin-bottom: 14px;
  }

  .xb-info-heading,
  .xb-route-heading {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.9rem;
    font-style: italic;
    font-weight: 300;
    margin: 0 0 14px;
    color: #fff;
  }

  .xb-info-desc,
  .xb-route-desc {
    color: #b9b2ab;
    font-size: 13px;
    line-height: 1.85;
    letter-spacing: 0.02em;
  }

  .xb-route-link {
    color: #d6b25e;
    text-decoration: none;
    font-size: 11px;
    letter-spacing: 2px;
    display: inline-flex;
    flex-direction: column;
    gap: 8px;
    margin-top: 24px;
  }

  .xb-route-link .line,
  .xb-inline-link .line,
  .xb-related-link .line {
    width: 30px;
    height: 1px;
    background: #d6b25e;
    transition: 0.4s;
  }

  .xb-route-link:hover .line,
  .xb-inline-link:hover .line,
  .xb-related-link:hover .line {
    width: 60px;
  }

  .xb-stories {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 0 120px;
    display: flex;
    flex-direction: column;
    gap: 150px;
  }

  .xb-story-row {
    display: flex;
    align-items: center;
    gap: 80px;
    flex-direction: row;
  }

  .xb-story-row.row-reverse {
    flex-direction: row-reverse;
  }

  .xb-story-image {
    flex: 1.1;
    position: relative;
  }

  .xb-story-content {
    flex: 1;
    padding: 20px 0;
  }

  .img-reveal-wrapper {
    position: relative;
    aspect-ratio: 3 / 4;
    overflow: hidden;
    background-color: #111;
  }

  .img-reveal-wrapper::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, rgba(0,0,0,0) 60%, rgba(0,0,0,0.3) 100%);
    pointer-events: none;
  }

  .img-reveal-wrapper img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: brightness(0.8) contrast(1.05) saturate(1.05);
    transition: transform 2.5s cubic-bezier(0.1, 1, 0.2, 1);
  }

  .xb-story-row:hover img {
    transform: scale(1.08);
  }

  .story-tag {
    color: #d6b25e;
    font-size: 10px;
    letter-spacing: 3px;
    text-transform: uppercase;
    margin-bottom: 20px;
    display: block;
  }

  .story-heading {
    font-family: 'Cormorant Garamond', serif;
    font-style: italic;
    font-size: 2.5rem;
    letter-spacing: 0.05em;
    margin-bottom: 24px;
  }

  .story-desc {
    font-family: 'Montserrat', sans-serif;
    font-size: 13px;
    line-height: 1.8;
    letter-spacing: 0.03em;
    color: #a8a29e;
    max-width: 450px;
    font-weight: 300;
  }

  .xb-inline-link,
  .xb-related-link {
    color: #d6b25e;
    text-decoration: none;
    font-size: 11px;
    letter-spacing: 2px;
    display: inline-flex;
    flex-direction: column;
    gap: 8px;
    margin-top: 24px;
  }

  .xb-related-grid {
    margin-top: 48px;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 24px;
    text-align: left;
  }

  .xb-related-card {
    background: rgba(255,255,255,0.02);
    border: 1px solid rgba(255,255,255,0.08);
    padding: 28px 24px;
    min-height: 100%;
  }

  .xb-related-tag {
    display: block;
    color: #d6b25e;
    font-size: 10px;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    margin-bottom: 14px;
  }

  .xb-related-heading {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.9rem;
    font-style: italic;
    font-weight: 300;
    margin: 0 0 14px;
    color: #fff;
  }

  .xb-related-desc {
    color: #b9b2ab;
    font-size: 13px;
    line-height: 1.85;
    letter-spacing: 0.02em;
  }

  .xb-cta-shell {
    max-width: 980px;
    margin: 48px auto 0;
    padding: 46px 42px;
    border: 1px solid rgba(214,178,94,0.18);
    background:
      linear-gradient(180deg, rgba(255,255,255,0.02) 0%, rgba(255,255,255,0.008) 100%),
      radial-gradient(circle at top right, rgba(214,178,94,0.08), transparent 35%);
  }

  .xb-cta-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(2rem, 4vw, 3rem);
    font-style: italic;
    font-weight: 300;
    line-height: 1.12;
    margin: 0 0 18px;
    color: #fff;
  }

  .xb-cta-desc {
    max-width: 760px;
    margin: 0 auto;
    color: #cfcac4;
    font-size: 14px;
    line-height: 1.9;
    letter-spacing: 0.02em;
  }

  .xb-cta-actions {
    display: flex;
    justify-content: center;
    gap: 14px;
    flex-wrap: wrap;
    margin-top: 30px;
  }

  .xb-cta-btn {
    min-width: 210px;
    padding: 14px 22px;
    text-decoration: none;
    font-size: 11px;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    transition: 0.3s ease;
  }

  .xb-cta-btn.primary {
    background: #d6b25e;
    color: #111;
    border: 1px solid #d6b25e;
  }

  .xb-cta-btn.primary:hover {
    background: #e5c06d;
    border-color: #e5c06d;
  }

  .xb-cta-btn.whatsapp,
  .xb-cta-btn.secondary {
    background: transparent;
    color: #fff;
    border: 1px solid rgba(255,255,255,0.18);
  }

  .xb-cta-btn.whatsapp:hover,
  .xb-cta-btn.secondary:hover {
    border-color: rgba(214,178,94,0.5);
    color: #d6b25e;
  }

  .xb-faq-list {
    max-width: 900px;
    margin: 48px auto 0;
    text-align: left;
  }

  .xb-faq-item {
    border-top: 1px solid rgba(255,255,255,0.12);
    padding: 0;
  }

  .xb-faq-item:last-child {
    border-bottom: 1px solid rgba(255,255,255,0.12);
  }

  .xb-faq-question {
    list-style: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    padding: 24px 0;
    font-size: 15px;
    color: #f5f5f4;
    letter-spacing: 0.02em;
  }

  .xb-faq-question::-webkit-details-marker {
    display: none;
  }

  .xb-faq-icon {
    width: 14px;
    height: 14px;
    position: relative;
    flex: 0 0 14px;
  }

  .xb-faq-icon::before,
  .xb-faq-icon::after {
    content: "";
    position: absolute;
    background: #d6b25e;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
    transition: 0.25s ease;
  }

  .xb-faq-icon::before {
    width: 14px;
    height: 1px;
  }

  .xb-faq-icon::after {
    width: 1px;
    height: 14px;
  }

  .xb-faq-item[open] .xb-faq-icon::after {
    opacity: 0;
  }

  .xb-faq-answer {
    color: #b9b2ab;
    font-size: 13px;
    line-height: 1.9;
    letter-spacing: 0.02em;
    padding: 0 0 24px;
    max-width: 760px;
  }

  @media (max-width: 990px) {
    .xb-container {
      padding: 0 24px;
    }

    .xb-header {
      padding: 90px 20px 110px;
    }

    .xb-main-title {
      font-size: 2.9rem;
    }

    .xb-intro-text {
      font-size: 14px;
      line-height: 1.85;
    }

    .xb-header-actions {
      flex-direction: column;
      align-items: stretch;
      max-width: 420px;
      margin: 30px auto 0;
    }

    .xb-top-btn {
      min-width: 0;
      width: 100%;
      text-align: center;
    }

    .xb-story-row,
    .xb-story-row.row-reverse {
      flex-direction: column;
      gap: 50px;
      margin-bottom: 0;
    }

    .xb-stories {
      gap: 90px;
      padding-bottom: 100px;
    }

    .img-reveal-wrapper {
      aspect-ratio: 4/5;
      width: 100%;
    }

    .xb-info-grid,
    .xb-route-grid,
    .xb-related-grid {
      grid-template-columns: 1fr;
    }

    .xb-cta-shell {
      padding: 34px 22px;
    }

    .xb-cta-actions {
      flex-direction: column;
      align-items: stretch;
    }

    .xb-cta-btn {
      min-width: 0;
      width: 100%;
      text-align: center;
    }
  }
</style>

<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,500;1,300&family=Montserrat:wght@300;400;600&display=swap" rel="stylesheet">

<div class="xb-wrapper" id="section-{{ section.id }}">
  {% assign info_blocks = section.blocks | where: 'type', 'info_item' %}
  {% assign story_blocks = section.blocks | where: 'type', 'story' %}
  {% assign related_blocks = section.blocks | where: 'type', 'related_tour' %}
  {% assign faq_blocks = section.blocks | where: 'type', 'faq_item' %}
  {% assign whatsapp_url = section.settings.whatsapp_url | default: 'https://api.whatsapp.com/send/?phone=8613211685553&text&type=phone_number&app_absent=0' %}

  <div class="xb-container">
    <header class="xb-header">
      {% if section.settings.sub_title != blank %}
        <span class="xb-subtitle">{{ section.settings.sub_title }}</span>
      {% endif %}
      {% if section.settings.main_title != blank %}
        <h1 class="xb-main-title">{{ section.settings.main_title }}</h1>
      {% endif %}
      {% if section.settings.intro_text != blank %}
        <div class="xb-intro-text">
          {{ section.settings.intro_text | newline_to_br }}
        </div>
      {% endif %}

      <div class="xb-header-actions">
        {% if section.settings.cta_primary_label != blank and section.settings.cta_primary_url != blank %}
          <a href="{{ section.settings.cta_primary_url }}" class="xb-top-btn primary">{{ section.settings.cta_primary_label }}</a>
        {% endif %}
        {% if section.settings.whatsapp_label != blank and whatsapp_url != blank %}
          <a href="{{ whatsapp_url }}" class="xb-top-btn whatsapp" target="_blank" rel="noopener">{{ section.settings.whatsapp_label }}</a>
        {% endif %}
        {% if section.settings.cta_secondary_label != blank and section.settings.cta_secondary_url != blank %}
          <a href="{{ section.settings.cta_secondary_url }}" class="xb-top-btn secondary">{{ section.settings.cta_secondary_label }}</a>
        {% endif %}
      </div>
    </header>

    {% if info_blocks.size > 0 %}
      <section class="xb-info-section">
        {% if section.settings.info_section_eyebrow != blank %}
          <span class="xb-section-eyebrow">{{ section.settings.info_section_eyebrow }}</span>
        {% endif %}
        {% if section.settings.info_section_title != blank %}
          <h2 class="xb-section-title">{{ section.settings.info_section_title }}</h2>
        {% endif %}
        {% if section.settings.info_section_intro != blank %}
          <div class="xb-section-intro">{{ section.settings.info_section_intro | newline_to_br }}</div>
        {% endif %}

        <div class="xb-info-grid">
          {% for block in info_blocks %}
            <article class="xb-info-card" {{ block.shopify_attributes }}>
              {% if block.settings.tag != blank %}
                <span class="xb-info-tag">{{ block.settings.tag }}</span>
              {% endif %}
              {% if block.settings.heading != blank %}
                <h3 class="xb-info-heading">{{ block.settings.heading }}</h3>
              {% endif %}
              {% if block.settings.description != blank %}
                <div class="xb-info-desc">{{ block.settings.description | newline_to_br }}</div>
              {% endif %}
            </article>
          {% endfor %}
        </div>
      </section>
    {% endif %}

    <section class="xb-route-section">
      <span class="xb-section-eyebrow">ROUTE PLANNING</span>
      <h2 class="xb-section-title">Plan Xishuangbanna With the Right Next Step</h2>
      <div class="xb-section-intro">
        Use this page as a planning hub, then move into a broader Yunnan route, a more focused Xishuangbanna stay, or a custom trip request built around your travel dates, preferred pace, and tropical interests.
      </div>

      <div class="xb-route-grid">
        <article class="xb-route-card">
          <span class="xb-route-tag">WIDER YUNNAN</span>
          <h3 class="xb-route-heading">Start With Yunnan Private Tours</h3>
          <div class="xb-route-desc">
            Compare broader routes that connect Xishuangbanna with Kunming, Pu’er, and other parts of Yunnan. This is the best next step if you are still deciding how much of southern Yunnan to include in one trip.
          </div>
          <a href="/collections/yunnan-private-tours" class="xb-route-link">
            VIEW YUNNAN TOURS
            <span class="line"></span>
          </a>
        </article>

        <article class="xb-route-card">
          <span class="xb-route-tag">TROPICAL STAY</span>
          <h3 class="xb-route-heading">Focus on Xishuangbanna Private Tours</h3>
          <div class="xb-route-desc">
            If you already know you want a slower tropical stay, move directly into Xishuangbanna private tours built around rainforest atmosphere, warm-weather comfort, and flexible pacing.
          </div>
          <a href="/collections/xishuangbanna-private-tours" class="xb-route-link">
            VIEW XISHUANGBANNA TOURS
            <span class="line"></span>
          </a>
        </article>

        <article class="xb-route-card">
          <span class="xb-route-tag">MORE IDEAS</span>
          <h3 class="xb-route-heading">Continue With Related Travel Guides</h3>
          <div class="xb-route-desc">
            Browse more Yunnan guides if you are still comparing destinations, timing, and route combinations before choosing a private itinerary.
          </div>
          <a href="/blogs/travel-guides" class="xb-route-link">
            READ MORE GUIDES
            <span class="line"></span>
          </a>
        </article>

        <article class="xb-route-card">
          <span class="xb-route-tag">CUSTOM PLANNING</span>
          <h3 class="xb-route-heading">Ask for a Custom Southern Yunnan Route</h3>
          <div class="xb-route-desc">
            If you already know your dates or want help connecting Xishuangbanna with Pu’er, tea country, or a wider Yunnan journey, move straight into a custom planning conversation.
          </div>
          <a href="/pages/bespoke-custom-travel" class="xb-route-link">
            REQUEST A CUSTOM TRIP
            <span class="line"></span>
          </a>
        </article>
      </div>
    </section>

    {% if story_blocks.size > 0 %}
      <div class="xb-stories">
        {% for block in story_blocks %}
          <div class="xb-story-row {% cycle '', 'row-reverse' %}" {{ block.shopify_attributes }}>
            <div class="xb-story-image">
              <div class="img-reveal-wrapper">
                {% if block.settings.image != blank %}
                  <img src="{{ block.settings.image | image_url: width: 1200 }}" alt="{{ block.settings.heading | escape }}" loading="lazy">
                {% else %}
                  {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}
                {% endif %}
              </div>
            </div>
            <div class="xb-story-content">
              {% if block.settings.tag != blank %}
                <span class="story-tag">{{ block.settings.tag }}</span>
              {% endif %}
              {% if block.settings.heading != blank %}
                <h2 class="story-heading">{{ block.settings.heading }}</h2>
              {% endif %}
              {% if block.settings.description != blank %}
                <div class="story-desc">{{ block.settings.description | newline_to_br }}</div>
              {% endif %}
              {% liquid
                assign story_cta_label = block.settings.button_label | strip
                assign story_cta_label_downcase = story_cta_label | downcase
                if story_cta_label_downcase == 'read the guide' or story_cta_label_downcase == 'read more'
                  if block.settings.heading != blank
                    assign story_cta_label = 'Read the ' | append: block.settings.heading | append: ' guide'
                  else
                    assign story_cta_label = 'Read the guide'
                  endif
                endif
              %}
              {% if story_cta_label != blank and block.settings.button_link != blank %}
                <a href="{{ block.settings.button_link }}" class="xb-inline-link">
                  {{ story_cta_label }}
                  <span class="line"></span>
                </a>
              {% endif %}
            </div>
          </div>
        {% endfor %}
      </div>
    {% endif %}

    {% if related_blocks.size > 0 %}
      <section class="xb-related-section">
        {% if section.settings.related_section_eyebrow != blank %}
          <span class="xb-section-eyebrow">{{ section.settings.related_section_eyebrow }}</span>
        {% endif %}
        {% if section.settings.related_section_title != blank %}
          <h2 class="xb-section-title">{{ section.settings.related_section_title }}</h2>
        {% endif %}
        {% if section.settings.related_section_intro != blank %}
          <div class="xb-section-intro">{{ section.settings.related_section_intro | newline_to_br }}</div>
        {% endif %}

        <div class="xb-related-grid">
          {% for block in related_blocks %}
            <article class="xb-related-card" {{ block.shopify_attributes }}>
              {% if block.settings.tag != blank %}
                <span class="xb-related-tag">{{ block.settings.tag }}</span>
              {% endif %}
              {% if block.settings.heading != blank %}
                <h3 class="xb-related-heading">{{ block.settings.heading }}</h3>
              {% endif %}
              {% if block.settings.description != blank %}
                <div class="xb-related-desc">{{ block.settings.description | newline_to_br }}</div>
              {% endif %}
              {% liquid
                assign related_cta_label = block.settings.button_label | strip
                assign related_cta_label_downcase = related_cta_label | downcase
                if related_cta_label_downcase == 'view tour' or related_cta_label_downcase == 'view journey' or related_cta_label_downcase == 'learn more'
                  if block.settings.heading != blank
                    assign related_cta_label = 'Explore ' | append: block.settings.heading
                  else
                    assign related_cta_label = 'See tour details'
                  endif
                endif
              %}
              {% if related_cta_label != blank and block.settings.button_link != blank %}
                <a href="{{ block.settings.button_link }}" class="xb-related-link">
                  {{ related_cta_label }}
                  <span class="line"></span>
                </a>
              {% endif %}
            </article>
          {% endfor %}
        </div>
      </section>
    {% endif %}

    <section class="xb-cta-section">
      {% if section.settings.cta_eyebrow != blank %}
        <span class="xb-section-eyebrow">{{ section.settings.cta_eyebrow }}</span>
      {% endif %}
      {% if section.settings.cta_title != blank %}
        <h2 class="xb-section-title">{{ section.settings.cta_title }}</h2>
      {% endif %}
      {% if section.settings.cta_intro != blank %}
        <div class="xb-section-intro">{{ section.settings.cta_intro | newline_to_br }}</div>
      {% endif %}

      <div class="xb-cta-shell">
        {% if section.settings.cta_box_title != blank %}
          <h3 class="xb-cta-title">{{ section.settings.cta_box_title }}</h3>
        {% endif %}
        {% if section.settings.cta_box_desc != blank %}
          <div class="xb-cta-desc">{{ section.settings.cta_box_desc | newline_to_br }}</div>
        {% endif %}

        <div class="xb-cta-actions">
          {% if section.settings.cta_primary_label != blank and section.settings.cta_primary_url != blank %}
            <a href="{{ section.settings.cta_primary_url }}" class="xb-cta-btn primary">{{ section.settings.cta_primary_label }}</a>
          {% endif %}
          {% if section.settings.whatsapp_label != blank and whatsapp_url != blank %}
            <a href="{{ whatsapp_url }}" class="xb-cta-btn whatsapp" target="_blank" rel="noopener">{{ section.settings.whatsapp_label }}</a>
          {% endif %}
          {% if section.settings.cta_secondary_label != blank and section.settings.cta_secondary_url != blank %}
            <a href="{{ section.settings.cta_secondary_url }}" class="xb-cta-btn secondary">{{ section.settings.cta_secondary_label }}</a>
          {% endif %}
        </div>
      </div>
    </section>

    {% if faq_blocks.size > 0 %}
      <section class="xb-faq-section">
        {% if section.settings.faq_section_eyebrow != blank %}
          <span class="xb-section-eyebrow">{{ section.settings.faq_section_eyebrow }}</span>
        {% endif %}
        {% if section.settings.faq_section_title != blank %}
          <h2 class="xb-section-title">{{ section.settings.faq_section_title }}</h2>
        {% endif %}
        {% if section.settings.faq_section_intro != blank %}
          <div class="xb-section-intro">{{ section.settings.faq_section_intro | newline_to_br }}</div>
        {% endif %}

        <div class="xb-faq-list">
          {% for block in faq_blocks %}
            <details class="xb-faq-item" {{ block.shopify_attributes }}>
              <summary class="xb-faq-question">
                <span>{{ block.settings.question }}</span>
                <span class="xb-faq-icon"></span>
              </summary>
              <div class="xb-faq-answer">
                {{ block.settings.answer | newline_to_br }}
              </div>
            </details>
          {% endfor %}
        </div>
      </section>
    {% endif %}
  </div>
</div>

{% if faq_blocks.size > 0 %}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {% for block in faq_blocks %}
        {
          "@type": "Question",
          "name": {{ block.settings.question | strip_html | strip | json }},
          "acceptedAnswer": {
            "@type": "Answer",
            "text": {{ block.settings.answer | strip_html | strip | json }}
          }
        }{% unless forloop.last %},{% endunless %}
      {% endfor %}
    ]
  }
  </script>
{% endif %}

{% if page %}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "name": "Home",
        "item": {{ request.origin | append: '/' | json }}
      },
      {
        "@type": "ListItem",
        "position": 2,
        "name": {{ page.title | json }},
        "item": {{ request.origin | append: page.url | json }}
      }
    ]
  }
  </script>
{% endif %}

