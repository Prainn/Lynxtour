{% comment %}
  Help Center - FAQ (Dark / Glass style)
  File: sections/help-center-faq.liquid
{% endcomment %}

<section class="hcfaq-{{ section.id }}">
  <div class="hcfaq__container">
    {%- assign hc_page_title = page.title | strip -%}
    {%- if hc_page_title == blank -%}
      {%- assign hc_page_title = 'Help Center' -%}
    {%- endif -%}
    <h1>{{ hc_page_title }}</h1>

    <div class="hcfaq__wrap">
      {%- if section.settings.title != blank -%}
        <h2 class="hcfaq__badge">{{ section.settings.title }}</h2>
      {%- endif -%}

      <div class="hcfaq__card">
        {%- assign shown = 0 -%}
        {%- for block in section.blocks -%}
          {%- if block.type == 'faq' -%}
            {%- assign shown = shown | plus: 1 -%}
            {%- if section.settings.max_items != blank and shown > section.settings.max_items -%}
              {%- break -%}
            {%- endif -%}

            <details
              class="hcfaq__item"
              {% if section.settings.open_first and shown == 1 %}open{% endif %}
              {{ block.shopify_attributes }}
            >
              <summary class="hcfaq__head">
                <h3 class="hcfaq__q">{{ block.settings.question }}</h3>
                <span class="hcfaq__chev" aria-hidden="true">
                  <svg viewBox="0 0 24 24" focusable="false">
                    <path d="M6.7 9.3a1 1 0 0 1 1.4 0L12 13.2l3.9-3.9a1 1 0 1 1 1.4 1.4l-4.6 4.6a1 1 0 0 1-1.4 0L6.7 10.7a1 1 0 0 1 0-1.4z"/>
                  </svg>
                </span>
              </summary>

              {%- if block.settings.answer != blank -%}
                <div class="hcfaq__body rte">
                  {{ block.settings.answer }}
                </div>
              {%- endif -%}
            </details>
          {%- endif -%}
        {%- endfor -%}

        {%- if shown == 0 -%}
          <div class="hcfaq__empty">请在该 Section 中添加 FAQ blocks。</div>
        {%- endif -%}
      </div>
    </div>

  </div>

  <style>
    .hcfaq-{{ section.id }}{
      --brand: var(--brand-color, #f59e0b);

      --panel: rgba(12, 10, 9, 0.92);
      --text: #ffffff;
      --sub: rgba(214, 211, 209, 0.85);
      --line: rgba(255,255,255,0.10);
      --line-2: rgba(255,255,255,0.08);
      --shadow: 0 10px 30px rgba(0,0,0,0.50);
      --radius: 18px;
      --pad: 20px;
    }

    .hcfaq-{{ section.id }} .hcfaq__container{
      max-width: {{ section.settings.max_width }}px;
      margin: 0 auto;
      padding: 18px 18px 22px;
      color: var(--text);
    }

    .hcfaq-{{ section.id }} .hcfaq__wrap{
      position: relative;
      padding-top: 26px;
    }

    .hcfaq-{{ section.id }} .hcfaq__badge{
      position: absolute;
      left: 18px;
      top: -12px;
      background: var(--panel);
      border: 1px solid var(--line);
      border-radius: 999px;
      padding: 6px 12px;
      font-size: 12px;
      font-weight: 700;
      letter-spacing: 1px;
      color: var(--text);
      box-shadow: var(--shadow);
      backdrop-filter: blur(15px);
      -webkit-backdrop-filter: blur(15px);
      z-index: 2;
      white-space: nowrap;
    }

    .hcfaq-{{ section.id }} .hcfaq__card{
      background: var(--panel);
      border: 1px solid var(--line);
      box-shadow: var(--shadow);
      border-radius: var(--radius);
      overflow: hidden;
      backdrop-filter: blur(15px);
      -webkit-backdrop-filter: blur(15px);
    }

    .hcfaq-{{ section.id }} .hcfaq__item{
      border-top: 1px solid var(--line-2);
    }
    .hcfaq-{{ section.id }} .hcfaq__item:first-child{
      border-top: 0;
    }

    .hcfaq-{{ section.id }} summary{
      list-style: none;
      cursor: pointer;
    }
    .hcfaq-{{ section.id }} summary::-webkit-details-marker{ display:none; }

    .hcfaq-{{ section.id }} .hcfaq__head{
      display:flex;
      align-items:center;
      justify-content:space-between;
      gap:14px;
      padding: 18px var(--pad);
      user-select:none;
      transition: background .2s ease, color .2s ease;
    }

    .hcfaq-{{ section.id }} .hcfaq__head:hover{
      background: rgba(255,255,255,0.03);
    }

    .hcfaq-{{ section.id }} .hcfaq__q{
      font-size: 14px;
      font-weight: 600;
      line-height: 1.25;
      color: var(--text);
    }

    .hcfaq-{{ section.id }} .hcfaq__chev{
      width: 22px;
      height: 22px;
      flex: 0 0 22px;
      color: rgba(255,255,255,0.85);
      transition: transform .18s ease, color .2s ease;
      display:grid;
      place-items:center;
    }

    .hcfaq-{{ section.id }} details[open] .hcfaq__chev{
      transform: rotate(180deg);
      color: var(--brand);
    }

    .hcfaq-{{ section.id }} .hcfaq__chev svg{
      width: 22px;
      height: 22px;
      fill: currentColor;
      display:block;
    }

    .hcfaq-{{ section.id }} .hcfaq__body{
      padding: 0 var(--pad) 18px;
      color: var(--sub);
      font-size: 13px;
      line-height: 1.7;
    }

    .hcfaq-{{ section.id }} .hcfaq__empty{
      padding: 14px 18px;
      color: var(--sub);
      font-size: 13px;
    }
.hcfaq-{{ section.id }}{
  --header-offset: 120px; /* 改成你 header 的实际高度 */
}

.hcfaq-{{ section.id }} .hcfaq__container{
  padding-top: calc(24px + var(--header-offset));
}

    @media (max-width: 720px){
      .hcfaq-{{ section.id }} .hcfaq__head{ padding: 16px 16px; }
      .hcfaq-{{ section.id }} .hcfaq__body{ padding: 0 16px 16px; }
      .hcfaq-{{ section.id }} .hcfaq__badge{ left: 14px; }
    }
  </style>

  {%- if section.settings.single_open -%}
    <script>
      (function () {
        var root = document.querySelector('.hcfaq-{{ section.id }}');
        if (!root) return;
        var all = root.querySelectorAll('details.hcfaq__item');
        all.forEach(function (d) {
          d.addEventListener('toggle', function () {
            if (!d.open) return;
            all.forEach(function (other) {
              if (other !== d) other.removeAttribute('open');
            });
          });
        });
      })();
    </script>
  {%- endif -%}
</section>

{% schema %}
{
  "name": "Help Center - FAQ (Dark)",
  "settings": [
    { "type": "text", "id": "title", "label": "左上角标题", "default": "热门常见问题" },
    { "type": "range", "id": "max_items", "label": "最多显示多少条", "min": 3, "max": 12, "step": 1, "default": 6 },
    { "type": "checkbox", "id": "open_first", "label": "默认展开第一条", "default": false },
    { "type": "checkbox", "id": "single_open", "label": "只允许同时展开一个", "default": true },
    { "type": "range", "id": "max_width", "label": "内容最大宽度(px)", "min": 720, "max": 1200, "step": 10, "default": 980 }
  ],
  "blocks": [
    {
      "type": "faq",
      "name": "FAQ",
      "settings": [
        { "type": "text", "id": "question", "label": "问题", "default": "如何取消订单并获得退款？" },
        { "type": "richtext", "id": "answer", "label": "答案", "default": "<p>在这里填写答案内容。</p>" }
      ]
    }
  ],
  "presets": [{ "name": "Help Center - FAQ (Dark)" }]
}
{% endschema %}
