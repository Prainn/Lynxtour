{% paginate blog.articles by 30 %}
  
  {%- style -%}
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }

    @media screen and (max-width: 768px) {
      .section-{{ section.id }}-padding {
        padding-top: {{ section.settings.padding_top | divided_by: 1.5 }}px;
        padding-bottom: {{ section.settings.padding_bottom | divided_by: 1.5 }}px;
      }
    }
  {%- endstyle -%}

  <style>
    .luxury-blog-page {
      background-color: #080808;
      color: #e0e0e0;
      padding-left: 20px;
      padding-right: 20px;
      font-family: "Helvetica Neue", Arial, sans-serif;
    }

    .blog-container {
      max-width: 1200px;
      margin: 0 auto;
    }

    .blog-page-title {
      text-align: center;
      margin-bottom: 15px;
      font-size: 2.5em;
      letter-spacing: 2px;
      color: #D4AF37;
      background: linear-gradient(to right, #B8860B, #FFD700, #B8860B);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      text-transform: uppercase;
    }

    .blog-page-subtitle {
      text-align: center;
      color: #888;
      font-size: 1.1em;
      margin-bottom: 40px;
      max-width: 600px;
      margin-left: auto;
      margin-right: auto;
      line-height: 1.6;
    }

    .blog-search-wrap {
      max-width: 760px;
      margin: 0 auto 40px;
    }

    .blog-search-form {
      display: flex;
      gap: 12px;
      align-items: center;
      border: 1px solid #2a2a2a;
      background: #111;
      padding: 12px 14px;
      border-radius: 6px;
      transition: border-color 0.3s ease, box-shadow 0.3s ease;
    }

    .blog-search-form:focus-within {
      border-color: #D4AF37;
      box-shadow: 0 0 0 3px rgba(212, 175, 55, 0.08);
    }

    .blog-search-icon {
      color: #D4AF37;
      flex: 0 0 auto;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .blog-search-input {
      width: 100%;
      background: transparent;
      border: 0;
      outline: none;
      color: #fff;
      font-size: 1em;
      line-height: 1.4;
    }

    .blog-search-input::placeholder {
      color: #777;
    }

    .blog-search-clear {
      flex: 0 0 auto;
      background: transparent;
      color: #aaa;
      border: 1px solid #333;
      padding: 8px 14px;
      font-size: 0.78em;
      letter-spacing: 1px;
      text-transform: uppercase;
      cursor: pointer;
      transition: all 0.3s ease;
    }

    .blog-search-clear:hover {
      border-color: #D4AF37;
      color: #D4AF37;
    }

    .blog-search-meta {
      margin-top: 14px;
      color: #888;
      font-size: 0.92em;
      text-align: center;
    }

    .blog-search-empty {
      display: none;
      margin-top: 24px;
      text-align: center;
      color: #888;
      border: 1px dashed #333;
      padding: 28px 20px;
      border-radius: 6px;
      background: #0d0d0d;
    }

    .blog-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 40px;
    }

    @media (min-width: 768px) {
      .blog-grid {
        grid-template-columns: repeat(var(--desktop-cols), 1fr);
      }
    }

    .blog-card {
      background-color: #121212;
      border: 1px solid #2a2a2a;
      border-radius: 4px;
      overflow: hidden;
      transition: all 0.4s ease;
      display: flex;
      flex-direction: column;
      height: 100%;
    }

    .blog-card:hover {
      border-color: #D4AF37;
      transform: translateY(-8px);
      box-shadow: 0 15px 30px rgba(212, 175, 55, 0.08);
    }

    .blog-card.is-hidden {
      display: none !important;
    }

    .blog-img-wrapper {
      width: 100%;
      height: 240px;
      overflow: hidden;
      display: block;
    }

    .blog-img-wrapper img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: transform 0.6s ease;
    }

    .blog-card:hover .blog-img-wrapper img {
      transform: scale(1.08);
    }

    .blog-content {
      padding: 25px;
      display: flex;
      flex-direction: column;
      flex-grow: 1;
      gap: 15px;
    }

    .blog-date {
      font-size: 0.8em;
      color: #D4AF37;
      letter-spacing: 1px;
      margin: 0;
      text-transform: uppercase;
    }

    .blog-title {
      font-size: 1.3em;
      margin: 0;
      line-height: 1.4;
    }

    .blog-title a {
      text-decoration: none;
      color: #ffffff;
      transition: color 0.3s;
    }

    .blog-card:hover .blog-title a {
      color: #D4AF37;
    }

    .blog-excerpt {
      color: #888888;
      font-size: 0.95em;
      line-height: 1.6;
      margin: 0;
    }

    .btn-container {
      margin-top: auto;
      padding-top: 10px;
    }

    .btn-read-more {
      display: inline-block;
      padding: 10px 24px;
      color: #D4AF37;
      border: 1px solid #D4AF37;
      text-decoration: none;
      font-size: 0.9em;
      letter-spacing: 1px;
      transition: all 0.3s ease;
      text-transform: uppercase;
    }

    .btn-read-more:hover {
      background-color: #D4AF37;
      color: #000000;
    }

    .blog-pagination {
      text-align: center;
      margin-top: 60px;
    }
    
    .blog-pagination span {
      display: inline-block;
      margin: 0 5px;
    }

    .blog-pagination a,
    .blog-pagination .current {
      padding: 8px 16px;
      border: 1px solid #333;
      color: #aaa;
      text-decoration: none;
      transition: all 0.3s;
    }

    .blog-pagination a:hover {
      border-color: #D4AF37;
      color: #D4AF37;
    }

    .blog-pagination .current {
      background-color: #D4AF37;
      border-color: #D4AF37;
      color: #000;
      font-weight: bold;
    }
  </style>

  <div class="luxury-blog-page section-{{ section.id }}-padding">
    <div class="blog-container">
      
      <h1 class="blog-page-title">
        {% if section.settings.custom_heading != blank %}
          {{ section.settings.custom_heading }}
        {% else %}
          {{ blog.title }}
        {% endif %}
      </h1>

      {% if section.settings.custom_subheading != blank %}
        <p class="blog-page-subtitle">{{ section.settings.custom_subheading }}</p>
      {% endif %}

      {% if section.settings.show_blog_search %}
        <div class="blog-search-wrap" data-blog-search-wrap>
          <div class="blog-search-form">
            <span class="blog-search-icon" aria-hidden="true">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                <circle cx="11" cy="11" r="7"></circle>
                <path d="M20 20L17 17"></path>
              </svg>
            </span>

            <input
              type="search"
              class="blog-search-input"
              data-blog-search-input
              placeholder="{{ section.settings.blog_search_placeholder | escape }}"
              aria-label="{{ section.settings.blog_search_placeholder | escape }}"
            >

            <button type="button" class="blog-search-clear" data-blog-search-clear>
              {{ section.settings.blog_search_clear_text }}
            </button>
          </div>

          <div class="blog-search-meta" data-blog-search-meta>
            {{ section.settings.blog_search_helper_text }}
          </div>
        </div>
      {% endif %}

      <div class="blog-grid" style="--desktop-cols: {{ section.settings.columns_desktop }};">
        
        {% for article in blog.articles %}
          {% capture article_search_text %}
            {{ article.title }}
            {{ article.excerpt_or_content | strip_html }}
            {% for tag in article.tags %} {{ tag }} {% endfor %}
          {% endcapture %}

          <div
            class="blog-card"
            data-blog-card
            data-search="{{ article_search_text | strip | escape }}"
            data-title="{{ article.title | escape }}"
            data-url="{{ article.url }}"
          >
            {% if article.image %}
              <a href="{{ article.url }}" class="blog-img-wrapper">
                <img src="{{ article.image | img_url: '800x' }}" alt="{{ article.image.alt | escape }}">
              </a>
            {% endif %}
            
            <div class="blog-content">
              {% for block in section.blocks %}
                {% case block.type %}
                  
                  {% when 'date' %}
                    <div class="blog-date" {{ block.shopify_attributes }}>
                      {{ article.published_at | date: "%B %d, %Y" }}
                    </div>

                  {% when 'title' %}
                    <h2 class="blog-title" {{ block.shopify_attributes }}>
                      <a href="{{ article.url }}">{{ article.title }}</a>
                    </h2>
                  
                  {% when 'summary' %}
                    <div class="blog-excerpt" {{ block.shopify_attributes }}>
                      {{ article.excerpt_or_content | strip_html | truncatewords: 20 }}
                    </div>
                  
                  {% when 'button' %}
                    {% liquid
                      assign card_cta_text = block.settings.btn_text

                      if section.settings.card_cta_mode == 'custom'
                        if section.settings.card_cta_custom_text != blank
                          assign card_cta_text = section.settings.card_cta_custom_text
                        endif
                      elsif section.settings.card_cta_mode == 'dynamic'
                        assign clean_title = article.title
                        assign clean_title = clean_title | remove: 'Travel Guide' | remove: 'travel guide' | remove: 'Guide' | remove: 'guide' | strip
                        assign card_cta_text = section.settings.card_cta_prefix | append: ' ' | append: clean_title

                        if section.settings.card_cta_suffix != blank
                          assign card_cta_text = card_cta_text | append: ' ' | append: section.settings.card_cta_suffix
                        endif
                      endif

                      if card_cta_text == blank
                        assign card_cta_text = 'Read More'
                      endif
                    %}
                    <div class="btn-container" {{ block.shopify_attributes }}>
                      <a href="{{ article.url }}" class="btn-read-more" aria-label="{{ card_cta_text | escape }}">
                        {{ card_cta_text }}
                      </a>
                    </div>
                {% endcase %}
              {% endfor %}
            </div>
          </div>
        {% endfor %}
      </div>

      {% if section.settings.show_blog_search %}
        <div class="blog-search-empty" data-blog-search-empty hidden aria-live="polite"></div>
      {% endif %}

      {% if paginate.pages > 1 %}
        <div class="blog-pagination">
          {{ paginate | default_pagination: next: 'Next &raquo;', previous: '&laquo; Previous' }}
        </div>
      {% endif %}
    </div>
  </div>

  {% if section.settings.show_blog_search %}
    <script>
      (function () {
        const root = document.currentScript.closest('.shopify-section');
        if (!root) return;

        const input = root.querySelector('[data-blog-search-input]');
        const clearBtn = root.querySelector('[data-blog-search-clear]');
        const cards = Array.from(root.querySelectorAll('[data-blog-card]'));
        const meta = root.querySelector('[data-blog-search-meta]');
        const empty = root.querySelector('[data-blog-search-empty]');

        if (!input || !cards.length) return;

        const total = cards.length;
        const helperText = {{ section.settings.blog_search_helper_text | json }};
        const emptyText = {{ section.settings.blog_search_empty_text | json }};

        function normalize(str) {
          return (str || '')
            .toLowerCase()
            .replace(/\s+/g, ' ')
            .trim();
        }

        function updateResults() {
          const rawQuery = input.value.trim();
          const query = normalize(rawQuery);
          let visibleCount = 0;

          cards.forEach((card) => {
            const haystack = normalize(card.getAttribute('data-search'));
            const matched = !query || haystack.includes(query);

            card.classList.toggle('is-hidden', !matched);

            if (matched) visibleCount += 1;
          });

          if (meta) {
            if (query) {
              meta.textContent =
                visibleCount +
                ' result' +
                (visibleCount === 1 ? '' : 's') +
                ' for "' +
                rawQuery +
                '"';
            } else {
              meta.textContent =
                helperText ||
                (total + ' loaded article' + (total === 1 ? '' : 's'));
            }
          }

          if (empty) {
            const showEmpty = query !== '' && visibleCount === 0;
            empty.hidden = !showEmpty;
            empty.style.display = showEmpty ? 'block' : 'none';
            empty.textContent = showEmpty ? emptyText : '';
          }
        }

        input.addEventListener('input', updateResults);

        if (clearBtn) {
          clearBtn.addEventListener('click', function () {
            input.value = '';
            input.focus();
            updateResults();
          });
        }

        updateResults();
      })();
    </script>
  {% endif %}

{% endpaginate %}

{% schema %}
{
  "name": "Luxury Blog Grid",
  "settings": [
    {
      "type": "header",
      "content": "Section Padding (Spacing)"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 60,
      "max": 250,
      "step": 10,
      "unit": "px",
      "label": "Top Padding",
      "default": 160
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 40,
      "max": 150,
      "step": 10,
      "unit": "px",
      "label": "Bottom Padding",
      "default": 80
    },
    {
      "type": "header",
      "content": "Header Settings"
    },
    {
      "type": "text",
      "id": "custom_heading",
      "label": "Custom Heading",
      "info": "Leave blank to use the default blog title.",
      "default": "Explore the Extraordinary"
    },
    {
      "type": "textarea",
      "id": "custom_subheading",
      "label": "Subheading / Description",
      "default": "Follow our footsteps and discover the world's most luxurious and hidden travel destinations."
    },
    {
      "type": "header",
      "content": "Blog Search Settings"
    },
    {
      "type": "checkbox",
      "id": "show_blog_search",
      "label": "Show blog search",
      "default": true
    },
    {
      "type": "text",
      "id": "blog_search_placeholder",
      "label": "Search placeholder",
      "default": "Search articles by destination, landmark, or keyword"
    },
    {
      "type": "text",
      "id": "blog_search_clear_text",
      "label": "Clear button text",
      "default": "Clear"
    },
    {
      "type": "text",
      "id": "blog_search_helper_text",
      "label": "Helper text",
      "default": "Search articles by title, summary, or keyword."
    },
    {
      "type": "text",
      "id": "blog_search_empty_text",
      "label": "Empty state text",
      "default": "No matching articles found."
    },
    {
      "type": "header",
      "content": "Grid Layout Settings"
    },
    {
      "type": "header",
      "content": "Card CTA Settings"
    },
    {
      "type": "select",
      "id": "card_cta_mode",
      "label": "Card CTA mode",
      "options": [
        { "value": "dynamic", "label": "Dynamic: Read the [Title] Guide" },
        { "value": "custom", "label": "Custom text" }
      ],
      "default": "dynamic"
    },
    {
      "type": "text",
      "id": "card_cta_custom_text",
      "label": "Custom card CTA text",
      "default": "Read More"
    },
    {
      "type": "text",
      "id": "card_cta_prefix",
      "label": "Dynamic CTA prefix",
      "default": "Read the"
    },
    {
      "type": "text",
      "id": "card_cta_suffix",
      "label": "Dynamic CTA suffix",
      "default": "Guide"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 2,
      "max": 4,
      "step": 1,
      "default": 3,
      "label": "Columns on desktop"
    }
  ],
  "blocks": [
    {
      "type": "title",
      "name": "Article Title",
      "limit": 1
    },
    {
      "type": "date",
      "name": "Published Date",
      "limit": 1
    },
    {
      "type": "summary",
      "name": "Article Summary",
      "limit": 1
    },
    {
      "type": "button",
      "name": "Read More Button",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "btn_text",
          "label": "Button Text",
          "default": "Discover More"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Luxury Blog Grid",
      "blocks": [
        { "type": "date" },
        { "type": "title" },
        { "type": "summary" },
        { "type": "button" }
      ]
    }
  ]
}
{% endschema %}