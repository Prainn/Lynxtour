<section class="luxury-collection-wrapper" id="CollectionProductGrid">
  {%- assign is_shangrila_private_tours = false -%}
  {%- if collection.handle == 'shangri-la-private-tours' -%}
    {%- assign is_shangrila_private_tours = true -%}
  {%- endif -%}

  <header class="coll-hero-compact">
    <div class="hero-bg">
      {% if collection.image %}
        <img src="{{ collection.image | image_url: width: 2400 }}" alt="{{ collection.title | escape }} - Lynxtour" class="hero-img">
      {% else %}
        <div class="hero-placeholder"></div>
      {% endif %}
      <div class="hero-overlay"></div>
    </div>

    <div class="hero-text-container">
      <div class="hero-content">
        <div class="subtitle-wrap">
          <span class="coll-subtitle">
            {% if is_shangrila_private_tours %}
              THE LOST HORIZON
            {% else %}
              SELECTED JOURNEYS
            {% endif %}
          </span>
          <div class="subtitle-line"></div>
        </div>

        <h1 class="coll-title">
          {% if is_shangrila_private_tours %}
            Shangri-La Private Tours
          {% else %}
            {{ collection.title }}
          {% endif %}
        </h1>

        {% if is_shangrila_private_tours %}
          <div class="coll-desc-wrap">
            <div class="coll-desc">
              Discover private tours in Shangri-La shaped around Tibetan culture, highland landscapes, sacred monasteries, and slower journeys through northwest Yunnan.
            </div>
          </div>
        {% elsif collection.description != blank %}
          <div class="coll-desc-wrap">
            <div class="coll-desc">{{ collection.description | strip_html | truncatewords: 26 }}</div>
          </div>
        {% endif %}
      </div>
    </div>
  </header>

  <div class="coll-container">
    <div class="coll-meta-bar">
      <div class="meta-left">
        <span class="meta-number">{{ collection.products_count }}</span>
        <span class="meta-label">Selected Experiences</span>
      </div>
      <div class="meta-divider"></div>
      <div class="meta-right">
        <span class="meta-location">
          {% if is_shangrila_private_tours %}
            SHANGRI-LA / YUNNAN
          {% else %}
            YUNNAN / CHINA
          {% endif %}
        </span>
      </div>
    </div>

    {% paginate collection.products by 12 %}

      {% if is_shangrila_private_tours and paginate.current_page == 1 %}
        <section class="collection-copy-block collection-intro-block">
          <div class="collection-copy-inner">
            <h2 class="copy-heading">Private journeys through Shangri-La</h2>
            <div class="copy-richtext">
              <p>Shangri-La is one of the most distinctive destinations in Yunnan, known for its Tibetan culture, high-altitude grasslands, golden monasteries, snow mountain scenery, and a quieter spiritual atmosphere that feels different from anywhere else in the province. For many travelers, it is the point where a Yunnan journey becomes deeper, wider, and more memorable.</p>

              <p>Our Shangri-La private tours are designed for travelers who value flexibility, comfort, and a more personal pace. Whether you want to visit Songzanlin Monastery, explore old town streets, experience Tibetan cultural landscapes, or combine Shangri-La with Lijiang, Tiger Leaping Gorge, or Dali, a private tour allows you to shape the trip around your own interests, timing, and travel style.</p>

              <p>This collection brings together private Shangri-La tour ideas ranging from shorter cultural stays to multi-day northwest Yunnan journeys. It is ideal for couples, families, photographers, culturally curious travelers, and visitors looking for a more curated and comfortable highland experience in Yunnan.</p>
            </div>
          </div>
        </section>
      {% endif %}

      <div class="compact-grid" data-cols="3">
        {% for product in collection.products %}
          {% liquid
            assign included_main_keywords = 'independent group of|solo journey|double share|family & friends private group' | split: '|'
            assign excluded_keywords = 'single room supplement|room supplement|single supplement|supplement|children pricing|child|children|kid|kids|infant|baby|toddler|add-on|addon|upgrade|custom|extra bed|surcharge|儿童|小童|婴儿' | split: '|'

            assign collection_display_price = blank
            assign valid_main_variant_count = 0
            assign found_main_variant = false

            for variant in product.variants
              assign variant_title = variant.title | downcase | strip
              assign is_main_variant = false
              assign is_excluded = false

              for keyword in excluded_keywords
                if variant_title contains keyword
                  assign is_excluded = true
                  break
                endif
              endfor

              unless is_excluded
                for keyword in included_main_keywords
                  if variant_title contains keyword
                    assign is_main_variant = true
                    break
                  endif
                endfor

                if is_main_variant
                  assign found_main_variant = true
                  assign valid_main_variant_count = valid_main_variant_count | plus: 1

                  if collection_display_price == blank or variant.price < collection_display_price
                    assign collection_display_price = variant.price
                  endif
                endif
              endunless
            endfor

            if found_main_variant == false
              assign valid_main_variant_count = 0
              assign collection_display_price = blank

              for variant in product.variants
                assign variant_title = variant.title | downcase | strip
                assign is_excluded = false

                for keyword in excluded_keywords
                  if variant_title contains keyword
                    assign is_excluded = true
                    break
                  endif
                endfor

                unless is_excluded
                  assign valid_main_variant_count = valid_main_variant_count | plus: 1

                  if collection_display_price == blank or variant.price < collection_display_price
                    assign collection_display_price = variant.price
                  endif
                endunless
              endfor
            endif

            if collection_display_price == blank
              assign collection_display_price = product.price
            endif

            assign show_from_prefix = false
            if valid_main_variant_count > 1
              assign show_from_prefix = true
            endif
          %}

          <div class="grid-item reveal-item">
            <a href="{{ product.url }}" class="card-link">
              <div class="card-visual">
                {% if product.featured_image %}
                  <img
                    src="{{ product.featured_image | image_url: width: 1200 }}"
                    alt="{{ product.title | escape }}"
                    loading="lazy"
                  >
                {% else %}
                  <div class="card-placeholder"></div>
                {% endif %}

                <div class="card-overlay">
                  <div class="card-btn">EXPLORE</div>
                </div>

                {% if product.tags contains 'Mountain View' or product.tags contains 'Monastery' %}
                  <div class="route-indicator"><span class="dot-pulse"></span>EXCLUSIVE</div>
                {% endif %}
              </div>

              <div class="card-content">
                <div class="card-header">
                  <h3 class="product-title">{{ product.title }}</h3>
                  <div class="product-price">
                    {% if show_from_prefix %}
                      <span class="price-prefix">From </span>
                    {% endif %}
                    {{ collection_display_price | money_with_currency }}
                  </div>
                </div>
                <div class="product-info-row">
                  <span class="product-type">{{ product.type | default: 'Experience' }}</span>
                </div>
              </div>
            </a>
          </div>
        {% endfor %}
      </div>

      {% if paginate.pages > 1 %}
        <div class="luxury-pagination">
          {{ paginate | default_pagination }}
        </div>
      {% endif %}

      {% if is_shangrila_private_tours and paginate.current_page == 1 %}
        <section class="collection-copy-block collection-why-block">
          <div class="collection-copy-inner narrow">
            <h2 class="copy-heading">Why choose a private tour in Shangri-La?</h2>
            <div class="copy-richtext">
              <p>A private tour in Shangri-La allows you to experience the region with more comfort, flexibility, and time to adjust to the local rhythm. Instead of following a fixed group pace, you can spend more time in monasteries, old town streets, mountain viewpoints, and Tibetan cultural spaces that matter most to you. It also makes travel easier in a higher-altitude destination where a more thoughtful pace often creates a better overall experience.</p>
            </div>
          </div>
        </section>

        <section class="collection-copy-block collection-faq-block">
          <div class="collection-copy-inner">
            <h2 class="copy-heading">Shangri-La Private Tours FAQ</h2>

            <div class="faq-accordion">
              <div class="faq-acc-item is-open">
                <button type="button" class="faq-acc-trigger" aria-expanded="true">
                  <span class="faq-acc-question">How many days do you need in Shangri-La?</span>
                  <span class="faq-acc-icon" aria-hidden="true"></span>
                </button>
                <div class="faq-acc-panel" style="max-height: 260px;">
                  <div class="faq-acc-answer">
                    <p>For a first visit, 2 to 3 days in Shangri-La is often a good starting point. This allows time for Songzanlin Monastery, the old town area, and one or two nearby scenic or cultural experiences. If you prefer a slower pace or want to combine Shangri-La with Lijiang, Tiger Leaping Gorge, or other northwest Yunnan destinations, 4 to 6 days can work better.</p>
                  </div>
                </div>
              </div>

              <div class="faq-acc-item">
                <button type="button" class="faq-acc-trigger" aria-expanded="false">
                  <span class="faq-acc-question">Is Shangri-La suitable for first-time visitors to Yunnan?</span>
                  <span class="faq-acc-icon" aria-hidden="true"></span>
                </button>
                <div class="faq-acc-panel">
                  <div class="faq-acc-answer">
                    <p>Yes, but it is usually best suited to travelers who are interested in culture, mountain landscapes, and a more reflective travel pace. Because Shangri-La sits at a higher altitude than many other Yunnan destinations, it is often most comfortable when combined with lower-altitude stops such as Lijiang or Dali before arrival.</p>
                  </div>
                </div>
              </div>

              <div class="faq-acc-item">
                <button type="button" class="faq-acc-trigger" aria-expanded="false">
                  <span class="faq-acc-question">What can be included in a Shangri-La private tour?</span>
                  <span class="faq-acc-icon" aria-hidden="true"></span>
                </button>
                <div class="faq-acc-panel">
                  <div class="faq-acc-answer">
                    <p>Depending on the route, a Shangri-La private tour can include Songzanlin Monastery, Dukezong Old Town, Tibetan cultural landscapes, highland meadows, mountain viewpoints, and connections with Tiger Leaping Gorge, Lijiang, Meili Snow Mountain, or Dali. Different itineraries can be adjusted according to pace, altitude comfort, season, and personal interests.</p>
                  </div>
                </div>
              </div>

              <div class="faq-acc-item">
                <button type="button" class="faq-acc-trigger" aria-expanded="false">
                  <span class="faq-acc-question">Can Shangri-La be combined with Lijiang and Tiger Leaping Gorge?</span>
                  <span class="faq-acc-icon" aria-hidden="true"></span>
                </button>
                <div class="faq-acc-panel">
                  <div class="faq-acc-answer">
                    <p>Absolutely. Shangri-La is very often combined with Lijiang and Tiger Leaping Gorge as part of a classic northwest Yunnan route. This is one of the most popular ways to experience the region, as it balances cultural depth, dramatic landscapes, and a more gradual transition into higher-altitude travel.</p>
                  </div>
                </div>
              </div>

              <div class="faq-acc-item">
                <button type="button" class="faq-acc-trigger" aria-expanded="false">
                  <span class="faq-acc-question">Who are Shangri-La private tours best suited for?</span>
                  <span class="faq-acc-icon" aria-hidden="true"></span>
                </button>
                <div class="faq-acc-panel">
                  <div class="faq-acc-answer">
                    <p>Shangri-La private tours are especially well suited to culturally curious travelers, photographers, couples, small private groups, and visitors who want a more personal and comfortable experience in a highland destination. They are also a good choice for travelers who prefer flexibility over the pace of a standard group tour.</p>
                  </div>
                </div>
              </div>

              <div class="faq-acc-item">
                <button type="button" class="faq-acc-trigger" aria-expanded="false">
                  <span class="faq-acc-question">When is the best time to visit Shangri-La?</span>
                  <span class="faq-acc-icon" aria-hidden="true"></span>
                </button>
                <div class="faq-acc-panel">
                  <div class="faq-acc-answer">
                    <p>Shangri-La can be visited throughout the year, but spring and autumn are often especially rewarding for clear views, comfortable weather, and balanced travel conditions. Summer brings greener landscapes, while winter can feel quieter and more atmospheric. The best season depends on whether you prioritize scenery, cultural depth, photography, or a wider Yunnan route.</p>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </section>

        <script type="application/ld+json">
        {
          "@context": "https://schema.org",
          "@type": "FAQPage",
          "mainEntity": [
            {
              "@type": "Question",
              "name": "How many days do you need in Shangri-La?",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "For a first visit, 2 to 3 days in Shangri-La is often a good starting point. This allows time for Songzanlin Monastery, the old town area, and one or two nearby scenic or cultural experiences. If you prefer a slower pace or want to combine Shangri-La with Lijiang, Tiger Leaping Gorge, or other northwest Yunnan destinations, 4 to 6 days can work better."
              }
            },
            {
              "@type": "Question",
              "name": "Is Shangri-La suitable for first-time visitors to Yunnan?",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "Yes, but it is usually best suited to travelers who are interested in culture, mountain landscapes, and a more reflective travel pace. Because Shangri-La sits at a higher altitude than many other Yunnan destinations, it is often most comfortable when combined with lower-altitude stops such as Lijiang or Dali before arrival."
              }
            },
            {
              "@type": "Question",
              "name": "What can be included in a Shangri-La private tour?",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "Depending on the route, a Shangri-La private tour can include Songzanlin Monastery, Dukezong Old Town, Tibetan cultural landscapes, highland meadows, mountain viewpoints, and connections with Tiger Leaping Gorge, Lijiang, Meili Snow Mountain, or Dali. Different itineraries can be adjusted according to pace, altitude comfort, season, and personal interests."
              }
            },
            {
              "@type": "Question",
              "name": "Can Shangri-La be combined with Lijiang and Tiger Leaping Gorge?",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "Absolutely. Shangri-La is very often combined with Lijiang and Tiger Leaping Gorge as part of a classic northwest Yunnan route. This is one of the most popular ways to experience the region, as it balances cultural depth, dramatic landscapes, and a more gradual transition into higher-altitude travel."
              }
            },
            {
              "@type": "Question",
              "name": "Who are Shangri-La private tours best suited for?",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "Shangri-La private tours are especially well suited to culturally curious travelers, photographers, couples, small private groups, and visitors who want a more personal and comfortable experience in a highland destination. They are also a good choice for travelers who prefer flexibility over the pace of a standard group tour."
              }
            },
            {
              "@type": "Question",
              "name": "When is the best time to visit Shangri-La?",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "Shangri-La can be visited throughout the year, but spring and autumn are often especially rewarding for clear views, comfortable weather, and balanced travel conditions. Summer brings greener landscapes, while winter can feel quieter and more atmospheric. The best season depends on whether you prioritize scenery, cultural depth, photography, or a wider Yunnan route."
              }
            }
          ]
        }
        </script>

        <section class="collection-copy-block collection-outro-block">
          <div class="collection-copy-inner narrow">
            <h2 class="copy-heading">Explore Shangri-La tour ideas with Lynxtour</h2>
            <div class="copy-richtext">
              <p>If you are planning a journey through northwest Yunnan, this collection is designed to help you compare different Shangri-La private tour styles more easily. From shorter cultural stays to longer highland routes, Lynxtour offers private tour ideas that can be tailored around comfort, pace, altitude, and the places you most want to experience.</p>
            </div>
          </div>
        </section>
      {% endif %}

    {% endpaginate %}
  </div>
</section>

<style>
  #CollectionProductGrid{
    background-color:#050505;
    color:#fff;
    overflow:hidden;
    --header-safe: var(--page-first-copy-offset, 114px);
    --gold: #c4b5a6;
  }

  /* ===== HERO ===== */
  #CollectionProductGrid .coll-hero-compact{
    height: 56vh;
    min-height: 560px;
    position:relative;
    display:flex;
    align-items:center;
    justify-content:center;
    overflow:hidden;
    padding-top: var(--header-safe);
    box-sizing: border-box;
  }

  #CollectionProductGrid .hero-bg{
    position:absolute;
    inset:0;
    z-index:1;
  }

  #CollectionProductGrid .hero-img{
    width:100%;
    height:100%;
    object-fit:cover;
    object-position:center 22%;
    display:block;
    filter: brightness(0.88) contrast(1.06) saturate(1.03);
    transform: scale(1.02);
  }

  #CollectionProductGrid .hero-placeholder{
    width:100%;
    height:100%;
    background: #111;
  }

  #CollectionProductGrid .hero-overlay{
    position:absolute;
    inset:0;
    z-index:2;
    background:
      radial-gradient(1200px 420px at 50% 42%, rgba(0,0,0,0.18), rgba(0,0,0,0) 60%),
      linear-gradient(to bottom, rgba(5,5,5,0.12) 0%, rgba(5,5,5,0.75) 78%, rgba(5,5,5,1) 100%);
  }

  #CollectionProductGrid .hero-text-container{
    position:relative;
    z-index:10;
    width:100%;
    text-align:center;
    padding: 18px 20px 64px;
    box-sizing:border-box;
  }

  #CollectionProductGrid .hero-content{
    max-width: 920px;
    margin: 0 auto;
  }

  #CollectionProductGrid .coll-subtitle{
    color: #fff;
    font-size: 9px;
    letter-spacing: 0.8em;
    text-transform: uppercase;
    text-shadow: 0 2px 15px rgba(0,0,0,0.9);
  }

  #CollectionProductGrid .subtitle-line{
    width: 35px;
    height: 1px;
    background: var(--gold);
    opacity: 1;
    margin: 12px auto 0;
  }

  #CollectionProductGrid .coll-title{
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(3rem, 7vw, 4.5rem);
    font-weight: 300;
    font-style: italic;
    color: #fff;
    margin: 18px 0;
    letter-spacing: 0;
    text-shadow:
      0 4px 25px rgba(0,0,0,0.7),
      0 0 10px rgba(0,0,0,0.5),
      0 0 5px rgba(0,0,0,0.3);
  }

  #CollectionProductGrid .coll-desc{
    font-size: 14px;
    color: #fff;
    max-width: 560px;
    margin: 0 auto;
    line-height: 1.8;
    font-weight: 400;
    text-shadow: 0 2px 12px rgba(0,0,0,0.9);
    display: block;
    overflow: visible;
  }

  /* ===== META BAR ===== */
  #CollectionProductGrid .coll-container{
    max-width: 1400px;
    margin: 0 auto;
    padding: 42px 60px 100px;
  }

  #CollectionProductGrid .coll-meta-bar{
    display:flex;
    align-items:center;
    justify-content:center;
    gap:30px;
    margin-bottom: 48px;
    padding: 22px 0;
    border-top: 1px solid rgba(196,181,166,0.15);
    border-bottom: 1px solid rgba(196,181,166,0.15);
  }

  #CollectionProductGrid .meta-left,
  #CollectionProductGrid .meta-right{
    display:flex;
    align-items:baseline;
    gap:8px;
  }

  #CollectionProductGrid .meta-number{
    font-family:'Cormorant Garamond', serif;
    font-size: 26px;
    font-style: italic;
    color: var(--gold);
  }

  #CollectionProductGrid .meta-label{
    font-size: 9px;
    text-transform: uppercase;
    letter-spacing: 0.3em;
    color: rgba(255,255,255,0.45);
  }

  #CollectionProductGrid .meta-location{
    font-size: 10px;
    letter-spacing: 0.38em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.55);
    font-weight: 300;
  }

  #CollectionProductGrid .meta-divider{
    width: 1px;
    height: 20px;
    background: linear-gradient(to bottom, transparent, var(--gold), transparent);
    opacity: 0.65;
  }

  /* ===== COPY BLOCKS ===== */
  #CollectionProductGrid .collection-copy-block{
    border-top: 1px solid rgba(196, 181, 166, 0.12);
    padding-top: 42px;
    margin-bottom: 64px;
  }

  #CollectionProductGrid .collection-copy-inner{
    max-width: 980px;
    margin: 0 auto;
  }

  #CollectionProductGrid .collection-copy-inner.narrow{
    max-width: 860px;
  }

  #CollectionProductGrid .copy-heading{
    font-family:'Cormorant Garamond', serif;
    font-size: clamp(1.8rem, 4vw, 2.5rem);
    font-style:italic;
    font-weight:400;
    color:#fff;
    margin: 0 0 22px;
  }

  #CollectionProductGrid .copy-richtext p{
    color:#b4aca3;
    font-size:15px;
    line-height:1.9;
    margin:0 0 18px;
    letter-spacing:0.01em;
  }

  /* ===== FAQ Accordion ===== */
  #CollectionProductGrid .collection-faq-block{
    opacity: 0;
    transform: translateY(28px);
    transition: opacity 0.85s cubic-bezier(0.22, 1, 0.36, 1),
                transform 0.85s cubic-bezier(0.22, 1, 0.36, 1);
  }

  #CollectionProductGrid .collection-faq-block.is-visible{
    opacity: 1;
    transform: translateY(0);
  }

  #CollectionProductGrid .collection-faq-block .copy-heading{
    margin-bottom: 26px;
  }

  #CollectionProductGrid .faq-accordion{
    border-top: 1px solid rgba(196, 181, 166, 0.14);
  }

  #CollectionProductGrid .faq-acc-item{
    border-bottom: 1px solid rgba(196, 181, 166, 0.12);
    background: linear-gradient(
      180deg,
      rgba(255,255,255,0.01) 0%,
      rgba(255,255,255,0.005) 100%
    );
    transition: background 0.35s ease, border-color 0.35s ease;
  }

  #CollectionProductGrid .faq-acc-item:hover{
    background: linear-gradient(
      180deg,
      rgba(196,181,166,0.05) 0%,
      rgba(255,255,255,0.01) 100%
    );
  }

  #CollectionProductGrid .faq-acc-trigger{
    width: 100%;
    background: transparent;
    border: 0;
    color: #fff;
    padding: 22px 0;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    cursor: pointer;
    text-align: left;
  }

  #CollectionProductGrid .faq-acc-question{
    font-size: 17px;
    line-height: 1.5;
    font-weight: 400;
    color: #fff;
    transition: color 0.3s ease;
  }

  #CollectionProductGrid .faq-acc-item:hover .faq-acc-question,
  #CollectionProductGrid .faq-acc-item.is-open .faq-acc-question{
    color: #d8c8b8;
  }

  #CollectionProductGrid .faq-acc-icon{
    position: relative;
    width: 18px;
    height: 18px;
    flex: 0 0 18px;
  }

  #CollectionProductGrid .faq-acc-icon::before,
  #CollectionProductGrid .faq-acc-icon::after{
    content: "";
    position: absolute;
    top: 50%;
    left: 50%;
    background: #c4b5a6;
    transform: translate(-50%, -50%);
    transition: transform 0.28s ease, opacity 0.28s ease;
  }

  #CollectionProductGrid .faq-acc-icon::before{
    width: 18px;
    height: 1px;
  }

  #CollectionProductGrid .faq-acc-icon::after{
    width: 1px;
    height: 18px;
  }

  #CollectionProductGrid .faq-acc-item.is-open .faq-acc-icon::after{
    opacity: 0;
    transform: translate(-50%, -50%) scaleY(0.4);
  }

  #CollectionProductGrid .faq-acc-panel{
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.45s cubic-bezier(0.22, 1, 0.36, 1);
  }

  #CollectionProductGrid .faq-acc-answer{
    padding: 0 0 24px;
    max-width: 980px;
  }

  #CollectionProductGrid .faq-acc-answer p{
    color: #a59d94;
    font-size: 15px;
    line-height: 1.95;
    margin: 0;
  }

  /* ===== GRID ===== */
  #CollectionProductGrid .compact-grid{
    display:grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 50px 40px;
  }

  #CollectionProductGrid .reveal-item{
    opacity:0;
    transform: translateY(28px);
    transition: all 0.9s cubic-bezier(0.22, 1, 0.36, 1);
    will-change: transform, opacity;
  }

  #CollectionProductGrid .reveal-item.is-visible{
    opacity:1;
    transform: translateY(0);
  }

  /* ===== CARD ===== */
  #CollectionProductGrid .card-link{
    color:inherit;
    text-decoration:none;
    display:block;
  }

