<style>
  .km-wrapper {
    background-color: #0c0a09;
    color: #fff;
    padding: 100px 0;
    font-family: 'Montserrat', sans-serif;
  }

  .km-container {
    max-width: 1300px;
    margin: 0 auto;
    padding: 0 40px;
  }

  .km-header {
    text-align: center;
    padding: 120px 20px 160px;
    max-width: 1000px;
    margin: 0 auto;
    position: relative;
  }

  .km-subtitle {
    color: #fbbf24;
    font-family: 'Montserrat', sans-serif;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.6em;
    text-transform: uppercase;
    display: block;
    margin-bottom: 30px;
    opacity: 0.8;
  }

  .km-main-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(3rem, 7vw, 5.5rem);
    font-weight: 300;
    line-height: 1.1;
    margin-bottom: 45px;
    letter-spacing: 0.02em;
    color: #ffffff;
    font-style: italic;
  }

  .km-header::after {
    content: "";
    display: block;
    width: 1px;
    height: 60px;
    background: linear-gradient(to bottom, #fbbf24, transparent);
    margin: 0 auto 45px;
  }

  .km-intro-text {
    max-width: 700px;
    margin: 0 auto;
    color: #d6d3d1;
    line-height: 2;
    font-size: 16px;
    font-weight: 300;
    letter-spacing: 0.05em;
    font-family: 'Montserrat', sans-serif;
  }

  .km-section-eyebrow {
    display: block;
    color: #fbbf24;
    font-size: 10px;
    letter-spacing: 0.35em;
    text-transform: uppercase;
    margin-bottom: 14px;
  }

  .km-section-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(2rem, 4vw, 3.2rem);
    font-style: italic;
    font-weight: 300;
    line-height: 1.15;
    margin: 0 0 18px;
    color: #fff;
  }

  .km-section-intro {
    max-width: 760px;
    margin: 0 auto 0;
    color: #cfcac4;
    font-size: 14px;
    line-height: 1.9;
    letter-spacing: 0.02em;
    text-align: center;
  }

  .km-info-section,
  .km-related-section,
  .km-cta-section,
  .km-faq-section {
    padding: 0 0 120px;
    text-align: center;
  }

  .km-info-grid {
    margin-top: 48px;
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 24px;
  }

  .km-info-card {
    background: rgba(255,255,255,0.02);
    border: 1px solid rgba(251,191,36,0.12);
    padding: 30px 28px;
    text-align: left;
    min-height: 100%;
  }

  .km-info-tag {
    display: block;
    color: #fbbf24;
    font-size: 10px;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    margin-bottom: 14px;
  }

  .km-info-heading {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.9rem;
    font-style: italic;
    font-weight: 300;
    margin: 0 0 14px;
    color: #fff;
  }

  .km-info-desc {
    color: #b9b2ab;
    font-size: 13px;
    line-height: 1.85;
    letter-spacing: 0.02em;
  }

  .km-stories {
    display: flex;
    flex-direction: column;
    gap: 150px;
    padding-bottom: 120px;
  }

  .km-story-row {
    display: flex;
    align-items: center;
    gap: 80px;
    flex-direction: row;
  }

  .row-reverse {
    flex-direction: row-reverse;
  }

  .km-story-image {
    flex: 1.2;
    position: relative;
  }

  .img-reveal-wrapper {
    overflow: hidden;
    aspect-ratio: 4/5;
    position: relative;
    background-color: #1c1917;
  }

  .img-reveal-wrapper::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, rgba(0,0,0,0) 60%, rgba(0,0,0,0.3) 100%);
    pointer-events: none;
  }

  .km-story-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: contrast(1.05) brightness(0.9);
    transition: transform 2s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .km-story-row:hover img {
    transform: scale(1.08);
    filter: contrast(1.1) brightness(0.95);
  }

  .km-story-content {
    flex: 1;
    padding: 20px 0;
  }

  .story-tag {
    color: #fbbf24;
    font-size: 10px;
    letter-spacing: 3px;
    text-transform: uppercase;
    margin-bottom: 20px;
    display: block;
  }

  .story-heading {
    font-family: 'Cormorant Garamond', serif;
    font-style: italic;
    font-size: 2.5rem;
    letter-spacing: 0.05em;
    margin-bottom: 24px;
  }

  .story-desc {
    font-family: 'Montserrat', sans-serif;
    font-size: 13px;
    line-height: 1.8;
    letter-spacing: 0.03em;
    color: #a8a29e;
    max-width: 450px;
    font-weight: 300;
  }

  .km-inline-link,
  .km-related-link {
    color: #fff;
    text-decoration: none;
    font-size: 11px;
    letter-spacing: 2px;
    display: inline-flex;
    flex-direction: column;
    gap: 8px;
    margin-top: 24px;
  }

  .km-inline-link .line,
  .km-related-link .line {
    width: 30px;
    height: 1px;
    background: #fbbf24;
    transition: 0.4s;
  }

  .km-inline-link:hover .line,
  .km-related-link:hover .line {
    width: 60px;
  }

  .km-related-grid {
    margin-top: 48px;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 24px;
    text-align: left;
  }

  .km-related-card {
    background: rgba(255,255,255,0.02);
    border: 1px solid rgba(255,255,255,0.08);
    padding: 28px 24px;
    min-height: 100%;
  }

  .km-related-tag {
    display: block;
    color: #fbbf24;
    font-size: 10px;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    margin-bottom: 14px;
  }

  .km-related-heading {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.9rem;
    font-style: italic;
    font-weight: 300;
    margin: 0 0 14px;
    color: #fff;
  }

  .km-related-desc {
    color: #b9b2ab;
    font-size: 13px;
    line-height: 1.85;
    letter-spacing: 0.02em;
  }

  .km-cta-shell {
    max-width: 980px;
    margin: 48px auto 0;
    padding: 46px 42px;
    border: 1px solid rgba(251,191,36,0.18);
    background:
      linear-gradient(180deg, rgba(255,255,255,0.02) 0%, rgba(255,255,255,0.008) 100%),
      radial-gradient(circle at top right, rgba(251,191,36,0.08), transparent 35%);
  }

  .km-cta-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(2rem, 4vw, 3rem);
    font-style: italic;
    font-weight: 300;
    line-height: 1.12;
    margin: 0 0 18px;
    color: #fff;
  }

  .km-cta-desc {
    max-width: 760px;
    margin: 0 auto;
    color: #cfcac4;
    font-size: 14px;
    line-height: 1.9;
    letter-spacing: 0.02em;
  }

  .km-cta-actions {
    display: flex;
    justify-content: center;
    gap: 14px;
    flex-wrap: wrap;
    margin-top: 30px;
  }

  .km-cta-btn {
    min-width: 210px;
    padding: 14px 22px;
    text-decoration: none;
    font-size: 11px;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    transition: 0.3s ease;
  }

  .km-cta-btn.primary {
    background: #fbbf24;
    color: #111;
    border: 1px solid #fbbf24;
  }

  .km-cta-btn.primary:hover {
    background: #ffcb47;
    border-color: #ffcb47;
  }

  .km-cta-btn.secondary {
    background: transparent;
    color: #fff;
    border: 1px solid rgba(255,255,255,0.18);
  }

  .km-cta-btn.secondary:hover {
    border-color: rgba(251,191,36,0.5);
    color: #fbbf24;
  }

  .km-faq-list {
    max-width: 900px;
    margin: 48px auto 0;
    text-align: left;
  }

  .km-faq-item {
    border-top: 1px solid rgba(255,255,255,0.12);
    padding: 0;
  }

  .km-faq-item:last-child {
    border-bottom: 1px solid rgba(255,255,255,0.12);
  }

  .km-faq-question {
    list-style: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    padding: 24px 0;
    font-size: 15px;
    color: #f5f5f4;
    letter-spacing: 0.02em;
  }

  .km-faq-question::-webkit-details-marker {
    display: none;
  }

  .km-faq-icon {
    width: 14px;
    height: 14px;
    position: relative;
    flex: 0 0 14px;
  }

  .km-faq-icon::before,
  .km-faq-icon::after {
    content: "";
    position: absolute;
    background: #fbbf24;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
    transition: 0.25s ease;
  }

  .km-faq-icon::before {
    width: 14px;
    height: 1px;
  }

  .km-faq-icon::after {
    width: 1px;
    height: 14px;
  }

  .km-faq-item[open] .km-faq-icon::after {
    opacity: 0;
  }

  .km-faq-answer {
    color: #b9b2ab;
    font-size: 13px;
    line-height: 1.9;
    letter-spacing: 0.02em;
    padding: 0 0 24px;
    max-width: 760px;
  }

  @media (max-width: 990px) {
    .km-container {
      padding: 0 24px;
    }

    .km-story-row,
    .row-reverse {
      flex-direction: column;
      gap: 40px;
    }

    .km-header {
      padding: 80px 20px 100px;
      margin-bottom: 40px;
    }

    .km-main-title {
      font-size: 2.8rem;
    }

    .km-intro-text {
      font-size: 14px;
      line-height: 1.8;
    }

    .km-header::after {
      height: 40px;
    }

    .km-stories {
      gap: 80px;
      padding-bottom: 100px;
    }

    .km-info-grid,
    .km-related-grid {
      grid-template-columns: 1fr;
    }

    .km-cta-shell {
      padding: 34px 22px;
    }

    .km-cta-actions {
      flex-direction: column;
      align-items: stretch;
    }

    .km-cta-btn {
      min-width: 0;
      width: 100%;
      text-align: center;
    }
  }
</style>

<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,500;1,300&family=Montserrat:wght@300;400;600&display=swap" rel="stylesheet">

<div class="km-wrapper" id="section-{{ section.id }}">
  {% assign info_blocks = section.blocks | where: 'type', 'info_item' %}
  {% assign story_blocks = section.blocks | where: 'type', 'story' %}
  {% assign related_blocks = section.blocks | where: 'type', 'related_tour' %}
  {% assign faq_blocks = section.blocks | where: 'type', 'faq_item' %}

  <div class="km-container">
    <header class="km-header">
      {% if section.settings.sub_title != blank %}
        <span class="km-subtitle">{{ section.settings.sub_title }}</span>
      {% endif %}
      {% if section.settings.main_title != blank %}
        <h1 class="km-main-title">{{ section.settings.main_title }}</h1>
      {% endif %}
      {% if section.settings.intro_text != blank %}
        <div class="km-intro-text">
          {{ section.settings.intro_text | newline_to_br }}
        </div>
      {% endif %}
    </header>

    {% if info_blocks.size > 0 %}
      <section class="km-info-section">
        {% if section.settings.info_section_eyebrow != blank %}
          <span class="km-section-eyebrow">{{ section.settings.info_section_eyebrow }}</span>
        {% endif %}
        {% if section.settings.info_section_title != blank %}
          <h2 class="km-section-title">{{ section.settings.info_section_title }}</h2>
        {% endif %}
        {% if section.settings.info_section_intro != blank %}
          <div class="km-section-intro">{{ section.settings.info_section_intro | newline_to_br }}</div>
        {% endif %}

        <div class="km-info-grid">
          {% for block in info_blocks %}
            <article class="km-info-card" {{ block.shopify_attributes }}>
              {% if block.settings.tag != blank %}
                <span class="km-info-tag">{{ block.settings.tag }}</span>
              {% endif %}
              {% if block.settings.heading != blank %}
                <h3 class="km-info-heading">{{ block.settings.heading }}</h3>
              {% endif %}
              {% if block.settings.description != blank %}
                <div class="km-info-desc">{{ block.settings.description | newline_to_br }}</div>
              {% endif %}
            </article>
          {% endfor %}
        </div>
      </section>
    {% endif %}

    {% if story_blocks.size > 0 %}
      <div class="km-stories">
        {% for block in story_blocks %}
          <div class="km-story-row {% cycle '', 'row-reverse' %}" {{ block.shopify_attributes }}>
            <div class="km-story-image">
              <div class="img-reveal-wrapper">
                {% if block.settings.image != blank %}
                  <img src="{{ block.settings.image | image_url: width: 1200 }}" alt="{{ block.settings.heading | escape }}" loading="lazy">
                {% else %}
                  {{ 'lifestyle-2' | placeholder_svg_tag: 'placeholder-svg' }}
                {% endif %}
              </div>
            </div>
            <div class="km-story-content">
              {% if block.settings.tag != blank %}
                <span class="story-tag">{{ block.settings.tag }}</span>
              {% endif %}
              {% if block.settings.heading != blank %}
                <h2 class="story-heading">{{ block.settings.heading }}</h2>
              {% endif %}
              {% if block.settings.description != blank %}
                <div class="story-desc">{{ block.settings.description | newline_to_br }}</div>
              {% endif %}
              {% liquid
                assign story_cta_label = block.settings.button_label | strip
                assign story_cta_label_downcase = story_cta_label | downcase
                if story_cta_label_downcase == 'read the guide' or story_cta_label_downcase == 'read more'
                  if block.settings.heading != blank
                    assign story_cta_label = 'Read the ' | append: block.settings.heading | append: ' guide'
                  else
                    assign story_cta_label = 'Read the guide'
                  endif
                endif
              %}
              {% if story_cta_label != blank and block.settings.button_link != blank %}
                <a href="{{ block.settings.button_link }}" class="km-inline-link">
                  {{ story_cta_label }}
                  <span class="line"></span>
                </a>
              {% endif %}
            </div>
          </div>
        {% endfor %}
      </div>
    {% endif %}

    {% if related_blocks.size > 0 %}
      <section class="km-related-section">
        {% if section.settings.related_section_eyebrow != blank %}
          <span class="km-section-eyebrow">{{ section.settings.related_section_eyebrow }}</span>
        {% endif %}
        {% if section.settings.related_section_title != blank %}
          <h2 class="km-section-title">{{ section.settings.related_section_title }}</h2>
        {% endif %}
        {% if section.settings.related_section_intro != blank %}
          <div class="km-section-intro">{{ section.settings.related_section_intro | newline_to_br }}</div>
        {% endif %}

        <div class="km-related-grid">
          {% for block in related_blocks %}
            <article class="km-related-card" {{ block.shopify_attributes }}>
              {% if block.settings.tag != blank %}
                <span class="km-related-tag">{{ block.settings.tag }}</span>
              {% endif %}
              {% if block.settings.heading != blank %}
                <h3 class="km-related-heading">{{ block.settings.heading }}</h3>
              {% endif %}
              {% if block.settings.description != blank %}
                <div class="km-related-desc">{{ block.settings.description | newline_to_br }}</div>
              {% endif %}
              {% liquid
                assign related_cta_label = block.settings.button_label | strip
                assign related_cta_label_downcase = related_cta_label | downcase
                if related_cta_label_downcase == 'view tour' or related_cta_label_downcase == 'view journey' or related_cta_label_downcase == 'learn more'
                  if block.settings.heading != blank
                    assign related_cta_label = 'Explore ' | append: block.settings.heading
                  else
                    assign related_cta_label = 'See tour details'
                  endif
                endif
              %}
              {% if related_cta_label != blank and block.settings.button_link != blank %}
                <a href="{{ block.settings.button_link }}" class="km-related-link">
                  {{ related_cta_label }}
                  <span class="line"></span>
                </a>
              {% endif %}
            </article>
          {% endfor %}
        </div>
      </section>
    {% endif %}

    <section class="km-cta-section">
      {% if section.settings.cta_eyebrow != blank %}
        <span class="km-section-eyebrow">{{ section.settings.cta_eyebrow }}</span>
      {% endif %}
      {% if section.settings.cta_title != blank %}
        <h2 class="km-section-title">{{ section.settings.cta_title }}</h2>
      {% endif %}
      {% if section.settings.cta_intro != blank %}
        <div class="km-section-intro">{{ section.settings.cta_intro | newline_to_br }}</div>
      {% endif %}

      <div class="km-cta-shell">
        {% if section.settings.cta_box_title != blank %}
          <h3 class="km-cta-title">{{ section.settings.cta_box_title }}</h3>
        {% endif %}
        {% if section.settings.cta_box_desc != blank %}
          <div class="km-cta-desc">{{ section.settings.cta_box_desc | newline_to_br }}</div>
        {% endif %}

        <div class="km-cta-actions">
          {% if section.settings.cta_primary_label != blank and section.settings.cta_primary_url != blank %}
            <a href="{{ section.settings.cta_primary_url }}" class="km-cta-btn primary">{{ section.settings.cta_primary_label }}</a>
          {% endif %}
          {% if section.settings.cta_secondary_label != blank and section.settings.cta_secondary_url != blank %}
            <a href="{{ section.settings.cta_secondary_url }}" class="km-cta-btn secondary">{{ section.settings.cta_secondary_label }}</a>
          {% endif %}
        </div>
      </div>
    </section>

    {% if faq_blocks.size > 0 %}
      <section class="km-faq-section">
        {% if section.settings.faq_section_eyebrow != blank %}
          <span class="km-section-eyebrow">{{ section.settings.faq_section_eyebrow }}</span>
        {% endif %}
        {% if section.settings.faq_section_title != blank %}
          <h2 class="km-section-title">{{ section.settings.faq_section_title }}</h2>
        {% endif %}
        {% if section.settings.faq_section_intro != blank %}
          <div class="km-section-intro">{{ section.settings.faq_section_intro | newline_to_br }}</div>
        {% endif %}

        <div class="km-faq-list">
          {% for block in faq_blocks %}
            <details class="km-faq-item" {{ block.shopify_attributes }}>
              <summary class="km-faq-question">
                <span>{{ block.settings.question }}</span>
                <span class="km-faq-icon"></span>
              </summary>
              <div class="km-faq-answer">
                {{ block.settings.answer | newline_to_br }}
              </div>
            </details>
          {% endfor %}
        </div>
      </section>
    {% endif %}
  </div>
</div>

{% if faq_blocks.size > 0 %}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {% for block in faq_blocks %}
        {
          "@type": "Question",
          "name": {{ block.settings.question | strip_html | strip | json }},
          "acceptedAnswer": {
            "@type": "Answer",
            "text": {{ block.settings.answer | strip_html | strip | json }}
          }
        }{% unless forloop.last %},{% endunless %}
      {% endfor %}
    ]
  }
  </script>
{% endif %}

{% if page %}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "name": "Home",
        "item": {{ request.origin | append: '/' | json }}
      },
      {
        "@type": "ListItem",
        "position": 2,
        "name": {{ page.title | json }},
        "item": {{ request.origin | append: page.url | json }}
      }
    ]
  }
  </script>
{% endif %}

{% schema %}
{
  "name": "Kunming Page Stories Pro",
  "settings": [
    { "type": "text", "id": "main_title", "label": "主标题", "default": "Kunming Travel Guide" },
    { "type": "text", "id": "sub_title", "label": "副标题", "default": "THE CITY OF ETERNAL BLOOM" },
    { "type": "textarea", "id": "intro_text", "label": "引言描述", "default": "Kunming is the gateway to Yunnan, where mild weather, local culture, lakeside scenery, and easy day trips come together in one relaxed city." },

    { "type": "text", "id": "info_section_eyebrow", "label": "实用信息区眉题", "default": "PLAN YOUR JOURNEY" },
    { "type": "text", "id": "info_section_title", "label": "实用信息区标题", "default": "Know Kunming at a Glance" },
    { "type": "textarea", "id": "info_section_intro", "label": "实用信息区简介", "default": "A quick guide to why Kunming matters, what to see, when to go, and how to plan your stay." },

    { "type": "text", "id": "related_section_eyebrow", "label": "相关线路区眉题", "default": "RELATED TOURS" },
    { "type": "text", "id": "related_section_title", "label": "相关线路区标题", "default": "Continue Your Yunnan Journey" },
    { "type": "textarea", "id": "related_section_intro", "label": "相关线路区简介", "default": "Explore handpicked private tours and routes that connect naturally with Kunming." },

    { "type": "text", "id": "cta_eyebrow", "label": "CTA区眉题", "default": "PLAN YOUR PRIVATE TRIP" },
    { "type": "text", "id": "cta_title", "label": "CTA区标题", "default": "Turn This Guide Into a Real Journey" },
    { "type": "textarea", "id": "cta_intro", "label": "CTA区简介", "default": "If Kunming feels like the right starting point for your Yunnan route, move from the guide into a private journey shaped around city comfort, easy pacing, and nearby highlights." },
    { "type": "text", "id": "cta_box_title", "label": "CTA主标题", "default": "Plan a Private Trip to Kunming" },
