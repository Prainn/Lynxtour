<script>
document.addEventListener('DOMContentLoaded', function() {
  const root = document.getElementById('CollectionProductGrid');
  if (!root) return;

  const items = Array.from(root.querySelectorAll('.reveal-item'));
  const grid = root.querySelector('.compact-grid');
  const desktopCols = parseInt(grid?.getAttribute('data-cols') || '3', 10);

  if (items.length) {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          const isMobile = window.innerWidth <= 990;
          const cols = isMobile ? 2 : desktopCols;
          const i = items.indexOf(entry.target);
          const delay = (i % cols) * 140;
          setTimeout(() => entry.target.classList.add('is-visible'), delay);
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.12, rootMargin: '0px 0px -60px 0px' });

    items.forEach(item => observer.observe(item));
  }

  const faqBlock = root.querySelector('.collection-faq-block');
  if (faqBlock) {
    const faqBlockObserver = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          faqBlock.classList.add('is-visible');
          faqBlockObserver.unobserve(entry.target);
        }
      });
    }, {
      threshold: 0.16,
      rootMargin: '0px 0px -70px 0px'
    });

    faqBlockObserver.observe(faqBlock);
  }

  const accordionItems = root.querySelectorAll('.faq-acc-item');

  accordionItems.forEach((item) => {
    const trigger = item.querySelector('.faq-acc-trigger');
    const panel = item.querySelector('.faq-acc-panel');

    if (!trigger || !panel) return;

    if (item.classList.contains('is-open')) {
      panel.style.maxHeight = panel.scrollHeight + 'px';
      trigger.setAttribute('aria-expanded', 'true');
    } else {
      panel.style.maxHeight = '0px';
      trigger.setAttribute('aria-expanded', 'false');
    }

    trigger.addEventListener('click', () => {
      const isOpen = item.classList.contains('is-open');

      accordionItems.forEach((otherItem) => {
        const otherTrigger = otherItem.querySelector('.faq-acc-trigger');
        const otherPanel = otherItem.querySelector('.faq-acc-panel');

        otherItem.classList.remove('is-open');
        if (otherTrigger) otherTrigger.setAttribute('aria-expanded', 'false');
        if (otherPanel) otherPanel.style.maxHeight = '0px';
      });

      if (!isOpen) {
        item.classList.add('is-open');
        trigger.setAttribute('aria-expanded', 'true');
        panel.style.maxHeight = panel.scrollHeight + 'px';
      }
    });
  });

  window.addEventListener('resize', () => {
    root.querySelectorAll('.faq-acc-item.is-open .faq-acc-panel').forEach((panel) => {
      panel.style.maxHeight = panel.scrollHeight + 'px';
    });
  });
});
</script>
