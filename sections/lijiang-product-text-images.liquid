<script>
(function () {
  const SECTION_ID = '{{ section.id }}';

  function initFlipBook() {
    const root = document.getElementById('shopify-section-' + SECTION_ID) || document;
    const container = root.querySelector('#flip-book-' + SECTION_ID);
    if (!container) return;
    if (container.dataset.flipInit === '1') return;

    const pages = container.querySelectorAll('.mag-page');
    if (!pages.length) return;
    if (!(window.St && window.St.PageFlip)) return;

    try {
      const pageFlip = new St.PageFlip(container, {
        width: 550,
        height: 770,
        size: 'stretch',
        minWidth: 280,
        maxWidth: 1000,
        minHeight: 350,
        maxHeight: 1400,
        maxShadowOpacity: 0.6,
        showCover: false,
        usePortrait: true,
        mobileScrollSupport: true,
        autoSize: true
      });

      pageFlip.loadFromHTML(pages);
      container.dataset.flipInit = '1';
      container.classList.add('is-initialized');
      container._pageFlipInstance = pageFlip;

      const prevBtn = root.querySelector('#mag-prev-' + SECTION_ID);
      const nextBtn = root.querySelector('#mag-next-' + SECTION_ID);
      const indicator = root.querySelector('#mag-current-' + SECTION_ID);

      if (prevBtn) prevBtn.onclick = () => pageFlip.flipPrev();
      if (nextBtn) nextBtn.onclick = () => pageFlip.flipNext();

      pageFlip.on('flip', (e) => {
        if (indicator) indicator.textContent = String(e.data + 1);
      });

      if (indicator) indicator.textContent = '1';
    } catch (err) {
      console.error('[FlipBook] init failed:', err);
    }
  }

  function initContentToggle() {
    const root = document.getElementById('shopify-section-' + SECTION_ID) || document;
    const content = root.querySelector('#mag-rich-' + SECTION_ID);
    const button = root.querySelector('#mag-toggle-' + SECTION_ID);

    if (!content || !button) return;

    const updateToggleState = () => {
      const expanded = content.classList.contains('is-expanded');
      button.setAttribute('aria-expanded', expanded ? 'true' : 'false');
      button.textContent = expanded ? 'Show Less' : 'Read More';

      if (expanded) {
        button.style.display = 'inline-flex';
        return;
      }

      requestAnimationFrame(() => {
        const needsToggle = content.scrollHeight > content.clientHeight + 6;
        button.style.display = needsToggle ? 'inline-flex' : 'none';
      });
    };

    button.onclick = () => {
      content.classList.toggle('is-expanded');
      updateToggleState();
    };

    updateToggleState();

    let resizeTimer = null;
    window.addEventListener('resize', () => {
      clearTimeout(resizeTimer);
      resizeTimer = setTimeout(() => {
        updateToggleState();
      }, 120);
    });
  }

  let i = 0;
  const t = setInterval(() => {
    i++;
    if (window.St && window.St.PageFlip) {
      clearInterval(t);
      setTimeout(() => {
        initFlipBook();
        initContentToggle();
      }, 50);
    } else if (i > 100) {
      clearInterval(t);
      initContentToggle();
    }
  }, 100);

  document.addEventListener('DOMContentLoaded', function () {
    initContentToggle();
  });

  document.addEventListener('shopify:section:load', function (evt) {
    const target = evt.target;
    if (!target) return;

    if (target.querySelector && target.querySelector('#flip-book-' + SECTION_ID)) {
      const c = target.querySelector('#flip-book-' + SECTION_ID);
      if (c) delete c.dataset.flipInit;

      setTimeout(() => {
        requestAnimationFrame(() => {
          initFlipBook();
          initContentToggle();
        });
      }, 50);
    }
  });
})();
</script>

