<style>
  .lj-wrapper {
    background-color: #0b0b0b;
    color: #fff;
    padding: 60px 0;
    overflow: hidden;
    font-family: 'Montserrat', sans-serif;
  }

  .lj-container {
    max-width: 1300px;
    margin: 0 auto;
    padding: 0 40px;
  }

  .lj-header {
    text-align: center;
    padding: 120px 20px 120px;
    max-width: 1000px;
    margin: 0 auto;
    position: relative;
  }

  .lj-subtitle {
    color: #c4b5a6;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.6em;
    text-transform: uppercase;
    display: block;
    margin-bottom: 30px;
    opacity: 0.8;
  }

  .lj-main-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(3rem, 7vw, 5rem);
    font-weight: 300;
    line-height: 1.1;
    margin-bottom: 45px;
    letter-spacing: 0.05em;
    color: #ffffff;
    font-style: italic;
  }

  .lj-header::after {
    content: "";
    display: block;
    width: 1px;
    height: 60px;
    background: linear-gradient(to bottom, #c4b5a6, transparent);
    margin: 0 auto 45px;
  }

  .lj-intro-text {
    max-width: 700px;
    margin: 0 auto;
    color: #d6d3d1;
    line-height: 2;
    font-size: 16px;
    font-weight: 300;
    letter-spacing: 0.05em;
  }

  .lj-header-actions {
    display: flex;
    justify-content: center;
    gap: 14px;
    flex-wrap: wrap;
    margin-top: 34px;
  }

  .lj-top-btn {
    min-width: 210px;
    padding: 14px 22px;
    text-decoration: none;
    font-size: 11px;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    transition: 0.3s ease;
    border: 1px solid transparent;
  }

  .lj-top-btn.primary {
    background: #d4af37;
    color: #111;
    border-color: #d4af37;
  }

  .lj-top-btn.primary:hover {
    background: #e3bf4e;
    border-color: #e3bf4e;
  }

  .lj-top-btn.whatsapp,
  .lj-top-btn.secondary {
    background: transparent;
    color: #fff;
    border-color: rgba(255,255,255,0.18);
  }

  .lj-top-btn.whatsapp:hover,
  .lj-top-btn.secondary:hover {
    border-color: rgba(212,175,55,0.5);
    color: #d4af37;
  }

  .lj-section-eyebrow {
    display: block;
    color: #c4b5a6;
    font-size: 10px;
    letter-spacing: 0.35em;
    text-transform: uppercase;
    margin-bottom: 14px;
  }

  .lj-section-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(2rem, 4vw, 3.2rem);
    font-style: italic;
    font-weight: 300;
    line-height: 1.15;
    margin: 0 0 18px;
    color: #fff;
  }

  .lj-section-intro {
    max-width: 760px;
    margin: 0 auto;
    color: #cfcac4;
    font-size: 14px;
    line-height: 1.9;
    letter-spacing: 0.02em;
    text-align: center;
  }

  .lj-info-section,
  .lj-route-section,
  .lj-related-section,
  .lj-cta-section,
  .lj-faq-section {
    padding: 0 0 120px;
    text-align: center;
  }

  .lj-info-grid,
  .lj-route-grid {
    margin-top: 48px;
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 24px;
  }

  .lj-info-card,
  .lj-route-card {
    background: rgba(255,255,255,0.02);
    border: 1px solid rgba(196,181,166,0.12);
    padding: 30px 28px;
    text-align: left;
    min-height: 100%;
  }

  .lj-info-tag,
  .lj-route-tag,
  .lj-related-tag {
    display: block;
    color: #d4af37;
    font-size: 10px;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    margin-bottom: 14px;
  }

  .lj-info-heading,
  .lj-route-heading,
  .lj-related-heading {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.9rem;
    font-style: italic;
    font-weight: 300;
    margin: 0 0 14px;
    color: #fff;
  }

  .lj-info-desc,
  .lj-route-desc,
  .lj-related-desc {
    color: #b9b2ab;
    font-size: 13px;
    line-height: 1.85;
    letter-spacing: 0.02em;
  }

  .lj-route-desc a {
    color: #f1d995;
    text-decoration: none;
    border-bottom: 1px solid rgba(241, 217, 149, 0.35);
  }

  .lj-route-desc a:hover {
    color: #d4af37;
    border-bottom-color: rgba(212, 175, 55, 0.7);
  }

  .lj-route-link,
  .lj-inline-link,
  .lj-related-link {
    color: #fff;
    text-decoration: none;
    font-size: 11px;
    letter-spacing: 2px;
    display: inline-flex;
    flex-direction: column;
    gap: 8px;
    margin-top: 24px;
  }

  .lj-route-link .line,
  .lj-inline-link .line,
  .lj-related-link .line {
    width: 30px;
    height: 1px;
    background: #d4af37;
    transition: 0.4s;
  }

  .lj-route-link:hover .line,
  .lj-inline-link:hover .line,
  .lj-related-link:hover .line {
    width: 60px;
  }

  .lj-stories {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 0 120px;
    display: flex;
    flex-direction: column;
    gap: 150px;
  }

  .lj-story-row {
    display: flex;
    align-items: center;
    gap: 80px;
    flex-direction: row;
  }

  .lj-story-row.row-reverse {
    flex-direction: row-reverse;
  }

  .lj-story-image {
    flex: 1.2;
    position: relative;
  }

  .lj-story-content {
    flex: 1;
    padding: 20px 0;
  }

  .img-reveal-wrapper {
    position: relative;
    aspect-ratio: 4/5;
    overflow: hidden;
    background-color: #1a1a1a;
  }

  .img-reveal-wrapper::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, rgba(0,0,0,0) 60%, rgba(0,0,0,0.28) 100%);
    pointer-events: none;
  }

  .img-reveal-wrapper img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: brightness(0.8) sepia(0.1);
    transition: transform 2s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .lj-story-row:hover img {
    transform: scale(1.05);
  }

  .story-tag {
    color: #d4af37;
    font-size: 10px;
    letter-spacing: 3px;
    text-transform: uppercase;
    margin-bottom: 20px;
    display: block;
  }

  .story-heading {
    font-family: 'Cormorant Garamond', serif;
    font-style: italic;
    font-size: 2.5rem;
    letter-spacing: 0.05em;
    margin-bottom: 24px;
  }

  .story-desc {
    font-family: 'Montserrat', sans-serif;
    font-size: 13px;
    line-height: 1.8;
    letter-spacing: 0.03em;
    color: #a8a29e;
    max-width: 450px;
    font-weight: 300;
  }

  .lj-related-grid {
    margin-top: 48px;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 24px;
    text-align: left;
  }

  .lj-related-card {
    background: rgba(255,255,255,0.02);
    border: 1px solid rgba(255,255,255,0.08);
    padding: 28px 24px;
    min-height: 100%;
  }

  .lj-cta-shell {
    max-width: 980px;
    margin: 48px auto 0;
    padding: 46px 42px;
    border: 1px solid rgba(212,175,55,0.16);
    background:
      linear-gradient(180deg, rgba(255,255,255,0.02) 0%, rgba(255,255,255,0.008) 100%),
      radial-gradient(circle at top right, rgba(212,175,55,0.08), transparent 35%);
  }

  .lj-cta-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(2rem, 4vw, 3rem);
    font-style: italic;
    font-weight: 300;
    line-height: 1.12;
    margin: 0 0 18px;
    color: #fff;
  }

  .lj-cta-desc {
    max-width: 760px;
    margin: 0 auto;
    color: #cfcac4;
    font-size: 14px;
    line-height: 1.9;
    letter-spacing: 0.02em;
  }

  .lj-cta-actions {
    display: flex;
    justify-content: center;
    gap: 14px;
    flex-wrap: wrap;
    margin-top: 30px;
  }

  .lj-cta-btn {
    min-width: 210px;
    padding: 14px 22px;
    text-decoration: none;
    font-size: 11px;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    transition: 0.3s ease;
  }

  .lj-cta-btn.primary {
    background: #d4af37;
    color: #111;
    border: 1px solid #d4af37;
  }

  .lj-cta-btn.primary:hover {
    background: #e3bf4e;
    border-color: #e3bf4e;
  }

  .lj-cta-btn.whatsapp,
  .lj-cta-btn.secondary {
    background: transparent;
    color: #fff;
    border: 1px solid rgba(255,255,255,0.18);
  }

  .lj-cta-btn.whatsapp:hover,
  .lj-cta-btn.secondary:hover {
    border-color: rgba(212,175,55,0.5);
    color: #d4af37;
  }

  .lj-faq-list {
    max-width: 900px;
    margin: 48px auto 0;
    text-align: left;
  }

  .lj-faq-item {
    border-top: 1px solid rgba(255,255,255,0.12);
    padding: 0;
  }

  .lj-faq-item:last-child {
    border-bottom: 1px solid rgba(255,255,255,0.12);
  }

  .lj-faq-question {
    list-style: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    padding: 24px 0;
    font-size: 15px;
    color: #f5f5f4;
    letter-spacing: 0.02em;
  }

  .lj-faq-question::-webkit-details-marker {
    display: none;
  }

  .lj-faq-icon {
    width: 14px;
    height: 14px;
    position: relative;
    flex: 0 0 14px;
  }

  .lj-faq-icon::before,
  .lj-faq-icon::after {
    content: "";
    position: absolute;
    background: #d4af37;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
    transition: 0.25s ease;
  }

  .lj-faq-icon::before {
    width: 14px;
    height: 1px;
  }

  .lj-faq-icon::after {
    width: 1px;
    height: 14px;
  }

  .lj-faq-item[open] .lj-faq-icon::after {
    opacity: 0;
  }

  .lj-faq-answer {
    color: #b9b2ab;
    font-size: 13px;
    line-height: 1.9;
    letter-spacing: 0.02em;
    padding: 0 0 24px;
    max-width: 760px;
  }

  @media (max-width: 990px) {
    .lj-container {
      padding: 0 24px;
    }

    .lj-header {
      padding: 80px 20px 100px;
    }

    .lj-main-title {
      font-size: 2.8rem;
    }

    .lj-intro-text {
      font-size: 14px;
      line-height: 1.8;
    }

    .lj-story-row,
    .lj-story-row.row-reverse {
      flex-direction: column;
      gap: 40px;
      margin-bottom: 0;
    }

    .lj-stories {
      gap: 80px;
      padding-bottom: 100px;
    }

    .lj-info-grid,
    .lj-route-grid,
    .lj-related-grid {
      grid-template-columns: 1fr;
    }

    .lj-header-actions {
      flex-direction: column;
      align-items: stretch;
      margin-top: 28px;
    }

    .lj-top-btn {
      min-width: 0;
      width: 100%;
      text-align: center;
    }

    .lj-cta-shell {
      padding: 34px 22px;
    }

    .lj-cta-actions {
      flex-direction: column;
      align-items: stretch;
    }

    .lj-cta-btn {
      min-width: 0;
      width: 100%;
      text-align: center;
    }
  }
</style>

<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,500;1,300&family=Montserrat:wght@300;400;600&display=swap" rel="stylesheet">

<div class="lj-wrapper" id="section-{{ section.id }}">
  {% assign info_blocks = section.blocks | where: 'type', 'info_item' %}
  {% assign story_blocks = section.blocks | where: 'type', 'story' %}
  {% assign related_blocks = section.blocks | where: 'type', 'related_tour' %}
  {% assign faq_blocks = section.blocks | where: 'type', 'faq_item' %}
  {% assign whatsapp_url = section.settings.whatsapp_url | default: 'https://api.whatsapp.com/send/?phone=8613211685553&text&type=phone_number&app_absent=0' %}

  <div class="lj-container">
    <header class="lj-header">
      {% if section.settings.sub_title != blank %}
        <span class="lj-subtitle">{{ section.settings.sub_title }}</span>
      {% endif %}
      {% if section.settings.main_title != blank %}
        <h1 class="lj-main-title">{{ section.settings.main_title }}</h1>
      {% endif %}
      {% if section.settings.intro_text != blank %}
        <div class="lj-intro-text">
          {{ section.settings.intro_text | newline_to_br }}
        </div>
      {% endif %}

    </header>

    {% if info_blocks.size > 0 %}
      <section class="lj-info-section">
        {% if section.settings.info_section_eyebrow != blank %}
          <span class="lj-section-eyebrow">{{ section.settings.info_section_eyebrow }}</span>
        {% endif %}
        {% if section.settings.info_section_title != blank %}
          <h2 class="lj-section-title">{{ section.settings.info_section_title }}</h2>
        {% endif %}
        {% if section.settings.info_section_intro != blank %}
          <div class="lj-section-intro">{{ section.settings.info_section_intro | newline_to_br }}</div>
        {% endif %}

        <div class="lj-info-grid">
          {% for block in info_blocks %}
            <article class="lj-info-card" {{ block.shopify_attributes }}>
              {% if block.settings.tag != blank %}
                <span class="lj-info-tag">{{ block.settings.tag }}</span>
              {% endif %}
              {% if block.settings.heading != blank %}
                <h3 class="lj-info-heading">{{ block.settings.heading }}</h3>
              {% endif %}
              {% if block.settings.description != blank %}
                <div class="lj-info-desc">{{ block.settings.description | newline_to_br }}</div>
              {% endif %}
            </article>
          {% endfor %}
        </div>
      </section>
    {% endif %}

    {% comment %}<section class="lj-route-section">
      <span class="lj-section-eyebrow">ROUTE PLANNING</span>
      <h2 class="lj-section-title">Plan Lijiang With the Right Next Step</h2>
      <div class="lj-section-intro">
        Use this page as a planning hub, then move into a broader Yunnan route, a connected Shangri-La journey, or a custom trip request shaped around your dates, pace, and interests.
      </div>

      <div class="lj-route-grid">
        <article class="lj-route-card">
          <span class="lj-route-tag">CLASSIC YUNNAN</span>
          <h3 class="lj-route-heading">Explore Yunnan Private Tours</h3>
          <div class="lj-route-desc">
            Compare broader routes that connect Lijiang with Kunming, Dali, and Shangri-La, then choose the itinerary length that fits your trip best.
          </div>
          <a href="/collections/yunnan-private-tours" class="lj-route-link">
            Explore Yunnan private tours
            <span class="line"></span>
          </a>
        </article>

        <article class="lj-route-card">
          <span class="lj-route-tag">NORTHWEST YUNNAN</span>
          <h3 class="lj-route-heading">Continue to Shangri-La Travel Guide</h3>
          <div class="lj-route-desc">
            Build a stronger northwest Yunnan route by combining Lijiang’s old-town rhythm with Tibetan highlands, monasteries, and alpine scenery.
          </div>
          <a href="/pages/shangri-la" class="lj-route-link">
            Continue to Shangri-La travel guide
            <span class="line"></span>
          </a>
        </article>

        <article class="lj-route-card">
          <span class="lj-route-tag">TRAVEL IDEAS</span>
          <h3 class="lj-route-heading">See Jade Dragon Snow Mountain Guide</h3>
          <div class="lj-route-desc">
            Read more destination guides, route ideas, and planning articles before you decide how to connect Lijiang with the rest of your Yunnan journey.
          </div>
          <a href="/blogs/travel-guides/jade-dragon-snow-mountain-guide" class="lj-route-link">
            See Jade Dragon Snow Mountain guide
            <span class="line"></span>
          </a>
        </article>

        <article class="lj-route-card">
          <span class="lj-route-tag">CUSTOM SUPPORT</span>
          <h3 class="lj-route-heading">Plan a Custom Northwest Yunnan Trip</h3>
          <div class="lj-route-desc">
            Need help deciding how many days to stay, whether to include Jade Dragon Snow Mountain, or how to connect Lijiang with Dali and Shangri-La?
          </div>
          <a href="/pages/bespoke-custom-travel" class="lj-route-link">
            Plan a custom northwest Yunnan trip
            <span class="line"></span>
          </a>
        </article>
      </div>
    </section>{% endcomment %}

    {% if story_blocks.size > 0 %}
      <div class="lj-stories">
        {% for block in story_blocks %}
          <div class="lj-story-row {% cycle '', 'row-reverse' %}" {{ block.shopify_attributes }}>
            <div class="lj-story-image">
              <div class="img-reveal-wrapper">
                {% if block.settings.image != blank %}
                  <img src="{{ block.settings.image | image_url: width: 1200 }}" alt="{{ block.settings.heading | escape }}" loading="lazy">
                {% else %}
                  {{ 'lifestyle-2' | placeholder_svg_tag: 'placeholder-svg' }}
                {% endif %}
              </div>
            </div>
            <div class="lj-story-content">
              {% if block.settings.tag != blank %}
                <span class="story-tag">{{ block.settings.tag }}</span>
              {% endif %}
              {% if block.settings.heading != blank %}
                <h2 class="story-heading">{{ block.settings.heading }}</h2>
              {% endif %}
              {% if block.settings.description != blank %}
                <div class="story-desc">{{ block.settings.description | newline_to_br }}</div>
              {% endif %}
              {% liquid
                assign story_cta_label = block.settings.button_label | strip
                assign story_cta_label_downcase = story_cta_label | downcase
                if story_cta_label_downcase == 'read the guide' or story_cta_label_downcase == 'read more'
                  if block.settings.heading != blank
                    assign story_cta_label = 'Read the ' | append: block.settings.heading | append: ' guide'
                  else
                    assign story_cta_label = 'Read the guide'
                  endif
                endif
              %}
              {% if story_cta_label != blank and block.settings.button_link != blank %}
                <a href="{{ block.settings.button_link }}" class="lj-inline-link">
                  {{ story_cta_label }}
                  <span class="line"></span>
                </a>
              {% endif %}
            </div>
          </div>
        {% endfor %}
      </div>
    {% endif %}

    <section class="lj-route-section">
      <span class="lj-section-eyebrow">ROUTE PLANNING</span>
      <h2 class="lj-section-title">Plan the Next Step After Lijiang</h2>
      <div class="lj-section-intro">
        Once the destination basics are clear, use these route pages to compare Lijiang stays, mountain days, scenic detours, and the northbound route toward Shangri-La.
      </div>

      <div class="lj-route-grid">
        <article class="lj-route-card">
          <span class="lj-route-tag">COMMERCIAL NEXT STEP</span>
          <h3 class="lj-route-heading">Explore Lijiang Private Tours</h3>
          <div class="lj-route-desc">
            Compare route lengths and private travel styles built around old-town time, Jade Dragon Snow Mountain, and the wider northwest Yunnan cluster.
          </div>
          <a href="/collections/lijiang-private-tours" class="lj-route-link">
            Explore Lijiang private tours
            <span class="line"></span>
          </a>
        </article>

        <article class="lj-route-card">
          <span class="lj-route-tag">ITINERARY OPTIONS</span>
          <h3 class="lj-route-heading">See 2-Day and 3-Day Lijiang Itineraries</h3>
          <div class="lj-route-desc">
            Use the <a href="/pages/lijiang-itinerary-2-days">2-day Lijiang itinerary</a> if you are short on time, or compare it with the <a href="/pages/lijiang-itinerary-3-days">3-day Lijiang itinerary</a> if you want a fuller balance of old town, mountain scenery, and cultural stops.
          </div>
          <a href="/pages/lijiang-itinerary-3-days" class="lj-route-link">
            See 2-day and 3-day Lijiang itineraries
            <span class="line"></span>
          </a>
        </article>

        <article class="lj-route-card">
          <span class="lj-route-tag">FLAGSHIP DAY</span>
          <h3 class="lj-route-heading">Explore the Jade Dragon Snow Mountain Private Tour</h3>
          <div class="lj-route-desc">
            If the main decision is how to handle the mountain day itself, this product page is the clearest route from destination research into a bookable Lijiang experience.
          </div>
          <a href="/products/jade-dragon-snow-mountain-private-tour" class="lj-route-link">
            Explore the Jade Dragon Snow Mountain private tour
            <span class="line"></span>
          </a>
        </article>

        <article class="lj-route-card">
          <span class="lj-route-tag">SCENIC DETOUR</span>
          <h3 class="lj-route-heading">See the Tiger Leaping Gorge Route</h3>
          <div class="lj-route-desc">
            Compare the gorge as a scenic day from Lijiang or as part of the road north if you want more dramatic landscape logic in the wider route.
          </div>
          <a href="/pages/tiger-leaping-gorge-from-lijiang" class="lj-route-link">
            See the Tiger Leaping Gorge route
            <span class="line"></span>
          </a>
        </article>

        <article class="lj-route-card">
          <span class="lj-route-tag">NORTHBOUND ROUTE</span>
          <h3 class="lj-route-heading">See the Lijiang to Shangri-La Private Tour</h3>
          <div class="lj-route-desc">
            This is the strongest next page if your Lijiang stay is meant to continue north into Tibetan highlands, monasteries, and a fuller northwest Yunnan pairing.
          </div>
          <a href="/products/lijiang-to-shangri-la-private-tour" class="lj-route-link">
            See the Lijiang to Shangri-La private tour
            <span class="line"></span>
          </a>
        </article>
      </div>
    </section>

    {% if related_blocks.size > 0 %}
      <section class="lj-related-section">
        {% if section.settings.related_section_eyebrow != blank %}
          <span class="lj-section-eyebrow">{{ section.settings.related_section_eyebrow }}</span>
        {% endif %}
        {% if section.settings.related_section_title != blank %}
          <h2 class="lj-section-title">{{ section.settings.related_section_title }}</h2>
        {% endif %}
        {% if section.settings.related_section_intro != blank %}
          <div class="lj-section-intro">{{ section.settings.related_section_intro | newline_to_br }}</div>
        {% endif %}

        <div class="lj-related-grid">
          {% for block in related_blocks %}
            <article class="lj-related-card" {{ block.shopify_attributes }}>
              {% if block.settings.tag != blank %}
                <span class="lj-related-tag">{{ block.settings.tag }}</span>
              {% endif %}
              {% if block.settings.heading != blank %}
                <h3 class="lj-related-heading">{{ block.settings.heading }}</h3>
              {% endif %}
              {% if block.settings.description != blank %}
                <div class="lj-related-desc">{{ block.settings.description | newline_to_br }}</div>
              {% endif %}
              {% liquid
                assign related_cta_label = block.settings.button_label | strip
                assign related_cta_label_downcase = related_cta_label | downcase
                if related_cta_label_downcase == 'view tour' or related_cta_label_downcase == 'view journey' or related_cta_label_downcase == 'learn more'
                  if block.settings.heading != blank
                    assign related_cta_label = 'Explore ' | append: block.settings.heading
                  else
                    assign related_cta_label = 'See tour details'
                  endif
                endif
              %}
              {% if related_cta_label != blank and block.settings.button_link != blank %}
                <a href="{{ block.settings.button_link }}" class="lj-related-link">
                  {{ related_cta_label }}
                  <span class="line"></span>
                </a>
              {% endif %}
            </article>
          {% endfor %}
        </div>
      </section>
    {% endif %}

    <section class="lj-cta-section">
      {% if section.settings.cta_eyebrow != blank %}
        <span class="lj-section-eyebrow">{{ section.settings.cta_eyebrow }}</span>
      {% endif %}
      {% if section.settings.cta_title != blank %}
        <h2 class="lj-section-title">{{ section.settings.cta_title }}</h2>
      {% endif %}
      {% if section.settings.cta_intro != blank %}
        <div class="lj-section-intro">{{ section.settings.cta_intro | newline_to_br }}</div>
      {% endif %}

      <div class="lj-cta-shell">
        {% if section.settings.cta_box_title != blank %}
          <h3 class="lj-cta-title">{{ section.settings.cta_box_title }}</h3>
        {% endif %}
        {% if section.settings.cta_box_desc != blank %}
          <div class="lj-cta-desc">{{ section.settings.cta_box_desc | newline_to_br }}</div>
        {% endif %}

        <div class="lj-cta-actions">
          {% if section.settings.cta_primary_label != blank and section.settings.cta_primary_url != blank %}
            <a href="{{ section.settings.cta_primary_url }}" class="lj-cta-btn primary">{{ section.settings.cta_primary_label }}</a>
          {% endif %}
          {% if section.settings.whatsapp_label != blank and whatsapp_url != blank %}
            <a href="{{ whatsapp_url }}" class="lj-cta-btn whatsapp" target="_blank" rel="noopener">{{ section.settings.whatsapp_label }}</a>
          {% endif %}
          {% if section.settings.cta_secondary_label != blank and section.settings.cta_secondary_url != blank %}
            <a href="{{ section.settings.cta_secondary_url }}" class="lj-cta-btn secondary">{{ section.settings.cta_secondary_label }}</a>
          {% endif %}
        </div>
      </div>
    </section>

    {% if faq_blocks.size > 0 %}
      <section class="lj-faq-section">
        {% if section.settings.faq_section_eyebrow != blank %}
          <span class="lj-section-eyebrow">{{ section.settings.faq_section_eyebrow }}</span>
        {% endif %}
        {% if section.settings.faq_section_title != blank %}
          <h2 class="lj-section-title">{{ section.settings.faq_section_title }}</h2>
        {% endif %}
        {% if section.settings.faq_section_intro != blank %}
          <div class="lj-section-intro">{{ section.settings.faq_section_intro | newline_to_br }}</div>
        {% endif %}

        <div class="lj-faq-list">
          {% for block in faq_blocks %}
            <details class="lj-faq-item" {{ block.shopify_attributes }}>
              <summary class="lj-faq-question">
                <span>{{ block.settings.question }}</span>
                <span class="lj-faq-icon"></span>
              </summary>
              <div class="lj-faq-answer">
                {{ block.settings.answer | newline_to_br }}
              </div>
            </details>
          {% endfor %}
        </div>
      </section>
    {% endif %}
  </div>
</div>

{% if faq_blocks.size > 0 %}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {% for block in faq_blocks %}
        {
          "@type": "Question",
          "name": {{ block.settings.question | strip_html | strip | json }},
          "acceptedAnswer": {
            "@type": "Answer",
            "text": {{ block.settings.answer | strip_html | strip | json }}
          }
        }{% unless forloop.last %},{% endunless %}
      {% endfor %}
    ]
  }
  </script>
{% endif %}

{% if page %}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "name": "Home",
        "item": {{ request.origin | append: '/' | json }}
      },
      {
        "@type": "ListItem",
        "position": 2,
        "name": {{ page.title | json }},
        "item": {{ request.origin | append: page.url | json }}
      }
    ]
  }
  </script>
{% endif %}

