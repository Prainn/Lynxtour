{% liquid
  assign review_count = 0
  assign total_rating = 0

  for block in section.blocks
    if block.settings.review_text != blank and block.settings.author_name != blank and block.settings.rating != blank
      assign review_count = review_count | plus: 1
      assign total_rating = total_rating | plus: block.settings.rating
    endif
  endfor

  assign average_rating = 0
  if review_count > 0
    assign average_rating = total_rating | times: 1.0 | divided_by: review_count | round: 1
  endif
%}

<section id="lx-product-reviews-{{ section.id }}" class="lx-pr-section">
  <div class="lx-pr-container">

    {%- if section.settings.show_section and review_count > 0 -%}
      <!-- 1. Review Header -->
      <div class="lx-pr-header">
        <div class="lx-pr-header-main">
          {%- if section.settings.eyebrow != blank -%}
            <p class="lx-pr-eyebrow">{{ section.settings.eyebrow }}</p>
          {%- endif -%}

          {%- if section.settings.heading != blank -%}
            <h2 class="lx-pr-title">{{ section.settings.heading }}</h2>
          {%- endif -%}

          {%- if section.settings.subheading != blank -%}
            <div class="lx-pr-subtitle">{{ section.settings.subheading }}</div>
          {%- endif -%}
        </div>

        <div class="lx-pr-summary">
          <div class="lx-pr-score-row">
            <div class="lx-pr-score">{{ average_rating }}</div>
            <div class="lx-pr-stars" aria-label="{{ average_rating }} out of 5 stars">
              {%- assign rounded_avg = average_rating | round -%}
              {%- for i in (1..5) -%}
                <span class="lx-pr-star {% if i <= rounded_avg %}is-filled{% endif %}">★</span>
              {%- endfor -%}
            </div>
          </div>

          <div class="lx-pr-meta">
            <p>Based on {{ review_count }} guest review{% if review_count > 1 %}s{% endif %}</p>
            {%- if section.settings.summary_keywords != blank -%}
              <p class="lx-pr-keywords">{{ section.settings.summary_keywords }}</p>
            {%- endif -%}
          </div>
        </div>
      </div>

      <!-- 2. Review Highlights -->
      <div class="lx-pr-highlights">
        {%- if section.settings.highlight_1_title != blank -%}
          <div class="lx-pr-highlight-card">
            <h3>{{ section.settings.highlight_1_title }}</h3>
            <p>{{ section.settings.highlight_1_text }}</p>
          </div>
        {%- endif -%}

        {%- if section.settings.highlight_2_title != blank -%}
          <div class="lx-pr-highlight-card">
            <h3>{{ section.settings.highlight_2_title }}</h3>
            <p>{{ section.settings.highlight_2_text }}</p>
          </div>
        {%- endif -%}

        {%- if section.settings.highlight_3_title != blank -%}
          <div class="lx-pr-highlight-card">
            <h3>{{ section.settings.highlight_3_title }}</h3>
            <p>{{ section.settings.highlight_3_text }}</p>
          </div>
        {%- endif -%}

        {%- if section.settings.highlight_4_title != blank -%}
          <div class="lx-pr-highlight-card">
            <h3>{{ section.settings.highlight_4_title }}</h3>
            <p>{{ section.settings.highlight_4_text }}</p>
          </div>
        {%- endif -%}
      </div>

      <!-- 3. Review Cards -->
      <div class="lx-pr-reviews-wrap">
        <div class="lx-pr-reviews-head">
          <h3 class="lx-pr-reviews-title">{{ section.settings.cards_heading }}</h3>

          <div class="lx-pr-nav">
            <button type="button" class="lx-pr-nav-btn" data-review-prev aria-label="Previous reviews">
              &#10094;
            </button>
            <button type="button" class="lx-pr-nav-btn" data-review-next aria-label="Next reviews">
              &#10095;
            </button>
          </div>
        </div>

        <div class="lx-pr-reviews-track" data-review-track>
          {%- for block in section.blocks -%}
            {%- if block.settings.review_text != blank and block.settings.author_name != blank and block.settings.rating != blank -%}
              <article class="lx-pr-card" {{ block.shopify_attributes }}>
                <div class="lx-pr-card-top">
                  <div class="lx-pr-card-stars" aria-label="{{ block.settings.rating }} out of 5 stars">
                    {%- for i in (1..5) -%}
                      <span class="lx-pr-star {% if i <= block.settings.rating %}is-filled{% endif %}">★</span>
                    {%- endfor -%}
                  </div>

                  {%- if block.settings.trip_type != blank -%}
                    <span class="lx-pr-chip">{{ block.settings.trip_type }}</span>
                  {%- endif -%}
                </div>

                <div class="lx-pr-card-body">
                  <p class="lx-pr-review-text" id="review-text-{{ section.id }}-{{ block.id }}">
                    {{ block.settings.review_text }}
                  </p>

                  <button
                    type="button"
                    class="lx-pr-toggle"
                    data-review-toggle
                    data-target="review-text-{{ section.id }}-{{ block.id }}"
                  >
                    See More
                  </button>
                </div>

                <div class="lx-pr-card-footer">
                  <div class="lx-pr-author">
                    <div class="lx-pr-avatar">
                      {%- if block.settings.author_image != blank -%}
                        <img
                          src="{{ block.settings.author_image | image_url: width: 120 }}"
                          alt="{{ block.settings.author_name | escape }}"
                          loading="lazy"
                          width="60"
                          height="60"
                        >
                      {%- else -%}
                        <span>{{ block.settings.author_name | slice: 0 }}</span>
                      {%- endif -%}
                    </div>

                    <div class="lx-pr-author-info">
                      <h4>{{ block.settings.author_name }}</h4>

                      {%- if block.settings.author_meta != blank -%}
                        <p>{{ block.settings.author_meta }}</p>
                      {%- endif -%}
                    </div>
                  </div>

                  {%- if block.settings.travel_date != blank -%}
                    <div class="lx-pr-date">{{ block.settings.travel_date }}</div>
                  {%- endif -%}
                </div>
              </article>
            {%- endif -%}
          {%- endfor -%}
        </div>
      </div>

      <!-- 4. Trust + CTA -->
      <div class="lx-pr-cta">
        <div class="lx-pr-cta-copy">
          {%- if section.settings.cta_heading != blank -%}
            <h3>{{ section.settings.cta_heading }}</h3>
          {%- endif -%}

          {%- if section.settings.cta_text != blank -%}
            <p>{{ section.settings.cta_text }}</p>
          {%- endif -%}
        </div>

        {%- if section.settings.cta_button_label != blank and section.settings.cta_button_link != blank -%}
          <a href="{{ section.settings.cta_button_link | escape }}" class="lx-pr-cta-btn">
            {{ section.settings.cta_button_label }}
          </a>
        {%- endif -%}
      </div>
    {%- elsif request.design_mode -%}
      <div class="lx-pr-empty">
        <p>Add review blocks to display this section on the product page.</p>
      </div>
    {%- endif -%}
  </div>

  {%- if product and review_count > 0 -%}
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Product",
      "name": {{ product.title | strip | json }},
      "url": {{ shop.url | append: product.url | json }},
      {%- if product.featured_image -%}
        "image": [{{ product.featured_image | image_url: width: 1200 | prepend: "https:" | json }}],
      {%- endif -%}
      "description": {{ product.description | strip_html | strip_newlines | truncate: 300 | json }},
      "brand": {
        "@type": "Brand",
        "name": {{ shop.name | json }}
      },
      "aggregateRating": {
        "@type": "AggregateRating",
        "ratingValue": {{ average_rating }},
        "reviewCount": {{ review_count }},
        "bestRating": 5,
        "worstRating": 1
      },
      "review": [
        {%- assign first_review = true -%}
        {%- for block in section.blocks -%}
          {%- if block.settings.review_text != blank and block.settings.author_name != blank and block.settings.rating != blank -%}
            {%- unless first_review -%},{%- endunless -%}
            {
              "@type": "Review",
              "author": {
                "@type": "Person",
                "name": {{ block.settings.author_name | strip | json }}
              },
              "reviewBody": {{ block.settings.review_text | strip_html | strip_newlines | strip | json }},
              "reviewRating": {
                "@type": "Rating",
                "ratingValue": {{ block.settings.rating }},
                "bestRating": 5,
                "worstRating": 1
              },
              "publisher": {
                "@type": "Organization",
                "name": {{ shop.name | json }}
              }
            }
            {%- assign first_review = false -%}
          {%- endif -%}
        {%- endfor -%}
      ]
    }
    </script>
  {%- endif -%}
</section>

<script>
  (function () {
    const section = document.getElementById('lx-product-reviews-{{ section.id }}');
    if (!section) return;

    const track = section.querySelector('[data-review-track]');
    const prevBtn = section.querySelector('[data-review-prev]');
    const nextBtn = section.querySelector('[data-review-next]');

    if (track && prevBtn && nextBtn) {
      const scrollAmount = () => Math.max(track.clientWidth * 0.9, 280);

      prevBtn.addEventListener('click', function () {
        track.scrollBy({ left: -scrollAmount(), behavior: 'smooth' });
      });

      nextBtn.addEventListener('click', function () {
        track.scrollBy({ left: scrollAmount(), behavior: 'smooth' });
      });
    }

    section.querySelectorAll('[data-review-toggle]').forEach(function (button) {
      button.addEventListener('click', function () {
        const targetId = button.getAttribute('data-target');
        const target = document.getElementById(targetId);
        if (!target) return;

        const expanded = target.classList.toggle('is-expanded');
        button.textContent = expanded ? 'See Less' : 'See More';
      });
    });
  })();
</script>

<style>
  html {
    scroll-behavior: smooth;
  }

  #lx-ota-form {
    scroll-margin-top: 140px;
  }

  #lx-product-reviews-{{ section.id }} {
    --lx-pr-bg: #0b0b0d;
    --lx-pr-bg-soft: #121216;
    --lx-pr-card: rgba(255,255,255,0.04);
    --lx-pr-card-strong: rgba(255,255,255,0.06);
    --lx-pr-border: rgba(212, 177, 106, 0.16);
    --lx-pr-border-strong: rgba(212, 177, 106, 0.28);
    --lx-pr-gold: #d4b16a;
    --lx-pr-gold-soft: #f2dfb7;
    --lx-pr-text: #f5f2eb;
    --lx-pr-muted: rgba(245, 242, 235, 0.72);
    --lx-pr-muted-2: rgba(245, 242, 235, 0.5);
    background:
      radial-gradient(circle at top right, rgba(212,177,106,0.08), transparent 30%),
      linear-gradient(180deg, #0a0a0c 0%, #0d0d10 100%);
    color: var(--lx-pr-text);
    padding: 88px 0;
    overflow: hidden;
  }

  #lx-product-reviews-{{ section.id }} .lx-pr-container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 40px;
  }

  #lx-product-reviews-{{ section.id }} .lx-pr-header {
    display: grid;
    grid-template-columns: minmax(0, 1.4fr) minmax(320px, 0.6fr);
    gap: 28px;
    align-items: end;
    margin-bottom: 28px;
  }

  #lx-product-reviews-{{ section.id }} .lx-pr-eyebrow {
    margin: 0 0 10px;
    color: var(--lx-pr-gold);
    text-transform: uppercase;
    letter-spacing: 0.22em;
    font-size: 12px;
    line-height: 1.2;
  }

  #lx-product-reviews-{{ section.id }} .lx-pr-title {
    margin: 0;
    font-size: clamp(28px, 4vw, 48px);
    line-height: 1.08;
    font-weight: 500;
    letter-spacing: -0.02em;
    color: var(--lx-pr-text);
  }

  #lx-product-reviews-{{ section.id }} .lx-pr-subtitle {
    margin-top: 14px;
    max-width: 760px;
    color: var(--lx-pr-muted);
    font-size: 16px;
    line-height: 1.75;
  }

  #lx-product-reviews-{{ section.id }} .lx-pr-summary {
    background: linear-gradient(180deg, rgba(255,255,255,0.05), rgba(255,255,255,0.03));
    border: 1px solid var(--lx-pr-border);
    border-radius: 24px;
    padding: 24px;
    backdrop-filter: blur(10px);
  }

  #lx-product-reviews-{{ section.id }} .lx-pr-score-row {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-bottom: 10px;
  }

  #lx-product-reviews-{{ section.id }} .lx-pr-score {
    font-size: 44px;
    line-height: 1;
    font-weight: 500;
    color: var(--lx-pr-gold-soft);
  }

  #lx-product-reviews-{{ section.id }} .lx-pr-stars,
  #lx-product-reviews-{{ section.id }} .lx-pr-card-stars {
    display: flex;
    gap: 4px;
    align-items: center;
  }

  #lx-product-reviews-{{ section.id }} .lx-pr-star {
    color: rgba(212, 177, 106, 0.26);
    font-size: 14px;
    line-height: 1;
  }

  #lx-product-reviews-{{ section.id }} .lx-pr-star.is-filled {
    color: var(--lx-pr-gold);
  }

  #lx-product-reviews-{{ section.id }} .lx-pr-meta p {
    margin: 0;
    color: var(--lx-pr-muted);
    font-size: 13px;
    line-height: 1.7;
  }

  #lx-product-reviews-{{ section.id }} .lx-pr-keywords {
    color: var(--lx-pr-muted-2);
    margin-top: 4px;
  }

  #lx-product-reviews-{{ section.id }} .lx-pr-highlights {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 16px;
    margin-bottom: 34px;
  }

  #lx-product-reviews-{{ section.id }} .lx-pr-highlight-card {
    background: var(--lx-pr-card);
    border: 1px solid rgba(255,255,255,0.06);
    border-radius: 22px;
    padding: 22px 20px;
    min-height: 146px;
  }

  #lx-product-reviews-{{ section.id }} .lx-pr-highlight-card h3 {
    margin: 0 0 10px;
    font-size: 16px;
    font-weight: 500;
    color: var(--lx-pr-text);
  }

  #lx-product-reviews-{{ section.id }} .lx-pr-highlight-card p {
    margin: 0;
    color: var(--lx-pr-muted);
    font-size: 14px;
    line-height: 1.75;
  }

  #lx-product-reviews-{{ section.id }} .lx-pr-reviews-wrap {
    margin-bottom: 34px;
  }

  #lx-product-reviews-{{ section.id }} .lx-pr-reviews-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    margin-bottom: 18px;
  }

  #lx-product-reviews-{{ section.id }} .lx-pr-reviews-title {
    margin: 0;
    font-size: 22px;
    line-height: 1.2;
    font-weight: 500;
    color: var(--lx-pr-text);
  }

  #lx-product-reviews-{{ section.id }} .lx-pr-nav {
    display: flex;
    gap: 10px;
    flex-shrink: 0;
  }

  #lx-product-reviews-{{ section.id }} .lx-pr-nav-btn {
    width: 42px;
    height: 42px;
    border-radius: 999px;
    border: 1px solid var(--lx-pr-border-strong);
    background: rgba(212,177,106,0.08);
    color: var(--lx-pr-gold);
    cursor: pointer;
    transition: 0.25s ease;
  }

  #lx-product-reviews-{{ section.id }} .lx-pr-nav-btn:hover {
    background: rgba(212,177,106,0.18);
    border-color: rgba(212,177,106,0.42);
  }

  #lx-product-reviews-{{ section.id }} .lx-pr-reviews-track {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 18px;
  }

  #lx-product-reviews-{{ section.id }} .lx-pr-card {
    background:
      linear-gradient(180deg, rgba(255,255,255,0.055), rgba(255,255,255,0.028));
    border: 1px solid rgba(255,255,255,0.06);
    border-radius: 24px;
    padding: 24px;
    min-height: 100%;
    display: flex;
    flex-direction: column;
  }

  #lx-product-reviews-{{ section.id }} .lx-pr-card-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    margin-bottom: 18px;
  }

  #lx-product-reviews-{{ section.id }} .lx-pr-chip {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 30px;
    padding: 6px 12px;
    border-radius: 999px;
    background: rgba(212,177,106,0.08);
    border: 1px solid rgba(212,177,106,0.18);
    color: var(--lx-pr-gold-soft);
    font-size: 11px;
    line-height: 1;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    white-space: nowrap;
  }

  #lx-product-reviews-{{ section.id }} .lx-pr-card-body {
    flex: 1 1 auto;
  }

  #lx-product-reviews-{{ section.id }} .lx-pr-review-text {
    margin: 0;
    color: var(--lx-pr-muted);
    font-size: 15px;
    line-height: 1.85;
    display: -webkit-box;
    -webkit-line-clamp: 6;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  #lx-product-reviews-{{ section.id }} .lx-pr-review-text.is-expanded {
    display: block;
    -webkit-line-clamp: initial;
    overflow: visible;
  }

  #lx-product-reviews-{{ section.id }} .lx-pr-toggle {
    margin-top: 10px;
    padding: 0;
    background: transparent;
    border: 0;
    color: var(--lx-pr-gold);
    font-size: 12px;
    line-height: 1.4;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    cursor: pointer;
  }

  #lx-product-reviews-{{ section.id }} .lx-pr-card-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    margin-top: 22px;
    padding-top: 18px;
    border-top: 1px solid rgba(255,255,255,0.06);
  }

  #lx-product-reviews-{{ section.id }} .lx-pr-author {
    display: flex;
    align-items: center;
    gap: 12px;
    min-width: 0;
  }

  #lx-product-reviews-{{ section.id }} .lx-pr-avatar {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    overflow: hidden;
    background: rgba(255,255,255,0.08);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--lx-pr-gold-soft);
    font-size: 18px;
    flex-shrink: 0;
  }

  #lx-product-reviews-{{ section.id }} .lx-pr-avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  #lx-product-reviews-{{ section.id }} .lx-pr-author-info h4 {
    margin: 0;
    color: var(--lx-pr-text);
    font-size: 15px;
    line-height: 1.3;
    font-weight: 500;
  }

  #lx-product-reviews-{{ section.id }} .lx-pr-author-info p,
  #lx-product-reviews-{{ section.id }} .lx-pr-date {
    margin: 4px 0 0;
    color: var(--lx-pr-muted-2);
    font-size: 12px;
    line-height: 1.5;
  }

  #lx-product-reviews-{{ section.id }} .lx-pr-date {
    white-space: nowrap;
    margin: 0;
  }

  #lx-product-reviews-{{ section.id }} .lx-pr-cta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    padding: 28px 30px;
    border-radius: 28px;
    background:
      linear-gradient(135deg, rgba(212,177,106,0.10), rgba(255,255,255,0.03));
    border: 1px solid var(--lx-pr-border);
  }

  #lx-product-reviews-{{ section.id }} .lx-pr-cta-copy h3 {
    margin: 0 0 8px;
    font-size: 24px;
    line-height: 1.2;
    font-weight: 500;
    color: var(--lx-pr-text);
  }

  #lx-product-reviews-{{ section.id }} .lx-pr-cta-copy p {
    margin: 0;
    color: var(--lx-pr-muted);
    font-size: 15px;
    line-height: 1.8;
    max-width: 760px;
  }

  #lx-product-reviews-{{ section.id }} .lx-pr-cta-btn {
    flex-shrink: 0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 52px;
    padding: 0 24px;
    border-radius: 999px;
    text-decoration: none;
    background: var(--lx-pr-gold);
    color: #111;
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    transition: transform 0.25s ease, opacity 0.25s ease;
  }

  #lx-product-reviews-{{ section.id }} .lx-pr-cta-btn:hover {
    transform: translateY(-1px);
    opacity: 0.92;
  }

  #lx-product-reviews-{{ section.id }} .lx-pr-empty {
    padding: 28px 30px;
    border: 1px dashed rgba(255,255,255,0.14);
    border-radius: 20px;
    color: var(--lx-pr-muted);
    text-align: center;
  }

  @media (max-width: 1199px) {
    #lx-product-reviews-{{ section.id }} .lx-pr-header {
      grid-template-columns: 1fr;
    }

    #lx-product-reviews-{{ section.id }} .lx-pr-highlights {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    #lx-product-reviews-{{ section.id }} .lx-pr-reviews-track {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    #lx-product-reviews-{{ section.id }} .lx-pr-cta {
      flex-direction: column;
      align-items: flex-start;
    }
  }

  @media (max-width: 767px) {
    #lx-product-reviews-{{ section.id }} {
      padding: 64px 0;
    }

    #lx-product-reviews-{{ section.id }} .lx-pr-container {
      padding: 0 20px;
    }

    #lx-product-reviews-{{ section.id }} .lx-pr-summary {
      padding: 20px;
    }

    #lx-product-reviews-{{ section.id }} .lx-pr-highlights {
      grid-template-columns: 1fr;
      gap: 12px;
    }

    #lx-product-reviews-{{ section.id }} .lx-pr-highlight-card {
      min-height: auto;
    }

    #lx-product-reviews-{{ section.id }} .lx-pr-reviews-head {
      align-items: flex-end;
    }

    #lx-product-reviews-{{ section.id }} .lx-pr-reviews-track {
      display: flex;
      gap: 14px;
      overflow-x: auto;
      padding-bottom: 6px;
      scroll-snap-type: x mandatory;
      scrollbar-width: none;
    }

    #lx-product-reviews-{{ section.id }} .lx-pr-reviews-track::-webkit-scrollbar {
      display: none;
    }

    #lx-product-reviews-{{ section.id }} .lx-pr-card {
      flex: 0 0 85%;
      scroll-snap-align: start;
      min-width: 85%;
    }

    #lx-product-reviews-{{ section.id }} .lx-pr-card-footer {
      flex-direction: column;
      align-items: flex-start;
    }

    #lx-product-reviews-{{ section.id }} .lx-pr-nav {
      display: none;
    }

    #lx-product-reviews-{{ section.id }} .lx-pr-cta {
      padding: 24px 20px;
