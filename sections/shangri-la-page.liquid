<style>
  .sr-wrapper {
    background-color: #050505;
    color: #fff;
    padding: 60px 0;
    overflow: hidden;
    font-family: 'Montserrat', sans-serif;
  }

  .sr-container {
    max-width: 1300px;
    margin: 0 auto;
    padding: 0 40px;
  }

  .sr-header {
    text-align: center;
    padding: 140px 20px 160px;
    max-width: 1000px;
    margin: 0 auto;
    position: relative;
  }

  .sr-subtitle {
    color: #d4af37;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.7em;
    text-transform: uppercase;
    display: block;
    margin-bottom: 30px;
    opacity: 0.9;
  }

  .sr-main-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(3.2rem, 8vw, 5.5rem);
    font-weight: 300;
    line-height: 1.1;
    margin-bottom: 45px;
    letter-spacing: 0.08em;
    color: #ffffff;
    font-style: italic;
  }

  .sr-header::after {
    content: "";
    display: block;
    width: 1px;
    height: 80px;
    background: linear-gradient(to bottom, #d4af37, transparent);
    margin: 0 auto 45px;
  }

  .sr-intro-text {
    max-width: 750px;
    margin: 0 auto;
    color: #e5e5e5;
    line-height: 2.1;
    font-size: 16px;
    font-weight: 300;
    letter-spacing: 0.05em;
  }

  .sr-section-eyebrow {
    display: block;
    color: #d4af37;
    font-size: 10px;
    letter-spacing: 0.35em;
    text-transform: uppercase;
    margin-bottom: 14px;
  }

  .sr-section-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(2rem, 4vw, 3.2rem);
    font-style: italic;
    font-weight: 300;
    line-height: 1.15;
    margin: 0 0 18px;
    color: #fff;
  }

  .sr-section-intro {
    max-width: 760px;
    margin: 0 auto;
    color: #cfcac4;
    font-size: 14px;
    line-height: 1.9;
    letter-spacing: 0.02em;
    text-align: center;
  }

  .sr-info-section,
  .sr-related-section,
  .sr-cta-section,
  .sr-faq-section {
    padding: 0 0 120px;
    text-align: center;
  }

  .sr-info-grid {
    margin-top: 48px;
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 24px;
  }

  .sr-info-card {
    background: rgba(255,255,255,0.02);
    border: 1px solid rgba(212,175,55,0.14);
    padding: 30px 28px;
    text-align: left;
    min-height: 100%;
  }

  .sr-info-tag {
    display: block;
    color: #d4af37;
    font-size: 10px;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    margin-bottom: 14px;
  }

  .sr-info-heading {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.9rem;
    font-style: italic;
    font-weight: 300;
    margin: 0 0 14px;
    color: #fff;
  }

  .sr-info-desc {
    color: #b9b2ab;
    font-size: 13px;
    line-height: 1.85;
    letter-spacing: 0.02em;
  }

  .sr-stories {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 0 120px;
    display: flex;
    flex-direction: column;
    gap: 150px;
  }

  .sr-story-row {
    display: flex;
    align-items: center;
    gap: 80px;
    flex-direction: row;
  }

  .sr-story-row.row-reverse {
    flex-direction: row-reverse;
  }

  .sr-story-image {
    flex: 1.1;
    position: relative;
  }

  .sr-story-content {
    flex: 1;
    padding: 20px 0;
  }

  .img-reveal-wrapper {
    position: relative;
    aspect-ratio: 3 / 4;
    overflow: hidden;
    background-color: #111;
  }

  .img-reveal-wrapper::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, rgba(0,0,0,0) 60%, rgba(0,0,0,0.3) 100%);
    pointer-events: none;
  }

  .img-reveal-wrapper img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: brightness(0.75) contrast(1.1);
    transition: transform 2.5s cubic-bezier(0.1, 1, 0.2, 1);
  }

  .sr-story-row:hover img {
    transform: scale(1.08);
  }

  .story-tag {
    color: #d4af37;
    font-size: 10px;
    letter-spacing: 3px;
    text-transform: uppercase;
    margin-bottom: 20px;
    display: block;
  }

  .story-heading {
    font-family: 'Cormorant Garamond', serif;
    font-style: italic;
    font-size: 2.5rem;
    letter-spacing: 0.05em;
    margin-bottom: 24px;
  }

  .story-desc {
    font-family: 'Montserrat', sans-serif;
    font-size: 13px;
    line-height: 1.8;
    letter-spacing: 0.03em;
    color: #a8a29e;
    max-width: 450px;
    font-weight: 300;
  }

  .sr-inline-link,
  .sr-related-link {
    color: #d4af37;
    text-decoration: none;
    font-size: 11px;
    letter-spacing: 2px;
    display: inline-flex;
    flex-direction: column;
    gap: 8px;
    margin-top: 24px;
  }

  .sr-inline-link .line,
  .sr-related-link .line {
    width: 30px;
    height: 1px;
    background: #d4af37;
    transition: 0.4s;
  }

  .sr-inline-link:hover .line,
  .sr-related-link:hover .line {
    width: 60px;
  }

  .sr-related-grid {
    margin-top: 48px;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 24px;
    text-align: left;
  }

  .sr-related-card {
    background: rgba(255,255,255,0.02);
    border: 1px solid rgba(255,255,255,0.08);
    padding: 28px 24px;
    min-height: 100%;
  }

  .sr-related-tag {
    display: block;
    color: #d4af37;
    font-size: 10px;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    margin-bottom: 14px;
  }

  .sr-related-heading {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.9rem;
    font-style: italic;
    font-weight: 300;
    margin: 0 0 14px;
    color: #fff;
  }

  .sr-related-desc {
    color: #b9b2ab;
    font-size: 13px;
    line-height: 1.85;
    letter-spacing: 0.02em;
  }

  .sr-cta-shell {
    max-width: 980px;
    margin: 48px auto 0;
    padding: 46px 42px;
    border: 1px solid rgba(212,175,55,0.16);
    background:
      linear-gradient(180deg, rgba(255,255,255,0.02) 0%, rgba(255,255,255,0.008) 100%),
      radial-gradient(circle at top right, rgba(212,175,55,0.08), transparent 35%);
  }

  .sr-cta-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(2rem, 4vw, 3rem);
    font-style: italic;
    font-weight: 300;
    line-height: 1.12;
    margin: 0 0 18px;
    color: #fff;
  }

  .sr-cta-desc {
    max-width: 760px;
    margin: 0 auto;
    color: #cfcac4;
    font-size: 14px;
    line-height: 1.9;
    letter-spacing: 0.02em;
  }

  .sr-cta-actions {
    display: flex;
    justify-content: center;
    gap: 14px;
    flex-wrap: wrap;
    margin-top: 30px;
  }

  .sr-cta-btn {
    min-width: 210px;
    padding: 14px 22px;
    text-decoration: none;
    font-size: 11px;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    transition: 0.3s ease;
  }

  .sr-cta-btn.primary {
    background: #d4af37;
    color: #111;
    border: 1px solid #d4af37;
  }

  .sr-cta-btn.primary:hover {
    background: #e3bf4e;
    border-color: #e3bf4e;
  }

  .sr-cta-btn.secondary {
    background: transparent;
    color: #fff;
    border: 1px solid rgba(255,255,255,0.18);
  }

  .sr-cta-btn.secondary:hover {
    border-color: rgba(212,175,55,0.5);
    color: #d4af37;
  }

  .sr-faq-list {
    max-width: 900px;
    margin: 48px auto 0;
    text-align: left;
  }

  .sr-faq-item {
    border-top: 1px solid rgba(255,255,255,0.12);
    padding: 0;
  }

  .sr-faq-item:last-child {
    border-bottom: 1px solid rgba(255,255,255,0.12);
  }

  .sr-faq-question {
    list-style: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    padding: 24px 0;
    font-size: 15px;
    color: #f5f5f4;
    letter-spacing: 0.02em;
  }

  .sr-faq-question::-webkit-details-marker {
    display: none;
  }

  .sr-faq-icon {
    width: 14px;
    height: 14px;
    position: relative;
    flex: 0 0 14px;
  }

  .sr-faq-icon::before,
  .sr-faq-icon::after {
    content: "";
    position: absolute;
    background: #d4af37;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
    transition: 0.25s ease;
  }

  .sr-faq-icon::before {
    width: 14px;
    height: 1px;
  }

  .sr-faq-icon::after {
    width: 1px;
    height: 14px;
  }

  .sr-faq-item[open] .sr-faq-icon::after {
    opacity: 0;
  }

  .sr-faq-answer {
    color: #b9b2ab;
    font-size: 13px;
    line-height: 1.9;
    letter-spacing: 0.02em;
    padding: 0 0 24px;
    max-width: 760px;
  }

  @media (max-width: 990px) {
    .sr-container {
      padding: 0 24px;
    }

    .sr-header {
      padding: 90px 20px 110px;
    }

    .sr-main-title {
      font-size: 2.9rem;
    }

    .sr-intro-text {
      font-size: 14px;
      line-height: 1.85;
    }

    .sr-story-row,
    .sr-story-row.row-reverse {
      flex-direction: column;
      gap: 50px;
      margin-bottom: 0;
    }

    .sr-stories {
      gap: 90px;
      padding-bottom: 100px;
    }

    .img-reveal-wrapper {
      aspect-ratio: 4/5;
      width: 100%;
    }

    .sr-info-grid,
    .sr-related-grid {
      grid-template-columns: 1fr;
    }

    .sr-cta-shell {
      padding: 34px 22px;
    }

    .sr-cta-actions {
      flex-direction: column;
      align-items: stretch;
    }

    .sr-cta-btn {
      min-width: 0;
      width: 100%;
      text-align: center;
    }
  }
</style>

<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,500;1,300&family=Montserrat:wght@300;400;600&display=swap" rel="stylesheet">

<div class="sr-wrapper" id="section-{{ section.id }}">
  {% assign info_blocks = section.blocks | where: 'type', 'info_item' %}
  {% assign story_blocks = section.blocks | where: 'type', 'story' %}
  {% assign related_blocks = section.blocks | where: 'type', 'related_tour' %}
  {% assign faq_blocks = section.blocks | where: 'type', 'faq_item' %}

  <div class="sr-container">
    <header class="sr-header">
      {% if section.settings.sub_title != blank %}
        <span class="sr-subtitle">{{ section.settings.sub_title }}</span>
      {% endif %}
      {% if section.settings.main_title != blank %}
        <h1 class="sr-main-title">{{ section.settings.main_title }}</h1>
      {% endif %}
      {% if section.settings.intro_text != blank %}
        <div class="sr-intro-text">
          {{ section.settings.intro_text | newline_to_br }}
        </div>
      {% endif %}
    </header>

    {% if info_blocks.size > 0 %}
      <section class="sr-info-section">
        {% if section.settings.info_section_eyebrow != blank %}
          <span class="sr-section-eyebrow">{{ section.settings.info_section_eyebrow }}</span>
        {% endif %}
        {% if section.settings.info_section_title != blank %}
          <h2 class="sr-section-title">{{ section.settings.info_section_title }}</h2>
        {% endif %}
        {% if section.settings.info_section_intro != blank %}
          <div class="sr-section-intro">{{ section.settings.info_section_intro | newline_to_br }}</div>
        {% endif %}

        <div class="sr-info-grid">
          {% for block in info_blocks %}
            <article class="sr-info-card" {{ block.shopify_attributes }}>
              {% if block.settings.tag != blank %}
                <span class="sr-info-tag">{{ block.settings.tag }}</span>
              {% endif %}
              {% if block.settings.heading != blank %}
                <h3 class="sr-info-heading">{{ block.settings.heading }}</h3>
              {% endif %}
              {% if block.settings.description != blank %}
                <div class="sr-info-desc">{{ block.settings.description | newline_to_br }}</div>
              {% endif %}
            </article>
          {% endfor %}
        </div>
      </section>
    {% endif %}

    {% if story_blocks.size > 0 %}
      <div class="sr-stories">
        {% for block in story_blocks %}
          <div class="sr-story-row {% cycle '', 'row-reverse' %}" {{ block.shopify_attributes }}>
            <div class="sr-story-image">
              <div class="img-reveal-wrapper">
                {% if block.settings.image != blank %}
                  <img src="{{ block.settings.image | image_url: width: 1200 }}" alt="{{ block.settings.heading | escape }}" loading="lazy">
                {% else %}
                  {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}
                {% endif %}
              </div>
            </div>
            <div class="sr-story-content">
              {% if block.settings.tag != blank %}
                <span class="story-tag">{{ block.settings.tag }}</span>
              {% endif %}
              {% if block.settings.heading != blank %}
                <h2 class="story-heading">{{ block.settings.heading }}</h2>
              {% endif %}
              {% if block.settings.description != blank %}
                <div class="story-desc">{{ block.settings.description | newline_to_br }}</div>
              {% endif %}
              {% if block.settings.button_label != blank and block.settings.button_link != blank %}
                <a href="{{ block.settings.button_link }}" class="sr-inline-link">
                  {{ block.settings.button_label }}
                  <span class="line"></span>
                </a>
              {% endif %}
            </div>
          </div>
        {% endfor %}
      </div>
    {% endif %}

    {% if related_blocks.size > 0 %}
      <section class="sr-related-section">
        {% if section.settings.related_section_eyebrow != blank %}
          <span class="sr-section-eyebrow">{{ section.settings.related_section_eyebrow }}</span>
        {% endif %}
        {% if section.settings.related_section_title != blank %}
          <h2 class="sr-section-title">{{ section.settings.related_section_title }}</h2>
        {% endif %}
        {% if section.settings.related_section_intro != blank %}
          <div class="sr-section-intro">{{ section.settings.related_section_intro | newline_to_br }}</div>
        {% endif %}

        <div class="sr-related-grid">
          {% for block in related_blocks %}
            <article class="sr-related-card" {{ block.shopify_attributes }}>
              {% if block.settings.tag != blank %}
                <span class="sr-related-tag">{{ block.settings.tag }}</span>
              {% endif %}
              {% if block.settings.heading != blank %}
                <h3 class="sr-related-heading">{{ block.settings.heading }}</h3>
              {% endif %}
              {% if block.settings.description != blank %}
                <div class="sr-related-desc">{{ block.settings.description | newline_to_br }}</div>
              {% endif %}
              {% if block.settings.button_label != blank and block.settings.button_link != blank %}
                <a href="{{ block.settings.button_link }}" class="sr-related-link">
                  {{ block.settings.button_label }}
                  <span class="line"></span>
                </a>
              {% endif %}
            </article>
          {% endfor %}
        </div>
      </section>
    {% endif %}

    <section class="sr-cta-section">
      {% if section.settings.cta_eyebrow != blank %}
        <span class="sr-section-eyebrow">{{ section.settings.cta_eyebrow }}</span>
      {% endif %}
      {% if section.settings.cta_title != blank %}
        <h2 class="sr-section-title">{{ section.settings.cta_title }}</h2>
      {% endif %}
      {% if section.settings.cta_intro != blank %}
        <div class="sr-section-intro">{{ section.settings.cta_intro | newline_to_br }}</div>
      {% endif %}

      <div class="sr-cta-shell">
        {% if section.settings.cta_box_title != blank %}
          <h3 class="sr-cta-title">{{ section.settings.cta_box_title }}</h3>
        {% endif %}
        {% if section.settings.cta_box_desc != blank %}
          <div class="sr-cta-desc">{{ section.settings.cta_box_desc | newline_to_br }}</div>
        {% endif %}

        <div class="sr-cta-actions">
          {% if section.settings.cta_primary_label != blank and section.settings.cta_primary_url != blank %}
            <a href="{{ section.settings.cta_primary_url }}" class="sr-cta-btn primary">{{ section.settings.cta_primary_label }}</a>
          {% endif %}
          {% if section.settings.cta_secondary_label != blank and section.settings.cta_secondary_url != blank %}
            <a href="{{ section.settings.cta_secondary_url }}" class="sr-cta-btn secondary">{{ section.settings.cta_secondary_label }}</a>
          {% endif %}
        </div>
      </div>
    </section>

    {% if faq_blocks.size > 0 %}
      <section class="sr-faq-section">
        {% if section.settings.faq_section_eyebrow != blank %}
          <span class="sr-section-eyebrow">{{ section.settings.faq_section_eyebrow }}</span>
        {% endif %}
        {% if section.settings.faq_section_title != blank %}
          <h2 class="sr-section-title">{{ section.settings.faq_section_title }}</h2>
        {% endif %}
        {% if section.settings.faq_section_intro != blank %}
          <div class="sr-section-intro">{{ section.settings.faq_section_intro | newline_to_br }}</div>
        {% endif %}

        <div class="sr-faq-list">
          {% for block in faq_blocks %}
            <details class="sr-faq-item" {{ block.shopify_attributes }}>
              <summary class="sr-faq-question">
                <span>{{ block.settings.question }}</span>
                <span class="sr-faq-icon"></span>
              </summary>
              <div class="sr-faq-answer">
                {{ block.settings.answer | newline_to_br }}
              </div>
            </details>
          {% endfor %}
        </div>
      </section>
    {% endif %}
  </div>
</div>

{% if faq_blocks.size > 0 %}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {% for block in faq_blocks %}
        {
          "@type": "Question",
          "name": {{ block.settings.question | strip_html | strip | json }},
          "acceptedAnswer": {
            "@type": "Answer",
            "text": {{ block.settings.answer | strip_html | strip | json }}
          }
        }{% unless forloop.last %},{% endunless %}
      {% endfor %}
    ]
  }
  </script>
{% endif %}

{% if page %}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "name": "Home",
        "item": {{ request.origin | append: '/' | json }}
      },
      {
        "@type": "ListItem",
        "position": 2,
        "name": {{ page.title | json }},
        "item": {{ request.origin | append: page.url | json }}
      }
    ]
  }
  </script>
{% endif %}

{% schema %}
{
  "name": "Shangri-La Page Stories ",
  "settings": [
    { "type": "text", "id": "main_title", "label": "主标题", "default": "Shangri-La Travel Guide" },
    { "type": "text", "id": "sub_title", "label": "副标题", "default": "THE LOST HORIZON" },
    { "type": "textarea", "id": "intro_text", "label": "引言描述", "default": "Shangri-La reveals a higher, quieter, and more spiritual side of Yunnan, where Tibetan culture, sacred monasteries, alpine forests, and wide plateau skies shape every journey." },

    { "type": "text", "id": "info_section_eyebrow", "label": "实用信息区眉题", "default": "PLAN YOUR STAY" },
    { "type": "text", "id": "info_section_title", "label": "实用信息区标题", "default": "Know Shangri-La at a Glance" },
    { "type": "textarea", "id": "info_section_intro", "label": "实用信息区简介", "default": "A quick guide to why Shangri-La matters, what to see, when to go, and how to plan your time on the plateau." },

    { "type": "text", "id": "related_section_eyebrow", "label": "相关线路区眉题", "default": "RELATED TOURS" },
    { "type": "text", "id": "related_section_title", "label": "相关线路区标题", "default": "Continue Through the Tibetan Highlands" },
    { "type": "textarea", "id": "related_section_intro", "label": "相关线路区简介", "default": "Explore routes that connect Shangri-La with classic Yunnan highlights, sacred mountains, and deeper highland landscapes." },

    { "type": "text", "id": "cta_eyebrow", "label": "CTA区眉题", "default": "PLAN YOUR PRIVATE TRIP" },
    { "type": "text", "id": "cta_title", "label": "CTA区标题", "default": "Turn This Guide Into a Real Journey" },
    { "type": "textarea", "id": "cta_intro", "label": "CTA区简介", "default": "If Shangri-La feels like the missing piece of your Yunnan route, start from the guide and move straight into a private itinerary." },
    { "type": "text", "id": "cta_box_title", "label": "CTA主标题", "default": "Plan a Private Trip to Shangri-La" },
    { "type": "textarea", "id": "cta_box_desc", "label": "CTA描述", "default": "Choose a ready-made route or start a custom Yunnan plan shaped around altitude comfort, culture, scenic pacing, and your preferred travel style." },
    { "type": "text", "id": "cta_primary_label", "label": "主按钮文案", "default": "VIEW PRIVATE TOURS" },
    { "type": "text", "id": "cta_primary_url", "label": "主按钮链接", "default": "/collections/shangri-la-private-tours" },
    { "type": "text", "id": "cta_secondary_label", "label": "副按钮文案", "default": "CUSTOM TRIP REQUEST" },
    { "type": "text", "id": "cta_secondary_url", "label": "副按钮链接", "default": "/pages/contact-us" },

    { "type": "text", "id": "faq_section_eyebrow", "label": "FAQ区眉题", "default": "FAQ" },
    { "type": "text", "id": "faq_section_title", "label": "FAQ区标题", "default": "Before You Go" },
    { "type": "textarea", "id": "faq_section_intro", "label": "FAQ区简介", "default": "Helpful answers for travelers planning a first visit to Shangri-La." }
