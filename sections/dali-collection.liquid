<section class="luxury-collection-wrapper" id="CollectionProductGrid-{{ section.id }}">
  {%- assign is_dali_private_tours = false -%}
  {%- if collection.handle == 'dali-private-tours' -%}
    {%- assign is_dali_private_tours = true -%}
  {%- endif -%}

  <!-- 1) HERO -->
  <header class="coll-hero-compact">
    <div class="hero-bg">
      {% if collection.image %}
        <img src="{{ collection.image | image_url: width: 2400 }}" alt="{{ collection.title | escape }} - Lynxtour" class="hero-img">
      {% else %}
        <div class="hero-placeholder"></div>
      {% endif %}
      <div class="hero-overlay"></div>
    </div>

    <div class="hero-text-container">
      <div class="hero-content">
        <div class="subtitle-wrap">
          <span class="coll-subtitle">
            {% if is_dali_private_tours %}
              BETWEEN CANGSHAN AND ERHAI
            {% else %}
              {{ section.settings.subtitle_text }}
            {% endif %}
          </span>
          <div class="subtitle-line"></div>
        </div>

        <h1 class="coll-title">
          {% if is_dali_private_tours %}
            Dali Private Tours
          {% else %}
            {{ collection.title }}
          {% endif %}
        </h1>

        {% if is_dali_private_tours %}
          <div class="coll-desc-wrap">
            <div class="coll-desc">
              Discover Dali with a private itinerary shaped around Erhai Lake, Bai culture, old-town streets, and a slower pace.
              <br>
              Compare short Dali stays and longer western Yunnan routes that use Dali as a key stop.
            </div>
          </div>
        {% elsif collection.description != blank %}
          <div class="coll-desc-wrap">
            <div class="coll-desc">{{ collection.description | strip_html }}</div>
          </div>
        {% endif %}

      </div>
    </div>
  </header>

  <!-- 2) LIST -->
  <div class="coll-container">
    {% paginate collection.products by section.settings.page_size %}

      {% if is_dali_private_tours and paginate.current_page == 1 %}
        <section class="collection-copy-block collection-intro-block">
          <div class="collection-copy-inner">
            <h2 class="copy-heading">Why Choose a Private Tour in Dali?</h2>
            <div class="copy-richtext">
              <p>Dali is best enjoyed at a slower pace. A private tour gives you more time for lakeside viewpoints, village streets, Bai culture, and flexible stops around Erhai without being rushed by a fixed group schedule.</p>
              <p>Start here if you want to <a href="/pages/dali">See our Dali travel guide</a>, <a href="/pages/dali-itinerary-3-days">see the Dali itinerary for 3 days</a>, or <a href="/pages/dali-to-lijiang-private-tour">see the Dali to Lijiang private tour</a>.</p>
            </div>
          </div>
        </section>
      {% endif %}

      <div class="coll-meta-bar">
        <div class="meta-left">
          <span class="meta-number">{{ collection.products_count }}</span>
          <span class="meta-label">Selected Experiences</span>
        </div>
        <div class="meta-divider"></div>
        <div class="meta-right">
          <span class="meta-location">
            {% if is_dali_private_tours %}
              DALI / YUNNAN
            {% else %}
              {{ section.settings.location_text }}
            {% endif %}
          </span>
        </div>
      </div>

      <div class="compact-grid" data-cols="{{ section.settings.desktop_cols }}" id="CollectionGrid-{{ section.id }}">
        {% for product in collection.products %}
          {% liquid
            assign included_main_keywords = 'independent group of' | split: '|'
            assign excluded_keywords = 'single room supplement|room supplement|single supplement|supplement|children pricing|child|children|kid|kids|infant|baby|toddler|add-on|addon|upgrade|custom|extra bed|surcharge|儿童|小童|婴儿' | split: '|'

            assign collection_display_price = blank
            assign valid_main_variant_count = 0
            assign found_main_variant = false

            for variant in product.variants
              assign variant_title = variant.title | downcase | strip
              assign is_main_variant = false
              assign is_excluded = false

              for keyword in excluded_keywords
                if variant_title contains keyword
                  assign is_excluded = true
                  break
                endif
              endfor

              unless is_excluded
                for keyword in included_main_keywords
                  if variant_title contains keyword
                    assign is_main_variant = true
                    break
                  endif
                endfor

                if is_main_variant
                  assign found_main_variant = true
                  assign valid_main_variant_count = valid_main_variant_count | plus: 1

                  if collection_display_price == blank or variant.price < collection_display_price
                    assign collection_display_price = variant.price
                  endif
                endif
              endunless
            endfor

            if found_main_variant == false
              assign valid_main_variant_count = 0
              assign collection_display_price = blank

              for variant in product.variants
                assign variant_title = variant.title | downcase | strip
                assign is_excluded = false

                for keyword in excluded_keywords
                  if variant_title contains keyword
                    assign is_excluded = true
                    break
                  endif
                endfor

                unless is_excluded
                  assign valid_main_variant_count = valid_main_variant_count | plus: 1

                  if collection_display_price == blank or variant.price < collection_display_price
                    assign collection_display_price = variant.price
                  endif
                endunless
              endfor
            endif

            if collection_display_price == blank
              assign collection_display_price = product.price
            endif

            assign show_from_prefix = false
            if valid_main_variant_count > 1
              assign show_from_prefix = true
            endif
          %}

          <div class="grid-item reveal-item">
            <a href="{{ product.url }}" class="card-link">
              <div class="card-visual">
                {% if product.featured_image %}
                  <img
                    src="{{ product.featured_image | image_url: width: 1200 }}"
                    alt="{{ product.title | escape }}"
                    loading="lazy"
                  >
                {% else %}
                  <div class="card-img-placeholder"></div>
                {% endif %}

                <div class="card-overlay">
                  <div class="card-btn">SEE TOUR DETAILS</div>
                </div>

                {% if product.tags contains section.settings.badge_tag %}
                  <div class="route-indicator"><span class="dot-pulse"></span>{{ section.settings.badge_text }}</div>
                {% endif %}
              </div>

              <div class="card-content">
                <div class="card-header">
                  <h3 class="product-title">{{ product.title }}</h3>
                  <div class="product-price">
                    {% if show_from_prefix %}
                      <span class="price-prefix">From </span>
                    {% endif %}
                    {{ collection_display_price | money_with_currency }}
                  </div>
                </div>
                <div class="product-info-row">
                  <span class="product-type">{{ product.type | default: 'Experience' }}</span>
                </div>
              </div>
            </a>
          </div>
        {% endfor %}
      </div>

      {% if paginate.pages > 1 %}
        <div class="luxury-pagination">
          {{ paginate | default_pagination }}
        </div>
      {% endif %}

      {% if is_dali_private_tours and paginate.current_page == 1 %}
        <section class="collection-copy-block collection-why-block">
          <div class="collection-copy-inner narrow">
            <h2 class="copy-heading">Dali in 2 Days or 3 Days?</h2>
            <div class="copy-richtext">
              <p>A 2-day Dali route covers the main highlights such as Erhai Lake, Dali Old Town, and one or two scenic villages. A 3-day route works better if you want a more relaxed pace, extra time in Xizhou, or a fuller circle around Erhai.</p>
            </div>
          </div>
        </section>

        <section class="collection-copy-block collection-outro-block">
          <div class="collection-copy-inner narrow">
            <h2 class="copy-heading">Can You Combine Dali with Lijiang?</h2>
            <div class="copy-richtext">
              <p>Yes. Dali and Lijiang are one of the easiest and most rewarding pairs in Yunnan. Many travelers start with Dali’s open lake scenery and village life, then continue to Lijiang for old-town atmosphere and mountain views.</p>
              <p><a href="/pages/dali">See our Dali travel guide</a> or <a href="/products/kunming-dali-lijiang-shangri-la-8-day-private-tour">explore the 8-day Yunnan private tour</a>.</p>
            </div>
          </div>
        </section>

        <section class="collection-copy-block collection-faq-block">
          <div class="collection-copy-inner">
            <h2 class="copy-heading">Dali Private Tours FAQ</h2>

            <div class="faq-accordion">
              <div class="faq-acc-item is-open">
                <button type="button" class="faq-acc-trigger" aria-expanded="true">
                  <span class="faq-acc-question">How many days do you need in Dali?</span>
                  <span class="faq-acc-icon" aria-hidden="true"></span>
                </button>
                <div class="faq-acc-panel" style="max-height: 260px;">
                  <div class="faq-acc-answer">
                    <p>For a first visit, 2 to 3 days in Dali is often ideal. This gives you enough time to experience Dali Old Town, Erhai Lake, and one or two nearby cultural or scenic areas such as Xizhou or Cangshan. If you prefer a slower pace or want to combine Dali with Lijiang or Shangri-La, 4 to 6 days can be a better fit.</p>
                  </div>
                </div>
              </div>

              <div class="faq-acc-item">
                <button type="button" class="faq-acc-trigger" aria-expanded="false">
                  <span class="faq-acc-question">Is Dali suitable for first-time visitors to Yunnan?</span>
                  <span class="faq-acc-icon" aria-hidden="true"></span>
                </button>
                <div class="faq-acc-panel">
                  <div class="faq-acc-answer">
                    <p>Yes. Dali is one of the best places for first-time visitors to Yunnan, especially for travelers who want a gentler pace, scenic landscapes, and cultural depth without the intensity of a major city. It also connects very well with other classic Yunnan destinations, making it a strong stop within a wider itinerary.</p>
                  </div>
                </div>
              </div>

              <div class="faq-acc-item">
                <button type="button" class="faq-acc-trigger" aria-expanded="false">
                  <span class="faq-acc-question">What can be included in a Dali private tour?</span>
                  <span class="faq-acc-icon" aria-hidden="true"></span>
                </button>
                <div class="faq-acc-panel">
                  <div class="faq-acc-answer">
                    <p>Depending on the route, a Dali private tour can include Dali Old Town, Erhai Lake, Xizhou, Zhoucheng, Cangshan viewpoints, Bai cultural experiences, and connections with nearby destinations such as Lijiang, Shaxi, or Shangri-La. Different itineraries can be adjusted according to pace, interests, and season.</p>
                  </div>
                </div>
              </div>

              <div class="faq-acc-item">
                <button type="button" class="faq-acc-trigger" aria-expanded="false">
                  <span class="faq-acc-question">Can Dali be combined with Lijiang and Shangri-La?</span>
                  <span class="faq-acc-icon" aria-hidden="true"></span>
                </button>
                <div class="faq-acc-panel">
                  <div class="faq-acc-answer">
                    <p>Absolutely. Dali is very often combined with Lijiang and Shangri-La as part of a classic northwest Yunnan route. It works especially well as a scenic and more relaxed stop between the stronger cultural atmosphere of Lijiang and the higher-altitude landscapes of Shangri-La.</p>
                  </div>
                </div>
              </div>

              <div class="faq-acc-item">
                <button type="button" class="faq-acc-trigger" aria-expanded="false">
                  <span class="faq-acc-question">Who are Dali private tours best suited for?</span>
                  <span class="faq-acc-icon" aria-hidden="true"></span>
                </button>
                <div class="faq-acc-panel">
                  <div class="faq-acc-answer">
                    <p>Dali private tours are especially well suited to couples, families, slow-travel lovers, photographers, and travelers who prefer a more flexible and less hurried experience. They are also a good choice for visitors who want to enjoy Yunnan’s landscapes and culture in a more comfortable and curated way.</p>
                  </div>
                </div>
              </div>

              <div class="faq-acc-item">
                <button type="button" class="faq-acc-trigger" aria-expanded="false">
                  <span class="faq-acc-question">When is the best time to visit Dali?</span>
                  <span class="faq-acc-icon" aria-hidden="true"></span>
                </button>
                <div class="faq-acc-panel">
                  <div class="faq-acc-answer">
                    <p>Dali can be visited throughout the year, but spring and autumn are often especially pleasant for weather, visibility, and overall travel comfort. Summer brings greener scenery around Erhai and the surrounding mountains, while winter can feel quieter and more open. The best season depends on whether you prioritize scenery, weather, photography, or a wider Yunnan route.</p>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </section>

        <script type="application/ld+json">
        {
          "@context": "https://schema.org",
          "@type": "FAQPage",
          "mainEntity": [
            {
              "@type": "Question",
              "name": "How many days do you need in Dali?",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "For a first visit, 2 to 3 days in Dali is often ideal. This gives you enough time to experience Dali Old Town, Erhai Lake, and one or two nearby cultural or scenic areas such as Xizhou or Cangshan. If you prefer a slower pace or want to combine Dali with Lijiang or Shangri-La, 4 to 6 days can be a better fit."
              }
            },
            {
              "@type": "Question",
              "name": "Is Dali suitable for first-time visitors to Yunnan?",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "Yes. Dali is one of the best places for first-time visitors to Yunnan, especially for travelers who want a gentler pace, scenic landscapes, and cultural depth without the intensity of a major city. It also connects very well with other classic Yunnan destinations, making it a strong stop within a wider itinerary."
              }
            },
            {
              "@type": "Question",
              "name": "What can be included in a Dali private tour?",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "Depending on the route, a Dali private tour can include Dali Old Town, Erhai Lake, Xizhou, Zhoucheng, Cangshan viewpoints, Bai cultural experiences, and connections with nearby destinations such as Lijiang, Shaxi, or Shangri-La. Different itineraries can be adjusted according to pace, interests, and season."
              }
            },
            {
              "@type": "Question",
              "name": "Can Dali be combined with Lijiang and Shangri-La?",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "Absolutely. Dali is very often combined with Lijiang and Shangri-La as part of a classic northwest Yunnan route. It works especially well as a scenic and more relaxed stop between the stronger cultural atmosphere of Lijiang and the higher-altitude landscapes of Shangri-La."
              }
            },
            {
              "@type": "Question",
              "name": "Who are Dali private tours best suited for?",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "Dali private tours are especially well suited to couples, families, slow-travel lovers, photographers, and travelers who prefer a more flexible and less hurried experience. They are also a good choice for visitors who want to enjoy Yunnan’s landscapes and culture in a more comfortable and curated way."
              }
            },
            {
              "@type": "Question",
              "name": "When is the best time to visit Dali?",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "Dali can be visited throughout the year, but spring and autumn are often especially pleasant for weather, visibility, and overall travel comfort. Summer brings greener scenery around Erhai and the surrounding mountains, while winter can feel quieter and more open. The best season depends on whether you prioritize scenery, weather, photography, or a wider Yunnan route."
              }
            }
          ]
        }
        </script>

      {% endif %}

    {% endpaginate %}
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "name": "Home",
          "item": {{ request.origin | append: '/' | json }}
        },
        {
          "@type": "ListItem",
          "position": 2,
          "name": {{ collection.title | json }},
          "item": {{ canonical_url | json }}
        }
      ]
    }
    </script>
  </div>
</section>

<style>
  #CollectionProductGrid-{{ section.id }}{
    background-color: #050505;
    color: #fff;
    overflow: hidden;
    --header-safe: var(--page-first-copy-offset, 114px);
  }

  /* --- HERO SECTION --- */
  #CollectionProductGrid-{{ section.id }} .coll-hero-compact{
    height: {{ section.settings.hero_height_vh }}vh;
    min-height: {{ section.settings.hero_min_height }}px;
    position: relative;
    display:flex;
    align-items:center;
    justify-content:center;
    padding-top: var(--header-safe);
    box-sizing: border-box;
  }

  #CollectionProductGrid-{{ section.id }} .hero-bg{
    position:absolute;
    inset:0;
    z-index:1;
  }

  #CollectionProductGrid-{{ section.id }} .hero-img{
    width:100%;
    height:100%;
    object-fit:cover;
    filter: brightness({{ section.settings.hero_brightness | divided_by: 100.0 }});
  }

  #CollectionProductGrid-{{ section.id }} .hero-placeholder{
    background:#111;
    width:100%;
    height:100%;
  }

  #CollectionProductGrid-{{ section.id }} .hero-overlay{
    position:absolute;
    inset:0;
    background: linear-gradient(to bottom, rgba(5,5,5,0) 0%, rgba(5,5,5,0.9) 100%);
    z-index:2;
  }

  #CollectionProductGrid-{{ section.id }} .hero-text-container{
    position:relative;
    z-index:10;
    text-align:center;
    width:100%;
    padding: 18px 18px 56px;
  }

  #CollectionProductGrid-{{ section.id }} .hero-content{
    max-width: 920px;
    margin: 0 auto;
  }

  #CollectionProductGrid-{{ section.id }} .coll-hero-actions{
    display:flex;
    gap:12px;
    justify-content:center;
    flex-wrap:wrap;
    margin-top: 22px;
  }

  #CollectionProductGrid-{{ section.id }} .coll-hero-btn{
    display:inline-flex;
    align-items:center;
    justify-content:center;
    min-height: 42px;
    padding: 0 16px;
    text-decoration:none;
    border: 1px solid rgba(255,255,255,0.18);
    color:#fff;
    transition: .25s ease;
  }

  #CollectionProductGrid-{{ section.id }} .coll-hero-btn.primary{
    background:#d4af37;
    border-color:#d4af37;
    color:#111;
  }

  #CollectionProductGrid-{{ section.id }} .coll-hero-btn.primary:hover{
    background:#e3bf4e;
    border-color:#e3bf4e;
  }

  #CollectionProductGrid-{{ section.id }} .coll-hero-btn.secondary:hover{
    border-color: rgba(255,255,255,0.34);
    background: rgba(255,255,255,0.03);
  }

  #CollectionProductGrid-{{ section.id }} .coll-subtitle{
    color:#c4b5a6;
    font-size:8px;
    letter-spacing:0.6em;
    text-transform:uppercase;
  }

  #CollectionProductGrid-{{ section.id }} .subtitle-line{
    width:35px;
    height:1px;
    background:#c4b5a6;
    opacity:1;
    margin: 12px auto 0;
  }

  #CollectionProductGrid-{{ section.id }} .coll-title{
    font-family:'Cormorant Garamond', serif;
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight:300;
    font-style:italic;
    margin: 10px 0;
    color:#fff;
  }

  #CollectionProductGrid-{{ section.id }} .coll-desc{
    font-size:13px;
    color:#888;
    max-width: 560px;
    margin: 0 auto;
    line-height: 1.7;
    display: -webkit-box;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 3;
    overflow: hidden;
    text-wrap: balance;
  }

  /* --- CONTAINER --- */
  #CollectionProductGrid-{{ section.id }} .coll-container{
    max-width: 1400px;
    margin: 0 auto;
    padding: 40px 60px 100px;
  }

  /* --- META BAR --- */
  #CollectionProductGrid-{{ section.id }} .coll-meta-bar{
    display:flex;
    align-items:center;
    justify-content:center;
    gap:30px;
    margin-bottom: 48px;
    padding: 20px 0;
    border-top: 1px solid rgba(196,181,166,0.15);
    border-bottom: 1px solid rgba(196,181,166,0.15);
  }

  #CollectionProductGrid-{{ section.id }} .meta-left,
  #CollectionProductGrid-{{ section.id }} .meta-right{
    display:flex;
    align-items:baseline;
    gap:8px;
  }

  #CollectionProductGrid-{{ section.id }} .meta-number{
    font-family:'Cormorant Garamond', serif;
    font-size:24px;
    font-style:italic;
    color:#c4b5a6;
  }

  #CollectionProductGrid-{{ section.id }} .meta-label{
    font-size:9px;
    text-transform:uppercase;
    letter-spacing:0.3em;
    color:#666;
  }

  #CollectionProductGrid-{{ section.id }} .meta-location{
    font-size:10px;
    letter-spacing:0.4em;
    text-transform:uppercase;
    color:#888;
    font-weight:300;
  }

  #CollectionProductGrid-{{ section.id }} .meta-divider{
    width:1px;
    height:20px;
    background: linear-gradient(to bottom, transparent, #c4b5a6, transparent);
    opacity:0.6;
  }

  /* --- COPY BLOCKS --- */
  #CollectionProductGrid-{{ section.id }} .collection-copy-block{
    border-top: 1px solid rgba(196, 181, 166, 0.12);
    padding-top: 42px;
    margin-bottom: 64px;
  }

  #CollectionProductGrid-{{ section.id }} .collection-copy-inner{
    max-width: 980px;
    margin: 0 auto;
  }

  #CollectionProductGrid-{{ section.id }} .collection-copy-inner.narrow{
    max-width: 860px;
  }

  #CollectionProductGrid-{{ section.id }} .copy-heading{
    font-family:'Cormorant Garamond', serif;
    font-size: clamp(1.8rem, 4vw, 2.5rem);
    font-style:italic;
    font-weight:400;
    color:#fff;
    margin: 0 0 22px;
  }

  #CollectionProductGrid-{{ section.id }} .copy-richtext p{
    color:#b4aca3;
    font-size:15px;
    line-height:1.9;
    margin:0 0 18px;
    letter-spacing:0.01em;
  }

  #CollectionProductGrid-{{ section.id }} .copy-richtext a{
    color:#e7d6bf;
    text-decoration:none;
    border-bottom:1px solid rgba(231,214,191,0.28);
  }

  #CollectionProductGrid-{{ section.id }} .copy-richtext a:hover{
    color:#fff;
    border-color: rgba(255,255,255,0.45);
  }

  /* --- FAQ Accordion --- */
  #CollectionProductGrid-{{ section.id }} .collection-faq-block{
    opacity: 0;
    transform: translateY(28px);
    transition: opacity 0.85s cubic-bezier(0.22, 1, 0.36, 1),
                transform 0.85s cubic-bezier(0.22, 1, 0.36, 1);
  }

  #CollectionProductGrid-{{ section.id }} .collection-faq-block.is-visible{
    opacity: 1;
    transform: translateY(0);
  }

  #CollectionProductGrid-{{ section.id }} .collection-faq-block .copy-heading{
    margin-bottom: 26px;
  }

  #CollectionProductGrid-{{ section.id }} .faq-accordion{
    border-top: 1px solid rgba(196, 181, 166, 0.14);
  }

  #CollectionProductGrid-{{ section.id }} .faq-acc-item{
    border-bottom: 1px solid rgba(196, 181, 166, 0.12);
    background: linear-gradient(
      180deg,
      rgba(255,255,255,0.01) 0%,
      rgba(255,255,255,0.005) 100%
    );
    transition: background 0.35s ease, border-color 0.35s ease;
  }

  #CollectionProductGrid-{{ section.id }} .faq-acc-item:hover{
    background: linear-gradient(
      180deg,
      rgba(196,181,166,0.05) 0%,
      rgba(255,255,255,0.01) 100%
    );
  }

  #CollectionProductGrid-{{ section.id }} .faq-acc-trigger{
    width: 100%;
    background: transparent;
    border: 0;
    color: #fff;
    padding: 22px 0;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    cursor: pointer;
    text-align: left;
  }

  #CollectionProductGrid-{{ section.id }} .faq-acc-question{
    font-size: 17px;
    line-height: 1.5;
    font-weight: 400;
    color: #fff;
    transition: color 0.3s ease;
  }

  #CollectionProductGrid-{{ section.id }} .faq-acc-item:hover .faq-acc-question,
  #CollectionProductGrid-{{ section.id }} .faq-acc-item.is-open .faq-acc-question{
    color: #d8c8b8;
  }

  #CollectionProductGrid-{{ section.id }} .faq-acc-icon{
    position: relative;
    width: 18px;
    height: 18px;
    flex: 0 0 18px;
  }

  #CollectionProductGrid-{{ section.id }} .faq-acc-icon::before,
