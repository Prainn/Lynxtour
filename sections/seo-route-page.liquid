<style>
  .seo-route {
    background: #050505;
    color: #f5f5f4;
    padding: 60px 0;
    font-family: 'Montserrat', sans-serif;
  }

  .seo-route__container {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 40px;
  }

  .seo-route__hero {
    max-width: 1020px;
    margin: 0 auto;
    padding: 120px 20px 110px;
    text-align: center;
  }

  .seo-route__eyebrow,
  .seo-route__section-eyebrow {
    display: block;
    margin-bottom: 16px;
    color: #d4af37;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.34em;
    text-transform: uppercase;
  }

  .seo-route__title,
  .seo-route__section-title,
  .seo-route__cta-title {
    margin: 0;
    color: #fff;
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(2.7rem, 6vw, 4.8rem);
    font-style: italic;
    font-weight: 300;
    line-height: 1.08;
  }

  .seo-route__hero::after {
    content: "";
    display: block;
    width: 1px;
    height: 60px;
    margin: 42px auto 36px;
    background: linear-gradient(to bottom, rgba(212, 175, 55, 0.8), transparent);
  }

  .seo-route__intro,
  .seo-route__section-intro,
  .seo-route__cta-copy {
    max-width: 800px;
    margin: 0 auto;
    color: #cfcac4;
    font-size: 15px;
    line-height: 1.9;
    letter-spacing: 0.02em;
  }

  .seo-route__section {
    padding-bottom: 110px;
    text-align: center;
  }

  .seo-route__grid {
    display: grid;
    gap: 24px;
    margin-top: 44px;
  }

  .seo-route__grid--three {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .seo-route__grid--two {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .seo-route__card {
    min-height: 100%;
    padding: 30px 28px;
    border: 1px solid rgba(255, 255, 255, 0.08);
    background: rgba(255, 255, 255, 0.02);
    text-align: left;
  }

  .seo-route__card-tag {
    display: block;
    margin-bottom: 14px;
    color: #d4af37;
    font-size: 10px;
    letter-spacing: 0.28em;
    text-transform: uppercase;
  }

  .seo-route__card-title {
    margin: 0 0 14px;
    color: #fff;
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.9rem;
    font-style: italic;
    font-weight: 300;
    line-height: 1.15;
  }

  .seo-route__card-copy {
    color: #b9b2ab;
    font-size: 13px;
    line-height: 1.9;
    letter-spacing: 0.02em;
  }

  .seo-route__link {
    display: inline-flex;
    flex-direction: column;
    gap: 8px;
    margin-top: 22px;
    color: #fff;
    text-decoration: none;
    font-size: 11px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
  }

  .seo-route__link-line {
    width: 34px;
    height: 1px;
    background: #d4af37;
    transition: width 0.3s ease;
  }

  .seo-route__link:hover .seo-route__link-line {
    width: 60px;
  }

  .seo-route__cta {
    max-width: 980px;
    margin: 0 auto;
    padding: 48px 42px;
    border: 1px solid rgba(212, 175, 55, 0.16);
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.02), rgba(255, 255, 255, 0.008)),
      radial-gradient(circle at top right, rgba(212, 175, 55, 0.08), transparent 34%);
  }

  .seo-route__cta-title {
    font-size: clamp(2rem, 4vw, 3rem);
    margin-bottom: 16px;
  }

  .seo-route__cta-actions {
    display: flex;
    justify-content: center;
    gap: 14px;
    flex-wrap: wrap;
    margin-top: 30px;
  }

  .seo-route__button {
    min-width: 220px;
    padding: 14px 22px;
    border: 1px solid rgba(255, 255, 255, 0.18);
    color: #fff;
    text-decoration: none;
    font-size: 11px;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    transition: 0.3s ease;
  }

  .seo-route__button--primary {
    background: #d4af37;
    border-color: #d4af37;
    color: #111;
  }

  .seo-route__button--primary:hover {
    background: #e3bf4e;
    border-color: #e3bf4e;
  }

  .seo-route__button--secondary:hover {
    color: #d4af37;
    border-color: rgba(212, 175, 55, 0.5);
  }

  .seo-route__faq-list {
    max-width: 900px;
    margin: 44px auto 0;
    text-align: left;
  }

  .seo-route__faq-item {
    border-top: 1px solid rgba(255, 255, 255, 0.12);
  }

  .seo-route__faq-item:last-child {
    border-bottom: 1px solid rgba(255, 255, 255, 0.12);
  }

  .seo-route__faq-question {
    display: flex;
    justify-content: space-between;
    gap: 20px;
    padding: 24px 0;
    cursor: pointer;
    color: #f5f5f4;
    list-style: none;
    font-size: 15px;
    letter-spacing: 0.02em;
  }

  .seo-route__faq-question::-webkit-details-marker {
    display: none;
  }

  .seo-route__faq-icon {
    position: relative;
    width: 14px;
    height: 14px;
    flex: 0 0 14px;
  }

  .seo-route__faq-icon::before,
  .seo-route__faq-icon::after {
    content: "";
    position: absolute;
    left: 50%;
    top: 50%;
    background: #d4af37;
    transform: translate(-50%, -50%);
    transition: opacity 0.25s ease;
  }

  .seo-route__faq-icon::before {
    width: 14px;
    height: 1px;
  }

  .seo-route__faq-icon::after {
    width: 1px;
    height: 14px;
  }

  .seo-route__faq-item[open] .seo-route__faq-icon::after {
    opacity: 0;
  }

  .seo-route__faq-answer {
    padding: 0 0 24px;
    color: #b9b2ab;
    font-size: 13px;
    line-height: 1.9;
    letter-spacing: 0.02em;
  }

  @media (max-width: 989px) {
    .seo-route__container {
      padding: 0 24px;
    }

    .seo-route__hero {
      padding: 84px 10px 90px;
    }

    .seo-route__grid--two,
    .seo-route__grid--three {
      grid-template-columns: 1fr;
    }

    .seo-route__cta {
      padding: 36px 22px;
    }

    .seo-route__cta-actions {
      flex-direction: column;
      align-items: stretch;
    }

    .seo-route__button {
      width: 100%;
      min-width: 0;
      text-align: center;
    }
  }
</style>

<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,500;1,300&family=Montserrat:wght@300;400;600&display=swap" rel="stylesheet">

{% assign feature_blocks = section.blocks | where: 'type', 'feature' %}
{% assign link_blocks = section.blocks | where: 'type', 'link_card' %}
{% assign faq_blocks = section.blocks | where: 'type', 'faq_item' %}

<div class="seo-route" id="section-{{ section.id }}">
  <div class="seo-route__container">
    <header class="seo-route__hero">
      {% if section.settings.eyebrow != blank %}<span class="seo-route__eyebrow">{{ section.settings.eyebrow }}</span>{% endif %}
      <h1 class="seo-route__title">{{ section.settings.title | escape }}</h1>
      {% if section.settings.intro != blank %}<div class="seo-route__intro">{{ section.settings.intro | newline_to_br }}</div>{% endif %}
    </header>

    {% if feature_blocks.size > 0 %}
      <section class="seo-route__section">
        {% if section.settings.features_eyebrow != blank %}<span class="seo-route__section-eyebrow">{{ section.settings.features_eyebrow }}</span>{% endif %}
        {% if section.settings.features_title != blank %}<h2 class="seo-route__section-title">{{ section.settings.features_title }}</h2>{% endif %}
        {% if section.settings.features_intro != blank %}<div class="seo-route__section-intro">{{ section.settings.features_intro | newline_to_br }}</div>{% endif %}
        <div class="seo-route__grid seo-route__grid--three">
          {% for block in feature_blocks %}
            <article class="seo-route__card" {{ block.shopify_attributes }}>
              {% if block.settings.tag != blank %}<span class="seo-route__card-tag">{{ block.settings.tag }}</span>{% endif %}
              {% if block.settings.heading != blank %}<h3 class="seo-route__card-title">{{ block.settings.heading }}</h3>{% endif %}
              {% if block.settings.copy != blank %}<div class="seo-route__card-copy">{{ block.settings.copy | newline_to_br }}</div>{% endif %}
            </article>
          {% endfor %}
        </div>
      </section>
    {% endif %}

    {% if link_blocks.size > 0 %}
      <section class="seo-route__section">
        {% if section.settings.links_eyebrow != blank %}<span class="seo-route__section-eyebrow">{{ section.settings.links_eyebrow }}</span>{% endif %}
        {% if section.settings.links_title != blank %}<h2 class="seo-route__section-title">{{ section.settings.links_title }}</h2>{% endif %}
        {% if section.settings.links_intro != blank %}<div class="seo-route__section-intro">{{ section.settings.links_intro | newline_to_br }}</div>{% endif %}
        <div class="seo-route__grid seo-route__grid--two">
          {% for block in link_blocks %}
            <article class="seo-route__card" {{ block.shopify_attributes }}>
              {% if block.settings.tag != blank %}<span class="seo-route__card-tag">{{ block.settings.tag }}</span>{% endif %}
              {% if block.settings.heading != blank %}<h3 class="seo-route__card-title">{{ block.settings.heading }}</h3>{% endif %}
              {% if block.settings.copy != blank %}<div class="seo-route__card-copy">{{ block.settings.copy | newline_to_br }}</div>{% endif %}
              {% if block.settings.link_label != blank and block.settings.link_url != blank %}
                <a class="seo-route__link" href="{{ block.settings.link_url }}">
                  {{ block.settings.link_label }}
                  <span class="seo-route__link-line"></span>
                </a>
              {% endif %}
            </article>
          {% endfor %}
        </div>
      </section>
    {% endif %}

    {% if section.settings.cta_title != blank or section.settings.cta_copy != blank %}
      <section class="seo-route__section">
        {% if section.settings.cta_eyebrow != blank %}<span class="seo-route__section-eyebrow">{{ section.settings.cta_eyebrow }}</span>{% endif %}
        <div class="seo-route__cta">
          {% if section.settings.cta_title != blank %}<h2 class="seo-route__cta-title">{{ section.settings.cta_title }}</h2>{% endif %}
          {% if section.settings.cta_copy != blank %}<div class="seo-route__cta-copy">{{ section.settings.cta_copy | newline_to_br }}</div>{% endif %}
          <div class="seo-route__cta-actions">
            {% if section.settings.cta_primary_label != blank and section.settings.cta_primary_url != blank %}
              <a class="seo-route__button seo-route__button--primary" href="{{ section.settings.cta_primary_url }}">{{ section.settings.cta_primary_label }}</a>
            {% endif %}
            {% if section.settings.cta_secondary_label != blank and section.settings.cta_secondary_url != blank %}
              <a class="seo-route__button seo-route__button--secondary" href="{{ section.settings.cta_secondary_url }}">{{ section.settings.cta_secondary_label }}</a>
            {% endif %}
          </div>
        </div>
      </section>
    {% endif %}

    {% if faq_blocks.size > 0 %}
      <section class="seo-route__section">
        {% if section.settings.faq_eyebrow != blank %}<span class="seo-route__section-eyebrow">{{ section.settings.faq_eyebrow }}</span>{% endif %}
        {% if section.settings.faq_title != blank %}<h2 class="seo-route__section-title">{{ section.settings.faq_title }}</h2>{% endif %}
        {% if section.settings.faq_intro != blank %}<div class="seo-route__section-intro">{{ section.settings.faq_intro | newline_to_br }}</div>{% endif %}
        <div class="seo-route__faq-list">
          {% for block in faq_blocks %}
            <details class="seo-route__faq-item" {{ block.shopify_attributes }}>
              <summary class="seo-route__faq-question">
                <span>{{ block.settings.question }}</span>
                <span class="seo-route__faq-icon"></span>
              </summary>
              <div class="seo-route__faq-answer">{{ block.settings.answer | newline_to_br }}</div>
            </details>
          {% endfor %}
        </div>
      </section>
    {% endif %}
  </div>
</div>

{% if faq_blocks.size > 0 %}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {% for block in faq_blocks %}
        {
          "@type": "Question",
          "name": {{ block.settings.question | strip_html | strip | json }},
          "acceptedAnswer": {
            "@type": "Answer",
            "text": {{ block.settings.answer | strip_html | strip | json }}
          }
        }{% unless forloop.last %},{% endunless %}
      {% endfor %}
    ]
  }
  </script>
{% endif %}

{% if product %}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": {{ request.origin | append: '/' | json }} },
      { "@type": "ListItem", "position": 2, "name": "Private Tours", "item": {{ request.origin | append: '/collections/yunnan-private-tours' | json }} },
      { "@type": "ListItem", "position": 3, "name": {{ product.title | json }}, "item": {{ request.origin | append: product.url | json }} }
    ]
  }
  </script>
{% endif %}

{% schema %}
{
  "name": "SEO Route Page",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "PRIVATE TOUR" },
    { "type": "text", "id": "title", "label": "H1 title", "default": "Sample route title" },
    { "type": "textarea", "id": "intro", "label": "Intro" },
    { "type": "text", "id": "features_eyebrow", "label": "Features eyebrow", "default": "WHY THIS WORKS" },
    { "type": "text", "id": "features_title", "label": "Features title", "default": "What this private route covers" },
    { "type": "textarea", "id": "features_intro", "label": "Features intro" },
    { "type": "text", "id": "links_eyebrow", "label": "Links eyebrow", "default": "ROUTE CONNECTIONS" },
    { "type": "text", "id": "links_title", "label": "Links title", "default": "Connect this route with the wider trip" },
    { "type": "textarea", "id": "links_intro", "label": "Links intro" },
    { "type": "text", "id": "cta_eyebrow", "label": "CTA eyebrow", "default": "CUSTOM SUPPORT" },
    { "type": "text", "id": "cta_title", "label": "CTA title", "default": "Ready to shape this into your own route?" },
    { "type": "textarea", "id": "cta_copy", "label": "CTA copy" },
    { "type": "text", "id": "cta_primary_label", "label": "Primary CTA label", "default": "Browse private tours" },
    { "type": "url", "id": "cta_primary_url", "label": "Primary CTA URL" },
    { "type": "text", "id": "cta_secondary_label", "label": "Secondary CTA label", "default": "Plan a custom Yunnan itinerary" },
    { "type": "url", "id": "cta_secondary_url", "label": "Secondary CTA URL" },
    { "type": "text", "id": "faq_eyebrow", "label": "FAQ eyebrow", "default": "FAQ" },
    { "type": "text", "id": "faq_title", "label": "FAQ title", "default": "Common questions" },
    { "type": "textarea", "id": "faq_intro", "label": "FAQ intro" }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature card",
      "settings": [
        { "type": "text", "id": "tag", "label": "Tag", "default": "COVERAGE" },
        { "type": "text", "id": "heading", "label": "Heading", "default": "What the route covers" },
        { "type": "textarea", "id": "copy", "label": "Copy" }
      ]
    },
    {
      "type": "link_card",
      "name": "Link card",
      "settings": [
        { "type": "text", "id": "tag", "label": "Tag", "default": "ROUTE SUPPORT" },
        { "type": "text", "id": "heading", "label": "Heading", "default": "Continue planning" },
        { "type": "textarea", "id": "copy", "label": "Copy" },
        { "type": "text", "id": "link_label", "label": "Link label", "default": "Browse related routes" },
        { "type": "url", "id": "link_url", "label": "Link URL" }
      ]
    },
    {
      "type": "faq_item",
      "name": "FAQ item",
      "settings": [
        { "type": "text", "id": "question", "label": "Question", "default": "Can this route be customized?" },
        { "type": "textarea", "id": "answer", "label": "Answer" }
      ]
    }
  ],
  "presets": [
    { "name": "SEO Route Page" }
  ]
}
{% endschema %}
