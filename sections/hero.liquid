<div class="hero-section" id="Hero-{{ section.id }}">
  <!-- 1. 顶部导航栏 -->
  <nav class="hero-header">
    <div class="logo-wrapper">
      {% if section.settings.logo_image != blank %}
        <img src="{{ section.settings.logo_image | img_url: '200x' }}" 
             alt="{{ shop.name }}" 
             class="hero-logo-img">
      {% endif %}
      <span class="hero-logo-text">{{ section.settings.logo_text }}</span>
    </div>

    <ul class="hero-nav-links">
      {% for link in section.settings.main_menu.links %}
        <li><a href="{{ link.url }}" class="hero-nav-item">{{ link.title }}</a></li>
      {% endfor %}
    </ul>
  </nav>

  <div class="hero-bg-container">
    <div class="hero-bg-image"></div>
  </div>
  
  <div class="hero-overlay"></div>
  
  <div class="hero-content">
    <h1 class="hero-title">{{ section.settings.main_title }}</h1>
    
    {% if section.settings.sub_title != blank %}
      <p class="hero-subtitle">{{ section.settings.sub_title }}</p>
    {% endif %}
    
    <!-- 修改：按钮容器 -->
    <div class="hero-button-wrapper">
      {% if section.settings.button_text != blank %}
        <a href="{{ section.settings.button_link }}" class="hero-btn hero-btn-primary">
          {{ section.settings.button_text }}
          <span class="btn-pulse"></span>
        </a>
      {% endif %}

      <!-- 新增：第二个按钮 -->
      {% if section.settings.button_text_2 != blank %}
        <a href="{{ section.settings.button_link_2 }}" class="hero-btn hero-btn-secondary">
          {{ section.settings.button_text_2 }}
        </a>
      {% endif %}
    </div>
  </div>

  <div class="scroll-guide">
    <div class="mouse"><div class="wheel"></div></div>
    <span class="scroll-text">SCROLL TO EXPLORE</span>
  </div>
</div>

<style>
  /* --- 导航样式 (同上) --- */
  .hero-header {
    position: absolute; top: 0; left: 0; width: 100%; padding: 30px 60px;
    z-index: 10; display: flex; align-items: center; justify-content: space-between;
  }
  .hero-nav-links { display: flex; list-style: none; gap: 40px; margin: 0; padding: 0; }
  .hero-nav-item { color: #ffffff; text-decoration: none; font-size: 0.85rem; letter-spacing: 0.15em; text-transform: uppercase; opacity: 0.8; }
  
  @media (max-width: 990px) { .hero-nav-links { display: none; } .hero-header { justify-content: center; } }

  /* --- 修改：按钮布局样式 --- */
  .hero-button-wrapper {
    display: flex;
    gap: 20px; /* 两个按钮之间的间距 */
    justify-content: center;
    align-items: center;
    flex-wrap: wrap; /* 手机端自动换行 */
  }

  .hero-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 18px 45px;
    text-decoration: none;
    font-size: 0.9rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    border-radius: 60px;
    position: relative;
    transition: all 0.4s cubic-bezier(0.19, 1, 0.22, 1);
    min-width: 200px;
  }

  /* 主按钮样式 (带背景) */
  .hero-btn-primary {
    background-color: {{ section.settings.btn_color }};
    color: {{ section.settings.btn_text_color }};
    box-shadow: 0 10px 40px {{ section.settings.btn_color | color_modify: 'alpha', 0.3 }};
  }

  /* 新增：次要按钮样式 (描边) */
  .hero-btn-secondary {
    background-color: transparent;
    color: #ffffff;
    border: 1px solid rgba(255,255,255,0.4);
    backdrop-filter: blur(5px);
  }

  .hero-btn:hover {
    transform: translateY(-5px);
    background-color: #ffffff;
    color: #1c1917;
    border-color: #ffffff;
  }

  .btn-pulse {
    position: absolute; inset: 0; border-radius: 60px;
    background: {{ section.settings.btn_color | color_modify: 'alpha', 0.5 }};
    z-index: -1;
    animation: btnBreath 3s infinite;
  }

  @keyframes btnBreath { 0% { transform: scale(1); opacity: 0.8; } 100% { transform: scale(1.6); opacity: 0; } }

  /* --- 基础布局保持不变 --- */
  .hero-section { position: relative; width: 100%; height: 100vh; display: flex; align-items: center; justify-content: center; text-align: center; color: #ffffff; overflow: hidden; background: #1c1917; }
  .hero-bg-container { position: absolute; inset: 0; z-index: 0; }
  .hero-bg-image { width: 100%; height: 100%; {% if section.settings.hero_image != blank %} background-image: url('{{ section.settings.hero_image | img_url: '2000x' }}'); {% endif %} background-size: cover; background-position: center {{ section.settings.bg_alignment }}; animation: kenBurns 20s infinite alternate; }
  @keyframes kenBurns { 0% { transform: scale(1); } 100% { transform: scale(1.15); } }
  .hero-overlay { position: absolute; inset: 0; background: linear-gradient(to bottom, rgba(0,0,0,0.3), rgba(0,0,0,0.6)); z-index: 1; }
  .hero-content { position: relative; z-index: 2; padding: 0 24px; max-width: 1200px; }
  .hero-title { font-size: clamp(2.6rem, 8vw, 5.5rem); font-weight: 800; margin-bottom: 20px; text-transform: uppercase; }
  .hero-subtitle { color: {{ section.settings.btn_color }}; font-size: clamp(0.9rem, 2.5vw, 1.2rem); letter-spacing: 0.6em; text-transform: uppercase; margin-bottom: 50px; display: block; }

  .scroll-guide { position: absolute; bottom: 40px; left: 50%; transform: translateX(-50%); z-index: 2; display: flex; flex-direction: column; align-items: center; gap: 12px; opacity: 0.7; }
  .mouse { width: 24px; height: 40px; border: 2px solid #fff; border-radius: 20px; position: relative; }
  .wheel { width: 2px; height: 8px; background: {{ section.settings.btn_color }}; position: absolute; top: 8px; left: 50%; transform: translateX(-50%); animation: mouseScroll 2s infinite; }
  @keyframes mouseScroll { 0% { opacity: 0; transform: translate(-50%, 0); } 100% { opacity: 0; transform: translate(-50%, 20px); } }
  .scroll-text { font-size: 9px; letter-spacing: 4px; }

  @media (max-width: 767px) {
    .hero-section { height: 95vh; }
    .hero-title { font-size: 2.8rem; }
    .hero-btn { width: 100%; padding: 15px 30px; } /* 移动端按钮宽度撑满更美观 */
  }
</style>

{% schema %}
{
  "name": "Hero Banner Pro",
  "settings": [
    { "type": "header", "content": "导航与Logo设置" },
    { "type": "link_list", "id": "main_menu", "label": "选择菜单", "default": "main-menu" },
    { "type": "image_picker", "id": "logo_image", "label": "品牌图片Logo" },
    { "type": "range", "id": "logo_height", "label": "Logo 高度", "min": 20, "max": 100, "step": 5, "unit": "px", "default": 40 },
    { "type": "text", "id": "logo_text", "label": "品牌文字Logo", "default": "YUNNAN TRAVEL" },
    
    { "type": "header", "content": "背景设置" },
    { "type": "image_picker", "id": "hero_image", "label": "背景大图" },
    { "type": "select", "id": "bg_alignment", "label": "手机端背景中心", "options": [ { "value": "left", "label": "靠左" }, { "value": "center", "label": "居中" }, { "value": "right", "label": "靠右" } ], "default": "center" },
    
    { "type": "header", "content": "按钮 1 (主按钮)" },
    { "type": "text", "id": "button_text", "label": "按钮1文字", "default": "立即开启定制" },
    { "type": "url", "id": "button_link", "label": "按钮1链接" },
    { "type": "color", "id": "btn_color", "label": "主色调 (按钮/副标题)", "default": "#fbbf24" },
    { "type": "color", "id": "btn_text_color", "label": "按钮1文字颜色", "default": "#1c1917" },
    
    { "type": "header", "content": "按钮 2 (新增次要按钮)" },
    { "type": "text", "id": "button_text_2", "label": "按钮2文字", "default": "了解更多" },
    { "type": "url", "id": "button_link_2", "label": "按钮2链接" },
    
    { "type": "header", "content": "内容设置" },
    { "type": "text", "id": "main_title", "label": "主标题 (大字)", "default": "探索云之南" },
    { "type": "text", "id": "sub_title", "label": "副标题 (小字)", "default": "PRIVATE & BESPOKE TRAVEL" }
  ],
  "presets": [
    { "name": "Hero Banner Pro" }
  ]
}
{% endschema %}