<style>
  .dali-wrapper {
    background-color: #000;
    color: #fff;
    padding: 60px 0;
    overflow: hidden;
    font-family: 'Montserrat', sans-serif;
  }

  .dali-container {
    max-width: 1300px;
    margin: 0 auto;
    padding: 0 40px;
  }

  .dali-header {
    text-align: center;
    padding: 120px 20px 140px;
    max-width: 1000px;
    margin: 0 auto;
    position: relative;
  }

  .dali-subtitle {
    color: #e2e8f0;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.6em;
    text-transform: uppercase;
    display: block;
    margin-bottom: 30px;
    opacity: 0.8;
  }

  .dali-main-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(3rem, 7vw, 5rem);
    font-weight: 300;
    line-height: 1.1;
    margin-bottom: 45px;
    letter-spacing: 0.1em;
    color: #ffffff;
    font-style: italic;
  }

  .dali-header::after {
    content: "";
    display: block;
    width: 1px;
    height: 60px;
    background: linear-gradient(to bottom, #e2e8f0, transparent);
    margin: 0 auto 45px;
  }

  .dali-intro-text {
    max-width: 700px;
    margin: 0 auto;
    color: #a8a29e;
    line-height: 2;
    font-size: 16px;
    font-weight: 300;
    letter-spacing: 0.05em;
  }



  .dali-header-actions {
    display: flex;
    justify-content: center;
    gap: 14px;
    flex-wrap: wrap;
    margin-top: 34px;
  }

  .dali-quick-btn {
    min-width: 210px;
    padding: 14px 22px;
    text-decoration: none;
    font-size: 11px;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    transition: 0.3s ease;
    border: 1px solid rgba(255,255,255,0.18);
    color: #fff;
    background: transparent;
  }

  .dali-quick-btn.primary {
    background: #d4af37;
    color: #111;
    border-color: #d4af37;
  }

  .dali-quick-btn.primary:hover {
    background: #e3bf4e;
    border-color: #e3bf4e;
  }

  .dali-quick-btn.secondary:hover,
  .dali-quick-btn.tertiary:hover {
    border-color: rgba(212,175,55,0.5);
    color: #d4af37;
  }

  .dali-section-eyebrow {
    display: block;
    color: #e2e8f0;
    font-size: 10px;
    letter-spacing: 0.35em;
    text-transform: uppercase;
    margin-bottom: 14px;
  }

  .dali-section-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(2rem, 4vw, 3.2rem);
    font-style: italic;
    font-weight: 300;
    line-height: 1.15;
    margin: 0 0 18px;
    color: #fff;
  }

  .dali-section-intro {
    max-width: 760px;
    margin: 0 auto;
    color: #cfcac4;
    font-size: 14px;
    line-height: 1.9;
    letter-spacing: 0.02em;
    text-align: center;
  }

  .dali-info-section,
  .dali-related-section,
  .dali-cta-section,
  .dali-faq-section {
    padding: 0 0 120px;
    text-align: center;
  }

  .dali-info-grid {
    margin-top: 48px;
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 24px;
  }

  .dali-info-card {
    background: rgba(255,255,255,0.02);
    border: 1px solid rgba(226,232,240,0.12);
    padding: 30px 28px;
    text-align: left;
    min-height: 100%;
  }

  .dali-info-tag {
    display: block;
    color: #d4af37;
    font-size: 10px;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    margin-bottom: 14px;
  }

  .dali-info-heading {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.9rem;
    font-style: italic;
    font-weight: 300;
    margin: 0 0 14px;
    color: #fff;
  }

  .dali-info-desc {
    color: #b9b2ab;
    font-size: 13px;
    line-height: 1.85;
    letter-spacing: 0.02em;
  }

  .dali-stories {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 0 120px;
    display: flex;
    flex-direction: column;
    gap: 150px;
  }

  .dali-story-row {
    display: flex;
    align-items: center;
    gap: 80px;
    flex-direction: row;
  }

  .dali-story-row.row-reverse {
    flex-direction: row-reverse;
  }

  .dali-story-image {
    flex: 1.2;
    position: relative;
  }

  .dali-story-content {
    flex: 1;
    padding: 20px 0;
  }

  .img-reveal-wrapper {
    overflow: hidden;
    aspect-ratio: 4 / 5;
    position: relative;
    background-color: #1a1a1a;
  }

  .img-reveal-wrapper::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, rgba(0,0,0,0) 60%, rgba(0,0,0,0.28) 100%);
    pointer-events: none;
  }

  .img-reveal-wrapper img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: brightness(0.85) contrast(1.05);
    transition: transform 2s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .dali-story-row:hover img {
    transform: scale(1.05);
  }

  .story-tag {
    color: #d4af37;
    font-size: 10px;
    letter-spacing: 3px;
    text-transform: uppercase;
    margin-bottom: 20px;
    display: block;
  }

  .story-heading {
    font-family: 'Cormorant Garamond', serif;
    font-style: italic;
    font-size: 2.5rem;
    letter-spacing: 0.05em;
    margin-bottom: 24px;
  }

  .story-desc {
    font-family: 'Montserrat', sans-serif;
    font-size: 13px;
    line-height: 1.8;
    letter-spacing: 0.03em;
    color: #a8a29e;
    max-width: 450px;
    font-weight: 300;
  }

  .dali-inline-link,
  .dali-related-link {
    color: #fff;
    text-decoration: none;
    font-size: 11px;
    letter-spacing: 2px;
    display: inline-flex;
    flex-direction: column;
    gap: 8px;
    margin-top: 24px;
  }

  .dali-inline-link .line,
  .dali-related-link .line {
    width: 30px;
    height: 1px;
    background: #d4af37;
    transition: 0.4s;
  }

  .dali-inline-link:hover .line,
  .dali-related-link:hover .line {
    width: 60px;
  }

  .dali-related-grid {
    margin-top: 48px;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 24px;
    text-align: left;
  }

  .dali-related-card {
    background: rgba(255,255,255,0.02);
    border: 1px solid rgba(255,255,255,0.08);
    padding: 28px 24px;
    min-height: 100%;
  }

  .dali-related-tag {
    display: block;
    color: #d4af37;
    font-size: 10px;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    margin-bottom: 14px;
  }

  .dali-related-heading {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.9rem;
    font-style: italic;
    font-weight: 300;
    margin: 0 0 14px;
    color: #fff;
  }

  .dali-related-desc {
    color: #b9b2ab;
    font-size: 13px;
    line-height: 1.85;
    letter-spacing: 0.02em;
  }



  .dali-route-section {
    padding: 0 0 120px;
    text-align: center;
  }

  .dali-route-grid {
    margin-top: 48px;
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 24px;
    text-align: left;
  }

  .dali-route-card {
    background: rgba(255,255,255,0.02);
    border: 1px solid rgba(255,255,255,0.08);
    padding: 30px 28px;
    min-height: 100%;
  }

  .dali-route-tag {
    display: block;
    color: #d4af37;
    font-size: 10px;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    margin-bottom: 14px;
  }

  .dali-route-heading {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.9rem;
    font-style: italic;
    font-weight: 300;
    margin: 0 0 14px;
    color: #fff;
  }

  .dali-route-desc {
    color: #b9b2ab;
    font-size: 13px;
    line-height: 1.85;
    letter-spacing: 0.02em;
  }

  .dali-route-link {
    color: #fff;
    text-decoration: none;
    font-size: 11px;
    letter-spacing: 2px;
    display: inline-flex;
    flex-direction: column;
    gap: 8px;
    margin-top: 24px;
  }

  .dali-route-link .line {
    width: 30px;
    height: 1px;
    background: #d4af37;
    transition: 0.4s;
  }

  .dali-route-link:hover .line {
    width: 60px;
  }

  .dali-cta-shell {
    max-width: 980px;
    margin: 48px auto 0;
    padding: 46px 42px;
    border: 1px solid rgba(212,175,55,0.16);
    background:
      linear-gradient(180deg, rgba(255,255,255,0.02) 0%, rgba(255,255,255,0.008) 100%),
      radial-gradient(circle at top right, rgba(212,175,55,0.08), transparent 35%);
  }

  .dali-cta-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(2rem, 4vw, 3rem);
    font-style: italic;
    font-weight: 300;
    line-height: 1.12;
    margin: 0 0 18px;
    color: #fff;
  }

  .dali-cta-desc {
    max-width: 760px;
    margin: 0 auto;
    color: #cfcac4;
    font-size: 14px;
    line-height: 1.9;
    letter-spacing: 0.02em;
  }

  .dali-cta-actions {
    display: flex;
    justify-content: center;
    gap: 14px;
    flex-wrap: wrap;
    margin-top: 30px;
  }

  .dali-cta-btn {
    min-width: 210px;
    padding: 14px 22px;
    text-decoration: none;
    font-size: 11px;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    transition: 0.3s ease;
  }

  .dali-cta-btn.primary {
    background: #d4af37;
    color: #111;
    border: 1px solid #d4af37;
  }

  .dali-cta-btn.primary:hover {
    background: #e3bf4e;
    border-color: #e3bf4e;
  }

  .dali-cta-btn.secondary {
    background: transparent;
    color: #fff;
    border: 1px solid rgba(255,255,255,0.18);
  }

  .dali-cta-btn.secondary:hover {
    border-color: rgba(212,175,55,0.5);
    color: #d4af37;
  }

  .dali-faq-list {
    max-width: 900px;
    margin: 48px auto 0;
    text-align: left;
  }

  .dali-faq-item {
    border-top: 1px solid rgba(255,255,255,0.12);
    padding: 0;
  }

  .dali-faq-item:last-child {
    border-bottom: 1px solid rgba(255,255,255,0.12);
  }

  .dali-faq-question {
    list-style: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    padding: 24px 0;
    font-size: 15px;
    color: #f5f5f4;
    letter-spacing: 0.02em;
  }

  .dali-faq-question::-webkit-details-marker {
    display: none;
  }

  .dali-faq-icon {
    width: 14px;
    height: 14px;
    position: relative;
    flex: 0 0 14px;
  }

  .dali-faq-icon::before,
  .dali-faq-icon::after {
    content: "";
    position: absolute;
    background: #d4af37;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
    transition: 0.25s ease;
  }

  .dali-faq-icon::before {
    width: 14px;
    height: 1px;
  }

  .dali-faq-icon::after {
    width: 1px;
    height: 14px;
  }

  .dali-faq-item[open] .dali-faq-icon::after {
    opacity: 0;
  }

  .dali-faq-answer {
    color: #b9b2ab;
    font-size: 13px;
    line-height: 1.9;
    letter-spacing: 0.02em;
    padding: 0 0 24px;
    max-width: 760px;
  }

  @media (max-width: 990px) {
    .dali-container {
      padding: 0 24px;
    }

    .dali-header {
      padding: 80px 20px 100px;
    }

    .dali-main-title {
      font-size: 2.8rem;
    }

    .dali-intro-text {
      font-size: 14px;
      line-height: 1.8;
    }

    .dali-story-row,
    .dali-story-row.row-reverse {
      flex-direction: column;
      gap: 40px;
    }

    .dali-stories {
      gap: 80px;
      padding-bottom: 100px;
    }

    .dali-info-grid,
    .dali-related-grid,
    .dali-route-grid {
      grid-template-columns: 1fr;
    }

    .dali-header-actions {
      flex-direction: column;
      align-items: stretch;
      max-width: 420px;
      margin-left: auto;
      margin-right: auto;
    }

    .dali-quick-btn {
      min-width: 0;
      width: 100%;
      text-align: center;
    }

    .dali-cta-shell {
      padding: 34px 22px;
    }

    .dali-cta-actions {
      flex-direction: column;
      align-items: stretch;
    }

    .dali-cta-btn {
      min-width: 0;
      width: 100%;
      text-align: center;
    }
  }
</style>

<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,500;1,300&family=Montserrat:wght@300;400;600&display=swap" rel="stylesheet">

<div class="dali-wrapper" id="section-{{ section.id }}">
  {% assign info_blocks = section.blocks | where: 'type', 'info_item' %}
  {% assign story_blocks = section.blocks | where: 'type', 'story' %}
  {% assign related_blocks = section.blocks | where: 'type', 'related_tour' %}
  {% assign faq_blocks = section.blocks | where: 'type', 'faq_item' %}

  <div class="dali-container">
    <header class="dali-header">
      {% if section.settings.sub_title != blank %}
        <span class="dali-subtitle">{{ section.settings.sub_title }}</span>
      {% endif %}
      {% if section.settings.main_title != blank %}
        <h1 class="dali-main-title">{{ section.settings.main_title }}</h1>
      {% endif %}
      {% if section.settings.intro_text != blank %}
        <div class="dali-intro-text">
          {{ section.settings.intro_text | newline_to_br }}
        </div>
      {% endif %}

      {% assign has_header_actions = false %}
      {% if section.settings.quick_primary_label != blank and section.settings.quick_primary_url != blank %}
        {% assign has_header_actions = true %}
      {% endif %}
      {% if section.settings.quick_secondary_label != blank and section.settings.quick_secondary_url != blank %}
        {% assign has_header_actions = true %}
      {% endif %}
      {% if section.settings.whatsapp_label != blank and section.settings.whatsapp_url != blank %}
        {% assign has_header_actions = true %}
      {% endif %}

      {% if has_header_actions %}
        <div class="dali-header-actions">
          {% if section.settings.quick_primary_label != blank and section.settings.quick_primary_url != blank %}
            <a href="{{ section.settings.quick_primary_url }}" class="dali-quick-btn primary">{{ section.settings.quick_primary_label }}</a>
          {% endif %}
          {% if section.settings.whatsapp_label != blank and section.settings.whatsapp_url != blank %}
            <a href="{{ section.settings.whatsapp_url }}" class="dali-quick-btn secondary" target="_blank" rel="noopener">{{ section.settings.whatsapp_label }}</a>
          {% endif %}
          {% if section.settings.quick_secondary_label != blank and section.settings.quick_secondary_url != blank %}
            <a href="{{ section.settings.quick_secondary_url }}" class="dali-quick-btn tertiary">{{ section.settings.quick_secondary_label }}</a>
          {% endif %}
        </div>
      {% endif %}
    </header>

    {% if info_blocks.size > 0 %}
      <section class="dali-info-section">
        {% if section.settings.info_section_eyebrow != blank %}
          <span class="dali-section-eyebrow">{{ section.settings.info_section_eyebrow }}</span>
        {% endif %}
        {% if section.settings.info_section_title != blank %}
          <h2 class="dali-section-title">{{ section.settings.info_section_title }}</h2>
        {% endif %}
        {% if section.settings.info_section_intro != blank %}
          <div class="dali-section-intro">{{ section.settings.info_section_intro | newline_to_br }}</div>
        {% endif %}

        <div class="dali-info-grid">
          {% for block in info_blocks %}
            <article class="dali-info-card" {{ block.shopify_attributes }}>
              {% if block.settings.tag != blank %}
                <span class="dali-info-tag">{{ block.settings.tag }}</span>
              {% endif %}
              {% if block.settings.heading != blank %}
                <h3 class="dali-info-heading">{{ block.settings.heading }}</h3>
              {% endif %}
              {% if block.settings.description != blank %}
                <div class="dali-info-desc">{{ block.settings.description | newline_to_br }}</div>
              {% endif %}
            </article>
          {% endfor %}
        </div>
      </section>
    {% endif %}

    <section class="dali-route-section">
      <span class="dali-section-eyebrow">ROUTE PLANNING</span>
      <h2 class="dali-section-title">Plan Beyond Dali</h2>
      <div class="dali-section-intro">Use Dali as a relaxed base for Erhai Lake, village culture, and wider western Yunnan journeys that connect smoothly with Lijiang and custom private routes.</div>

      <div class="dali-route-grid">
        <article class="dali-route-card">
          <span class="dali-route-tag">YUNNAN HUB</span>
          <h3 class="dali-route-heading">Explore Yunnan Private Tours</h3>
          <div class="dali-route-desc">Compare broader Yunnan private itineraries if you want to connect Dali with Lijiang, Shangri-La, Kunming, or longer province-wide routes.</div>
          <a href="/collections/yunnan-private-tours" class="dali-route-link">VIEW YUNNAN TOURS<span class="line"></span></a>
        </article>

        <article class="dali-route-card">
          <span class="dali-route-tag">NEXT STOP</span>
          <h3 class="dali-route-heading">Continue to Lijiang</h3>
          <div class="dali-route-desc">Many travelers pair Dali with Lijiang for old-town atmosphere, mountain scenery, and a natural next step through northwest Yunnan.</div>
          <a href="/pages/lijiang" class="dali-route-link">SEE LIJIANG GUIDE<span class="line"></span></a>
        </article>

        <article class="dali-route-card">
          <span class="dali-route-tag">TRAVEL IDEAS</span>
          <h3 class="dali-route-heading">Read More Yunnan Guides</h3>
          <div class="dali-route-desc">Use our wider travel guide library to compare destinations, seasonal advice, and scenic route ideas before choosing your final itinerary.</div>
          <a href="/blogs/travel-guides" class="dali-route-link">BROWSE GUIDES<span class="line"></span></a>
        </article>

        <article class="dali-route-card">
          <span class="dali-route-tag">CUSTOM HELP</span>
          <h3 class="dali-route-heading">Build a Custom Dali Route</h3>
          <div class="dali-route-desc">Need help deciding how many days to stay, whether to circle Erhai, or how to connect Dali with other Yunnan stops? Talk to us directly.</div>
          <a href="/pages/bespoke-custom-travel" class="dali-route-link">CONTACT US<span class="line"></span></a>
        </article>
      </div>
    </section>

    {% if story_blocks.size > 0 %}
      <div class="dali-stories">
        {% for block in story_blocks %}
          <div class="dali-story-row {% cycle '', 'row-reverse' %}" {{ block.shopify_attributes }}>
            <div class="dali-story-image">
              <div class="img-reveal-wrapper">
                {% if block.settings.image != blank %}
                  <img src="{{ block.settings.image | image_url: width: 1200 }}" alt="{{ block.settings.heading | escape }}" loading="lazy">
                {% else %}
                  {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}
                {% endif %}
              </div>
            </div>
            <div class="dali-story-content">
              {% if block.settings.tag != blank %}
                <span class="story-tag">{{ block.settings.tag }}</span>
              {% endif %}
              {% if block.settings.heading != blank %}
                <h2 class="story-heading">{{ block.settings.heading }}</h2>
              {% endif %}
              {% if block.settings.description != blank %}
                <div class="story-desc">{{ block.settings.description | newline_to_br }}</div>
              {% endif %}
              {% if block.settings.button_label != blank and block.settings.button_link != blank %}
                <a href="{{ block.settings.button_link }}" class="dali-inline-link">
                  {{ block.settings.button_label }}
                  <span class="line"></span>
                </a>
              {% endif %}
            </div>
          </div>
        {% endfor %}
      </div>
    {% endif %}

    {% if related_blocks.size > 0 %}
      <section class="dali-related-section">
        {% if section.settings.related_section_eyebrow != blank %}
          <span class="dali-section-eyebrow">{{ section.settings.related_section_eyebrow }}</span>
        {% endif %}
        {% if section.settings.related_section_title != blank %}
          <h2 class="dali-section-title">{{ section.settings.related_section_title }}</h2>
        {% endif %}
        {% if section.settings.related_section_intro != blank %}
          <div class="dali-section-intro">{{ section.settings.related_section_intro | newline_to_br }}</div>
        {% endif %}

        <div class="dali-related-grid">
          {% for block in related_blocks %}
            <article class="dali-related-card" {{ block.shopify_attributes }}>
              {% if block.settings.tag != blank %}
                <span class="dali-related-tag">{{ block.settings.tag }}</span>
              {% endif %}
              {% if block.settings.heading != blank %}
                <h3 class="dali-related-heading">{{ block.settings.heading }}</h3>
              {% endif %}
              {% if block.settings.description != blank %}
                <div class="dali-related-desc">{{ block.settings.description | newline_to_br }}</div>
              {% endif %}
              {% if block.settings.button_label != blank and block.settings.button_link != blank %}
                <a href="{{ block.settings.button_link }}" class="dali-related-link">
                  {{ block.settings.button_label }}
                  <span class="line"></span>
                </a>
              {% endif %}
            </article>
          {% endfor %}
        </div>
      </section>
    {% endif %}

    <section class="dali-cta-section">
      {% if section.settings.cta_eyebrow != blank %}
        <span class="dali-section-eyebrow">{{ section.settings.cta_eyebrow }}</span>
      {% endif %}
      {% if section.settings.cta_title != blank %}
        <h2 class="dali-section-title">{{ section.settings.cta_title }}</h2>
      {% endif %}
      {% if section.settings.cta_intro != blank %}
        <div class="dali-section-intro">{{ section.settings.cta_intro | newline_to_br }}</div>
      {% endif %}

      <div class="dali-cta-shell">
        {% if section.settings.cta_box_title != blank %}
          <h3 class="dali-cta-title">{{ section.settings.cta_box_title }}</h3>
        {% endif %}
        {% if section.settings.cta_box_desc != blank %}
          <div class="dali-cta-desc">{{ section.settings.cta_box_desc | newline_to_br }}</div>
        {% endif %}

        <div class="dali-cta-actions">
          {% if section.settings.cta_primary_label != blank and section.settings.cta_primary_url != blank %}
            <a href="{{ section.settings.cta_primary_url }}" class="dali-cta-btn primary">{{ section.settings.cta_primary_label }}</a>
          {% endif %}
          {% if section.settings.whatsapp_label != blank and section.settings.whatsapp_url != blank %}
            <a href="{{ section.settings.whatsapp_url }}" class="dali-cta-btn secondary" target="_blank" rel="noopener">{{ section.settings.whatsapp_label }}</a>
          {% endif %}
          {% if section.settings.cta_secondary_label != blank and section.settings.cta_secondary_url != blank %}
            <a href="{{ section.settings.cta_secondary_url }}" class="dali-cta-btn secondary">{{ section.settings.cta_secondary_label }}</a>
          {% endif %}
        </div>
      </div>
    </section>

    {% if faq_blocks.size > 0 %}
      <section class="dali-faq-section">
        {% if section.settings.faq_section_eyebrow != blank %}
          <span class="dali-section-eyebrow">{{ section.settings.faq_section_eyebrow }}</span>
        {% endif %}
        {% if section.settings.faq_section_title != blank %}
          <h2 class="dali-section-title">{{ section.settings.faq_section_title }}</h2>
        {% endif %}
        {% if section.settings.faq_section_intro != blank %}
          <div class="dali-section-intro">{{ section.settings.faq_section_intro | newline_to_br }}</div>
        {% endif %}

        <div class="dali-faq-list">
          {% for block in faq_blocks %}
            <details class="dali-faq-item" {{ block.shopify_attributes }}>
              <summary class="dali-faq-question">
                <span>{{ block.settings.question }}</span>
                <span class="dali-faq-icon"></span>
              </summary>
              <div class="dali-faq-answer">
                {{ block.settings.answer | newline_to_br }}
              </div>
            </details>
          {% endfor %}
        </div>
      </section>
    {% endif %}
  </div>
</div>

{% if faq_blocks.size > 0 %}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {% for block in faq_blocks %}
        {
          "@type": "Question",
          "name": {{ block.settings.question | strip_html | strip | json }},
          "acceptedAnswer": {
            "@type": "Answer",
            "text": {{ block.settings.answer | strip_html | strip | json }}
          }
        }{% unless forloop.last %},{% endunless %}
      {% endfor %}
    ]
  }
  </script>
{% endif %}

{% if page %}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "name": "Home",
        "item": {{ request.origin | append: '/' | json }}
      },
      {
        "@type": "ListItem",
        "position": 2,
        "name": {{ page.title | json }},
        "item": {{ request.origin | append: page.url | json }}
      }
    ]
  }
  </script>
{% endif %}

