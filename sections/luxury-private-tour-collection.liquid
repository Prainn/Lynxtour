<div class="luxury-collection-wrapper" id="CollectionProductGrid">

  {%- comment -%} 1. Bright & Full Hero Section (Shangri-La Optimized) {%- endcomment -%}
  <header class="coll-hero-compact">
    <div class="hero-bg">
      {% if collection.image %}
        <img src="{{ collection.image | image_url: width: 2400 }}" alt="{{ collection.title | escape }}" class="hero-img">
      {% else %}
        <div class="hero-placeholder"></div>
      {% endif %}

      {%- comment -%} 高级：轻薄遮罩 + 底部黑场渐变（稳定可读，不会“半黑”） {%- endcomment -%}
      <div class="hero-overlay"></div>
    </div>

    <div class="hero-text-container">
      <div class="hero-content">
        <div class="subtitle-wrap">
          <span class="coll-subtitle">CURATED LUXURY ACROSS YUNNAN</span>
          <div class="subtitle-line"></div>
        </div>

        <h1 class="coll-title">{{ collection.title | default: 'SHANGRI-LA' }}</h1>

        <div class="coll-desc-wrap">
          <div class="coll-desc">
            {% if collection.description != blank %}
              {{ collection.description | strip_html }}
            {% else %}
              At the edge of the Tibetan Plateau, where golden monasteries meet sacred snow peaks. Discover a realm of profound stillness and timeless wonder in our high-altitude sanctuary.
            {% endif %}
          </div>
        </div>
      </div>
    </div>
  </header>

  {%- comment -%} 2. Content Section {%- endcomment -%}
  <div class="coll-container">
    <div class="coll-meta-bar">
      <div class="meta-left">
        <span class="meta-number">{{ collection.products_count }}</span>
        <span class="meta-label">Selected Experiences</span>
      </div>
      <div class="meta-divider"></div>
      <div class="meta-right">
        <span class="meta-location">YUNNAN / CHINA</span>
      </div>
    </div>

    {% paginate collection.products by 12 %}
      <div class="compact-grid" data-cols="3">
        {% for product in collection.products %}
          {% liquid
  assign collection_display_price = blank
  assign valid_main_variant_count = 0

  for variant in product.variants
    assign variant_title = variant.title | downcase | strip
    assign is_excluded = false

    if variant_title contains 'single room supplement'
      assign is_excluded = true
    elsif variant_title contains 'room supplement'
      assign is_excluded = true
    elsif variant_title contains 'single supplement'
      assign is_excluded = true
    elsif variant_title contains 'supplement'
      assign is_excluded = true
    elsif variant_title contains 'add-on'
      assign is_excluded = true
    elsif variant_title contains 'upgrade'
      assign is_excluded = true
    elsif variant_title contains 'custom'
      assign is_excluded = true
    elsif variant_title contains 'extra bed'
      assign is_excluded = true
    elsif variant_title contains 'surcharge'
      assign is_excluded = true
    endif

    unless is_excluded
      assign valid_main_variant_count = valid_main_variant_count | plus: 1

      if collection_display_price == blank or variant.price < collection_display_price
        assign collection_display_price = variant.price
      endif
    endunless
  endfor

  if collection_display_price == blank
    assign collection_display_price = product.price
  endif

  assign show_from_prefix = false
  if valid_main_variant_count > 1
    assign show_from_prefix = true
  endif
%}
          <div class="grid-item reveal-item">
            <a href="{{ product.url }}" class="card-link">
              <div class="card-visual">
                {% if product.featured_image %}
                  <img
                    src="{{ product.featured_image | image_url: width: 1200 }}"
                    alt="{{ product.title | escape }}"
                    loading="lazy"
                  >
                {% else %}
                  <div class="card-placeholder"></div>
                {% endif %}

                <div class="card-overlay">
                  <div class="card-btn">EXPLORE</div>
                </div>

                {% if product.tags contains 'Mountain View' or product.tags contains 'Monastery' %}
                  <div class="route-indicator"><span class="dot-pulse"></span>EXCLUSIVE</div>
                {% endif %}
              </div>

              <div class="card-content">
                <div class="card-header">
                  <h3 class="product-title">{{ product.title }}</h3>
                  <div class="product-price">
  {% if show_from_prefix %}
    <span class="price-prefix">From </span>
  {% endif %}
  {{ collection_display_price | money_with_currency }}
</div>
                </div>
                <div class="product-info-row">
                  <span class="product-type">{{ product.type | default: 'Experience' }}</span>
                </div>
              </div>
            </a>
          </div>
        {% endfor %}
      </div>
    {% endpaginate %}
  </div>
</div>

<style>
  /* ===== Scoped: only affect this module ===== */
  #CollectionProductGrid{
    background-color:#050505;
    color:#fff;
    overflow:hidden;

    /* 你的主题 header 可能是 fixed/absolute：用这个顶出安全区 */
    --header-safe: 96px;
    --gold: #c4b5a6;
  }

  /* ===== HERO ===== */
  #CollectionProductGrid .coll-hero-compact{
    height: 56vh;
    min-height: 560px;
    position:relative;
    display:flex;
    align-items:center;
    justify-content:center;
    overflow:hidden;
    padding-top: var(--header-safe); /* 关键：避免导航压住 */
    box-sizing: border-box;
  }

  #CollectionProductGrid .hero-bg{
    position:absolute;
    inset:0;
    z-index:1;
  }

  #CollectionProductGrid .hero-img{
    width:100%;
    height:100%;
    object-fit:cover;
    object-position:center 22%;
    display:block;

    /* 雪山/天空强曝光时更稳：轻微压亮度 + 提对比（比 brightness(1) 更高级） */
    filter: brightness(0.88) contrast(1.06) saturate(1.03);
    transform: scale(1.02); /* 防止边缘出现 1px 缝 */
  }

  #CollectionProductGrid .hero-placeholder{
    width:100%;
    height:100%;
    background: #111;
  }

  /* 高级遮罩：上方几乎透明、底部渐暗接黑场 */
  #CollectionProductGrid .hero-overlay{
    position:absolute;
    inset:0;
    z-index:2;
    background:
      radial-gradient(1200px 420px at 50% 42%, rgba(0,0,0,0.18), rgba(0,0,0,0) 60%),
      linear-gradient(to bottom, rgba(5,5,5,0.12) 0%, rgba(5,5,5,0.75) 78%, rgba(5,5,5,1) 100%);
  }

  #CollectionProductGrid .hero-text-container{
    position:relative;
    z-index:10;
    width:100%;
    text-align:center;

    /* 顶部避免挤到导航，底部避免 desc 被裁 */
    padding: 18px 20px 64px;
    box-sizing:border-box;
  }

  #CollectionProductGrid .hero-content{
    max-width: 920px;
    margin: 0 auto;
  }

  /* subtitle：更“轻”、更仪式感 */
#CollectionProductGrid .coll-subtitle{
  color: #fff;
  font-size: 9px;               /* Dali: 9px */
  letter-spacing: 0.8em;        /* Dali: 0.8em */
  text-transform: uppercase;
  text-shadow: 0 2px 15px rgba(0,0,0,0.9);
}

 /* subtitle 下划线同 Dali */
#CollectionProductGrid .subtitle-line{
  width: 35px;
  height: 1px;
  background: var(--dali-gold);
  opacity: 1;
  margin: 12px auto 0;
}
/* === DALI Font System Override for Shangri-La === */
#CollectionProductGrid{
  --dali-gold: #c4b5a6;
}

  /* 标题：同 Dali 的字重/斜体/阴影气质 */
#CollectionProductGrid .coll-title{
  font-family: 'Cormorant Garamond', serif;
  font-size: clamp(3rem, 7vw, 4.5rem); /* Dali: 7vw/4.5rem */
  font-weight: 300;
  font-style: italic;
  color: #fff;
  margin: 18px 0;
  letter-spacing: 0; /* Dali 版本通常不额外加 tracking，避免“飘” */
  text-shadow:
    0 4px 25px rgba(0,0,0,0.7),
    0 0 10px rgba(0,0,0,0.5),
    0 0 5px rgba(0,0,0,0.3);
}

  /* 描述：同 Dali 的字号/颜色/阴影质感 */
#CollectionProductGrid .coll-desc{
  font-size: 14px;             /* Dali: 14px */
  color: #fff;
  max-width: 500px;            /* Dali: 500px */
  margin: 0 auto;
  line-height: 1.8;            /* Dali: 1.8 */
  font-weight: 400;
  text-shadow: 0 2px 12px rgba(0,0,0,0.9);

  /* 如果你想完全像 Dali（不裁行），把 clamp 去掉 */
  display: block;
  overflow: visible;
}
  /* ===== META BAR ===== */
  #CollectionProductGrid .coll-container{
    max-width: 1400px;
    margin: 0 auto;
    padding: 42px 60px 100px;
  }

  #CollectionProductGrid .coll-meta-bar{
    display:flex;
    align-items:center;
    justify-content:center;
    gap:30px;
    margin-bottom: 78px;
    padding: 22px 0;
    border-top: 1px solid rgba(196,181,166,0.15);
    border-bottom: 1px solid rgba(196,181,166,0.15);
  }

  #CollectionProductGrid .meta-left,
  #CollectionProductGrid .meta-right{
    display:flex;
    align-items:baseline;
    gap:8px;
  }

  #CollectionProductGrid .meta-number{
    font-family:'Cormorant Garamond', serif;
    font-size: 26px;
    font-style: italic;
    color: var(--gold);
  }

  #CollectionProductGrid .meta-label{
    font-size: 9px;
    text-transform: uppercase;
    letter-spacing: 0.3em;
    color: rgba(255,255,255,0.45);
  }

  #CollectionProductGrid .meta-location{
    font-size: 10px;
    letter-spacing: 0.38em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.55);
    font-weight: 300;
  }

  #CollectionProductGrid .meta-divider{
    width: 1px;
    height: 20px;
    background: linear-gradient(to bottom, transparent, var(--gold), transparent);
    opacity: 0.65;
  }

  /* ===== GRID ===== */
  #CollectionProductGrid .compact-grid{
    display:grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 50px 40px;
  }

  #CollectionProductGrid .reveal-item{
    opacity:0;
    transform: translateY(28px);
    transition: all 0.9s cubic-bezier(0.22, 1, 0.36, 1);
    will-change: transform, opacity;
  }
  #CollectionProductGrid .reveal-item.is-visible{
    opacity:1;
    transform: translateY(0);
  }

  /* ===== CARD ===== */
  #CollectionProductGrid .card-link{
    color:inherit;
    text-decoration:none;
    display:block;
  }

  #CollectionProductGrid .card-visual{
    position:relative;
    overflow:hidden;
    aspect-ratio: 0.85;
    background:#0a0a0a;
    border: 0.5px solid rgba(255,255,255,0.06);
  }

  #CollectionProductGrid .card-visual img{
    width:100%;
    height:100%;
    object-fit:cover;
    transition: transform 1.6s cubic-bezier(0.19, 1, 0.22, 1);
    transform: scale(1.01);
  }

  #CollectionProductGrid .card-placeholder{
    width:100%;
    height:100%;
    background:#111;
  }

  #CollectionProductGrid .card-overlay{
    position:absolute;
    inset:0;
    display:flex;
    align-items:center;
    justify-content:center;
    transition: all 0.6s ease;
    background: rgba(0,0,0,0);
    backdrop-filter: blur(0px);
  }

  #CollectionProductGrid .card-btn{
    color:#fff;
    font-size: 8px;
    letter-spacing: 0.32em;
    border: 0.5px solid rgba(255,255,255,0.9);
    padding: 8px 16px;
    opacity:0;
    transform: translateY(10px);
    transition: 0.45s ease;
  }

  #CollectionProductGrid .card-content{ margin-top: 14px; }
  #CollectionProductGrid .card-header{
  display:flex;
  flex-direction:column;
  align-items:flex-start;
  gap:6px;
}

#CollectionProductGrid .product-title{
  width:100%;
  margin:0;
}

#CollectionProductGrid .product-price{
  margin:0;
  white-space:normal;
}
  #CollectionProductGrid .product-info-row{
    font-size: 8px;
    color: rgba(255,255,255,0.35);
    text-transform: uppercase;
    letter-spacing: .12em;
    margin-top: 6px;
  }

  #CollectionProductGrid .grid-item:hover img{ transform: scale(1.08); }
  #CollectionProductGrid .grid-item:hover .card-overlay{
    background: rgba(0,0,0,0.30);
    backdrop-filter: blur(6px);
  }
  #CollectionProductGrid .grid-item:hover .card-btn{
    opacity:1;
    transform: translateY(0);
  }
  #CollectionProductGrid .grid-item:hover .product-title{ color: var(--gold); }

  #CollectionProductGrid .route-indicator{
    position:absolute;
    top: 12px;
    left: 12px;
    background: rgba(0,0,0,0.55);
    padding: 4px 8px;
    font-size: 7px;
    color: #fff;
    display:flex;
    align-items:center;
    gap: 4px;
    letter-spacing: .12em;
  }
  #CollectionProductGrid .dot-pulse{
    width:4px;
    height:4px;
    background: var(--gold);
    border-radius: 50%;
    box-shadow: 0 0 6px rgba(196,181,166,0.9);
  }

  /* ===== Responsive ===== */
  /* ===== Responsive ===== */
@media (max-width: 990px) {
  #CollectionProductGrid {
    --header-safe: 84px;
  }

  /* Hero */
  #CollectionProductGrid .coll-hero-compact {
    height: auto;
    min-height: 420px;
    padding-top: var(--header-safe);
  }

  #CollectionProductGrid .hero-text-container {
    padding: 18px 20px 48px;
  }

  #CollectionProductGrid .hero-content {
    padding: 0 20px;
  }

  #CollectionProductGrid .coll-title {
    font-size: clamp(2rem, 8vw, 3.2rem);
    line-height: 1.05;
    margin: 16px 0 12px;
  }

  #CollectionProductGrid .coll-desc {
    font-size: 14px;
    line-height: 1.8;
    max-width: 640px;
  }

  /* Main container */
  #CollectionProductGrid .coll-container {
    padding: 32px 16px 80px;
  }

  /* Grid */
  #CollectionProductGrid .compact-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 26px 14px;
    align-items: start;
  }

  #CollectionProductGrid .grid-item {
    min-width: 0;
  }

  #CollectionProductGrid .card-visual {
    aspect-ratio: 0.82;
  }

  #CollectionProductGrid .card-content {
    margin-top: 12px;
  }

  /* 核心修复：标题和价格上下排，且这次带上作用域前缀 */
  #CollectionProductGrid .card-header {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    justify-content: flex-start;
    gap: 6px;
  }

  #CollectionProductGrid .product-title {
    width: 100%;
    margin: 0;
    font-family: 'Cormorant Garamond', serif;
    font-size: 15px;
    font-style: italic;
    font-weight: 400;
    line-height: 1.4;
    letter-spacing: 0;
    word-break: normal;
    overflow-wrap: anywhere;
  }

  #CollectionProductGrid .product-price {
    margin: 0;
    font-size: 12px;
    line-height: 1.2;
    color: #9f9f9f;
    white-space: nowrap;
    flex-shrink: 0;
  }

  #CollectionProductGrid .price-prefix {
    opacity: 0.78;
  }

  #CollectionProductGrid .product-info-row {
    margin-top: 8px;
    font-size: 9px;
    letter-spacing: 0.14em;
  }

  /* Meta bar */
  #CollectionProductGrid .coll-meta-bar {
    margin-bottom: 38px;
    padding: 18px 0;
    gap: 22px;
  }

  #CollectionProductGrid .meta-number {
    font-size: 22px;
  }

  #CollectionProductGrid .meta-label {
    font-size: 8px;
  }

  #CollectionProductGrid .meta-location {
    font-size: 9px;
    letter-spacing: 0.32em;
  }

  /* FAQ */
  #CollectionProductGrid .faq-acc-trigger {
    padding: 18px 0;
    gap: 16px;
  }

  #CollectionProductGrid .faq-acc-question {
    font-size: 15px;
    line-height: 1.55;
  }

  #CollectionProductGrid .faq-acc-answer p {
    font-size: 14px;
    line-height: 1.85;
  }

  #CollectionProductGrid .copy-richtext p {
    font-size: 14px;
  }

  /* 修正原来写错的 faq-item 类名 */
  #CollectionProductGrid .collection-faq-block .faq-acc-item:hover {
    transform: none;
  }
}

@media (max-width: 768px) {
  #CollectionProductGrid .coll-meta-bar {
    flex-direction: column;
    gap: 14px;
    border: none;
  }

  #CollectionProductGrid .meta-divider {
    width: 30px;
    height: 1px;
    background: linear-gradient(to right, transparent, #c4b5a6, transparent);
  }

  #CollectionProductGrid .collection-copy-block {
    padding-top: 28px;
    margin-bottom: 42px;
  }

  #CollectionProductGrid .copy-heading {
    margin-bottom: 18px;
  }

  #CollectionProductGrid .faq-acc-answer {
    padding-bottom: 20px;
  }
}

@media (max-width: 430px) {
  #CollectionProductGrid .compact-grid {
    gap: 24px 12px;
  }

  #CollectionProductGrid .product-title {
    font-size: 14px;
    line-height: 1.36;
  }

  #CollectionProductGrid .product-price {
    font-size: 11px;
  }

  #CollectionProductGrid .product-info-row {
    font-size: 8px;
    letter-spacing: 0.12em;
  }
}
 

</style>

<script>
document.addEventListener('DOMContentLoaded', function() {
  const root = document.getElementById('CollectionProductGrid');
  if (!root) return;

  const items = Array.from(root.querySelectorAll('.reveal-item'));
  if (!items.length) return;

  const grid = root.querySelector('.compact-grid');
  const cols = parseInt(grid?.getAttribute('data-cols') || '3', 10);

  const observer = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (entry.isIntersecting) {
        const i = items.indexOf(entry.target);
        const delay = (i % cols) * 140; // 交错更高级
        setTimeout(() => entry.target.classList.add('is-visible'), delay);
        observer.unobserve(entry.target);
      }
    });
  }, { threshold: 0.12, rootMargin: '0px 0px -60px 0px' });

  items.forEach(item => observer.observe(item));
});
</script>
