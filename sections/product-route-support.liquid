{% assign feature_blocks = section.blocks | where: 'type', 'feature' %}
{% assign link_blocks = section.blocks | where: 'type', 'link_card' %}
{% assign faq_blocks = section.blocks | where: 'type', 'faq_item' %}
{% assign is_jade_route_support = false %}
{% assign is_shangrila_route_support = false %}

{% if product.handle == 'jade-dragon-snow-mountain-private-tour' %}
  {% assign is_jade_route_support = true %}
{% elsif product.handle == 'lijiang-to-shangri-la-private-tour' %}
  {% assign is_shangrila_route_support = true %}
{% endif %}

<style>
  .product-route-support {
    background: #1a1a1a;
    color: #ffffff;
    padding: 56px 0 72px;
  }

  .product-route-support__container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .product-route-support__inner {
    background: #242424;
    border: 1px solid #333333;
    border-radius: 16px;
    padding: 40px;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.28);
  }

  .product-route-support__header {
    max-width: 860px;
    margin-bottom: 36px;
  }

  .product-route-support__eyebrow,
  .product-route-support__section-eyebrow {
    display: inline-block;
    margin-bottom: 12px;
    color: #d4b106;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .product-route-support__title,
  .product-route-support__section-title {
    margin: 0;
    color: #ffffff;
    font-size: 30px;
    line-height: 1.2;
    font-weight: 700;
  }

  .product-route-support__intro,
  .product-route-support__section-intro,
  .product-route-support__faq-answer {
    margin-top: 14px;
    color: #c9c9c9;
    font-size: 15px;
    line-height: 1.85;
  }

  .product-route-support__section + .product-route-support__section {
    margin-top: 42px;
  }

  .product-route-support__grid {
    display: grid;
    gap: 18px;
    margin-top: 24px;
  }

  .product-route-support__grid--features {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .product-route-support__grid--links {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .product-route-support__card {
    min-height: 100%;
    padding: 24px;
    background: #1f1f1f;
    border: 1px solid #353535;
    border-radius: 12px;
  }

  .product-route-support__card-tag {
    display: inline-block;
    margin-bottom: 10px;
    color: #d4b106;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .product-route-support__card-title {
    margin: 0;
    color: #ffffff;
    font-size: 20px;
    line-height: 1.35;
    font-weight: 700;
  }

  .product-route-support__card-copy {
    margin-top: 12px;
    color: #c9c9c9;
    font-size: 14px;
    line-height: 1.85;
  }

  .product-route-support__link {
    display: inline-block;
    margin-top: 16px;
    color: #f4d35e;
    font-size: 13px;
    font-weight: 700;
    line-height: 1.5;
    text-decoration: none;
  }

  .product-route-support__link:hover {
    text-decoration: underline;
  }

  .product-route-support__faq-list {
    margin-top: 24px;
    border-top: 1px solid #353535;
  }

  .product-route-support__faq-item {
    border-bottom: 1px solid #353535;
  }

  .product-route-support__faq-question {
    display: flex;
    justify-content: space-between;
    gap: 16px;
    padding: 18px 0;
    color: #ffffff;
    cursor: pointer;
    list-style: none;
    font-size: 16px;
    font-weight: 600;
    line-height: 1.5;
  }

  .product-route-support__faq-question::-webkit-details-marker {
    display: none;
  }

  .product-route-support__faq-icon {
    flex: 0 0 auto;
    color: #d4b106;
    font-size: 18px;
    line-height: 1;
  }

  .product-route-support__faq-answer {
    margin-top: 0;
    padding: 0 0 18px;
  }

  .product-route-support.jade-route-support,
  .product-route-support.shangrila-route-support {
    background: #141414;
    padding: 64px 0 78px;
  }

  .product-route-support.jade-route-support .product-route-support__container,
  .product-route-support.shangrila-route-support .product-route-support__container {
    max-width: 1180px;
  }

  .product-route-support.jade-route-support .product-route-support__inner,
  .product-route-support.shangrila-route-support .product-route-support__inner {
    border-color: rgba(212, 177, 106, 0.16);
    border-radius: 10px;
    background: #101010;
    padding: 46px;
    box-shadow: 0 24px 70px rgba(0, 0, 0, 0.42);
  }

  .product-route-support.jade-route-support .product-route-support__header,
  .product-route-support.shangrila-route-support .product-route-support__header {
    max-width: 720px;
    margin-bottom: 42px;
  }

  .product-route-support.jade-route-support .product-route-support__title,
  .product-route-support.shangrila-route-support .product-route-support__title {
    max-width: 700px;
    font-size: clamp(30px, 3vw, 40px);
    line-height: 1.16;
    font-weight: 600;
  }

  .product-route-support.jade-route-support .product-route-support__intro,
  .product-route-support.shangrila-route-support .product-route-support__intro,
  .product-route-support.jade-route-support .product-route-support__section-intro,
  .product-route-support.shangrila-route-support .product-route-support__section-intro {
    max-width: 72ch;
    color: rgba(245, 242, 235, 0.74);
    line-height: 1.82;
  }

  .product-route-support.jade-route-support .product-route-support__section + .product-route-support__section,
  .product-route-support.shangrila-route-support .product-route-support__section + .product-route-support__section {
    margin-top: 48px;
    padding-top: 38px;
    border-top: 1px solid rgba(212, 177, 106, 0.14);
  }

  .product-route-support.jade-route-support .product-route-support__section-title,
  .product-route-support.shangrila-route-support .product-route-support__section-title {
    max-width: 720px;
    font-size: clamp(24px, 2.2vw, 32px);
    line-height: 1.22;
    font-weight: 600;
  }

  .product-route-support.jade-route-support .product-route-support__grid,
  .product-route-support.shangrila-route-support .product-route-support__grid {
    gap: 14px;
  }

  .product-route-support.jade-route-support .product-route-support__grid--features,
  .product-route-support.shangrila-route-support .product-route-support__grid--features {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .product-route-support.jade-route-support .product-route-support__grid--links,
  .product-route-support.shangrila-route-support .product-route-support__grid--links {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .product-route-support.jade-route-support .product-route-support__card,
  .product-route-support.shangrila-route-support .product-route-support__card {
    border-color: rgba(212, 177, 106, 0.13);
    border-radius: 8px;
    background: rgba(255, 255, 255, 0.035);
    padding: 22px;
  }

  .product-route-support.jade-route-support .product-route-support__card-title,
  .product-route-support.shangrila-route-support .product-route-support__card-title {
    font-size: 18px;
    font-weight: 600;
  }

  .product-route-support.jade-route-support .product-route-support__card-copy,
  .product-route-support.shangrila-route-support .product-route-support__card-copy {
    color: rgba(245, 242, 235, 0.7);
    line-height: 1.76;
  }

  .product-route-support.jade-route-support .product-route-support__link,
  .product-route-support.shangrila-route-support .product-route-support__link {
    color: #f2dfb7;
    border-bottom: 1px solid rgba(212, 177, 106, 0.3);
  }

  .product-route-support.jade-route-support .product-route-support__link:hover,
  .product-route-support.shangrila-route-support .product-route-support__link:hover {
    color: #d4b16a;
    border-color: rgba(212, 177, 106, 0.6);
    text-decoration: none;
  }

  .product-route-support.jade-route-support .product-route-support__faq-list,
  .product-route-support.shangrila-route-support .product-route-support__faq-list {
    border-top-color: rgba(255, 255, 255, 0.08);
  }

  .product-route-support.jade-route-support .product-route-support__faq-item,
  .product-route-support.shangrila-route-support .product-route-support__faq-item {
    border-bottom-color: rgba(255, 255, 255, 0.08);
  }

  .product-route-support.jade-route-support .product-route-support__faq-question,
  .product-route-support.shangrila-route-support .product-route-support__faq-question {
    padding: 20px 0;
    font-weight: 600;
  }

  .product-route-support.jade-route-support .product-route-support__faq-answer,
  .product-route-support.shangrila-route-support .product-route-support__faq-answer {
    max-width: 78ch;
    color: rgba(245, 242, 235, 0.72);
  }

  .product-route-support.jade-route-support .product-route-support__grid--features {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .product-route-support.jade-route-support .product-route-support__grid--links .product-route-support__card,
  .product-route-support.shangrila-route-support .product-route-support__grid--links .product-route-support__card {
    display: flex;
    min-height: 100%;
    flex-direction: column;
  }

  .product-route-support.jade-route-support .product-route-support__grid--links .product-route-support__link,
  .product-route-support.shangrila-route-support .product-route-support__grid--links .product-route-support__link {
    align-self: flex-start;
    margin-top: auto;
    padding-top: 18px;
  }

  @media (max-width: 989px) {
    .product-route-support {
      padding: 40px 0 56px;
    }

    .product-route-support__inner {
      padding: 28px 22px;
    }

    .product-route-support__title,
    .product-route-support__section-title {
      font-size: 26px;
    }

    .product-route-support__grid--features,
    .product-route-support__grid--links {
      grid-template-columns: 1fr;
    }

    .product-route-support.jade-route-support,
    .product-route-support.shangrila-route-support {
      padding: 44px 0 60px;
    }

    .product-route-support.jade-route-support .product-route-support__container,
    .product-route-support.shangrila-route-support .product-route-support__container {
      padding: 0 16px;
    }

    .product-route-support.jade-route-support .product-route-support__inner,
    .product-route-support.shangrila-route-support .product-route-support__inner {
      border-radius: 8px;
      padding: 28px 18px;
    }

    .product-route-support.jade-route-support .product-route-support__header,
    .product-route-support.shangrila-route-support .product-route-support__header {
      margin-bottom: 32px;
    }

    .product-route-support.jade-route-support .product-route-support__section + .product-route-support__section,
    .product-route-support.shangrila-route-support .product-route-support__section + .product-route-support__section {
      margin-top: 34px;
      padding-top: 30px;
    }

    .product-route-support.jade-route-support .product-route-support__grid--features,
    .product-route-support.shangrila-route-support .product-route-support__grid--features,
    .product-route-support.jade-route-support .product-route-support__grid--links,
    .product-route-support.shangrila-route-support .product-route-support__grid--links {
      grid-template-columns: 1fr;
    }

    .product-route-support.jade-route-support .product-route-support__card,
    .product-route-support.shangrila-route-support .product-route-support__card {
      padding: 18px;
    }

    .product-route-support.jade-route-support .product-route-support__faq-question,
    .product-route-support.shangrila-route-support .product-route-support__faq-question {
      padding: 18px 0;
    }
  }
</style>

<section class="product-route-support{% if is_jade_route_support %} jade-route-support{% endif %}{% if is_shangrila_route_support %} shangrila-route-support{% endif %}" id="section-{{ section.id }}">
  <div class="product-route-support__container">
    <div class="product-route-support__inner">
      <header class="product-route-support__header">
        {% if section.settings.eyebrow != blank %}
          <span class="product-route-support__eyebrow">{{ section.settings.eyebrow }}</span>
        {% endif %}
        {% if section.settings.title != blank %}
          <h2 class="product-route-support__title">{{ section.settings.title }}</h2>
        {% endif %}
        {% if section.settings.intro != blank %}
          <div class="product-route-support__intro">{{ section.settings.intro | newline_to_br }}</div>
        {% endif %}
      </header>

      {% if feature_blocks.size > 0 %}
        <section class="product-route-support__section">
          {% if section.settings.features_eyebrow != blank %}
            <span class="product-route-support__section-eyebrow">{{ section.settings.features_eyebrow }}</span>
          {% endif %}
          {% if section.settings.features_title != blank %}
            <h3 class="product-route-support__section-title">{{ section.settings.features_title }}</h3>
          {% endif %}
          {% if section.settings.features_intro != blank %}
            <div class="product-route-support__section-intro">{{ section.settings.features_intro | newline_to_br }}</div>
          {% endif %}
          <div class="product-route-support__grid product-route-support__grid--features">
            {% for block in feature_blocks %}
              <article class="product-route-support__card" {{ block.shopify_attributes }}>
                {% if block.settings.tag != blank %}
                  <span class="product-route-support__card-tag">{{ block.settings.tag }}</span>
                {% endif %}
                {% if block.settings.heading != blank %}
                  <h4 class="product-route-support__card-title">{{ block.settings.heading }}</h4>
                {% endif %}
                {% if block.settings.copy != blank %}
                  <div class="product-route-support__card-copy">{{ block.settings.copy | newline_to_br }}</div>
                {% endif %}
              </article>
            {% endfor %}
          </div>
        </section>
      {% endif %}

      {% if link_blocks.size > 0 %}
        <section class="product-route-support__section">
          {% if section.settings.links_eyebrow != blank %}
            <span class="product-route-support__section-eyebrow">{{ section.settings.links_eyebrow }}</span>
          {% endif %}
          {% if section.settings.links_title != blank %}
            <h3 class="product-route-support__section-title">{{ section.settings.links_title }}</h3>
          {% endif %}
          {% if section.settings.links_intro != blank %}
            <div class="product-route-support__section-intro">{{ section.settings.links_intro | newline_to_br }}</div>
          {% endif %}
          <div class="product-route-support__grid product-route-support__grid--links">
            {% for block in link_blocks %}
              <article class="product-route-support__card" {{ block.shopify_attributes }}>
                {% if block.settings.tag != blank %}
                  <span class="product-route-support__card-tag">{{ block.settings.tag }}</span>
                {% endif %}
                {% if block.settings.heading != blank %}
                  <h4 class="product-route-support__card-title">{{ block.settings.heading }}</h4>
                {% endif %}
                {% if block.settings.copy != blank %}
                  <div class="product-route-support__card-copy">{{ block.settings.copy | newline_to_br }}</div>
                {% endif %}
                {% if block.settings.link_label != blank and block.settings.link_url != blank %}
                  <a class="product-route-support__link" href="{{ block.settings.link_url }}">{{ block.settings.link_label }}</a>
                {% endif %}
              </article>
            {% endfor %}
          </div>
        </section>
      {% endif %}

      {% if faq_blocks.size > 0 %}
        <section class="product-route-support__section">
          {% if section.settings.faq_eyebrow != blank %}
            <span class="product-route-support__section-eyebrow">{{ section.settings.faq_eyebrow }}</span>
          {% endif %}
          {% if section.settings.faq_title != blank %}
            <h3 class="product-route-support__section-title">{{ section.settings.faq_title }}</h3>
          {% endif %}
          {% if section.settings.faq_intro != blank %}
            <div class="product-route-support__section-intro">{{ section.settings.faq_intro | newline_to_br }}</div>
          {% endif %}
          <div class="product-route-support__faq-list">
            {% for block in faq_blocks %}
              <details class="product-route-support__faq-item" {{ block.shopify_attributes }}>
                <summary class="product-route-support__faq-question">
                  <span>{{ block.settings.question }}</span>
                  <span class="product-route-support__faq-icon">+</span>
                </summary>
                <div class="product-route-support__faq-answer">{{ block.settings.answer | newline_to_br }}</div>
              </details>
            {% endfor %}
          </div>
        </section>
      {% endif %}
    </div>
  </div>
</section>

{% if faq_blocks.size > 0 %}
  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {% for block in faq_blocks %}
          {
            "@type": "Question",
            "name": {{ block.settings.question | strip_html | strip | json }},
            "acceptedAnswer": {
              "@type": "Answer",
              "text": {{ block.settings.answer | strip_html | strip | json }}
            }
          }{% unless forloop.last %},{% endunless %}
        {% endfor %}
      ]
    }
  </script>
{% endif %}

{% schema %}
{
  "name": "Product Route Support",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "TRIP PLANNING NOTES" },
    { "type": "text", "id": "title", "label": "Title", "default": "Helpful planning context for this route" },
    { "type": "textarea", "id": "intro", "label": "Intro" },
    { "type": "text", "id": "features_eyebrow", "label": "Feature eyebrow", "default": "WHY THIS TRIP WORKS" },
    { "type": "text", "id": "features_title", "label": "Feature title", "default": "What to know before you book" },
    { "type": "textarea", "id": "features_intro", "label": "Feature intro" },
    { "type": "text", "id": "links_eyebrow", "label": "Links eyebrow", "default": "RELATED PLANNING" },
    { "type": "text", "id": "links_title", "label": "Links title", "default": "Related routes and destination planning" },
    { "type": "textarea", "id": "links_intro", "label": "Links intro" },
    { "type": "text", "id": "faq_eyebrow", "label": "FAQ eyebrow", "default": "FAQ" },
    { "type": "text", "id": "faq_title", "label": "FAQ title", "default": "Common route questions" },
    { "type": "textarea", "id": "faq_intro", "label": "FAQ intro" }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature",
      "settings": [
        { "type": "text", "id": "tag", "label": "Tag", "default": "PLANNING" },
        { "type": "text", "id": "heading", "label": "Heading", "default": "Why this route works well" },
        { "type": "textarea", "id": "copy", "label": "Copy" }
      ]
    },
    {
      "type": "link_card",
      "name": "Link card",
      "settings": [
        { "type": "text", "id": "tag", "label": "Tag", "default": "NEXT STEP" },
        { "type": "text", "id": "heading", "label": "Heading", "default": "Continue planning" },
        { "type": "textarea", "id": "copy", "label": "Copy" },
        { "type": "text", "id": "link_label", "label": "Link label", "default": "Browse related private tours" },
        { "type": "url", "id": "link_url", "label": "Link URL" }
      ]
    },
    {
      "type": "faq_item",
      "name": "FAQ item",
      "settings": [
        { "type": "text", "id": "question", "label": "Question", "default": "Can this route be customized?" },
        { "type": "textarea", "id": "answer", "label": "Answer" }
      ]
    }
  ],
  "presets": [
    { "name": "Product Route Support" }
  ]
}
{% endschema %}
