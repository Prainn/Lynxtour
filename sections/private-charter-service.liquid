                                {% when 'flight' %}
                                  <svg class="tl-ico" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                                    <path d="M2 16l20-6-20-6 6 6-6 6Z" stroke-linejoin="round"/>
                                    <path d="M8 10h6" stroke-linecap="round"/>
                                  </svg>

                                {% when 'train' %}
                                  <svg class="tl-ico" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                                    <path d="M7 3h10a3 3 0 0 1 3 3v9a3 3 0 0 1-3 3H7a3 3 0 0 1-3-3V6a3 3 0 0 1 3-3Z" stroke-linejoin="round"/>
                                    <path d="M7 21l2-3M17 21l-2-3" stroke-linecap="round"/>
                                    <circle cx="8" cy="14" r="1.2"/><circle cx="16" cy="14" r="1.2"/>
                                  </svg>

                                {% when 'hike' %}
                                  <svg class="tl-ico" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                                    <path d="M14 5a2 2 0 1 1-4 0a2 2 0 0 1 4 0Z"/>
                                    <path d="M8 21l2-7 3 2 2 5" stroke-linecap="round" stroke-linejoin="round"/>
                                    <path d="M10 14l-2-3 3-2 3 2" stroke-linejoin="round"/>
                                    <path d="M16 10l2-2" stroke-linecap="round"/>
                                  </svg>

                                {% when 'free' %}
                                  <svg class="tl-ico" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                                    <path d="M5 21V4" stroke-linecap="round"/>
                                    <path d="M5 4c6 0 6 4 12 4v9c-6 0-6-4-12-4" stroke-linejoin="round"/>
                                  </svg>

                                {% else %}
                                  <svg class="tl-ico" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                                    <path d="M12 21s6-4.5 6-10a6 6 0 1 0-12 0c0 5.5 6 10 6 10Z" stroke-linejoin="round"/>
                                  </svg>
                              {% endcase %}
                            </div>

                            <div>
                              <div class="tl-head">
                                <div class="tl-title">{{ it.title }}</div>
                                {% if it.time != blank %}
                                  <div class="tl-time">{{ it.time }}</div>
                                {% endif %}
                              </div>

                              {% if it.duration != blank or it.tag != blank %}
                                <div class="tl-meta">
                                  {% if it.duration != blank %}
                                    <span class="tl-meta-item">🕒 {{ it.duration }}</span>
                                  {% endif %}
                                  {% if it.tag != blank %}
                                    <span class="tl-meta-item tl-tag">🏳️ {{ it.tag }}</span>
                                  {% endif %}
                                </div>
                              {% endif %}

                              {% if it.desc != blank %}
                                <div class="tl-desc">{{ it.desc | newline_to_br }}</div>
