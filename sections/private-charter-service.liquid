<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr@4.6.13/dist/flatpickr.min.css">

<style>
  :root {
    --gold: #d4b106;
    --dark-bg: #1a1a1a;
    --dark-card: #242424;
    --text-white: #ffffff;
    --text-gray: #a0a0a0;
    --border-color: #333333;
    --header-safe-height: 120px;
    --sidebar-sticky-top: calc(var(--header-safe-height) + 20px);
  }

  .ota-wrapper{
    background: var(--dark-bg);
    color: var(--text-white);
    font-family: "PingFang SC", sans-serif;
    padding-top: calc(var(--header-safe-height) + 20px);
    position: relative;
    z-index: 1;
  }

  .ota-container{
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    gap: 30px;
    align-items: flex-start;
  }

  .ota-main-config{
    flex: 2;
    background: var(--dark-card);
    border-radius: 16px;
    padding: 40px;
    border: 1px solid var(--border-color);
    box-shadow: 0 10px 30px rgba(0,0,0,0.3);
  }

  .ota-header{
    display:flex;
    justify-content:space-between;
    align-items:center;
    margin-bottom:30px;
    gap: 16px;
  }

  .ota-section-title{
    font-size:24px;
    font-weight:300;
    letter-spacing:2px;
    margin:0;
  }

  .ota-reset{
    background: transparent;
    color: var(--gold);
    border: 1px solid var(--gold);
    padding: 4px 14px;
    border-radius: 20px;
    cursor: pointer;
    font-size: 12px;
    transition: .2s;
    white-space: nowrap;
  }

  .ota-reset:hover{
    background: rgba(212,177,6,0.10);
  }

  .ota-group{
    margin-bottom: 32px;
  }

  .ota-label{
    color: var(--gold);
    font-size:14px;
    margin-bottom:12px;
    display:block;
    letter-spacing:1px;
    font-weight:600;
  }

  .ota-subhint{
    margin: 8px 0 0;
    color:#888;
    font-size:12px;
    line-height:1.6;
  }

  .ota-date-box{
    position: relative;
    z-index: 20;
  }

  .ota-date-input{
    width: 100%;
    background: #0c0a09;
    color: #fff;
    border: 1px solid var(--border-color);
    padding: 14px 50px 14px 16px;
    border-radius: 10px;
    outline: none;
    cursor: pointer;
    font-size: 15px;
    transition: .2s;
  }

  .ota-date-input:focus{
    border-color: var(--gold);
    box-shadow: 0 0 0 3px rgba(212,177,6,0.10);
  }

  .ota-date-btn{
    position:absolute;
    right:8px;
    top:50%;
    transform:translateY(-50%);
    width:36px;
    height:36px;
    border:0;
    background: transparent;
    color: var(--gold);
    pointer-events: auto;
    cursor: pointer;
  }

  .ota-tag-container{
    display:flex;
    gap:12px;
    flex-wrap:wrap;
  }

  .ota-tag{
    border: 1px solid var(--border-color);
    padding: 10px 18px;
    border-radius: 10px;
    font-size: 13px;
    color: var(--text-gray);
    cursor: pointer;
    transition: .2s;
    user-select: none;
  }

  .ota-tag.active{
    border-color: var(--gold);
    color: var(--gold);
    background: rgba(212,177,6,0.08);
    box-shadow: 0 0 15px rgba(212,177,6,0.10);
  }

  .ota-tag.disabled{
    opacity: .4;
    cursor: not-allowed;
    border-style:dashed;
  }

  .ota-item-row{
    display:flex;
    justify-content:space-between;
    align-items:center;
    padding: 16px 0;
    border-bottom: 1px solid #333;
    gap: 16px;
  }

  .ota-item-row:last-child{
    border-bottom: none;
  }

  .ota-item-info{
    min-width: 0;
  }

  .ota-item-name{
    font-size: 15px;
    color:#e5e5e5;
    display: block;
  }

  .item-desc-tag{
    font-size: 11px;
    color:#888;
    margin-top: 6px;
    line-height:1.6;
  }

  .ota-item-action{
    display:flex;
    align-items:center;
    gap: 15px;
    flex-shrink: 0;
  }

  .ota-item-price{
    color: var(--gold);
    font-weight: 800;
    font-size: 16px;
    white-space: nowrap;
  }

  .ota-stepper{
    display:flex;
    align-items:center;
    background:#000;
    border-radius: 10px;
    border: 1px solid var(--border-color);
    overflow:hidden;
  }

  .ota-stepper button{
    width: 34px;
    height: 34px;
    border:0;
    background: transparent;
    color: var(--gold);
    cursor: pointer;
    font-size: 18px;
    display:flex;
    align-items:center;
    justify-content:center;
  }

  .ota-stepper button:disabled{
    color:#444;
    cursor: not-allowed;
  }

  .ota-stepper input{
    width: 42px;
    border: 0;
    background: transparent;
    color:#fff;
    text-align:center;
    font-size: 14px;
    -moz-appearance: textfield;
  }

  .ota-footer{
    display:flex;
    justify-content:space-between;
    align-items:flex-start;
    margin-top: 20px;
    border-top: 1px solid var(--border-color);
    padding-top: 26px;
    gap: 20px;
  }

  .ota-total-price{
    font-size: 32px;
    color: var(--gold);
    font-weight: 900;
    line-height: 1;
  }

  .ota-hint{
    margin: 6px 0 0;
    color:#666;
    font-size:12px;
    line-height: 1.6;
  }

  .ota-btns-area{
    display:flex;
    flex-direction:column;
    gap: 12px;
    flex: 1;
  }

  .ota-btns{
    display:flex;
    gap: 12px;
    justify-content:flex-end;
  }

  .ota-btn-cart,
  .ota-btn-buy{
    padding: 14px 24px;
    border-radius: 10px;
    cursor: pointer;
    font-weight: 800;
    transition: .2s;
    font-size: 14px;
    position: relative;
    white-space: nowrap;
  }

  .ota-btn-cart{
    background: transparent;
    border:1px solid var(--gold);
    color: var(--gold);
  }

  .ota-btn-cart:hover{
    background: rgba(212,177,6,0.10);
  }

  .ota-btn-buy{
    background: var(--gold);
    color:#000;
    border:0;
  }

  .ota-btn-buy:hover{
    filter: brightness(1.07);
  }

  .js-submit:disabled{
    opacity: .7;
    cursor: wait;
  }

  .js-submit.loading{
    color: transparent !important;
  }

  .js-submit.loading::after{
    content:"";
    position:absolute;
    left:50%;
    top:50%;
    width:18px;
    height:18px;
    margin:-9px;
    border:2px solid rgba(0,0,0,0.25);
    border-top-color: currentColor;
    border-radius: 50%;
    animation: ota-spin .8s infinite linear;
  }

  .ota-btn-cart.loading::after{
    border-color: rgba(212,177,6,0.25);
    border-top-color: var(--gold);
  }

  @keyframes ota-spin{
    to{ transform: rotate(360deg); }
  }

  .ota-sidebar{
    flex: 1;
    position: sticky;
    top: var(--sidebar-sticky-top);
    z-index: 10;
  }

  .sidebar-sticky-card{
    background: var(--dark-card);
    border-radius: 16px;
    border: 1px solid var(--border-color);
    max-height: calc(100vh - var(--sidebar-sticky-top) - 20px);
    overflow: hidden;
    display:flex;
    flex-direction:column;
  }

  .sidebar-head{
    padding: 16px 20px;
    border-bottom: 1px solid #333;
    flex-shrink:0;
  }

  .sidebar-head h3{
    margin:0;
    font-size:16px;
    font-weight:700;
    letter-spacing:1px;
  }

  .sidebar-content-wrapper{
    padding: 0 20px 20px;
    overflow-y:auto;
    -webkit-overflow-scrolling: touch;
  }

  .sidebar-labels{
    padding: 15px 0 10px;
    position: sticky;
    top: 0;
    background: var(--dark-card);
    z-index: 4;
  }

  .s-tag{
    background: #333;
    color:#eee;
    padding: 4px 10px;
    border-radius: 6px;
    font-size: 11px;
    margin: 0 6px 6px 0;
    display:inline-block;
    border: 1px solid #444;
  }

  .accordion-item{
    border:1px solid #333;
    border-radius:12px;
    margin-bottom:10px;
    background:#1c1c1c;
    overflow:hidden;
  }

  .accordion-header{
    padding:14px;
    display:flex;
    justify-content:space-between;
    align-items:center;
    cursor:pointer;
    background:#222;
    transition:.2s;
    user-select:none;
  }

  .accordion-header:hover{
    background:#2a2a2a;
  }

  .day-icon{
    color: var(--gold);
    font-size:12px;
    font-weight:900;
    text-transform:uppercase;
    letter-spacing: .8px;
  }

  .arrow-icon{
    font-size:10px;
    color:#666;
    transition:.2s;
  }

  .accordion-item.active .arrow-icon{
    transform: rotate(180deg);
    color: var(--gold);
  }

  .accordion-content{
    display:none;
    padding:8px 15px 15px;
    border-top:1px solid #333;
    background:#181818;
  }

  .accordion-item.active .accordion-content{
    display:block;
  }

  .day-text-content{
    font-size:13px;
    line-height:1.8;
    color:#ccc;
    margin-bottom:12px;
  }

  .day-timeline{
    padding-left: 0 !important;
    position: relative;
  }

  .day-timeline::before{
    content: "";
    position: absolute;
    left: 14px !important;
    top: 8px;
    bottom: 8px;
    width: 1px;
    background: rgba(255,255,255,0.10);
  }

  .tl-item{
    --tl-accent: var(--tl-spot);
    position: relative !important;
    display: grid !important;
    grid-template-columns: 32px 1fr !important;
    column-gap: 12px !important;
    padding: 10px 0 18px !important;
  }

  .tl-item[data-type="meal"]  { --tl-accent: #F6C945; }
  .tl-item[data-type="car"]   { --tl-accent: #8C7CFF; }
  .tl-item[data-type="spot"]  { --tl-accent: #39D98A; }
  .tl-item[data-type="hotel"] { --tl-accent: #58B6FF; }
  .tl-item[data-type="flight"]{ --tl-accent: #FF6B8A; }
  .tl-item[data-type="train"] { --tl-accent: #6FE3FF; }
  .tl-item[data-type="hike"]  { --tl-accent: #B6E36F; }
  .tl-item[data-type="free"]  { --tl-accent: #D4B106; }

  .tl-dot{
    width: 28px;
    height: 28px;
    border-radius: 999px;
    display:flex;
    align-items:center;
    justify-content:center;
    color: var(--tl-accent);
    background: transparent !important;
    border: 1px solid rgba(255,255,255,0.18) !important;
    box-shadow: none !important;
    position: relative !important;
    left: auto !important;
    top: auto !important;
    margin-top: 2px !important;
    z-index: 1;
  }

  .tl-ico{
    width:16px;
    height:16px;
    display:block;
  }

  .tl-head{
    display:flex;
    justify-content:space-between;
    align-items:center !important;
    gap: 12px;
    flex-wrap: wrap;
  }

  .tl-title{
    color:#fff;
    font-size: 14px;
    font-weight: 700;
  }

  .tl-time{
    color: var(--gold);
    font-size: 11px;
    font-weight: 700;
  }

  .tl-meta{
    display:flex;
    flex-wrap:wrap;
    gap: 8px;
    margin-top: 6px;
  }

  .tl-meta-item{
    font-size: 11px;
    color:#9c9c9c;
    padding: 4px 8px;
    border: 1px solid rgba(255,255,255,0.08);
    background: rgba(255,255,255,0.03);
    border-radius: 999px;
  }

  .tl-desc{
    font-size: 12px;
    line-height: 1.75;
    color:#bdbdbd;
    margin-top: 8px;
  }

  .day-gallery{
    margin-top: 12px;
    display: grid;
    gap: 10px;
  }

  .day-img-wrap{
    position: relative;
    overflow: hidden;
    border-radius: 12px;
    border: 1px solid rgba(255,255,255,0.10);
    background: #111;
  }

  .day-img{
    width: 100%;
    height: 100% !important;
    object-fit: cover !important;
    display: block;
    transform: scale(1.001);
  }

  .day-gallery--1{
    grid-template-columns: 1fr;
  }

  .day-gallery--1 .day-img-wrap{
    height: 260px;
  }

  .day-gallery--2{
    grid-template-columns: 1fr 1fr;
  }

  .day-gallery--2 .day-img-wrap{
    height: 180px;
  }

  .day-gallery--3{
    grid-template-columns: 1.35fr 1fr;
    grid-auto-rows: 140px;
  }

  .day-gallery--3 .day-img-wrap:first-child{
    grid-row: span 2;
  }

  .day-img-wrap.is-more::after{
    content: attr(data-more);
    position: absolute;
    right: 10px;
    bottom: 10px;
    padding: 6px 10px;
    border-radius: 999px;
    font-size: 12px;
    font-weight: 900;
    color: #fff;
    background: rgba(0,0,0,0.55);
    border: 1px solid rgba(255,255,255,0.18);
    backdrop-filter: blur(6px);
  }

  .custom-tour-view{
    display:none;
    text-align:center;
    padding: 40px 20px;
    background: rgba(255,255,255,0.05);
    border-radius: 12px;
    border: 1px dashed var(--gold);
  }

  .custom-icon{
    font-size:30px;
    margin-bottom: 15px;
    display:block;
  }

  .custom-title{
    font-size:18px;
    color:#fff;
    margin:0 0 10px;
  }

  .custom-desc{
    font-size:13px;
    color:#aaa;
    margin:0 0 25px;
    line-height:1.7;
  }

  .btn-contact-custom{
    background: var(--gold);
    color:#000;
    padding: 12px 30px;
    border:0;
    border-radius: 10px;
    font-weight: 900;
    cursor: pointer;
    text-decoration:none;
    display:inline-block;
    margin: 6px 6px 0;
  }

  .ota-wrapper{
    padding-top: calc(var(--header-safe-height, 160px) + 20px) !important;
  }

  .flatpickr-calendar{
    background: #111 !important;
    border: 1px solid #333 !important;
    border-radius: 12px !important;
    box-shadow: 0 12px 26px rgba(0,0,0,0.55) !important;
    overflow: visible !important;
    z-index: 999999 !important;
    color-scheme: dark;
  }

  .flatpickr-months{
    display: flex !important;
    align-items: center !important;
    position: relative !important;
    height: 48px !important;
    padding: 8px 36px 0 !important;
    background: #111 !important;
    overflow: visible !important;
  }

  .flatpickr-current-month{
    position: static !important;
    display: flex !important;
    align-items: center !important;
    justify-content: center !important;
    width: 100% !important;
    height: 32px !important;
    line-height: 32px !important;
    padding: 0 !important;
    opacity: 1 !important;
    visibility: visible !important;
    color: #fff !important;
  }

  .flatpickr-monthDropdown-months{
    background: #111 !important;
    color: #fff !important;
    border: 1px solid #333 !important;
    border-radius: 10px !important;
    padding: 0 10px !important;
    font-size: 14px !important;
    font-weight: 800 !important;
    height: 32px !important;
    line-height: 32px !important;
    margin: 0 !important;
    -webkit-appearance: menulist !important;
    appearance: menulist !important;
  }

  .flatpickr-monthDropdown-months option{
    background: #111 !important;
    color: #fff !important;
  }

  .flatpickr-monthDropdown-months option:checked{
    background: #222 !important;
    color: var(--gold) !important;
  }

  .flatpickr-current-month .numInputWrapper{
    width: 70px !important;
    height: 32px !important;
  }

  .flatpickr-current-month input.cur-year{
    background: transparent !important;
    border: 0 !important;
    color: var(--gold) !important;
    font-size: 14px !important;
    font-weight: 900 !important;
    height: 32px !important;
    line-height: 32px !important;
    padding: 0 !important;
    opacity: 1 !important;
    visibility: visible !important;
  }

  .flatpickr-prev-month,
  .flatpickr-next-month{
    top: 8px !important;
    height: 32px !important;
    display: flex !important;
    align-items: center !important;
    z-index: 20 !important;
  }

  .flatpickr-prev-month svg,
  .flatpickr-next-month svg{
    fill: var(--gold) !important;
  }

  .flatpickr-weekdays{
    background: #111 !important;
    height: 28px !important;
    display: flex !important;
    align-items: center !important;
  }

  span.flatpickr-weekday{
    color: #888 !important;
    font-size: 12px !important;
    font-weight: 600 !important;
  }

  .flatpickr-innerContainer,
  .flatpickr-days,
  .dayContainer{
    background: #111 !important;
  }

  .flatpickr-day{
    color: #fff !important;
    background: transparent !important;
    border-color: transparent !important;
    border-radius: 8px !important;
    display: flex !important;
    flex-direction: column !important;
    justify-content: flex-start !important;
    align-items: center !important;
    padding-top: 6px !important;
    height: 60px !important;
    line-height: 1 !important;
  }

  .flatpickr-day:hover{
    background: #2a2a2a !important;
    color: var(--gold) !important;
  }

  .flatpickr-day.selected,
  .flatpickr-day.startRange,
  .flatpickr-day.endRange{
    background: var(--gold) !important;
    color: #000 !important;
    border-color: var(--gold) !important;
    font-weight: 900 !important;
  }

  .flatpickr-day.today{
    border-color: var(--gold) !important;
  }

  .flatpickr-day.prevMonthDay,
  .flatpickr-day.nextMonthDay{
    color: #555 !important;
  }

  .flatpickr-day.flatpickr-disabled,
  .flatpickr-day.disabled{
    color: #333 !important;
  }

  .day-price{
    font-size: 10px;
    color: var(--gold);
    margin-top: 5px;
    font-weight: 500;
    transform: scale(0.92);
  }

  .flatpickr-day.selected .day-price{
    color: #000 !important;
    font-weight: 900;
  }

  .ota-date-box{
    position: relative;
  }

  .ota-date-btn{
    pointer-events: auto !important;
    cursor: pointer;
    z-index: 5;
  }

  .ota-date-input{
    position: relative;
    z-index: 1;
  }

  .ota-info-actions{
    display: flex;
    gap: 12px;
    margin-bottom: 2px;
  }

  .ota-info-btn{
    flex: 1;
    min-width: 0;
    padding: 12px 16px;
    border-radius: 10px;
    cursor: pointer;
    font-weight: 700;
    font-size: 13px;
    border: 1px solid rgba(212,177,6,0.35);
    background: rgba(212,177,6,0.06);
    color: var(--gold);
    transition: .2s;
  }

  .ota-info-btn:hover{
    background: rgba(212,177,6,0.12);
    border-color: var(--gold);
  }

  .ota-popup[hidden]{
    display: none !important;
  }

  .ota-popup{
    position: fixed;
    inset: 0;
    z-index: 999999;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 20px;
  }

  .ota-popup__backdrop{
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,0.58);
    backdrop-filter: blur(3px);
  }

  .ota-popup__card{
    position: relative;
    z-index: 1;
    width: min(560px, calc(100vw - 30px));
    max-height: min(78vh, 720px);
    overflow: hidden;
    background: #1f1f1f;
    border: 1px solid var(--border-color);
    border-radius: 16px;
    box-shadow: 0 20px 50px rgba(0,0,0,0.45);
  }

  .ota-popup__head{
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 18px 20px;
    border-bottom: 1px solid rgba(255,255,255,0.08);
  }

  .ota-popup__title{
    margin: 0;
    font-size: 18px;
    font-weight: 800;
    color: var(--gold);
    letter-spacing: .5px;
  }

  .ota-popup__close{
    width: 34px;
    height: 34px;
    border: 0;
    border-radius: 999px;
    background: rgba(255,255,255,0.06);
    color: #fff;
    cursor: pointer;
    font-size: 16px;
    line-height: 1;
  }

  .ota-popup__close:hover{
    background: rgba(255,255,255,0.12);
  }

  .ota-popup__body{
    padding: 18px 20px 22px;
    overflow-y: auto;
    max-height: calc(78vh - 72px);
  }

  .ota-popup-copy{
    color: #cfcfcf;
    font-size: 13px;
    line-height: 1.9;
  }

  @media (max-width: 990px){
    .ota-container{
      flex-direction:column;
      padding: 0 15px;
    }

    .ota-main-config{
      padding: 24px;
    }

    .ota-sidebar{
      position: static;
      width:100%;
      margin-top: 20px;
    }

    .sidebar-sticky-card{
      max-height: none;
      overflow: visible;
    }

    .ota-footer{
      flex-direction:column;
    }

    .ota-btns{
      justify-content: stretch;
      flex-direction: column;
    }

    .ota-btn-cart,
    .ota-btn-buy{
      width: 100%;
    }

    .ota-info-actions{
      flex-direction: column;
    }

    .ota-popup{
      padding: 14px;
    }

    .ota-popup__card{
      width: 100%;
    }

    .day-gallery--1 .day-img-wrap{
      height: 200px;
    }

    .day-gallery--2 .day-img-wrap{
      height: 150px;
    }

    .day-gallery--3{
      grid-auto-rows: 115px;
    }

    .ota-item-row{
      align-items: flex-start;
      flex-direction: column;
    }

    .ota-item-action{
      width: 100%;
      justify-content: space-between;
    }
  }
</style>

{%- assign seo_variant = product.selected_or_first_available_variant -%}
{%- assign seo_product_url = shop.url | append: product.url -%}
{%- assign seo_product_description = product.description | strip_html | strip_newlines | strip -%}

<div class="ota-wrapper" data-dot-style="outline">
  <div class="ota-container">

    <div class="ota-main-config">
      <div class="ota-header">
        <h1 class="ota-section-title">Choose charter options</h1>
        <button type="button" class="ota-reset js-reset">Reset selections</button>
      </div>

      <div class="ota-group">
        <label class="ota-label">Travel date</label>
        <div class="ota-date-box">
          <input
            type="text"
            id="TravelDate"
            class="ota-date-input"
            value="{{ 'now' | date: '%Y-%m-%d' }}"
            readonly
            placeholder="Select a date"
          >
          <button type="button" class="ota-date-btn" aria-label="Choose date">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
              <path d="M7 2v3M17 2v3M3.5 9h17" stroke-linecap="round"/>
              <path d="M6.5 6h11c2 0 3 1 3 3v10c0 2-1 3-3 3h-11c-2 0-3-1-3-3V9c0-2 1-3 3-3Z" stroke-linejoin="round"/>
            </svg>
          </button>
        </div>
        <p class="ota-subhint">Please select your departure date. It will be submitted with the order.</p>
      </div>

      <div class="ota-group">
        <label class="ota-label">Vehicle type</label>
        <div class="ota-tag-container" id="PackageTabs">
          <div class="ota-tag active" data-type="sedan">5-Seater Sedan / SUV</div>
          <div class="ota-tag" data-type="mpv">7-Seater Premium MPV</div>
          <div class="ota-tag" data-type="custom">Custom Charter</div>
        </div>
        <p class="ota-subhint">Select your preferred vehicle type.</p>
      </div>

      <div id="StandardBookingView">
        <div class="ota-group">
          <label class="ota-label">Service days</label>
          <p class="ota-subhint">Select the number of charter service days you would like to book.</p>

          <div class="ota-item-list">
            {% for variant in product.variants %}
              {%- assign vehicle_label = variant.option1 | default: variant.title | strip -%}
              {%- assign vehicle_lc = vehicle_label | downcase -%}

              {%- assign pkg_type = 'sedan' -%}
              {%- if vehicle_lc contains '7-seater' or vehicle_lc contains 'mpv' or vehicle_lc contains 'business' or vehicle_lc contains '商务' or vehicle_lc contains '7座' -%}
                {%- assign pkg_type = 'mpv' -%}
              {%- endif -%}

              {%- assign row_title = variant.option2 | strip -%}
              {%- if row_title == blank -%}
                {%- assign row_title = 'Daily charter service (up to 8 hours / 300 km)' -%}
              {%- endif -%}

              {%- assign desc_text = 'Ideal for 1–3 adults, up to 2 pieces of 24-inch luggage. Suitable for couples, small families, and business travel.' -%}
              {%- if pkg_type == 'mpv' -%}
                {%- assign desc_text = 'Ideal for 4–6 adults, up to 3–4 pieces of 24-inch luggage. Suitable for families, friends, and parent-child travel.' -%}
              {%- endif -%}

              <div
                class="ota-item-row"
                data-variant-id="{{ variant.id }}"
                data-base-price="{{ variant.price }}"
                data-package="{{ pkg_type }}"
                data-service-label="{{ vehicle_label | escape }}"
                data-min-qty="1"
                style="{% if pkg_type != 'sedan' %}display:none;{% endif %}"
              >
                <div class="ota-item-info">
                  <span class="ota-item-name">{{ row_title }}</span>
                  <div class="item-desc-tag">{{ desc_text }}</div>
                </div>

                <div class="ota-item-action">
                  <span class="ota-item-price money">{{ variant.price | money }}</span>

                  <div class="ota-stepper">
                    <button type="button" class="js-qty" data-delta="-1" aria-label="Decrease" disabled>-</button>
                    <input type="number" value="0" min="0" readonly inputmode="numeric">
                    <button type="button" class="js-qty" data-delta="1" aria-label="Increase">+</button>
                  </div>
                </div>
              </div>
            {% endfor %}
          </div>
        </div>
      </div>

      <div id="CustomTourView" class="custom-tour-view">
        <span class="custom-icon">🚐</span>
        <h3 class="custom-title">Custom charter request</h3>
        <p class="custom-desc">
          Need a different route, pickup city, vehicle type, or travel duration?<br>
          Our team can create a private Yunnan car charter plan based on your dates, destinations, and group size.
        </p>
        <a href="/pages/contact-us" class="btn-contact-custom">Contact a travel advisor</a>
        <a href="tel:0871-63218099" class="btn-contact-custom">Call hotline 0871-63218099</a>
        <a href="https://wa.me/8613211685553" target="_blank" class="btn-contact-custom">Message on WhatsApp</a>
      </div>

      <div class="ota-footer">
        <div class="ota-total-box">
          <div class="ota-total-price money" id="FinalGrandTotal">
            {{ 0 | money }}
          </div>
          <p class="ota-hint">Estimated total based on selected service days</p>
        </div>

        <div class="ota-btns-area">
          <div class="ota-info-actions">
            <button type="button" class="ota-info-btn" data-modal="included">What's included</button>
            <button type="button" class="ota-info-btn" data-modal="notes">Booking notes</button>
          </div>

          <div class="ota-btns">
            <button type="button" class="ota-btn-cart js-submit" data-type="cart">Add to booking list</button>
            <button type="button" class="ota-btn-buy js-submit" data-type="buy">Book now</button>
          </div>

          <div class="ota-popup" id="OtaInfoPopup" hidden>
            <div class="ota-popup__backdrop"></div>

            <div class="ota-popup__card" role="dialog" aria-modal="true" aria-labelledby="OtaInfoPopupTitle">
              <div class="ota-popup__head">
                <h3 class="ota-popup__title" id="OtaInfoPopupTitle"></h3>
                <button type="button" class="ota-popup__close" aria-label="Close">✕</button>
              </div>
              <div class="ota-popup__body" id="OtaInfoPopupBody"></div>
            </div>

            <div class="ota-popup-source" data-popup-key="included" hidden>
              <div class="ota-popup-copy">
                <strong>What’s Included</strong><br><br>

                • Private vehicle service within the confirmed itinerary<br>
                • Fuel costs<br>
                • Dedicated driver-guide service<br>
                • Driver meal allowance<br>
                • Road tolls and parking fees within the planned route<br>
                • One bottle of mineral water per person per day<br>
                • Basic travel accident insurance<br><br>

                <strong>Not Included</strong><br><br>

                • Attraction entrance tickets<br>
                • Meals not specifically included<br>
                • Hotel accommodation<br>
                • Driver accommodation subsidy for overnight long-distance routes<br>
                • Overtime beyond 8 hours / 300 km per day (RMB 50/hour)<br>
                • Personal expenses and optional activities
              </div>
            </div>

            <div class="ota-popup-source" data-popup-key="notes" hidden>
              <div class="ota-popup-copy">
                <strong>Booking Notes</strong><br><br>

                1. Standard service hours are 08:30–18:30. Adjustments can be made according to your actual route and needs.<br><br>

                2. This product is priced per vehicle per day. The total shown on the page is an estimate based on selected service days and vehicle type.<br><br>

                3. Recommended vehicle capacity:<br>
                • 5-Seater Sedan / SUV: 1–3 adults, up to 2 pieces of 24-inch luggage<br>
                • 7-Seater Premium MPV: 4–6 adults, up to 3–4 pieces of 24-inch luggage<br><br>

                4. For high-altitude mountain routes such as Northwest Yunnan, a higher-power SUV or premium MPV is recommended.<br><br>

                5. One child safety seat can be reserved free of charge upon advance request.<br><br>

                6. Please carry valid passport or identification documents. Attraction access rules may vary by region and season.<br><br>

                7. Final quotation and service confirmation depend on route, distance, duration, season, and availability.
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <aside class="ota-sidebar">
      <div class="sidebar-sticky-card">
        <div class="sidebar-head">
          <h3>Service overview</h3>
        </div>

        <div class="sidebar-content-wrapper">
          <div class="sidebar-labels">
            {% if product.metafields.custom.service_tags.value != blank %}
              {% assign tags = product.metafields.custom.service_tags.value | split: ',' %}
              {% for tag in tags %}
                <span class="s-tag">{{ tag }}</span>
              {% endfor %}
            {% else %}
              <span class="s-tag">Private Tour</span>
              <span class="s-tag">Driver-Guide</span>
              <span class="s-tag">Flexible Route</span>
            {% endif %}
          </div>

          <div class="itinerary-preview">
            {% assign days = product.metafields.custom.itinerary_days.value %}

            {% if days != blank %}
              <div class="ota-accordion">
                {% for d in days %}
                  <div class="accordion-item {% if forloop.first %}active{% endif %}">
                    <div class="accordion-header" role="button" tabindex="0">
                      <div class="header-left">
                        <span class="day-icon">Day {{ d.day_number }}</span>
                      </div>
                      <span class="arrow-icon">▼</span>
                    </div>

                    <div class="accordion-content">
                      <div class="day-timeline">
                        {% assign items = d.items.value %}
                        {% for it in items %}
                          <div class="tl-item" data-type="{{ it.type }}">
                            <div class="tl-dot" aria-hidden="true">
                              {% assign t = it.type | downcase %}
                              {% case t %}
                                {% when 'meal' %}
                                  <svg class="tl-ico" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                                    <path d="M8 3v7a3 3 0 0 1-3 3H4" stroke-linecap="round"/>
                                    <path d="M4 3v10" stroke-linecap="round"/>
                                    <path d="M14 3v8a3 3 0 0 0 3 3h1V3" stroke-linecap="round"/>
                                  </svg>

                                {% when 'car' %}
                                  <svg class="tl-ico" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                                    <path d="M3 13l1-4a3 3 0 0 1 3-2h10a3 3 0 0 1 3 2l1 4" stroke-linejoin="round"/>
                                    <path d="M5 13h14v5a2 2 0 0 1-2 2h-1" stroke-linejoin="round"/>
                                    <circle cx="7" cy="18" r="1.2"/><circle cx="17" cy="18" r="1.2"/>
                                  </svg>

                                {% when 'spot' %}
                                  <svg class="tl-ico" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                                    <path d="M12 21s6-4.5 6-10a6 6 0 1 0-12 0c0 5.5 6 10 6 10Z" stroke-linejoin="round"/>
                                    <path d="M12 11.5V8.2" stroke-linecap="round"/>
                                  </svg>

                                {% when 'hotel' %}
                                  <svg class="tl-ico" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                                    <path d="M3 11h18" stroke-linecap="round"/>
                                    <path d="M5 11V7a2 2 0 0 1 2-2h3v6" stroke-linejoin="round"/>
                                    <path d="M14 11V7a2 2 0 0 1 2-2h3v6" stroke-linejoin="round"/>
                                    <path d="M4 20v-5a2 2 0 0 1 2-2h12a2 2 0 0 1 2 2v5" stroke-linejoin="round"/>
