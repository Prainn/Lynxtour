<style>
  /* 全局重置 */
  .luxury-collection-wrapper {
    background-color: #050505;
    color: #fff;
    overflow: hidden;
  }

  /* --- HERO SECTION --- */
  .coll-hero-compact {
    height: 40vh;
    min-height: 350px;
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: 1;
  }

  .hero-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: brightness(0.5);
  }

  .hero-placeholder {
    background: #111;
    width: 100%;
    height: 100%;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, rgba(5,5,5,0) 0%, rgba(5,5,5,0.9) 100%);
    z-index: 2;
  }

  .hero-text-container {
    position: relative;
    z-index: 10;
    text-align: center;
    width: 100%;
  }

  .hero-content {
    max-width: 920px;
    margin: 0 auto;
    padding: 0 18px;
  }

  .coll-hero-actions {
    display: flex;
    gap: 12px;
    justify-content: center;
    flex-wrap: wrap;
    margin-top: 22px;
  }

  .coll-hero-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 42px;
    padding: 0 16px;
    text-decoration: none;
    border: 1px solid rgba(255,255,255,0.18);
    color: #fff;
    transition: 0.25s ease;
  }

  .coll-hero-btn.primary {
    background: #d4af37;
    border-color: #d4af37;
    color: #111;
  }

  .coll-hero-btn.primary:hover {
    background: #e3bf4e;
    border-color: #e3bf4e;
  }

  .coll-hero-btn.secondary:hover {
    border-color: rgba(255,255,255,0.34);
    background: rgba(255,255,255,0.03);
  }

  .subtitle-wrap {
    margin-bottom: 6px;
  }

  .coll-subtitle {
    color: #c4b5a6;
    font-size: 8px;
    letter-spacing: 0.6em;
    text-transform: uppercase;
  }

  .subtitle-line {
    width: 35px;
    height: 1px;
    background: #c4b5a6;
    margin: 12px auto 0;
  }

  .coll-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 300;
    font-style: italic;
    margin: 10px 0;
    color: #fff;
  }

  .coll-desc {
    font-size: 13px;
    color: #888;
    max-width: 560px;
    margin: 0 auto;
    line-height: 1.7;
    display: -webkit-box;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 3;
    overflow: hidden;
  }

  /* --- 文案模块 --- */
  .collection-copy-block {
    border-top: 1px solid rgba(196, 181, 166, 0.12);
    padding-top: 42px;
    margin-bottom: 64px;
  }

  .collection-copy-inner {
    max-width: 980px;
    margin: 0 auto;
  }

  .collection-copy-inner.narrow {
    max-width: 860px;
  }

  .copy-heading {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(1.8rem, 4vw, 2.5rem);
    font-style: italic;
    font-weight: 400;
    color: #fff;
    margin: 0 0 22px;
  }

  .copy-richtext p {
    color: #b4aca3;
    font-size: 15px;
    line-height: 1.9;
    margin: 0 0 18px;
    letter-spacing: 0.01em;
  }

  .copy-richtext a {
    color: #e7d6bf;
    text-decoration: none;
    border-bottom: 1px solid rgba(231,214,191,0.28);
  }

  .copy-richtext a:hover {
    color: #fff;
    border-color: rgba(255,255,255,0.45);
  }

  /* --- FAQ Accordion --- */
  .collection-faq-block .copy-heading {
    margin-bottom: 26px;
  }

  .faq-accordion {
    border-top: 1px solid rgba(196, 181, 166, 0.14);
  }

  .faq-acc-item {
    border-bottom: 1px solid rgba(196, 181, 166, 0.12);
    background: linear-gradient(
      180deg,
      rgba(255,255,255,0.01) 0%,
      rgba(255,255,255,0.005) 100%
    );
    transition: background 0.35s ease, border-color 0.35s ease, transform 0.35s ease;
  }

  .faq-acc-item:hover {
    background: linear-gradient(
      180deg,
      rgba(196,181,166,0.05) 0%,
      rgba(255,255,255,0.01) 100%
    );
  }

  .faq-acc-trigger {
    width: 100%;
    background: transparent;
    border: 0;
    color: #fff;
    padding: 22px 0;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    cursor: pointer;
    text-align: left;
  }

  .faq-acc-question {
    font-size: 17px;
    line-height: 1.5;
    font-weight: 400;
    color: #fff;
    transition: color 0.3s ease;
  }

  .faq-acc-item:hover .faq-acc-question,
  .faq-acc-item.is-open .faq-acc-question {
    color: #d8c8b8;
  }

  .faq-acc-icon {
    position: relative;
    width: 18px;
    height: 18px;
    flex: 0 0 18px;
  }

  .faq-acc-icon::before,
  .faq-acc-icon::after {
    content: "";
    position: absolute;
    top: 50%;
    left: 50%;
    background: #c4b5a6;
    transform: translate(-50%, -50%);
    transition: transform 0.28s ease, opacity 0.28s ease, background 0.28s ease;
  }

  .faq-acc-icon::before {
    width: 18px;
    height: 1px;
  }

  .faq-acc-icon::after {
    width: 1px;
    height: 18px;
  }

  .faq-acc-item.is-open .faq-acc-icon::after {
    opacity: 0;
    transform: translate(-50%, -50%) scaleY(0.4);
  }

  .faq-acc-panel {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.45s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .faq-acc-answer {
    padding: 0 0 24px;
    max-width: 980px;
  }

  .faq-acc-answer p {
    color: #a59d94;
    font-size: 15px;
    line-height: 1.95;
    margin: 0;
  }

  .collection-faq-block {
    opacity: 0;
    transform: translateY(28px);
    transition: opacity 0.85s cubic-bezier(0.22, 1, 0.36, 1),
                transform 0.85s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .collection-faq-block.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* --- FAQ 动画增强 --- */
  .collection-faq-block .copy-heading {
    opacity: 0;
    transform: translateY(24px);
    transition: opacity 0.8s cubic-bezier(0.22, 1, 0.36, 1),
                transform 0.8s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .collection-faq-block .faq-item {
    position: relative;
    opacity: 0;
    transform: translateY(34px);
    filter: blur(6px);
    transition:
      opacity 0.85s cubic-bezier(0.22, 1, 0.36, 1),
      transform 0.85s cubic-bezier(0.22, 1, 0.36, 1),
      filter 0.85s cubic-bezier(0.22, 1, 0.36, 1),
      border-color 0.35s ease,
      background 0.35s ease,
      box-shadow 0.35s ease;
    transition-delay: var(--faq-delay, 0ms);
    padding: 24px 18px 20px;
    border-top: 1px solid rgba(196, 181, 166, 0.12);
    background: linear-gradient(
      180deg,
      rgba(255,255,255,0.015) 0%,
      rgba(255,255,255,0.005) 100%
    );
    overflow: hidden;
  }

  .collection-faq-block .faq-item::before {
    content: "";
    position: absolute;
    top: 0;
    left: 18px;
    width: 0;
    height: 1px;
    background: linear-gradient(to right, #c4b5a6, transparent);
    transition: width 0.45s ease;
  }

  .collection-faq-block.is-visible .copy-heading {
    opacity: 1;
    transform: translateY(0);
  }

  .collection-faq-block.is-visible .faq-item {
    opacity: 1;
    transform: translateY(0);
    filter: blur(0);
  }

  .collection-faq-block .faq-item:hover {
    transform: translateY(-4px);
    border-top-color: rgba(196, 181, 166, 0.28);
    background: linear-gradient(
      180deg,
      rgba(196,181,166,0.06) 0%,
      rgba(255,255,255,0.012) 100%
    );
    box-shadow: 0 14px 30px rgba(0,0,0,0.18);
  }

  .collection-faq-block .faq-item:hover::before {
    width: 140px;
  }

  .collection-faq-block .faq-item h3 {
    transition: color 0.3s ease;
  }

  .collection-faq-block .faq-item:hover h3 {
    color: #d8c8b8;
  }

  .collection-faq-block .faq-item p {
    transition: color 0.3s ease;
  }

  .collection-faq-block .faq-item:hover p {
    color: #b7afa6;
  }

  @media (max-width: 990px) {
    .collection-faq-block .faq-item {
      transform: translateY(26px);
      padding: 20px 14px 18px;
    }

    .collection-faq-block .faq-item:hover {
      transform: translateY(-2px);
    }
  }

  /* --- 精致三列网格布局 --- */
  .coll-container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 40px 60px 100px;
  }

  .compact-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 50px 40px;
  }

  /* --- 入场动画初始状态 --- */
  .reveal-item {
    opacity: 0;
    transform: translateY(30px);
    transition: all 0.8s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .reveal-item.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* --- 卡片视觉与交互 --- */
  .card-link {
    color: inherit;
    text-decoration: none;
    display: block;
  }

  .card-visual {
    position: relative;
    overflow: hidden;
    aspect-ratio: 0.85;
    background: #0a0a0a;
    border: 0.5px solid rgba(255,255,255,0.05);
  }

  .card-visual img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 1.5s cubic-bezier(0.19, 1, 0.22, 1);
  }

  .card-img-placeholder {
    width: 100%;
    height: 100%;
    background: #111;
  }

  .card-overlay {
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,0);
    transition: all 0.6s ease;
    display: flex;
    align-items: center;
    justify-content: center;
    backdrop-filter: blur(0px);
  }

  .card-btn {
    color: #fff;
    font-size: 8px;
    letter-spacing: 0.3em;
    border: 0.5px solid #fff;
    padding: 8px 16px;
    opacity: 0;
    transform: translateY(10px);
    transition: 0.4s ease;
  }

  .grid-item:hover img { transform: scale(1.08); }
  .grid-item:hover .card-overlay { background: rgba(0,0,0,0.3); backdrop-filter: blur(5px); }
  .grid-item:hover .card-btn { opacity: 1; transform: translateY(0); }
  .grid-item:hover .product-title { color: #c4b5a6; }

  .card-content { margin-top: 15px; }

  .card-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 16px;
  }

  .product-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: 18px;
    font-weight: 300;
    font-style: italic;
    transition: color 0.3s ease;
    margin: 0;
    min-width: 0;
  }

  .product-price {
    font-size: 12px;
    color: #aaa;
    font-weight: 300;
    white-space: nowrap;
    flex-shrink: 0;
    margin: 0;
  }

  .price-prefix {
    opacity: 0.8;
  }

  .product-info-row {
    font-size: 8px;
    color: #555;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin-top: 5px;
  }

  .route-indicator {
    position: absolute;
    top: 12px;
    left: 12px;
    background: rgba(0,0,0,0.5);
    padding: 4px 8px;
    font-size: 7px;
    color: #fff;
    display: flex;
    align-items: center;
    gap: 4px;
  }

  .dot-pulse {
    width: 4px;
    height: 4px;
    background: #c4b5a6;
    border-radius: 50%;
    box-shadow: 0 0 5px #c4b5a6;
  }

  /* --- 重新设计的 Meta Bar --- */
  .coll-meta-bar {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 30px;
    margin-bottom: 48px;
    padding: 20px 0;
    border-top: 1px solid rgba(196, 181, 166, 0.15);
    border-bottom: 1px solid rgba(196, 181, 166, 0.15);
  }

  .meta-left,
  .meta-right {
    display: flex;
    align-items: baseline;
    gap: 8px;
  }

  .meta-number {
    font-family: 'Cormorant Garamond', serif;
    font-size: 24px;
    font-style: italic;
    color: #c4b5a6;
  }

  .meta-label {
    font-size: 9px;
    text-transform: uppercase;
    letter-spacing: 0.3em;
    color: #666;
  }

  .meta-location {
    font-size: 10px;
    letter-spacing: 0.4em;
    text-transform: uppercase;
    color: #888;
    font-weight: 300;
  }

  .meta-divider {
    width: 1px;
    height: 20px;
    background: linear-gradient(to bottom, transparent, #c4b5a6, transparent);
    opacity: 0.6;
  }

  .collection-pagination {
    margin-top: 60px;
    text-align: center;
  }

  .collection-pagination a,
  .collection-pagination span {
    color: #aaa;
    text-decoration: none;
    margin: 0 8px;
    font-size: 12px;
    letter-spacing: 0.12em;
  }

  .collection-pagination .current {
    color: #fff;
  }

  @media (max-width: 990px) {
    .coll-hero-compact {
      height: auto;
      min-height: 420px;
    }

    .hero-content {
      padding: 0 20px;
    }

    .coll-hero-actions {
      margin-top: 18px;
    }

    .coll-title {
      font-size: clamp(2rem, 8vw, 3.2rem);
      line-height: 1.05;
    }

    .coll-desc {
      font-size: 14px;
      line-height: 1.8;
      max-width: 640px;
    }

    .coll-container {
      padding: 32px 16px 80px;
    }

    .compact-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 26px 14px;
      align-items: start;
    }

    .grid-item {
      min-width: 0;
    }

    .card-visual {
      aspect-ratio: 0.82;
    }

    .card-content {
      margin-top: 12px;
    }

    .card-header {
      display: flex;
      flex-direction: column;
      align-items: flex-start;
      justify-content: flex-start;
      gap: 6px;
    }

    .product-title {
      width: 100%;
      margin: 0;
      font-family: 'Cormorant Garamond', serif;
      font-size: 15px;
      font-style: italic;
      font-weight: 400;
      line-height: 1.4;
      letter-spacing: 0;
      word-break: normal;
      overflow-wrap: break-word;
    }

    .product-price {
      margin: 0;
      font-size: 12px;
      line-height: 1.2;
      color: #9f9f9f;
      white-space: nowrap;
      flex-shrink: 1;
    }

    .price-prefix {
      opacity: 0.78;
    }

    .product-info-row {
      margin-top: 8px;
      font-size: 9px;
      letter-spacing: 0.14em;
    }

    .coll-meta-bar {
      margin-bottom: 38px;
      padding: 18px 0;
      gap: 22px;
    }

    .meta-number {
      font-size: 22px;
    }

    .meta-label {
      font-size: 8px;
    }

    .meta-location {
      font-size: 9px;
      letter-spacing: 0.32em;
    }

    .faq-acc-trigger {
      padding: 18px 0;
      gap: 16px;
    }

    .faq-acc-question {
      font-size: 15px;
      line-height: 1.55;
    }

    .faq-acc-answer p {
      font-size: 14px;
      line-height: 1.85;
    }

    .copy-richtext p {
      font-size: 14px;
    }

    .collection-faq-block .faq-item {
      transform: translateY(26px);
      padding: 20px 14px 18px;
    }

    .collection-faq-block .faq-item:hover {
      transform: translateY(-2px);
    }

    .coll-hero-btn {
      width: 100%;
    }
  }

  @media (max-width: 768px) {
    .coll-meta-bar {
      flex-direction: column;
      gap: 14px;
      border: none;
    }

    .meta-divider {
      width: 30px;
      height: 1px;
      background: linear-gradient(to right, transparent, #c4b5a6, transparent);
    }

    .collection-copy-block {
      padding-top: 28px;
      margin-bottom: 42px;
    }

    .copy-heading {
      margin-bottom: 18px;
    }

    .faq-acc-answer {
      padding-bottom: 20px;
    }
  }

  @media (max-width: 430px) {
    .compact-grid {
      gap: 24px 12px;
    }

    .product-title {
      font-size: 14px;
      line-height: 1.36;
    }

    .product-price {
      font-size: 11px;
    }

    .product-info-row {
      font-size: 8px;
      letter-spacing: 0.12em;
    }
  }
</style>

<div class="luxury-collection-wrapper" id="CollectionProductGrid">

  {%- assign is_lijiang_private_tours = false -%}
  {%- if collection.handle == 'lijiang-private-tours' -%}
    {%- assign is_lijiang_private_tours = true -%}
  {%- endif -%}

  <header class="coll-hero-compact">
    <div class="hero-bg">
      {% if collection.image %}
        <img src="{{ collection.image | img_url: '2000x' }}" alt="{{ collection.title | escape }} - Lynxtour" class="hero-img">
      {% else %}
        <div class="hero-placeholder"></div>
      {% endif %}
      <div class="hero-overlay"></div>
    </div>

    <div class="hero-text-container">
      <div class="hero-content">
        <div class="subtitle-wrap">
          <span class="coll-subtitle">
            {% if is_lijiang_private_tours %}
              BENEATH THE JADE PEAK
            {% else %}
              SELECTED JOURNEYS
            {% endif %}
          </span>
          <div class="subtitle-line"></div>
        </div>

        <h1 class="coll-title">
          {% if is_lijiang_private_tours %}
            Lijiang Private Tours
          {% else %}
            {{ collection.title }}
          {% endif %}
        </h1>

        {% if is_lijiang_private_tours %}
          <div class="coll-desc-wrap">
            <div class="coll-desc">
              Explore Lijiang with a private itinerary built around old-town atmosphere, mountain scenery, and Naxi heritage.
              <br>
              Compare shorter Lijiang stays with wider routes linking Dali, Shangri-La, and beyond.
            </div>
          </div>
        {% elsif collection.description != blank %}
          <div class="coll-desc-wrap">
            <div class="coll-desc">{{ collection.description | strip_html }}</div>
          </div>
        {% endif %}

        {% if is_lijiang_private_tours %}
          <div class="coll-hero-actions">
            <a href="#CollectionGrid" class="coll-hero-btn primary">Compare Lijiang Routes</a>
            <a href="/pages/bespoke-custom-travel" class="coll-hero-btn secondary">Plan a Custom Lijiang Trip</a>
          </div>
        {% endif %}
      </div>
    </div>
  </header>

  <div class="coll-container">
    <div class="coll-meta-bar">
      <div class="meta-left">
        <span class="meta-number">{{ collection.products_count }}</span>
        <span class="meta-label">Selected Experiences</span>
      </div>
      <div class="meta-divider"></div>
      <div class="meta-right">
        <span class="meta-location">
          {% if is_lijiang_private_tours %}
            Lijiang, Yunnan
          {% else %}
            Yunnan, China
          {% endif %}
        </span>
      </div>
    </div>

    {% paginate collection.products by 12 %}

      {% if is_lijiang_private_tours and paginate.current_page == 1 %}
        <section class="collection-copy-block collection-intro-block">
          <div class="collection-copy-inner">
            <h2 class="copy-heading">Why Choose a Private Tour in Lijiang?</h2>
            <div class="copy-richtext">
              <p>A private tour in Lijiang gives you more freedom to balance old-town walks, scenic viewpoints, and day trips at your own pace. It works especially well for travelers who want culture, photography, and a more comfortable way to connect Lijiang with nearby destinations.</p>
              <p><a href="/pages/lijiang">See our Lijiang travel guide</a>, <a href="/blogs/travel-guides/jade-dragon-snow-mountain-guide">Explore Jade Dragon Snow Mountain ideas</a>, or <a href="/pages/bespoke-custom-travel">Plan a custom Lijiang itinerary</a>.</p>
            </div>
          </div>
        </section>
      {% endif %}

      <div class="compact-grid" id="CollectionGrid">
        {% for product in collection.products %}
          {% liquid
  assign included_main_keywords = 'independent group of' | split: '|'
  assign excluded_keywords = 'single room supplement|room supplement|single supplement|supplement|children pricing|child|children|kid|kids|infant|baby|toddler|add-on|addon|upgrade|custom|extra bed|surcharge|儿童|小童|婴儿' | split: '|'

  assign collection_display_price = blank
  assign valid_main_variant_count = 0
  assign found_main_variant = false

  for variant in product.variants
    assign variant_title = variant.title | downcase | strip
    assign is_main_variant = false
    assign is_excluded = false

    for keyword in excluded_keywords
      if variant_title contains keyword
        assign is_excluded = true
        break
      endif
    endfor

    unless is_excluded
      for keyword in included_main_keywords
        if variant_title contains keyword
          assign is_main_variant = true
          break
        endif
      endfor

      if is_main_variant
        assign found_main_variant = true
        assign valid_main_variant_count = valid_main_variant_count | plus: 1

        if collection_display_price == blank or variant.price < collection_display_price
          assign collection_display_price = variant.price
        endif
      endif
    endunless
  endfor

  if found_main_variant == false
    assign valid_main_variant_count = 0
    assign collection_display_price = blank

    for variant in product.variants
      assign variant_title = variant.title | downcase | strip
      assign is_excluded = false

      for keyword in excluded_keywords
        if variant_title contains keyword
          assign is_excluded = true
          break
        endif
      endfor

      unless is_excluded
        assign valid_main_variant_count = valid_main_variant_count | plus: 1

        if collection_display_price == blank or variant.price < collection_display_price
          assign collection_display_price = variant.price
        endif
      endunless
    endfor
  endif

  if collection_display_price == blank
    assign collection_display_price = product.price
  endif

  assign show_from_prefix = false
  if valid_main_variant_count > 1
    assign show_from_prefix = true
  endif
%}

