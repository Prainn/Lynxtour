<header class="site-header-wrapper" id="site-header">
  {%- if section.settings.show_slogan -%}
    <div class="slogan-bar-wrapper" id="slogan-node">
      <div class="slogan-inner">
        <div class="slogan-gradient"></div>
        <div class="slogan-content">
          <p class="slogan-text">{{ section.settings.slogan_text }}</p>
        </div>
      </div>
    </div>
  {%- endif -%}

  <nav class="main-nav-bar" id="nav-node">
    <div class="header-container flex-layout">
      <div class="header-left">
        <a href="/" class="logo-wrapper">
          {%- if section.settings.logo_image != blank -%}
            <img src="{{ section.settings.logo_image | img_url: '400x' }}" alt="{{ shop.name }}" class="header-logo-image" style="height: {{ section.settings.logo_height }}px;">
          {%- endif -%}
          <div class="logo-text-group">
            <span class="logo-cn">{{ section.settings.logo_text_cn }}</span>
            <span class="logo-en">{{ section.settings.logo_text_en }}</span>
          </div>
        </a>
      </div>

      <div class="header-right">
        <div class="desktop-nav">
          {%- assign nav_menu = linklists[section.settings.main_menu] -%}
          {%- for link in nav_menu.links -%}
            <div class="nav-group">
              <a href="{{ link.url }}" class="nav-item">
                {{ link.title }}{%- if link.links != blank -%}<span class="caret"></span>{%- endif -%}
              </a>
              {%- if link.links != blank -%}
                <div class="dropdown-menu">
                  {%- for childlink in link.links -%}
                    <a href="{{ childlink.url }}" class="dropdown-link">{{ childlink.title }}</a>
                  {%- endfor -%}
                </div>
              {%- endif -%}
            </div>
          {%- endfor -%}
        </div>
        
        <!-- 桌面端语言选择器 (仅在后台开启多语言时显示) -->
        {%- if localization.available_languages.size > 1 -%}
          <div class="desktop-lang-switch">
            {%- form 'localization', id: 'HeaderLanguageForm' -%}
              <div class="lang-selector-wrap">
                <input type="hidden" name="locale_code" value="{{ localization.language.iso_code }}">
                <span class="lang-icon">🌐</span>
                <select name="locale_code" class="lang-select" onchange="this.form.submit()">
                  {%- for language in localization.available_languages -%}
                    <option value="{{ language.iso_code }}" {% if language.iso_code == localization.language.iso_code %}selected{% endif %}>
                      {{ language.endonym_name | capitalize }}
                    </option>
                  {%- endfor -%}
                </select>
              </div>
            {%- endform -%}
          </div>
        {%- endif -%}

        <!-- 新增：桌面端客户账户 -->
        {%- if shop.customer_accounts_enabled -%}
          <div class="desktop-account-switch">
            {%- if customer -%}
              <a href="{{ routes.account_url }}" class="account-link">
                <span class="account-icon">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>
                </span>
                Account
              </a>
            {%- else -%}
              <a href="{{ routes.account_login_url }}" class="account-link">
                <span class="account-icon">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>
                </span>
                Sign in
              </a>
            {%- endif -%}
          </div>
        {%- endif -%}
        
        <button id="menu-toggle" class="mobile-toggle" aria-label="Open Menu">
          <span class="hamburger-box">
            <span class="hamburger-inner"></span>
          </span>
        </button>
      </div>
    </div>
  </nav>
</header>

<div class="mobile-drawer" id="mobile-drawer">
  <div class="drawer-overlay" id="drawer-overlay"></div>
  <div class="drawer-content">
    <div class="drawer-header">
       <span class="logo-cn">{{ section.settings.logo_text_cn }}</span>
       <button id="drawer-close" class="close-btn">&times;</button>
    </div>
    <div class="drawer-menu">
      {%- for link in linklists[section.settings.main_menu].links -%}
        <div class="drawer-item" data-mobile-nav-index="{{ forloop.index0 }}">
          <a href="{{ link.url }}" class="drawer-link">{{ link.title }}</a>
          {%- if link.links != blank -%}
            <div class="drawer-sub" data-drawer-submenu hidden></div>
          {%- endif -%}
        </div>
      {%- endfor -%}

      <!-- 移动端语言选择器 (在菜单底部) -->
      {%- if localization.available_languages.size > 1 -%}
        <div class="mobile-lang-switch">
          {%- form 'localization', id: 'MobileLanguageForm' -%}
            <p class="drawer-sub-link" style="margin-bottom:8px; opacity:0.5;">Language</p>
            <div class="lang-selector-wrap mobile-wrap">
              <input type="hidden" name="locale_code" value="{{ localization.language.iso_code }}">
              <select name="locale_code" class="lang-select mobile-select" onchange="this.form.submit()">
                {%- for language in localization.available_languages -%}
                  <option value="{{ language.iso_code }}" {% if language.iso_code == localization.language.iso_code %}selected{% endif %}>
                    {{ language.endonym_name | capitalize }}
                  </option>
                {%- endfor -%}
              </select>
            </div>
          {%- endform -%}
        </div>
      {%- endif -%}

      <!-- 新增：移动端客户账户 -->
      {%- if shop.customer_accounts_enabled -%}
        <div class="mobile-account-switch">
          <p class="drawer-sub-link" style="margin-bottom:8px; opacity:0.5;">Account</p>
          {%- if customer -%}
            <a href="{{ routes.account_url }}" class="drawer-link" style="display: flex; align-items: center; gap: 8px;">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>
              {{ customer.first_name | default: 'My Account' }}
            </a>
            <a href="{{ routes.account_logout_url }}" class="drawer-sub-link" style="margin-top: 5px;">Log out</a>
          {%- else -%}
            <a href="{{ routes.account_login_url }}" class="drawer-link" style="display: flex; align-items: center; gap: 8px;">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>
              Sign in
            </a>
          {%- endif -%}
        </div>
      {%- endif -%}

    </div>
  </div>
</div>

<style>
  :root {
  --brand-color: {{ section.settings.btn_color }};
  --slogan-h: {% if section.settings.show_slogan %}36px{% else %}0px{% endif %};
  --nav-h: 90px;
  --page-first-copy-gap: 24px;
  --page-first-copy-offset: calc(var(--nav-h) + var(--page-first-copy-gap));
}

  /* 基础布局 */
  .main-nav-bar { position: absolute; top: var(--slogan-h); left: 0; width: 100%; z-index: 1000; transition: 0.4s; }
  .main-nav-bar.is-stuck { position: fixed; top: 0; background: rgba(12, 10, 9, 0.95); backdrop-filter: blur(15px); }
  .header-container { max-width: 1440px; margin: 0 auto; padding: 0 60px; }
  .flex-layout { display: flex; justify-content: space-between; align-items: center; height: 90px; }
  
  .header-right { display: flex; align-items: center; gap: 20px; }

  .logo-wrapper { display: flex; align-items: center; gap: 12px; text-decoration: none; }
  .logo-cn { color: var(--brand-color); font-size: 20px; font-weight: 700; letter-spacing: 2px; }
  .logo-en { color: #d6d3d1; font-size: 9px; opacity: 0.6; letter-spacing: 1px; display: block; }

  /* --- 桌面菜单核心修正 --- */
  .desktop-nav { display: flex; gap: 10px; height: 100%; align-items: center; }
  
  .nav-group { 
    position: relative; 
    height: 100%;
    display: flex;
    align-items: center;
  }

  .nav-item { 
    color: #fff; 
    text-decoration: none; 
    font-size: 13px; 
    letter-spacing: 2px; 
    text-transform: uppercase; 
    padding: 0 15px;
    height: 90px; 
    display: flex;
    align-items: center;
    transition: 0.3s;
  }
  
  .nav-item:hover { color: var(--brand-color); }

  /* 二级菜单定位修正 */
  .dropdown-menu { 
    position: absolute; 
    top: 90%; 
    left: 0;  
    background: #0c0a09; 
    min-width: 200px; 
    padding: 10px 0;
    opacity: 0; 
    visibility: hidden; 
    transition: all 0.3s ease; 
    border: 1px solid rgba(255,255,255,0.1); 
    box-shadow: 0 10px 30px rgba(0,0,0,0.5);
    z-index: 1100;
  }

  .nav-group:hover .dropdown-menu { opacity: 1; visibility: visible; top: 100%; }

  .dropdown-link { display: block; padding: 12px 25px; color: #ccc; text-decoration: none; font-size: 12px; transition: 0.3s; white-space: nowrap; }
  .dropdown-link:hover { background: var(--brand-color); color: #000; padding-left: 30px; }

  .caret { border-top: 4px solid currentColor; border-left: 4px solid transparent; border-right: 4px solid transparent; margin-left: 8px; opacity: 0.6; }

  /* --- 语言选择器样式 --- */
  .desktop-lang-switch { display: flex; align-items: center; margin-left: 5px; }
  .lang-selector-wrap { position: relative; display: flex; align-items: center; }
  .lang-icon { color: #888; font-size: 14px; margin-right: 4px; pointer-events: none; }
  
  .lang-select {
    appearance: none; -webkit-appearance: none;
    background: transparent;
    color: #ccc;
    border: 1px solid rgba(255,255,255,0.2);
    border-radius: 4px;
    padding: 4px 8px 4px 8px;
    font-size: 11px;
    cursor: pointer;
    transition: 0.3s;
    outline: none;
    text-align: center;
  }
  .lang-select:hover { border-color: var(--brand-color); color: var(--brand-color); }
  .lang-select option { background: #0c0a09; color: #fff; }

  .mobile-lang-switch { margin-top: 30px; padding-top: 20px; border-top: 1px solid rgba(255,255,255,0.1); }
  .mobile-select { width: 100%; text-align: left; padding: 10px; font-size: 14px; border-color: rgba(255,255,255,0.1); }

  /* --- 新增：客户账户样式 --- */
  .desktop-account-switch { display: flex; align-items: center; margin-left: 10px; }
  .account-link { display: flex; align-items: center; gap: 6px; color: #ccc; text-decoration: none; font-size: 12px; font-weight: 500; letter-spacing: 1px; transition: 0.3s; text-transform: uppercase; }
  .account-link:hover { color: var(--brand-color); }
  .account-icon { color: var(--brand-color); display: flex; align-items: center; }
  
  .mobile-account-switch { margin-top: 20px; padding-top: 20px; border-top: 1px solid rgba(255,255,255,0.1); }

  /* --- 移动端样式 --- */
  .mobile-toggle { display: none; cursor: pointer; background: none; border: none; padding: 10px; }
  .hamburger-box { width: 24px; height: 18px; display: inline-block; position: relative; }
  .hamburger-inner, .hamburger-inner::before, .hamburger-inner::after { width: 24px; height: 2px; background-color: #fff; position: absolute; transition: 0.3s; }
  .hamburger-inner { top: 50%; transform: translateY(-50%); }
  .hamburger-inner::before { content: ""; top: -8px; }
  .hamburger-inner::after { content: ""; top: 8px; }

  .mobile-drawer { position: fixed; inset: 0; z-index: 2000; visibility: hidden; }
  .mobile-drawer.is-active { visibility: visible; }
  .drawer-overlay { position: absolute; inset: 0; background: rgba(0,0,0,0.8); opacity: 0; transition: 0.4s; }
  .mobile-drawer.is-active .drawer-overlay { opacity: 1; }
  .drawer-content { position: absolute; top: 0; right: -100%; width: 80%; max-width: 350px; height: 100%; background: #0c0a09; transition: 0.4s; padding: 40px 30px; overflow-y: auto; }
  .mobile-drawer.is-active .drawer-content { right: 0; }
  .drawer-link { color: #fff; text-decoration: none; font-size: 18px; display: block; margin-bottom: 15px; }
  .drawer-sub { padding-left: 15px; margin-bottom: 20px; border-left: 1px solid var(--brand-color); }
  .drawer-sub-link { color: #888; text-decoration: none; font-size: 14px; display: block; margin-bottom: 10px; }
  .close-btn { background: none; border: none; font-size: 28px; color: #fff; cursor: pointer; }

  @media (max-width: 990px) {
    .desktop-nav { display: none; }
    .desktop-lang-switch { display: none; }
    .desktop-account-switch { display: none; } /* 新增：手机端隐藏桌面账户按钮 */
    .mobile-toggle { display: block; }
    .header-container { padding: 0 24px; }
  }

  @media (max-width: 990px) {
  :root {
    --slogan-h: 0px;
    --nav-h: 72px;
    --page-first-copy-gap: 12px;
    --header-safe: calc(var(--nav-h) + env(safe-area-inset-top));
    --page-first-copy-offset: calc(var(--header-safe) + var(--page-first-copy-gap));
  }

  /* 移动端先隐藏 slogan，避免顶部高度叠加混乱 */
  .slogan-bar-wrapper {
    display: none !important;
  }

  /* 给固定 header 预留真实占位，避免下面内容顶上来 */
  #site-header {
    position: relative;
    z-index: 1000;
    height: var(--header-safe);
    min-height: calc(var(--nav-h) + env(safe-area-inset-top));
    box-sizing: border-box;
  }

  /* 移动端 header 从一开始就是固定的，不再 absolute 压首屏 */
  .main-nav-bar,
  .main-nav-bar.is-stuck {
    position: fixed !important;
    top: 0 !important;
    left: 0;
    width: 100%;
    background: rgba(12, 10, 9, 0.92) !important;
    backdrop-filter: blur(15px);
    -webkit-backdrop-filter: blur(15px);
    border-bottom: 1px solid rgba(255,255,255,0.08);
    z-index: 1000;
    height: var(--header-safe);
    box-sizing: border-box;
  }

  .header-container {
    padding: 0 20px;
    height: 100%;
  }

  .flex-layout {
    height: var(--header-safe);
    padding-top: env(safe-area-inset-top);
    box-sizing: border-box;
  }

  .header-left {
    flex: 1 1 auto;
    min-width: 0;
  }

  .header-right {
    flex: 0 0 auto;
    min-width: auto;
    gap: 10px;
  }

  .logo-wrapper {
    max-width: 100%;
    min-width: 0;
    gap: 10px;
  }

  .header-logo-image {
    max-height: 34px;
    width: auto;
    flex: 0 0 auto;
  }

  .logo-text-group {
    min-width: 0;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    justify-content: center;
    line-height: 1.05;
  }

  .logo-cn {
    font-size: 16px;
    letter-spacing: 1.2px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .logo-en {
    font-size: 7px;
    letter-spacing: 0.8px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .mobile-toggle {
    display: flex;
    flex: 0 0 44px;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    padding: 0;
  }
}
</style>

{%- assign mobile_nav_menu = linklists[section.settings.main_menu] -%}
<script type="application/json" id="mobile-nav-children-data">
{
  {%- assign mobile_nav_json_started = false -%}
  {%- for link in mobile_nav_menu.links -%}
    {%- if link.links != blank -%}
      {%- if mobile_nav_json_started -%},{%- endif -%}
      "{{ forloop.index0 }}":[
        {%- for childlink in link.links -%}
          {"title":{{ childlink.title | json }},"url":{{ childlink.url | json }}}{%- unless forloop.last -%},{%- endunless -%}
        {%- endfor -%}
      ]
      {%- assign mobile_nav_json_started = true -%}
    {%- endif -%}
  {%- endfor -%}
}
</script>

<script>
document.addEventListener('DOMContentLoaded', function() {
  const toggle = document.getElementById('menu-toggle');
  const drawer = document.getElementById('mobile-drawer');
  const close = document.getElementById('drawer-close');
  const overlay = document.getElementById('drawer-overlay');
  const nav = document.getElementById('nav-node');
  const mobileNavDataNode = document.getElementById('mobile-nav-children-data');

  let mobileNavChildren = {};
  if (mobileNavDataNode && mobileNavDataNode.textContent.trim() !== '') {
    try {
      mobileNavChildren = JSON.parse(mobileNavDataNode.textContent);
    } catch (error) {
      mobileNavChildren = {};
    }
  }

  const populateMobileDrawerSubmenus = () => {
    const drawerItems = document.querySelectorAll('.drawer-item[data-mobile-nav-index]');

    drawerItems.forEach((item) => {
      const submenu = item.querySelector('[data-drawer-submenu]');
      const submenuIndex = item.getAttribute('data-mobile-nav-index');
      const childLinks = mobileNavChildren[submenuIndex];

      if (!submenu || !Array.isArray(childLinks) || submenu.dataset.populated === 'true') return;

      childLinks.forEach((childLink) => {
        const childAnchor = document.createElement('a');
        childAnchor.className = 'drawer-sub-link';
        childAnchor.href = childLink.url;
        childAnchor.textContent = childLink.title;
        submenu.appendChild(childAnchor);
      });

      submenu.hidden = false;
      submenu.dataset.populated = 'true';
    });
  };

  if(toggle) toggle.addEventListener('click', () => {
    populateMobileDrawerSubmenus();
    drawer.classList.add('is-active');
  });
  if(close) close.addEventListener('click', () => drawer.classList.remove('is-active'));
  if(overlay) overlay.addEventListener('click', () => drawer.classList.remove('is-active'));

  window.addEventListener('scroll', () => {
    if (window.scrollY > 40) { nav.classList.add('is-stuck'); } 
    else { nav.classList.remove('is-stuck'); }
  });
});
</script>

{% schema %}
{
  "name": "Global Brand Header",
  "settings": [
    { "type": "image_picker", "id": "logo_image", "label": "Logo 图片" },
    { "type": "range", "id": "logo_height", "label": "Logo 高度", "min": 20, "max": 80, "step": 2, "default": 40, "unit": "px" },
    { "type": "text", "id": "logo_text_cn", "label": "中文名", "default": "云之旅" },
    { "type": "text", "id": "logo_text_en", "label": "英文名", "default": "CLOUD TRAVEL" },
    { "type": "checkbox", "id": "show_slogan", "label": "开启标语栏", "default": true },
    { "type": "text", "id": "slogan_text", "label": "标语内容", "default": "探索云之南 · 定制奢华之旅" },
    { "type": "link_list", "id": "main_menu", "label": "主菜单", "default": "main-menu" },
    { "type": "color", "id": "btn_color", "label": "品牌金色", "default": "#fbbf24" }
  ],
  "presets": [{ "name": "Global Brand Header" }]
}
{% endschema %}
