<section class="contact-pure-section" id="Contact-{{ section.id }}">
  <div class="contact-container">
    
    <!-- 左侧：表单区域 -->
    <div class="contact-message-wrapper">
      <h2 class="contact-title">{{ section.settings.title }}</h2>
      <p class="contact-intro">{{ section.settings.intro_text }}</p>
      
      {% form 'contact' %}
        {% if form.posted_successfully? %}
          <p class="form-success" tabindex="-1" autofocus>
            Message sent successfully. We will be in touch shortly.
          </p>
        {% endif %}

        {% if form.errors %}
          <div class="form-errors">
            {{ form.errors | default_errors }}
          </div>
        {% endif %}

        <div class="form-fields">
          <div class="field-group">
            <label for="ContactForm-name-{{ section.id }}" class="visually-hidden">Name</label>
            <input 
              type="text" 
              name="contact[name]" 
              id="ContactForm-name-{{ section.id }}" 
              value="{% if form.name %}{{ form.name }}{% elsif customer %}{{ customer.name }}{% endif %}" 
              placeholder="NAME" 
              autocomplete="name"
              required>
          </div>

          <div class="field-group">
            <label for="ContactForm-email-{{ section.id }}" class="visually-hidden">Email</label>
            <input 
              type="email" 
              name="contact[email]" 
              id="ContactForm-email-{{ section.id }}" 
              value="{% if form.email %}{{ form.email }}{% elsif customer %}{{ customer.email }}{% endif %}" 
              placeholder="EMAIL" 
              spellcheck="false" 
              autocapitalize="off" 
              autocomplete="email" 
              required>
          </div>

          <div class="field-group">
            <label for="ContactForm-body-{{ section.id }}" class="visually-hidden">Message</label>
            <textarea 
              name="contact[body]" 
              id="ContactForm-body-{{ section.id }}" 
              rows="4" 
              placeholder="MESSAGE" 
              required>{{- form.body -}}</textarea>
          </div>
        </div>

        <button type="submit" class="submit-btn-minimal">
          {{ section.settings.btn_text | default: 'SEND MESSAGE' }}
        </button>
      {% endform %}
    </div>

    <!-- 右侧：联系方式区域 -->
    <div class="contact-channels-wrapper">
      
      <div class="channel-group">
        <h3 class="channel-heading">DIRECT CONNECT</h3>
        
        {% if section.settings.whatsapp != blank %}
          {% assign clean_wa = section.settings.whatsapp | replace: ' ', '' | replace: '+', '' | replace: '-', '' %}
          <a href="https://wa.me/{{ clean_wa }}" class="direct-link" target="_blank" rel="noopener noreferrer">
            <span class="link-icon">→</span> WHATSAPP
          </a>
        {% endif %}

        {% if section.settings.email != blank %}
  <div class="direct-link-row">
    <a href="mailto:{{ section.settings.email }}" class="direct-link email-direct-link">
      <span class="link-icon">→</span>
      <span class="email-text">{{ section.settings.email }}</span>
    </a>

    <button
      type="button"
      class="copy-email-btn js-copy-email"
      data-email="{{ section.settings.email }}"
      aria-label="Copy email address"
      title="Copy email address">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <rect x="9" y="9" width="10" height="10" rx="2"></rect>
        <path d="M5 15V7a2 2 0 0 1 2-2h8"></path>
      </svg>
    </button>

    <span class="copy-success-msg" aria-live="polite" hidden></span>
  </div>
{% endif %}
      </div>

      <div class="channel-group">
        <h3 class="channel-heading">OUR OFFICE</h3>
        <p class="office-detail">{{ section.settings.address }}</p>
        <p class="office-detail">{{ section.settings.hours }}</p>
      </div>

      <div class="channel-group">
        <h3 class="channel-heading">FOLLOW OUR JOURNEY</h3>
        <div class="contact-social-icons">
          {% if section.settings.instagram_link != blank %}
            <a href="{{ section.settings.instagram_link }}" class="c-social-link" target="_blank" rel="noopener noreferrer" aria-label="Instagram">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg>
            </a>
          {% endif %}

          {% if section.settings.facebook_link != blank %}
            <a href="{{ section.settings.facebook_link }}" class="c-social-link" target="_blank" rel="noopener noreferrer" aria-label="Facebook">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path></svg>
            </a>
          {% endif %}

          {% if section.settings.tiktok_link != blank %}
            <a href="{{ section.settings.tiktok_link }}" class="c-social-link" target="_blank" rel="noopener noreferrer" aria-label="TikTok">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 12a4 4 0 1 0 4 4V4a5 5 0 0 0 5 5"></path></svg>
            </a>
          {% endif %}

          {% if section.settings.x_link != blank %}
            <a href="{{ section.settings.x_link }}" class="c-social-link" target="_blank" rel="noopener noreferrer" aria-label="X (Twitter)">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4l11.733 16h4.267l-11.733-16zM4 20l6.768-6.768m2.464-2.464l6.768-6.768"></path></svg>
            </a>
          {% endif %}

          {% if section.settings.youtube_link != blank %}
            <a href="{{ section.settings.youtube_link }}" class="c-social-link" target="_blank" rel="noopener noreferrer" aria-label="YouTube">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"><path d="M22.54 6.42a2.78 2.78 0 0 0-1.94-2C18.88 4 12 4 12 4s-6.88 0-8.6.42a2.78 2.78 0 0 0-1.94 2C1 8.14 1 12 1 12s0 3.86.42 5.58a2.78 2.78 0 0 0 1.94 2c1.72.42 8.6.42 8.6.42s6.88 0 8.6-.42a2.78 2.78 0 0 0 1.94-2C23 15.86 23 12 23 12s0-3.86-.42-5.58z"></path><polygon points="9.75 15.02 15.5 12 9.75 8.98 9.75 15.02"></polygon></svg>
            </a>
          {% endif %}
        </div>
      </div>
    </div>

  </div>
</section>

<style>
  #Contact-{{ section.id }} {
    --bg-color: {{ section.settings.bg_color }};
    --text-color: {{ section.settings.text_color }};
    --text-sub-color: {{ section.settings.text_color | color_modify: 'alpha', 0.6 }};
    --accent-color: {{ section.settings.accent_color }};
    --border-color: {{ section.settings.text_color | color_modify: 'alpha', 0.15 }};
    
    background-color: var(--bg-color);
    color: var(--text-color);
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    font-weight: 300;
  }

  .contact-container { 
    max-width: 1100px; 
    margin: 0 auto; 
    padding: 0 24px; 
    display: grid; 
    grid-template-columns: 1fr 1fr; 
    gap: 100px; 
  }

  .contact-title { 
    font-size: 28px; 
    letter-spacing: 0.3em; 
    color: var(--accent-color); 
    margin: 0 0 20px 0; 
    text-transform: uppercase; 
    line-height: 1.2;
  }

  .contact-intro { 
    color: var(--text-sub-color); 
    font-size: 14px; 
    line-height: 1.8; 
    margin-bottom: 40px; 
    max-width: 400px; 
    letter-spacing: 0.05em; 
  }

  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    border: 0;
  }
  
  .contact-message-wrapper input, 
  .contact-message-wrapper textarea {
    width: 100%; 
    background: transparent; 
    border: none; 
    border-bottom: 1px solid var(--border-color);
    padding: 15px 0; 
    color: var(--text-color); 
    font-size: 12px; 
    letter-spacing: 0.1em; 
    margin-bottom: 25px; 
    transition: all 0.3s ease;
    border-radius: 0;
    -webkit-appearance: none;
    font-family: inherit;
  }
  
  .contact-message-wrapper input::placeholder, 
  .contact-message-wrapper textarea::placeholder {
    color: var(--text-sub-color);
    opacity: 0.7;
  }

  .contact-message-wrapper input:focus, 
  .contact-message-wrapper textarea:focus { 
    outline: none; 
    border-bottom-color: var(--accent-color); 
  }

  .form-success {
    color: var(--accent-color);
    font-size: 13px;
    margin-bottom: 20px;
    letter-spacing: 0.05em;
  }

  .form-errors {
    color: #ef4444;
    font-size: 12px;
    margin-bottom: 20px;
    letter-spacing: 0.05em;
  }

  .form-errors ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .submit-btn-minimal {
    background: transparent; 
    border: 1px solid var(--border-color);
    color: var(--accent-color);
    padding: 14px 40px; 
    font-size: 11px; 
    letter-spacing: 0.25em; 
    cursor: pointer; 
    transition: all 0.4s ease;
    margin-top: 10px;
    text-transform: uppercase;
  }

  .submit-btn-minimal:hover { 
    background: var(--accent-color); 
    color: var(--bg-color); 
    border-color: var(--accent-color); 
  }

  .channel-group {
    margin-bottom: 50px;
  }

  .channel-group:last-child {
    margin-bottom: 0;
  }
  
  .channel-heading { 
    font-size: 10px; 
    letter-spacing: 0.4em; 
    color: var(--text-sub-color);
    margin: 0 0 25px 0; 
    text-transform: uppercase; 
    opacity: 0.8;
  }
  
  .direct-link { 
    display: inline-flex;
    align-items: center;
    font-size: 15px; 
    color: var(--text-color); 
    text-decoration: none; 
    margin-bottom: 18px; 
    letter-spacing: 0.15em; 
    transition: 0.3s ease;
  }

  .direct-link:hover {
    color: var(--accent-color);
    padding-left: 8px;
  }

  .link-icon {
    color: var(--accent-color);
    margin-right: 12px;
    font-size: 18px;
    line-height: 1;
  }

  .direct-link-row {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 14px;
    margin-bottom: 18px;
  }

  .direct-link-row .direct-link {
    margin-bottom: 0;
  }

  .copy-email-btn {
  background: transparent;
  border: 1px solid var(--border-color);
  color: var(--text-sub-color);
  width: 36px;
  height: 36px;
  padding: 0;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  transition: all 0.3s ease;
  font-family: inherit;
  line-height: 1;
  flex: 0 0 auto;
}

  .copy-email-btn:hover {
    color: var(--accent-color);
    border-color: var(--accent-color);
  }

  .copy-email-btn:disabled {
    opacity: 0.6;
    cursor: default;
  }

   .copy-success-msg {
  display: none;
  font-size: 10px;
  letter-spacing: 0.18em;
  color: var(--accent-color);
  text-transform: uppercase;
}

.copy-success-msg.is-visible {
  display: inline-block;
}

  .office-detail { 
    color: var(--text-sub-color); 
    font-size: 13px; 
    line-height: 2; 
    margin: 0 0 5px 0; 
    letter-spacing: 0.05em; 
  }

  .contact-social-icons {
    display: flex;
    gap: 20px;
    align-items: center;
    margin-top: 5px;
    flex-wrap: wrap;
  }

  .c-social-link { 
    color: var(--text-sub-color); 
    transition: all 0.3s ease; 
    display: flex; 
    align-items: center; 
    justify-content: center; 
  }

  .c-social-link:hover {
    color: var(--accent-color);
    transform: translateY(-3px);
  }

  @media (max-width: 900px) {
    .contact-container {
      grid-template-columns: 1fr;
      gap: 60px;
    }

    .contact-title {
      font-size: 24px;
    }

    #Contact-{{ section.id }} {
      padding-top: {{ section.settings.padding_top | divided_by: 1.5 }}px;
      padding-bottom: {{ section.settings.padding_bottom | divided_by: 1.5 }}px;
    }
  }

  @media (max-width: 640px) {
    .direct-link-row {
      align-items: flex-start;
      gap: 10px;
    }

    .copy-email-btn {
      width: auto;
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    const copyButtons = document.querySelectorAll('#Contact-{{ section.id }} .js-copy-email');

    async function copyText(text) {
      if (navigator.clipboard && window.isSecureContext) {
        await navigator.clipboard.writeText(text);
        return true;
      }

      const textarea = document.createElement('textarea');
      textarea.value = text;
      textarea.setAttribute('readonly', '');
      textarea.style.position = 'absolute';
      textarea.style.left = '-9999px';
      document.body.appendChild(textarea);
      textarea.select();

      let success = false;

      try {
        success = document.execCommand('copy');
      } catch (err) {
        success = false;
      }

      document.body.removeChild(textarea);
      return success;
    }

    copyButtons.forEach(button => {
      let timer = null;

      button.addEventListener('click', async function () {
        const email = this.getAttribute('data-email');
        const row = this.closest('.direct-link-row');
        const successMsg = row ? row.querySelector('.copy-success-msg') : null;

        if (!email || !successMsg) return;

        const copied = await copyText(email);

        if (copied) {
  clearTimeout(timer);

  this.disabled = true;
  successMsg.textContent = 'Copied';
  successMsg.hidden = false;
  successMsg.classList.add('is-visible');

  timer = setTimeout(() => {
    this.disabled = false;
    successMsg.classList.remove('is-visible');
    successMsg.hidden = true;
    successMsg.textContent = '';
  }, 2000);
} else {
  window.location.href = 'mailto:' + email;
}
      });
    });
  });
</script>

{% schema %}
{
  "name": "Pure Contact Page",
  "settings": [
    { "type": "header", "content": "Colors" },
    { "type": "color", "id": "bg_color", "label": "Background", "default": "#0a0a0a" },
    { "type": "color", "id": "text_color", "label": "Text", "default": "#ffffff" },
    { "type": "color", "id": "accent_color", "label": "Accent / Highlight", "default": "#fbbf24" },
    
    { "type": "header", "content": "Spacing" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 200, "step": 4, "unit": "px", "label": "Padding Top", "default": 160, "info": "Increase if header overlaps content" },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 200, "step": 4, "unit": "px", "label": "Padding Bottom", "default": 100 },

    { "type": "header", "content": "Text Content" },
    { "type": "text", "id": "title", "label": "Title", "default": "GET IN TOUCH" },
    { "type": "textarea", "id": "intro_text", "label": "Intro Text", "default": "For general inquiries, media or just a friendly hello, please use the form or reach out through our direct channels." },
    { "type": "text", "id": "btn_text", "label": "Button Text", "default": "SEND MESSAGE" },

    { "type": "header", "content": "Direct Channels" },
    { "type": "text", "id": "whatsapp", "label": "WhatsApp Number", "default": "+86 13211685553", "info": "Include country code" },
    { "type": "text", "id": "email", "label": "Email Address", "default": "hello@lynxtour.cn" },
    { "type": "text", "id": "address", "label": "Office Address", "default": "Kunming, Yunnan, China" },
    { "type": "text", "id": "hours", "label": "Working Hours", "default": "Mon - Sat: 9:00 AM - 6:00 PM (GMT+8)" },

    { "type": "header", "content": "Social Media Links" },
    { "type": "url", "id": "instagram_link", "label": "Instagram" },
    { "type": "url", "id": "facebook_link", "label": "Facebook" },
    { "type": "url", "id": "tiktok_link", "label": "TikTok" },
    { "type": "url", "id": "x_link", "label": "X (Twitter)" },
    { "type": "url", "id": "youtube_link", "label": "YouTube" }
  ],
  "presets": [
    {
      "name": "Pure Contact Page"
    }
  ]
}
{% endschema %}