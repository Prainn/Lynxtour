<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css" />

<style>
  .about-us-refined { --accent-color: #f59e0b; }
  .brand-slider .swiper-slide img { filter: none !important; transition: transform 3s ease; }
  .brand-slider .swiper-slide-active img { transform: scale(1.1); }
  .module-slider .swiper-slide img { filter: none !important; opacity: 0.6; transition: all 0.5s ease; }
  .module-slider .swiper-slide:hover img { opacity: 0.9; transform: scale(1.05); }
  .swiper-pagination-bullet { background: #fff !important; opacity: 0.4; }
  .swiper-pagination-bullet-active { background: var(--accent-color) !important; opacity: 1; }
  .swiper-scrollbar-drag { background: var(--accent-color) !important; }
  @media (max-width: 768px) { .brand-slider { aspect-ratio: 1/1 !important; } }
</style>

<div class="about-us-refined bg-stone-950 text-stone-300 overflow-hidden font-sans" style="padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px;">
  
  <section class="relative pt-24 pb-20 px-6 max-w-7xl mx-auto border-l border-stone-800 ml-6 md:ml-20 flex justify-between items-start">
  
  <div class="flex-1">
    <h1 class="flex flex-col gap-3 text-white leading-none mb-10 md:mb-14"> 
      <span class="text-2xl md:text-4xl font-extralight tracking-[0.5em] opacity-30 uppercase">One Soul</span>
      <span class="text-4xl md:text-6xl font-serif italic text-amber-500 tracking-[0.15em] py-1 ml-4 md:ml-10 border-l border-amber-500/20 pl-5">
        One Journey
      </span>
      <span class="text-2xl md:text-4xl font-light tracking-[0.6em] uppercase opacity-80 ml-8 md:ml-20">
        One Universe
      </span>
    </h1>

    <div class="max-w-xl text-stone-500 text-sm md:text-base border-l border-amber-500/20 pl-6">
      {{ section.settings.top_description }}
    </div>
  </div>

  <div class="hidden lg:flex flex-col items-center opacity-100" style="min-width: 80px; margin-left: 20px;">
    <div style="width: 1px; height: 140px; background: linear-gradient(to bottom, rgba(251,191,36,0), rgba(251,191,36,1) 50%, rgba(251,191,36,0)); box-shadow: 0 0 8px rgba(251,191,36,0.3);"></div>
    
    <div style="writing-mode: vertical-lr; text-orientation: mixed; color: #fbbf24; text-shadow: 0 0 5px rgba(251,191,36,0.2);" 
         class="py-12 text-[11px] tracking-[1em] uppercase font-medium">
      {{ section.settings.hero_tag }}
    </div>

    <div style="width: 1px; height: 80px; background: rgba(251,191,36,0.2);"></div>
  </div>

</section>

  <section class="py-24 px-6 max-w-7xl mx-auto relative">
    <div class="flex flex-col lg:flex-row items-center">
      <div class="w-full lg:w-3/5 relative mb-12 lg:mb-0">
        <div class="swiper brand-slider relative z-10 w-full aspect-[16/9] overflow-hidden rounded-sm shadow-2xl">
          <div class="swiper-wrapper">
            {%- assign has_slides = false -%}
            {% for block in section.blocks %}
              {% if block.type == 'slide' %}
                {%- assign has_slides = true -%}
                <div class="swiper-slide" {{ block.shopify_attributes }}>
                  <img
                    src="{{ block.settings.image | image_url: width: 1500 }}"
                    alt=""
                    class="w-full h-full object-cover"
                  >
                </div>
              {% endif %}
            {% endfor %}
          </div>
          <div class="swiper-pagination"></div>
        </div>
        <div class="absolute -top-6 -left-6 w-32 h-32 border-t border-l border-amber-500/40 z-0"></div>
        <div class="absolute -bottom-6 -right-6 w-3/4 h-2/3 border-b border-r border-stone-800 z-0"></div>
      </div>
      <div class="w-full lg:w-2/5 lg:-ml-20 z-20 bg-stone-900/90 backdrop-blur-xl p-10 md:p-16 border border-stone-800 shadow-2xl">
        <h2 class="text-amber-500 text-[10px] tracking-[0.4em] uppercase mb-4 font-bold">{{ section.settings.title_2_sub }}</h2>
        <h3 class="text-3xl text-white font-serif mb-6 leading-snug">{{ section.settings.title_2_main }}</h3>
        <div class="text-stone-400 text-sm leading-loose">{{ section.settings.description_2 }}</div>
      </div>
    </div>
  </section>

  <section class="py-24 px-6 border-t border-stone-900 bg-stone-950/50">
    <div class="max-w-7xl mx-auto">
      <div class="flex flex-col md:flex-row justify-between items-end mb-12 gap-6">
        <div class="max-w-md">
          <h4 class="text-white text-2xl font-serif italic">{{ section.settings.system_title }}</h4>
          <p class="text-stone-600 text-[9px] mt-4 uppercase tracking-[0.3em] font-bold">{{ section.settings.system_subtitle }}</p>
        </div>
        <div class="text-amber-500 font-mono text-xs tracking-widest hidden md:block">{{ section.settings.system_tag }}</div>
      </div>
      <div class="swiper module-slider overflow-visible">
        <div class="swiper-wrapper">
          {% for block in section.blocks %}
            {% if block.type == 'system_module' %}
              <div class="swiper-slide h-auto" {{ block.shopify_attributes }}>
                <div class="bg-stone-900/40 min-h-[420px] h-full relative group overflow-hidden border border-stone-800 rounded-sm">
                  <div class="absolute inset-0 z-0">
                    <img
                      src="{{ block.settings.module_img | image_url: width: 800 }}"
                      alt="{{ block.settings.module_name | default: section.settings.system_title | escape }}"
                      class="w-full h-full object-cover"
                    >
                    <div class="absolute inset-0 bg-gradient-to-t from-stone-950 via-stone-950/20 to-transparent"></div>
                  </div>
                  <div class="relative z-10 p-8 h-full flex flex-col justify-end">
                    <div class="text-amber-500/50 font-mono text-[9px] mb-4">MODULE 0{{ forloop.index }}</div>
                    <h5 class="text-white text-xl mb-3 font-serif">{{ block.settings.module_name }}</h5>
                    <p class="text-stone-300 text-xs leading-relaxed opacity-80">{{ block.settings.module_desc }}</p>
                  </div>
                </div>
              </div>
            {% endif %}
          {% endfor %}
        </div>
        <div class="swiper-scrollbar mt-12 bg-stone-900"></div>
      </div>
    </div>
  </section>

  <section class="py-24 px-6 text-center border-t border-stone-900 bg-stone-950">
    <div class="max-w-4xl mx-auto">
      <div class="w-12 h-[1px] bg-amber-500 mx-auto mb-10 opacity-50"></div>
      <div class="text-white font-serif text-xl md:text-2xl leading-relaxed italic opacity-90 mb-16">
        "{{ section.settings.accolades_text }}"
      </div>
      
      <div class="group inline-block">
        <a href="{{ section.settings.cta_link }}" class="text-amber-500 text-[10px] tracking-[0.4em] uppercase font-bold relative pb-2 block">
          {{ section.settings.cta_text }}
          <span class="absolute bottom-0 left-0 w-full h-[1px] bg-amber-500 scale-x-50 group-hover:scale-x-100 transition-transform duration-700"></span>
        </a>
      </div>
    </div>
  </section>
</div>

<script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>
<script>
  document.addEventListener('DOMContentLoaded', function() {
    new Swiper('.brand-slider', {
      loop: true, effect: 'fade', fadeEffect: { crossFade: true },
      autoplay: { delay: 5000 }, pagination: { el: '.swiper-pagination', clickable: true }
    });
    new Swiper('.module-slider', {
      slidesPerView: 1.2, spaceBetween: 20, scrollbar: { el: '.swiper-scrollbar', draggable: true },
      breakpoints: { 640: { slidesPerView: 2.2 }, 1024: { slidesPerView: 3.5 } }
    });
  });
</script>

{% schema %}
{
  "name": "About Us PRO Refined",
  "settings": [
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top Padding",
      "min": 0,
      "max": 160,
      "step": 4,
      "default": 80,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom Padding",
      "min": 0,
      "max": 160,
      "step": 4,
      "default": 80,
      "unit": "px"
    },
    {
      "type": "text",
      "id": "hero_tag",
      "label": "Slogan Tag",
      "default": "ABOUT LYNXTOUR"
    },
    {
      "type": "textarea",
      "id": "top_description",
      "label": "Top Intro",
      "default": "Lynxtour is a Yunnan private tours brand offering bespoke itineraries, private day trips, and charter services across Kunming, Dali, Lijiang, Shangri-La, Xishuangbanna, and beyond. We combine local destination knowledge with flexible planning to create more personal journeys through Yunnan."
    },
    {
      "type": "text",
      "id": "title_2_sub",
      "label": "Part 2 Subtitle",
      "default": "YUNNAN PRIVATE TOURS BRAND"
    },
    {
      "type": "text",
      "id": "title_2_main",
      "label": "Part 2 Title",
      "default": "Beyond Standard Travel Planning"
    },
    {
      "type": "richtext",
      "id": "description_2",
      "label": "Part 2 Description",
      "default": "<p>Lynxtour creates private journeys shaped by destination knowledge, flexible pacing, and a more personal way to explore Yunnan. From bespoke itineraries to day trips and charter services, we focus on comfort, local insight, and travel that feels thoughtfully designed rather than routine.</p>"
    },
    {
      "type": "text",
      "id": "system_title",
      "label": "Part 3 Heading",
      "default": "How We Design Travel"
    },
    {
      "type": "text",
      "id": "system_subtitle",
      "label": "Part 3 Subheading",
      "default": "Private, flexible, and destination-led"
    },
    {
      "type": "text",
      "id": "system_tag",
      "label": "Part 3 Side Tag",
      "default": "LYNXTOUR"
    },
    {
      "type": "textarea",
      "id": "accolades_text",
      "label": "Awards Text",
      "default": "We believe the best journeys are not only well arranged, but deeply felt, locally informed, and shaped around the traveler."
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "CTA Button Text",
      "default": "PLAN YOUR JOURNEY"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "CTA Link"
    }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Part 2: Slider Image",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        }
      ]
    },
    {
      "type": "system_module",
      "name": "Part 3: Module Card",
      "settings": [
        {
          "type": "image_picker",
          "id": "module_img",
          "label": "BG Image"
        },
        {
          "type": "text",
          "id": "module_name",
          "label": "Title",
          "default": "Module"
        },
        {
          "type": "textarea",
          "id": "module_desc",
          "label": "Desc",
          "default": "Details..."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "About Us PRO Refined"
    }
  ]
}
{% endschema %}
