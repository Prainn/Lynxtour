        "info_item_EitbgK": {
          "type": "info_item",
          "settings": {
            "tag": "HOW LONG",
            "heading": "How Many Days to Stay",
            "description": "Two days works for a first introduction, while three to four days gives you time for Songzanlin, Pudacuo, old-town atmosphere, and a wider highland pace. Add more time if Meili or Yubeng is included."
          }
        },
