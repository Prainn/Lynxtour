        "info_item_KtgtVU": {
          "type": "info_item",
          "settings": {
            "tag": "WHY VISIT",
            "heading": "Why Visit Dali",
            "description": "Dali is one of Yunnan’s most graceful destinations, where mountain light, lakeside calm, Bai heritage, and slow travel come together naturally. It is ideal for travelers who want scenery, culture, and a more restorative rhythm in one place."
          }
        },
        "info_item_tfGBAa": {
          "type": "info_item",
          "settings": {
            "tag": "TOP ATTRACTIONS",
            "heading": "Top Attractions",
            "description": "Cangshan, Erhai Lake, Xizhou, Dali Old Town, and the wider lakeside villages are among the most memorable highlights. Together, they give Dali its balance of mountain grandeur, open water, architecture, and everyday life."
          }
        },
        "info_item_mfwbHk": {
          "type": "info_item",
          "settings": {
            "tag": "BEST TIME",
            "heading": "Best Time to Visit Dali",
            "description": "Dali can be visited year-round, but spring and autumn are usually the most comfortable seasons for lakeside drives, village walks, and clear mountain views. These months offer the best mix of weather, atmosphere, and photography conditions."
          }
        },
        "info_item_qFxCqi": {
          "type": "info_item",
          "settings": {
            "tag": "HOW MANY DAYS",
            "heading": "A Simple 2-Day Dali Itinerary",
            "description": "Spend your first day in Dali Old Town and around Erhai Lake, then use your second day for Xizhou, village scenery, and a slower lakeside route. This is the easiest way to see Dali’s core highlights without feeling rushed."
          }
        },
        "info_item_6cHGyX": {
          "type": "info_item",
          "settings": {
            "tag": "THREE DAYS",
            "heading": "A Simple 3-Day Dali Itinerary",
            "description": "Use day one for Dali Old Town, day two for Erhai Lake and Xizhou, and keep day three for a slower lakeside circuit, Cangshan views, or extra village time. A 3-day stay gives Dali enough room to feel relaxed instead of rushed."
          }
        },
        "info_item_f6Uc3R": {
          "type": "info_item",
          "settings": {
            "tag": "ROUTE PAIRING",
            "heading": "How to Combine Dali with Lijiang",
            "description": "If you have more time, Dali pairs naturally with Lijiang. Start with Dali for open water, Bai heritage, and village life, then continue north for old-town atmosphere, mountain scenery, and a stronger northwest Yunnan route."
          }
        },
        "story_9aV8Cb": {
