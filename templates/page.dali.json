          "settings": {
            "tag": "WHY VISIT",
            "heading": "Why Visit Dali",
            "description": "Dali is one of Yunnan’s most graceful destinations, where mountain light, lakeside calm, Bai heritage, and slow travel come together naturally. It is ideal for travelers who want scenery, culture, and a more restorative rhythm in one place."
          }
        },
        "info_item_tfGBAa": {
          "type": "info_item",
          "settings": {
            "tag": "TOP ATTRACTIONS",
            "heading": "Top Attractions",
            "description": "Cangshan, Erhai Lake, Xizhou, Dali Old Town, and the wider lakeside villages are among the most memorable highlights. Together, they give Dali its balance of mountain grandeur, open water, architecture, and everyday life."
          }
        },
        "info_item_mfwbHk": {
          "type": "info_item",
          "settings": {
            "tag": "BEST TIME",
            "heading": "BEST TIME",
            "description": "Dali can be enjoyed year-round, but spring and autumn are especially pleasant for lakeside drives, village walks, outdoor cafés, and photography. These seasons usually offer the clearest balance of weather, atmosphere, and natural light."
          }
        },
        "info_item_qFxCqi": {
          "type": "info_item",
          "settings": {
            "tag": "HOW MANY DAYS",
            "heading": "How Many Days to Stay",
            "description": "Two days is a good introduction to Dali, while three days allows a more relaxed stay with Erhai, Dali Old Town, and nearby villages such as Xizhou. Travelers who enjoy slow travel often wish they had more time here."
          }
        },
        "info_item_6cHGyX": {
          "type": "info_item",
          "settings": {
            "tag": "WHO IT SUITS",
            "heading": "Who Dali Suits",
            "description": "Dali is ideal for couples, photographers, first-time Yunnan visitors, culture-focused travelers, and anyone looking for a softer and more elegant pace than a typical fast-moving itinerary."
          }
        },
