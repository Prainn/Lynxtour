<!doctype html>
<html class="no-js" lang="{{ request.locale.iso_code }}">
  <head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="theme-color" content="#050505">
    <link rel="canonical" href="{{ canonical_url }}">
    <link rel="preconnect" href="https://cdn.shopify.com" crossorigin>

    {% if settings.favicon != blank %}
      <link
        rel="icon"
        type="image/png"
        href="{{ settings.favicon | image_url: width: 48, height: 48 }}"
        sizes="48x48"
      >
      <link
        rel="apple-touch-icon"
        href="{{ settings.favicon | image_url: width: 180, height: 180 }}"
      >
    {% endif %}

    {% capture seo_title %}{{ page_title }}{% if current_page != 1 %} | Page {{ current_page }}{% endif %}{% endcapture %}
    {% assign seo_description_base = page_description | default: shop.description | strip_html | strip %}

    {% if seo_description_base != blank %}
      {% capture seo_description %}
        {% if current_page != 1 %}Page {{ current_page }} of {% endif %}{{ seo_description_base }}
      {% endcapture %}
    {% endif %}

    <title>{{ seo_title | strip }}</title>

    {% if seo_description_base != blank %}
      <meta name="description" content="{{ seo_description | strip | escape }}">
    {% endif %}

    <meta property="og:site_name" content="Lynxtour">
    <meta property="og:url" content="{{ canonical_url }}">
    <meta property="og:title" content="{{ seo_title | strip | escape }}">
    {% if seo_description_base != blank %}
      <meta property="og:description" content="{{ seo_description | strip | escape }}">
    {% endif %}
    <meta property="og:type" content="{% if request.page_type == 'product' %}product{% elsif request.page_type == 'article' %}article{% else %}website{% endif %}">

    {% if page_image %}
      <meta property="og:image" content="https:{{ page_image | image_url: width: 1200 }}">
      <meta property="og:image:secure_url" content="https:{{ page_image | image_url: width: 1200 }}">
      <meta name="twitter:image" content="https:{{ page_image | image_url: width: 1200 }}">
    {% elsif settings.logo != blank %}
      <meta property="og:image" content="{{ settings.logo | image_url: width: 1200 | prepend: 'https:' }}">
      <meta property="og:image:secure_url" content="{{ settings.logo | image_url: width: 1200 | prepend: 'https:' }}">
      <meta name="twitter:image" content="{{ settings.logo | image_url: width: 1200 | prepend: 'https:' }}">
    {% endif %}

    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="{{ seo_title | strip | escape }}">
    {% if seo_description_base != blank %}
      <meta name="twitter:description" content="{{ seo_description | strip | escape }}">
    {% endif %}

    {% if request.page_type == 'index' %}
      <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "WebSite",
        "name": "Lynxtour",
        "alternateName": ["Lynxtour Yunnan", "lynxtour.cn"],
        "url": "{{ shop.secure_url }}/"
      }
      </script>

      <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "Organization",
        "name": "Lynxtour",
        "url": "{{ shop.secure_url }}/"{% if settings.logo != blank %},
        "logo": "{{ settings.logo | image_url: width: 512 | prepend: 'https:' }}"
        {% endif %}
      }
      </script>
    {% endif %}

    {{ content_for_header }}

    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Noto+Serif+SC:wght@400;700&family=Inter:wght@400;500;700&display=swap" rel="stylesheet">

    <style>
      html {
        scroll-behavior: smooth;
      }

      /* 防止跳转后标题紧贴屏幕顶端，留出一点呼吸空间 */
      #dest-section {
        scroll-margin-top: 50px;
      }

      body {
        font-family: 'Inter', sans-serif;
      }

      .font-noto-serif-sc {
        font-family: 'Noto Serif SC', serif;
      }

      .prose h3 {
        font-size: 1.5rem;
        font-weight: 700;
        font-family: 'Noto Serif SC', serif;
        color: #f59e0b;
        margin-top: 1.5rem;
        margin-bottom: 0.75rem;
      }

      .prose p,
      .prose li {
        color: #d6d3d1;
        line-height: 1.625;
        margin-bottom: 0.75rem;
      }

      .prose li {
        margin-left: 1.5rem;
        list-style-type: disc;
      }
    </style>

    <script type="importmap">
    {
      "imports": {
        "@google/genai": "https://esm.sh/@google/genai@^1.38.0"
      }
    }
    </script>
  </head>

  <body class="bg-stone-900 text-stone-300">
    <a class="sr-only" href="#MainContent">Skip to content</a>
    <main id="MainContent" role="main">
      {{ content_for_layout }}
    </main>
  </body>
</html>