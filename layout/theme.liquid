<!doctype html>
<html class="no-js" lang="{{ request.locale.iso_code }}">
  <head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="theme-color" content="#050505">
    {%- liquid
      assign resolved_canonical_url = canonical_url
      assign article_is_duplicate_variant = false

      if request.page_type == 'article'
        assign article_slug = article.handle | split: '/' | last

        case article_slug
          when 'jade-dragon-snow-mountain-travel-guide'
            assign resolved_canonical_url = shop.secure_url | append: '/blogs/travel-guides/jade-dragon-snow-mountain-guide'
            assign article_is_duplicate_variant = true
          when 'lijiang-old-town-travel-guide'
            assign resolved_canonical_url = shop.secure_url | append: '/blogs/travel-guides/lijiang-old-town-guide'
            assign article_is_duplicate_variant = true
          when 'dali-old-town-travel-guide'
            assign resolved_canonical_url = shop.secure_url | append: '/blogs/day-trips/dali-old-town-day-trip-guide'
            assign article_is_duplicate_variant = true
        endcase
      endif
    -%}
    <link rel="canonical" href="{{ resolved_canonical_url }}">
    <link rel="preconnect" href="https://cdn.shopify.com" crossorigin>

    {% if settings.favicon != blank %}
      <link
        rel="icon"
        type="image/png"
        href="{{ settings.favicon | image_url: width: 48, height: 48 }}"
        sizes="48x48"
      >
      <link
        rel="apple-touch-icon"
        href="{{ settings.favicon | image_url: width: 180, height: 180 }}"
      >
    {% endif %}

    {%- liquid
  assign seo_title = page_title | strip

  if request.page_type == 'index'
    assign seo_title = 'Private Yunnan Travel, Day Trips & Charter Services | Lynxtour'
  elsif request.page_type == 'search'
    assign seo_title = 'Search Results'
  elsif seo_title == blank
    assign seo_title = shop.name
  endif

  if current_page > 1
    if request.page_type == 'collection' and collection.title != blank
      assign seo_title = collection.title | append: ' | Page ' | append: current_page
    elsif request.page_type == 'blog' and blog.title != blank
      assign seo_title = blog.title | append: ' | Page ' | append: current_page
    elsif request.page_type == 'search'
      assign seo_title = 'Search Results | Page ' | append: current_page
    else
      assign seo_title = seo_title | append: ' | Page ' | append: current_page
    endif
  endif

  assign seo_description = page_description | strip_html | strip
  assign page_fallback_description = blank

  if seo_description == blank
    case request.page_type
      when 'product'
        assign seo_description = product.description | strip_html | strip | truncate: 160
        if seo_description == blank and product.title != blank
          assign seo_description = 'Explore ' | append: product.title | append: ' with ' | append: shop.name | append: '.'
        endif
      when 'collection'
        assign seo_description = collection.description | strip_html | strip | truncate: 160
        if seo_description == blank and collection.title != blank
          assign seo_description = 'Browse ' | append: collection.title | append: ' with private tour options from ' | append: shop.name | append: '.'
        endif
      when 'article'
        assign seo_description = article.excerpt_or_content | strip_html | strip | truncate: 160
      when 'page'
        assign page_fallback_description = page.content | strip_html | strip

        if page_fallback_description == blank and page.title != blank
          comment
            Keep the priority conservative:
            1) merchant-authored SEO description
            2) page.content text
            3) a minimal title-based fallback
            This does not attempt to read section settings for custom page templates.
          endcomment
          assign page_fallback_description = 'Explore ' | append: page.title | append: ' with ' | append: shop.name | append: '.'
        endif

        assign seo_description = page_fallback_description | truncate: 160
      when 'blog'
        assign seo_description = 'Explore Yunnan travel guides, itinerary ideas, and destination inspiration from ' | append: shop.name | append: '.'
      when 'search'
        assign seo_description = 'Search ' | append: shop.name | append: ' for Yunnan private tours, day trips, travel guides, and charter services.'
      when 'index'
        assign seo_description = 'Discover private tours, curated day trips, and charter services across Yunnan with ' | append: shop.name | append: '.'
      else
        assign seo_description = shop.description | strip_html | strip | truncate: 160
    endcase
  endif

  if request.page_type == 'collection' and seo_description == blank
    if collection.title != blank
      assign seo_description = 'Browse ' | append: collection.title | append: ' with private tour options from ' | append: shop.name | append: '.'
    elsif shop.description != blank
      assign seo_description = shop.description | strip_html | strip | truncate: 160
    endif
  endif

  if current_page > 1 and seo_description != blank
    case request.page_type
      when 'collection'
        if collection.title != blank
          assign seo_description = 'Browse page ' | append: current_page | append: ' of the ' | append: collection.title | append: ' collection. ' | append: seo_description
        else
          assign seo_description = 'Browse page ' | append: current_page | append: '. ' | append: seo_description
        endif
      when 'blog'
        if blog.title != blank
          assign seo_description = 'Browse page ' | append: current_page | append: ' of the ' | append: blog.title | append: ' blog. ' | append: seo_description
        else
          assign seo_description = 'Browse page ' | append: current_page | append: '. ' | append: seo_description
        endif
      when 'search'
        assign seo_description = 'Search results page ' | append: current_page | append: '. ' | append: seo_description
      else
        assign seo_description = 'Browse page ' | append: current_page | append: '. ' | append: seo_description
    endcase
  endif

  if request.page_type == 'collection' and collection.handle == 'yunnan-private-day-trips'
    if current_page > 1
      assign seo_title = 'Yunnan Private Day Trips | Flexible One-Day Tours | Page ' | append: current_page
    else
      assign seo_title = 'Yunnan Private Day Trips | Flexible One-Day Tours'
    endif
    assign seo_description = 'Book private day trips in Yunnan with flexible routes, local drivers, and guided options from Kunming, Dali, Lijiang, and other destinations.'
  endif

  if request.page_type == 'index'
    assign seo_title = 'Private Yunnan Travel, Day Trips & Charter Services | Lynxtour'
    assign seo_description = 'Plan private tours in Yunnan with local experts. Explore Dali, Lijiang, Shangri-La and Kunming with custom itineraries, day trips and charter services.'
  elsif request.page_type == 'collection'
    case collection.handle
      when 'yunnan-private-tours'
        if current_page > 1
          assign seo_title = 'Yunnan Private Tours | Custom Yunnan Itineraries | Page ' | append: current_page
        else
          assign seo_title = 'Yunnan Private Tours | Custom Yunnan Itineraries'
        endif
        assign seo_description = 'Plan a private Yunnan tour with flexible routes across Kunming, Dali, Lijiang, Shangri-La, and more. Customize your itinerary with local travel support.'
      when 'yunnan-luxury-private-tours'
        if current_page > 1
          assign seo_title = 'Yunnan Luxury Private Tours | Boutique Custom Travel | Page ' | append: current_page
        else
          assign seo_title = 'Yunnan Luxury Private Tours | Boutique Custom Travel'
        endif
        assign seo_description = 'Design a luxury private Yunnan trip with boutique hotels, private transfers, curated routes, and personalized travel planning across Yunnan.'
      when 'dali-private-tours'
        if current_page > 1
          assign seo_title = 'Dali Private Tours | Custom Dali Itineraries | Page ' | append: current_page | append: ' | Lynxtour'
        else
          assign seo_title = 'Dali Private Tours | Custom Dali Itineraries | Lynxtour'
        endif
        assign seo_description = 'Explore Dali private tours with Erhai Lake, Dali Old Town, Xizhou and Cangshan. Compare flexible private itineraries and combine Dali with Lijiang or Shangri-La.'
      when 'lijiang-private-tours'
        if current_page > 1
          assign seo_title = 'Lijiang Private Tours | Custom Lijiang Itineraries | Page ' | append: current_page | append: ' | Lynxtour'
        else
          assign seo_title = 'Lijiang Private Tours | Custom Lijiang Itineraries | Lynxtour'
        endif
        assign seo_description = 'Compare Lijiang private tours with Jade Dragon Snow Mountain, Lijiang Old Town and northwest Yunnan routes. Plan a custom Lijiang itinerary with local support.'
    endcase
  elsif request.page_type == 'page'
    case page.handle
      when 'kunming'
        assign seo_title = 'Kunming Travel Guide | Things to Do & Private Tour Planning'
        assign seo_description = 'Plan a Kunming visit with top sights, day trip ideas, transport tips, and private Yunnan tour planning for Stone Forest, Dianchi Lake, and beyond.'
      when 'dali'
        assign seo_title = 'Dali Travel Guide | Things to Do, Itinerary & Private Tours'
        assign seo_description = 'Plan a Dali trip with old town, Erhai Lake, Cangshan, itinerary ideas, and private Yunnan route planning between Kunming and Lijiang.'
      when 'lijiang'
        assign seo_title = 'Lijiang Travel Guide | Jade Dragon Snow Mountain & Private Tours'
        assign seo_description = 'Plan a Lijiang trip with old town, Jade Dragon Snow Mountain, Baisha, Tiger Leaping Gorge, and private Yunnan route ideas.'
      when 'shangri-la'
        assign seo_title = 'Shangri-La Yunnan Travel Guide | Highland Route & Private Tours'
        assign seo_description = 'Plan a Shangri-La Yunnan trip with Songzanlin Monastery, old town, highland scenery, and private route ideas from Lijiang.'
      when 'xishuangbanna'
        assign seo_title = 'Xishuangbanna Travel Guide | Tropical Yunnan Private Tour Planning'
        assign seo_description = 'Plan a Xishuangbanna trip with tropical scenery, ethnic culture, tea routes, and private Yunnan travel planning.'
      when 'dali-itinerary-3-days'
        assign seo_title = 'Dali 3-Day Itinerary: Erhai Lake, Xizhou & Old Town'
        assign seo_description = 'Plan 3 days in Dali with Dali Old Town, Erhai Lake, Xizhou, Cangshan options, private route ideas, and onward travel to Lijiang.'
      when 'lijiang-itinerary-3-days'
        assign seo_title = 'Lijiang 3-Day Itinerary: Old Town, Jade Dragon & Baisha'
        assign seo_description = 'Plan 3 days in Lijiang with Old Town, Jade Dragon Snow Mountain, Baisha or Shuhe, private tour options, and onward travel to Shangri-La.'
      when 'dali-itinerary-2-days'
        assign seo_title = 'Dali Itinerary 2 Days: What to Do in Dali in 2 Days | Lynxtour'
        assign seo_description = 'Plan a Dali itinerary for 2 days with a practical route through Dali Old Town, Erhai Lake, and key highlights, plus how to compare it with a slower 3-day stay.'
      when 'lijiang-itinerary-2-days'
        assign seo_title = 'Lijiang Itinerary 2 Days: What to Do in Lijiang in 2 Days | Lynxtour'
        assign seo_description = 'Plan a Lijiang itinerary for 2 days with the right balance of Lijiang Old Town, Jade Dragon Snow Mountain, and the essential stops to prioritize in a short stay.'
      when 'tiger-leaping-gorge-from-lijiang'
        assign seo_title = 'Tiger Leaping Gorge From Lijiang: Private Route Planning | Lynxtour'
        assign seo_description = 'Compare Tiger Leaping Gorge from Lijiang with private route support, day trip versus onward Shangri-La logic, and the best fit inside a wider northwest Yunnan trip.'
      when 'dali-to-lijiang-private-tour'
        assign seo_title = 'Dali to Lijiang Private Tour: Custom Yunnan Route | Lynxtour'
        assign seo_description = 'Plan a Dali to Lijiang private tour with flexible pacing, comfortable route planning, and a clear look at why this Yunnan pairing works so well together.'
      when 'bespoke-custom-travel'
        assign seo_title = 'Custom Yunnan Itinerary | Bespoke Private Travel Planning'
        assign seo_description = 'Request a custom Yunnan itinerary built around your dates, travel style, hotels, and route preferences. Get private planning support from Lynx Tour.'
    endcase
  elsif request.page_type == 'article'
    assign article_slug = article.handle | split: '/' | last
    case article_slug
      when 'dianchi-lake-guide'
        assign seo_title = 'Dianchi Lake Kunming: Haigeng Dam, Seagulls & Visit Tips'
        assign seo_description = 'Plan a visit to Dianchi Lake in Kunming, including Haigeng Dam, winter seagulls, best season, transport tips, and how to include it in a private Yunnan trip.'
      when 'jade-dragon-snow-mountain-guide'
        assign seo_title = 'Jade Dragon Snow Mountain Guide: Tickets & Lijiang Tips'
        assign seo_description = 'Plan a Jade Dragon Snow Mountain visit from Lijiang with ticket tips, Blue Moon Valley, altitude notes, timing advice and private tour options.'
      when 'stone-forest-shilin-guide'
        assign seo_title = 'Stone Forest Kunming Guide: Shilin Travel Tips & Day Trip'
        assign seo_description = 'Plan a Stone Forest day trip from Kunming with Shilin travel tips, transport advice, timing, route ideas and private Yunnan tour options.'
      when 'lijiang-old-town-guide'
        assign seo_title = 'Lijiang Old Town Guide: What to See, Tips & Itinerary'
        assign seo_description = 'Explore Lijiang Old Town with walking tips, best areas, Naxi culture, nearby sights, itinerary ideas and private Lijiang tour options.'
    endcase
  elsif request.page_type == 'product'
    case product.handle
      when 'kunming-dali-lijiang-shangri-la-8-day-private-tour'
        assign seo_title = '8-Day Yunnan Private Tour | Kunming, Dali, Lijiang & Shangri-La'
        assign seo_description = 'Plan an 8-day private Yunnan tour across Kunming, Dali, Lijiang, and Shangri-La with flexible pacing, private transfers, and local itinerary support.'
      when 'jade-dragon-snow-mountain-private-tour'
        assign seo_title = 'Jade Dragon Snow Mountain Private Tour from Lijiang'
        assign seo_description = 'Visit Jade Dragon Snow Mountain and Blue Moon Valley on a private day tour from Lijiang with flexible timing, transport support, and local planning advice.'
      when 'lijiang-to-shangri-la-private-tour'
        assign seo_title = 'Lijiang to Shangri-La Private Tour | Tiger Leaping Gorge Route'
        assign seo_description = 'Travel from Lijiang to Shangri-La on a private Yunnan route with Tiger Leaping Gorge, flexible stops, private transport, and local itinerary support.'
      when 'yunnan-private-car-charter-tour'
        assign seo_title = 'Yunnan Private Car Charter | Car with Driver for Flexible Routes'
        assign seo_description = 'Book a private car with driver in Yunnan for flexible routes across Kunming, Dali, Lijiang, Shangri-La, and custom destinations.'
    endcase
  endif

  assign seo_share_image = blank
  if request.page_type == 'collection' and collection.image != blank
    assign seo_share_image = collection.image | image_url: width: 1200 | prepend: 'https:'
  elsif page_image
    assign seo_share_image = page_image | image_url: width: 1200 | prepend: 'https:'
  elsif settings.logo != blank
    assign seo_share_image = settings.logo | image_url: width: 1200 | prepend: 'https:'
  endif

  assign collection_has_tags = false
  assign collection_is_custom_sorted = false
  assign collection_is_parameter_page = false

  if request.page_type == 'collection'
    if current_tags and current_tags.size > 0
      assign collection_has_tags = true
    endif

    if collection.sort_by != blank and collection.sort_by != collection.default_sort_by
      assign collection_is_custom_sorted = true
    endif

    if collection_has_tags or collection_is_custom_sorted
      assign collection_is_parameter_page = true
    endif
  endif

  assign seo_title = seo_title | strip
  assign seo_description = seo_description | strip

  assign seo_title_downcase = seo_title | downcase
  assign shop_name_downcase = shop.name | downcase
  if seo_title != blank
    unless seo_title_downcase contains shop_name_downcase
    assign seo_title = seo_title | append: ' | ' | append: shop.name
    endunless
  endif
-%}

<title>{{ seo_title | escape }}</title>

{% if seo_description != blank %}
  <meta name="description" content="{{ seo_description | escape }}">
{% endif %}
{% if request.page_type == 'search' or collection_is_parameter_page or article_is_duplicate_variant %}
  <meta name="robots" content="noindex,follow">
{% endif %}

<meta property="og:site_name" content="Lynxtour">
<meta property="og:url" content="{{ resolved_canonical_url }}">
<meta property="og:title" content="{{ seo_title | escape }}">
{% if seo_description != blank %}
  <meta property="og:description" content="{{ seo_description | escape }}">
{% endif %}
<meta property="og:type" content="{% if request.page_type == 'product' %}product{% elsif request.page_type == 'article' %}article{% else %}website{% endif %}">

{% if seo_share_image != blank %}
  <meta property="og:image" content="{{ seo_share_image }}">
  <meta property="og:image:secure_url" content="{{ seo_share_image }}">
  <meta name="twitter:image" content="{{ seo_share_image }}">
{% endif %}

<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:title" content="{{ seo_title | escape }}">
{% if seo_description != blank %}
  <meta name="twitter:description" content="{{ seo_description | escape }}">
{% endif %}

    {% liquid
      assign lynx_schema_base_url = 'https://lynxtour.cn'
      assign lynx_organization_id = lynx_schema_base_url | append: '/#organization'
      assign lynx_website_id = lynx_schema_base_url | append: '/#website'
    %}
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": ["Organization", "TravelAgency"],
          "@id": {{ lynx_organization_id | json }},
          "name": "Lynxtour",
          "url": {{ lynx_schema_base_url | append: '/' | json }},
          "description": "Lynxtour provides private and custom Yunnan tours for international travelers, with local planning across Kunming, Dali, Lijiang, Shangri-La, Xishuangbanna, and wider Yunnan routes.",
          "areaServed": [
            { "@type": "AdministrativeArea", "name": "Yunnan" },
            { "@type": "City", "name": "Kunming" },
            { "@type": "City", "name": "Dali" },
            { "@type": "City", "name": "Lijiang" },
            { "@type": "City", "name": "Shangri-La" },
            { "@type": "City", "name": "Xishuangbanna" }
          ],
          "sameAs": [
            "https://www.instagram.com/lynxtourofficial/",
            "https://www.facebook.com/lynxtourofficial",
            "https://www.youtube.com/@lynxtour_official",
            "https://www.tiktok.com/@lynxtour_official"
          ],
          "telephone": "+86-871-63218099",
          "email": "biz@lynxtour.cn",
          "address": {
            "@type": "PostalAddress",
            "streetAddress": "Room 3011, Building 4, Xindu Longcheng, Panlong District",
            "addressLocality": "Kunming",
            "addressRegion": "Yunnan Province",
            "postalCode": "650051",
            "addressCountry": "CN"
          },
          "contactPoint": {
            "@type": "ContactPoint",
            "contactType": "customer service",
            "telephone": "+86-871-63218099",
            "email": "biz@lynxtour.cn",
            "availableLanguage": ["English", "Chinese"],
            "areaServed": ["Yunnan", "China"]
          },
          "openingHoursSpecification": [
            {
              "@type": "OpeningHoursSpecification",
              "dayOfWeek": [
                "Monday",
                "Tuesday",
                "Wednesday",
                "Thursday",
                "Friday",
                "Saturday"
              ],
              "opens": "09:00",
              "closes": "18:00"
            }
          ]{% if settings.logo != blank %},
          "logo": {{ settings.logo | image_url: width: 512 | prepend: 'https:' | json }},
          "image": {{ settings.logo | image_url: width: 512 | prepend: 'https:' | json }}{% endif %}
        },
        {
          "@type": "WebSite",
          "@id": {{ lynx_website_id | json }},
          "name": "Lynxtour",
          "alternateName": ["Lynxtour Yunnan", "lynxtour.cn"],
          "url": {{ lynx_schema_base_url | append: '/' | json }},
          "publisher": {
            "@id": {{ lynx_organization_id | json }}
          }
        }
      ]
    }
    </script>

    {{ content_for_header }}

    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Noto+Serif+SC:wght@400;700&family=Inter:wght@400;500;700&display=swap" rel="stylesheet">

    <style>
      :root {
        /*
          Lynx UI tokens: conservative global foundation extracted from the
          current homepage visual baseline. These are not applied broadly yet.
        */
        --lynx-color-bg: #0a0a0a;
        --lynx-color-surface: #111111;
        --lynx-color-surface-soft: rgba(255, 255, 255, 0.02);
        --lynx-color-text: #f7f2ea;
        --lynx-color-muted: rgba(232, 225, 214, 0.72);
        --lynx-color-border: rgba(216, 179, 95, 0.10);
        --lynx-color-primary: #fbbf24;
        --lynx-color-primary-hover: #ffffff;
        --lynx-color-primary-soft: rgba(251, 191, 36, 0.10);
        --lynx-color-luxury: #d8b35f;
        --lynx-hero-bg: #1c1917;
        --lynx-hero-overlay: linear-gradient(to bottom, rgba(0,0,0,0.2), rgba(0,0,0,0.6));
        --lynx-radius-card: 24px;
        --lynx-radius-button: 60px;
        --lynx-shadow-card: 0 16px 44px rgba(0, 0, 0, 0.22);
        --lynx-shadow-soft: 0 10px 30px rgba(0, 0, 0, 0.28);
        --lynx-section-padding-y: 108px;
        --lynx-section-padding-y-mobile: 64px;
        --lynx-container-max: 1220px;
        --lynx-readable-max: 760px;
        --lynx-card-gap: 22px;
      }

      html {
        scroll-behavior: smooth;
      }

      /* Lynx shared CTA layer. Section-specific button visuals remain unchanged. */
      .lynx-btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 44px;
        padding: 14px 24px;
        border: 1px solid transparent;
        border-radius: var(--lynx-radius-button);
        font: inherit;
        font-size: 0.9rem;
        font-weight: 600;
        line-height: 1.2;
        letter-spacing: 0.18em;
        text-align: center;
        text-decoration: none;
        text-transform: uppercase;
        cursor: pointer;
        transition: background-color 0.25s ease, border-color 0.25s ease, color 0.25s ease, box-shadow 0.25s ease, transform 0.25s ease;
        -webkit-tap-highlight-color: transparent;
      }

      .lynx-btn--primary {
        background: var(--lynx-color-primary);
        border-color: var(--lynx-color-primary);
        color: #1c1917;
      }

      .lynx-btn--primary:hover {
        background: var(--lynx-color-primary-hover);
        border-color: var(--lynx-color-primary-hover);
        color: #1c1917;
        box-shadow: var(--lynx-shadow-soft);
        transform: translateY(-2px);
      }

      .lynx-btn--secondary {
        background: transparent;
        border-color: rgba(255, 255, 255, 0.18);
        color: var(--lynx-color-text);
      }

      .lynx-btn--secondary:hover {
        border-color: var(--lynx-color-primary);
        color: var(--lynx-color-primary);
        background: var(--lynx-color-primary-soft);
      }

      .lynx-text-cta {
        color: var(--lynx-color-text);
        text-decoration: none;
        text-transform: uppercase;
        letter-spacing: 0.18em;
        transition: color 0.25s ease;
      }

      .lynx-text-cta:hover {
        color: var(--lynx-color-primary);
      }

      .lynx-btn:focus-visible,
      .lynx-text-cta:focus-visible,
      .hero-btn:focus-visible,
      .coll-hero-btn:focus-visible,
      .card-btn:focus-visible,
      .brand-link-chip:focus-visible,
      .dest-action:focus-visible,
      .dali-quick-btn:focus-visible,
      .dali-cta-btn:focus-visible,
      .dali-inline-link:focus-visible,
      .dali-related-link:focus-visible,
      .lj-top-btn:focus-visible,
      .lj-cta-btn:focus-visible,
      .lj-inline-link:focus-visible,
      .lj-related-link:focus-visible,
      .xb-top-btn:focus-visible,
      .xb-cta-btn:focus-visible,
      .xb-inline-link:focus-visible,
      .xb-related-link:focus-visible,
      .km-cta-btn:focus-visible,
      .km-inline-link:focus-visible,
      .km-related-link:focus-visible,
      .cta-submit-btn:focus-visible,
      .submit-btn-minimal:focus-visible,
      .copy-email-btn:focus-visible,
      .ai-submit-btn:focus-visible,
      .secondary-submit-btn:focus-visible,
      .btn-contact-custom:focus-visible,
      .ota-btn-cart:focus-visible,
      .ota-btn-buy:focus-visible,
      .ota-info-btn:focus-visible {
        outline: 2px solid var(--lynx-color-primary);
        outline-offset: 3px;
      }

      .lynx-btn:disabled,
      .lynx-btn[aria-disabled="true"],
      .cta-submit-btn:disabled,
      .submit-btn-minimal:disabled,
      .copy-email-btn:disabled,
      .ai-submit-btn:disabled,
      .secondary-submit-btn:disabled,
      .ota-btn-cart:disabled,
      .ota-btn-buy:disabled {
        opacity: 0.55;
        cursor: not-allowed;
        pointer-events: none;
      }

      @media (max-width: 767px) {
        .lynx-btn,
        .hero-btn,
        .coll-hero-btn,
        .dali-quick-btn,
        .dali-cta-btn,
        .lj-top-btn,
        .lj-cta-btn,
        .xb-top-btn,
        .xb-cta-btn,
        .km-cta-btn,
        .cta-submit-btn,
        .submit-btn-minimal,
        .copy-email-btn,
        .ai-submit-btn,
        .secondary-submit-btn,
        .btn-contact-custom,
        .ota-btn-cart,
        .ota-btn-buy,
        .ota-info-btn {
          min-height: 44px;
        }
      }

      /* Lynx shared card layer. Use for new card work; existing card visuals stay section-owned. */
      .lynx-card {
        background: var(--lynx-color-surface);
        border: 1px solid var(--lynx-color-border);
        border-radius: var(--lynx-radius-card);
        box-shadow: var(--lynx-shadow-card);
        color: var(--lynx-color-text);
        overflow: hidden;
      }

      .lynx-card--soft {
        background: var(--lynx-color-surface-soft);
        box-shadow: var(--lynx-shadow-soft);
      }

      .lynx-card--image {
        position: relative;
        min-height: 100%;
      }

      .lynx-card__media {
        position: relative;
        overflow: hidden;
        background: var(--lynx-color-surface);
      }

      .lynx-card__media img {
        display: block;
        width: 100%;
        height: 100%;
        object-fit: cover;
      }

      .lynx-card__content {
        padding: 24px;
      }

      .lynx-card__title {
        color: var(--lynx-color-text);
        margin: 0;
      }

      .lynx-card__text {
        color: var(--lynx-color-muted);
        margin: 0;
        line-height: 1.8;
      }

      .lynx-card__meta {
        color: var(--lynx-color-muted);
        font-size: 0.75rem;
        letter-spacing: 0.14em;
        text-transform: uppercase;
      }

      .lynx-card__tag {
        color: var(--lynx-color-luxury);
        font-size: 0.75rem;
        font-weight: 600;
        letter-spacing: 0.18em;
        text-transform: uppercase;
      }

      /* Lynx shared section and typography layer. Opt-in utilities based on the homepage rhythm. */
      .lynx-section {
        padding-top: var(--lynx-section-padding-y);
        padding-bottom: var(--lynx-section-padding-y);
      }

      .lynx-container {
        max-width: var(--lynx-container-max);
        margin-right: auto;
        margin-left: auto;
        padding-right: 20px;
        padding-left: 20px;
      }

      .lynx-readable {
        max-width: var(--lynx-readable-max);
        margin-right: auto;
        margin-left: auto;
      }

      .lynx-section-header {
        max-width: var(--lynx-readable-max);
        margin: 0 auto 58px;
        text-align: center;
      }

      .lynx-eyebrow {
        color: var(--lynx-color-luxury);
        font-size: 0.75rem;
        font-weight: 600;
        letter-spacing: 0.18em;
        text-transform: uppercase;
      }

      .lynx-section-title {
        color: var(--lynx-color-text);
        margin: 0;
        font-weight: 300;
        line-height: 1.15;
      }

      .lynx-section-text {
        color: var(--lynx-color-muted);
        margin: 0;
        line-height: 1.85;
      }

      .lynx-rich-text {
        color: var(--lynx-color-muted);
        max-width: var(--lynx-readable-max);
        line-height: 1.85;
      }

      .lynx-rich-text p,
      .lynx-rich-text ul,
      .lynx-rich-text ol {
        margin-top: 0;
        margin-bottom: 1.15rem;
      }

      .lynx-rich-text p:last-child,
      .lynx-rich-text ul:last-child,
      .lynx-rich-text ol:last-child {
        margin-bottom: 0;
      }

      .lynx-rich-text li {
        margin-bottom: 0.65rem;
      }

      .lynx-rich-text li:last-child {
        margin-bottom: 0;
      }

      @media (max-width: 767px) {
        .lynx-section {
          padding-top: var(--lynx-section-padding-y-mobile);
          padding-bottom: var(--lynx-section-padding-y-mobile);
        }

        .lynx-container {
          padding-right: 16px;
          padding-left: 16px;
        }

        .lynx-section-header {
          margin-bottom: 28px;
        }

        .lynx-section-text,
        .lynx-rich-text {
          line-height: 1.75;
        }
      }

      /* 防止跳转后标题紧贴屏幕顶端，留出一点呼吸空间 */
      #dest-section {
        scroll-margin-top: 50px;
      }

      body {
        font-family: 'Inter', sans-serif;
      }

      .font-noto-serif-sc {
        font-family: 'Noto Serif SC', serif;
      }

      .prose h3 {
        font-size: 1.5rem;
        font-weight: 700;
        font-family: 'Noto Serif SC', serif;
        color: #f59e0b;
        margin-top: 1.5rem;
        margin-bottom: 0.75rem;
      }

      .prose p,
      .prose li {
        color: #d6d3d1;
        line-height: 1.625;
        margin-bottom: 0.75rem;
      }

      .prose li {
        margin-left: 1.5rem;
        list-style-type: disc;
      }
    </style>

  </head>

  <body class="bg-stone-900 text-stone-300">
    <a class="sr-only" href="#MainContent">Skip to content</a>
    <main id="MainContent" role="main">
      {{ content_for_layout }}
    </main>
    {% render 'ga4-custom-events' %}
  </body>
</html>
