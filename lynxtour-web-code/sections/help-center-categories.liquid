{% comment %}
  Help Center - Categories (Dark / Glass style)
  Big card + top-left badge + per-block accent color
  File: sections/help-center-categories.liquid
{% endcomment %}

<section class="hccat-{{ section.id }}">
  <div class="hccat__container">

    <div class="hccat__wrap">
      {%- if section.settings.title != blank -%}
        <div class="hccat__badge">{{ section.settings.title }}</div>
      {%- endif -%}

      <div class="hccat__card">
        <div class="hccat__grid" style="
          --cols-desktop: {{ section.settings.cols_desktop }};
          --cols-tablet: {{ section.settings.cols_tablet }};
          --cols-mobile: {{ section.settings.cols_mobile }};
        ">
          {%- assign shown = 0 -%}
          {%- for block in section.blocks -%}
            {%- if block.type == 'category' -%}
              {%- assign shown = shown | plus: 1 -%}
              {%- assign accent = block.settings.accent | default: '#F59E0B' -%}

              <a class="hccat__item"
                 href="{{ block.settings.url | default: '#' }}"
                 {% if block.settings.open_new_tab %}target="_blank" rel="noopener"{% endif %}
                 style="--accent: {{ accent }};"
                 {{ block.shopify_attributes }}
              >
                <div class="hccat__icon">
                  {%- if block.settings.icon != blank -%}
                    {{ block.settings.icon
                      | image_url: width: 160
                      | image_tag:
                        loading: 'lazy',
                        class: 'hccat__img',
                        alt: block.settings.title
                    }}
                  {%- else -%}
                    <span class="hccat__placeholder" aria-hidden="true"></span>
                  {%- endif -%}
                </div>

                <div class="hccat__name">{{ block.settings.title }}</div>
              </a>
            {%- endif -%}
          {%- endfor -%}

          {%- if shown == 0 -%}
            <div class="hccat__empty">请在该 Section 中添加 Category blocks。</div>
          {%- endif -%}
        </div>
      </div>
    </div>

  </div>

  <style>
    .hccat-{{ section.id }}{
      --brand: var(--brand-color, #f59e0b);

      --panel: rgba(12, 10, 9, 0.92);
      --panel-2: rgba(255,255,255,0.03);
      --text: #ffffff;
      --sub: rgba(214, 211, 209, 0.85);
      --line: rgba(255,255,255,0.10);
      --line-2: rgba(255,255,255,0.08);
      --shadow: 0 10px 30px rgba(0,0,0,0.50);
      --shadow-item: 0 10px 24px rgba(0,0,0,0.35);
      --radius: 18px;
    }

    .hccat-{{ section.id }} .hccat__container{
      max-width: {{ section.settings.max_width }}px;
      margin: 0 auto;
      padding: 18px 18px 40px;
      color: var(--text);
    }

    .hccat-{{ section.id }} .hccat__wrap{
      position: relative;
      padding-top: 26px;
    }

    .hccat-{{ section.id }} .hccat__badge{
      position: absolute;
      left: 18px;
      top: -12px;
      background: var(--panel);
      border: 1px solid var(--line);
      border-radius: 999px;
      padding: 6px 12px;
      font-size: 12px;
      font-weight: 700;
      letter-spacing: 1px;
      color: var(--text);
      box-shadow: var(--shadow);
      backdrop-filter: blur(15px);
      -webkit-backdrop-filter: blur(15px);
      z-index: 2;
      white-space: nowrap;
    }

    .hccat-{{ section.id }} .hccat__card{
      background: var(--panel);
      border: 1px solid var(--line);
      border-radius: var(--radius);
      box-shadow: var(--shadow);
      padding: 18px;
      backdrop-filter: blur(15px);
      -webkit-backdrop-filter: blur(15px);
    }

    .hccat-{{ section.id }} .hccat__grid{
      display: grid;
      grid-template-columns: repeat({{ section.settings.cols_desktop }}, minmax(0, 1fr));
      gap: 18px;
    }

    .hccat-{{ section.id }} .hccat__item{
      --accent: var(--brand);

      background: var(--panel-2);
      border: 1px solid var(--line-2);
      border-radius: 16px;
      padding: 16px 10px 14px;
      text-decoration: none;
      color: inherit;
      box-shadow: var(--shadow-item);
      transition: transform .15s ease, box-shadow .15s ease, border-color .15s ease, background .15s ease;
      display: grid;
      justify-items: center;
      gap: 10px;
      min-height: 110px;
    }

    .hccat-{{ section.id }} .hccat__item:hover{
      transform: translateY(-2px);
      border-color: color-mix(in srgb, var(--accent) 40%, rgba(255,255,255,0.10));
      background: color-mix(in srgb, var(--accent) 8%, rgba(255,255,255,0.03));
      box-shadow: 0 14px 30px rgba(0,0,0,0.55);
    }

    .hccat-{{ section.id }} .hccat__icon{
      width: 56px;
      height: 56px;
      border-radius: 16px;
      background: color-mix(in srgb, var(--accent) 14%, transparent);
      display: grid;
      place-items: center;
      overflow: hidden;
    }

    .hccat-{{ section.id }} .hccat__img{
      width: 46px;
      height: 46px;
      object-fit: contain;
      display: block;
    }

    .hccat-{{ section.id }} .hccat__placeholder{
      width: 34px;
      height: 34px;
      border-radius: 12px;
      background: color-mix(in srgb, var(--accent) 26%, transparent);
      display: block;
    }

    .hccat-{{ section.id }} .hccat__name{
      font-size: 13px;
      font-weight: 600;
      text-align: center;
      color: var(--text);
      letter-spacing: .2px;
    }

    .hccat-{{ section.id }} .hccat__empty{
      padding: 14px 18px;
      color: var(--sub);
      font-size: 13px;
      border: 1px dashed var(--line-2);
      border-radius: 12px;
      grid-column: 1 / -1;
      background: rgba(255,255,255,0.02);
    }

    @media (max-width: 980px){
      .hccat-{{ section.id }} .hccat__grid{
        grid-template-columns: repeat({{ section.settings.cols_tablet }}, minmax(0, 1fr));
      }
    }

    @media (max-width: 720px){
      .hccat-{{ section.id }} .hccat__card{ padding: 14px; }
      .hccat-{{ section.id }} .hccat__grid{
        grid-template-columns: repeat({{ section.settings.cols_mobile }}, minmax(0, 1fr));
        gap: 14px;
      }
      .hccat-{{ section.id }} .hccat__item{ min-height: 104px; }
      .hccat-{{ section.id }} .hccat__badge{ left: 14px; }
    }
  </style>
</section>

{% schema %}
{
  "name": "HC Cats Dark",
  "settings": [
    { "type": "text", "id": "title", "label": "左上角标题", "default": "问题分类" },
    { "type": "range", "id": "max_width", "label": "内容最大宽度(px)", "min": 720, "max": 1200, "step": 10, "default": 980 },
    { "type": "range", "id": "cols_desktop", "label": "桌面端列数", "min": 2, "max": 6, "step": 1, "default": 4 },
    { "type": "range", "id": "cols_tablet", "label": "平板列数", "min": 2, "max": 5, "step": 1, "default": 3 },
    { "type": "range", "id": "cols_mobile", "label": "手机列数", "min": 1, "max": 3, "step": 1, "default": 2 }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Category",
      "settings": [
        { "type": "text", "id": "title", "label": "分类名称", "default": "个人订单" },
        { "type": "url", "id": "url", "label": "跳转链接" },
        { "type": "image_picker", "id": "icon", "label": "图标（建议 128x128 PNG/SVG）" },
        { "type": "color", "id": "accent", "label": "主题色（每个分类独立）", "default": "#F59E0B" },
        { "type": "checkbox", "id": "open_new_tab", "label": "新窗口打开", "default": false }
      ]
    }
  ],
  "presets": [{ "name": "HC Cats Dark" }]
}
{% endschema %}

