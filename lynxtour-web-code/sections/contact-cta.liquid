<div class="contact-cta-section">
  <div class="cta-container">
    <div class="cta-content">
      <div class="cta-decoration">
        <span class="cta-line"></span>
        <span class="cta-dot"></span>
        <span class="cta-line"></span>
      </div>

      <h2 class="cta-title">{{ section.settings.title }}</h2>
      <p class="cta-subtitle">{{ section.settings.subtitle }}</p>

      {%- form 'contact', id: 'ContactCTA' -%}
        {%- if form.posted_successfully? -%}
          <p class="cta-success">感谢您的信任。我们的私人旅行顾问将在 24 小时内与您联系。</p>
        {%- else -%}
          <div class="cta-form-inner">
            <div class="input-wrapper">
              <input type="text" name="contact[name]" id="cta-name" placeholder="您的称呼" required>
            </div>
            <div class="input-wrapper">
              <input type="tel" name="contact[phone]" id="cta-phone" placeholder="联系电话 / 微信" required>
            </div>
            <button type="submit" class="cta-submit-btn">
              <span>立即预约咨询</span>
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M5 12h14M12 5l7 7-7 7"></path>
              </svg>
            </button>
          </div>
        {%- endif -%}
      {%- endform -%}
      
      <p class="cta-privacy">我们将严格保护您的隐私信息，仅用于旅行方案设计。</p>
    </div>
  </div>
</div>

<style>
  .contact-cta-section {
    background-color: #0c0a09;
    padding: 140px 0;
    text-align: center;
    position: relative;
    border-top: 1px solid rgba(255,255,255,0.05);
  }

  .cta-container { max-width: 800px; margin: 0 auto; padding: 0 24px; }

  /* 装饰线条 */
  .cta-decoration { display: flex; align-items: center; justify-content: center; gap: 15px; margin-bottom: 30px; }
  .cta-line { width: 40px; height: 1px; background: #fbbf24; opacity: 0.5; }
  .cta-dot { width: 4px; height: 4px; background: #fbbf24; border-radius: 50%; }

  .cta-title { 
    color: #fff; 
    font-size: clamp(2rem, 5vw, 3rem); 
    font-weight: 700; 
    letter-spacing: 2px;
    margin-bottom: 20px;
  }

  .cta-subtitle { 
    color: #d6d3d1; 
    font-size: 16px; 
    letter-spacing: 1px;
    margin-bottom: 60px;
    line-height: 1.8;
  }

  /* 表单样式优化 */
  .cta-form-inner {
    display: flex;
    flex-wrap: wrap;
    gap: 15px;
    justify-content: center;
  }

  .input-wrapper { flex: 1; min-width: 250px; }

  .cta-form-inner input {
    width: 100%;
    background: transparent;
    border: none;
    border-bottom: 1px solid rgba(255,255,255,0.2);
    padding: 15px 0;
    color: #fff;
    font-size: 15px;
    transition: border-color 0.4s;
    outline: none;
  }

  .cta-form-inner input:focus { border-color: #fbbf24; }

  /* 按钮样式：延续 Hero 的琥珀金 */
  .cta-submit-btn {
    background: #fbbf24;
    color: #1c1917;
    border: none;
    padding: 15px 40px;
    font-size: 15px;
    font-weight: 600;
    border-radius: 2px;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 10px;
    transition: all 0.4s;
    letter-spacing: 1px;
  }

  .cta-submit-btn:hover {
    background: #fff;
    transform: translateY(-2px);
  }

  .cta-success { color: #fbbf24; font-size: 16px; border: 1px solid #fbbf24; padding: 20px; }
  .cta-privacy { color: #57534e; font-size: 12px; margin-top: 40px; letter-spacing: 1px; }

  @media (max-width: 767px) {
    .cta-form-inner { flex-direction: column; }
    .input-wrapper { min-width: 100%; }
    .contact-cta-section { padding: 100px 0; }
  }
</style>

{% schema %}
{
  "name": "Contact CTA",
  "settings": [
    { "type": "text", "id": "title", "label": "标题", "default": "开启您的私人定制之旅" },
    { "type": "text", "id": "subtitle", "label": "副标题", "default": "只需留下您的联系方式，我们的旅行专家将为您量身打造专属行程。" }
  ],
  "presets": [
    { "name": "Contact CTA" }
  ]
}
{% endschema %}