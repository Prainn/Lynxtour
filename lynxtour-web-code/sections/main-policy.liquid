{%- style -%}
  /* 强制黑金配色方案 */
  .policy-wrapper {
    background-color: #000000 !important;
    color: #FFFFFF !important;
    min-height: 80vh;
    padding-top: 60px;
    padding-bottom: 60px;
  }

  .policy-container {
    max-width: 900px;
    margin: 0 auto;
    padding-left: 20px;
    padding-right: 20px;
  }

  /* 标题强制品牌金 #fbbf24 */
  .policy-title {
    text-align: center;
    margin-bottom: 40px;
    text-transform: uppercase;
    letter-spacing: 2px;
    font-weight: 700;
    color: #fbbf24 !important; 
    border-bottom: 1px solid rgba(251, 191, 36, 0.3);
    padding-bottom: 20px;
  }

  .policy-content {
    line-height: 1.8;
    font-size: 16px;
  }

  .policy-content h1, 
  .policy-content h2, 
  .policy-content h3, 
  .policy-content h4 {
    color: #fbbf24 !important;
    margin-top: 30px;
    margin-bottom: 15px;
    font-weight: normal;
  }

  .policy-content a {
    color: #fbbf24 !important;
    text-decoration: none;
    border-bottom: 1px solid #fbbf24;
    transition: opacity 0.3s ease;
  }

  .policy-content a:hover {
    opacity: 0.8;
  }
  
  .policy-content li {
    margin-bottom: 10px;
    color: #e5e5e5;
  }
{%- endstyle -%}

<div class="policy-wrapper">
  <div class="policy-container">
    <div class="policy-header">
      <!-- 注意这里变成了 page.title -->
      <h1 class="policy-title h2">
        {{ page.title }}
      </h1>
    </div>

    <div class="policy-content rte">
      <!-- 注意这里变成了 page.content -->
      {{ page.content }}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Custom Policy Page",
  "settings": []
}
{% endschema %}