<div id="itinerary-anchor" class="itinerary-ai-section">
  <div class="max-w-7xl mx-auto px-6 relative z-10">
    
    {% if section.settings.main_title != blank %}
      <div class="section-header">
        <h2 class="section-main-title">{{ section.settings.main_title }}</h2>
        <div class="title-underline"></div>
      </div>
    {% endif %}

    <div class="flex flex-col lg:flex-row gap-8 items-stretch">
      
      <div class="w-full lg:w-[65%] bg-white/[0.015] p-8 md:p-10 border border-white/[0.05] shadow-2xl flex flex-col relative">
        <div class="mb-10 flex justify-between items-end border-b border-white/[0.05] pb-6">
          <div>
            <span class="text-amber-500/70 text-[10px] tracking-[0.4em] uppercase font-light">{{ section.settings.ai_pretitle }}</span>
            <h3 class="text-xl text-white font-light mt-2 tracking-[0.2em] uppercase">{{ section.settings.ai_title }}</h3>
          </div>
          <div class="text-stone-600 text-[9px] tracking-widest uppercase font-mono opacity-40">Algorithm v2.4</div>
        </div>

        <form id="itinerary-form" class="space-y-10 flex-grow">
          <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
            <div class="input-group">
              <label class="block text-stone-500 text-[9px] uppercase mb-3 tracking-[0.2em]">Duration (Days)</label>
              <input type="number" name="duration" value="7" class="custom-input w-full bg-transparent border-b border-stone-800 text-amber-100 py-2 outline-none focus:border-amber-500/50 transition-all font-mono">
            </div>
            <div class="input-group">
              <label class="block text-stone-500 text-[9px] uppercase mb-3 tracking-[0.2em]">Travelers</label>
              <select name="travelers" class="custom-input w-full bg-transparent border-b border-stone-800 text-amber-100 py-2 outline-none focus:border-amber-500/50 appearance-none cursor-pointer">
                <option value="Solo">Solo Traveler</option>
                <option value="Couple" selected>Couple</option>
                <option value="Family">Family Group</option>
                <option value="Friends">Small Group</option>
              </select>
            </div>
            <div class="input-group">
              <label class="block text-stone-500 text-[9px] uppercase mb-3 tracking-[0.2em]">Pace</label>
              <select name="pace" class="custom-input w-full bg-transparent border-b border-stone-800 text-amber-100 py-2 outline-none focus:border-amber-500/50 appearance-none cursor-pointer">
                <option value="Slow & Immersive">Slow & Immersive</option>
                <option value="Balanced" selected>Balanced</option>
                <option value="Active & Adventure">Active & Adventure</option>
              </select>
            </div>
          </div>

          <div class="input-group">
            <label class="block text-stone-500 text-[9px] uppercase mb-3 tracking-[0.2em]">Target Destinations</label>
            <input type="text" name="destinations" placeholder="Dali, Lijiang, Shangri-La..." class="custom-input w-full bg-transparent border-b border-stone-800 text-amber-100 py-2 outline-none focus:border-amber-500/50 transition-all italic text-xs">
          </div>

          <div class="input-group">
            <label class="block text-stone-500 text-[9px] uppercase mb-4 tracking-[0.2em]">Travel Interests</label>
            <div class="flex flex-wrap gap-3">
              {% assign tags = "Culture,Nature,Photography,Handicraft,Tea Tasting,Gourmet,Luxury" | split: ',' %}
              {% for tag in tags %}
                <button type="button" data-tag="{{ tag }}" class="tag-btn px-5 py-2.5 border border-white/10 text-[9px] text-stone-500 hover:text-white transition-all cursor-pointer uppercase tracking-[0.15em]">{{ tag }}</button>
              {% endfor %}
            </div>
          </div>

          <button type="submit" class="ai-submit-btn w-full border border-amber-500/50 text-amber-500/90 hover:bg-amber-500 hover:text-stone-950 py-5 transition-all flex justify-center items-center gap-3 tracking-[0.4em] text-[10px] bg-transparent">
            GENERATE BESPOKE JOURNEY
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M14 5l7 7-7 7M5 12h14" stroke-width="1"></path></svg>
          </button>
        </form>

        <div id="itinerary-display" class="hidden mt-10 pt-10 border-t border-white/[0.05] animate-reveal">
           <div id="itinerary-loading" class="flex flex-col items-center py-12">
              <div class="w-5 h-5 border border-amber-500/30 border-t-amber-500 rounded-full animate-spin mb-4"></div>
              <p class="text-amber-500/50 italic text-[9px] tracking-[0.2em] uppercase">Consulting AI Concierge...</p>
           </div>
           <div id="itinerary-result" class="prose-custom custom-scrollbar"></div>
        </div>
      </div>

      <div class="w-full lg:w-[35%] flex flex-col gap-6">
        <div id="booking-notif" class="bg-white/[0.02] border border-amber-500/10 p-5 shadow-2xl transition-all duration-1000 opacity-0 transform translate-y-2">
           <div class="flex items-center gap-4">
             <div class="w-1 h-1 rounded-full bg-amber-500/60 animate-pulse"></div>
             <div>
               <p id="notif-text" class="text-stone-400 text-[10px] tracking-wide font-light">Request from London received.</p>
             </div>
           </div>
        </div>

        <div class="flex-grow bg-white/[0.01] border border-white/[0.05] p-10 flex flex-col justify-center relative overflow-hidden shadow-xl">
          <div class="relative z-10">
            <span class="text-amber-500/60 text-[10px] tracking-[0.3em] uppercase font-light mb-4 block">Final Step</span>
            <h3 class="text-2xl font-light text-white mb-6 tracking-widest uppercase">{{ section.settings.cta_title }}</h3>
            <p class="text-stone-500 mb-10 leading-relaxed text-[11px] font-light">Transform your AI-generated spark into a meticulously planned reality.</p>

            {%- form 'contact', id: 'DualContactForm' -%}
              {%- if form.posted_successfully? -%}
                <div class="border border-amber-500/30 text-amber-500/80 p-6 text-[10px] tracking-[0.3em] text-center uppercase">Request Sent Successfully.</div>
              {%- else -%}
                <div class="space-y-10">
                  <div class="input-group">
                    <label class="block text-stone-600 text-[9px] uppercase mb-1 tracking-[0.2em]">Full Name</label>
                    <input type="text" name="contact[name]" class="w-full bg-transparent border-b border-stone-800 p-2 text-white outline-none focus:border-amber-500/50 transition-colors text-sm font-light" required>
                  </div>
                  <div class="input-group">
                    <label class="block text-stone-600 text-[9px] uppercase mb-1 tracking-[0.2em]">WhatsApp / Phone</label>
                    <input type="tel" name="contact[phone]" class="w-full bg-transparent border-b border-stone-800 p-2 text-white outline-none focus:border-amber-500/50 transition-colors text-sm font-light" required>
                  </div>
                  <button type="submit" class="w-full bg-transparent hover:bg-white text-white hover:text-stone-950 border border-white/20 py-4 transition-all uppercase tracking-[0.4em] text-[9px] mt-6 font-light">
                    Confirm Consultation
                  </button>
                </div>
              {%- endif -%}
            {%- endform -%}
          </div>
        </div>
      </div>

    </div>
  </div>
  
  <div class="section-bottom-gradient"></div>
</div>

<style>
  .itinerary-ai-section {
    position: relative;
    background-color: #0a0a0a;
    padding: 140px 0;
    overflow: hidden;
  }

  .section-header { text-align: center; margin-bottom: 90px; }
  .section-main-title { 
    color: #fff; font-size: clamp(1.5rem, 3.5vw, 2.2rem); 
    font-weight: 200; letter-spacing: 0.5em; 
    text-transform: uppercase; margin-bottom: 25px;
  }
  .title-underline { width: 30px; height: 1px; background: #fbbf24; margin: 0 auto; opacity: 0.4; }

  .section-bottom-gradient {
    position: absolute; bottom: 0; left: 0; width: 100%; height: 200px;
    background: linear-gradient(to bottom, transparent, rgba(10, 10, 10, 0.95) 90%);
    pointer-events: none;
  }

  /* 输入控件优化 */
  .custom-input { border-radius: 0 !important; }
  .custom-input option { background: #111; color: #fff; }

  /* 标签按钮 - 极简暗金风格 */
  .tag-btn {
    background: transparent;
    border-radius: 0;
  }
  .tag-btn:hover {
    border-color: rgba(255, 255, 255, 0.3);
  }
  .tag-btn.active {
    background: rgba(251, 191, 36, 0.05); /* 极其淡的金光 */
    border-color: #fbbf24;
    color: #fbbf24 !important;
  }
  
  /* 生成按钮 - 描边风格 */
  .ai-submit-btn {
    border-radius: 0;
    transition: all 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }

  /* AI 结果排版 */
  .prose-custom {
    max-height: 450px;
    overflow-y: auto;
    font-size: 13px;
    line-height: 2.2;
    color: #8c8c8c;
    padding-right: 25px;
    font-weight: 300;
  }
  .prose-custom h3 { color: #fbbf24; text-transform: uppercase; letter-spacing: 0.3em; font-size: 13px; margin: 40px 0 20px 0; font-weight: 400; }
  .custom-scrollbar::-webkit-scrollbar { width: 1px; }
  .custom-scrollbar::-webkit-scrollbar-thumb { background: #333; }

  .animate-reveal { animation: reveal 1.5s cubic-bezier(0.16, 1, 0.3, 1) forwards; }
  @keyframes reveal { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }
</style>

<script>
document.addEventListener('DOMContentLoaded', function() {
  const form = document.getElementById('itinerary-form');
  const display = document.getElementById('itinerary-display');
  const resultEl = document.getElementById('itinerary-result');
  const loadingEl = document.getElementById('itinerary-loading');
  const notif = document.getElementById('booking-notif');
  const notifText = document.getElementById('notif-text');

  const activities = ["Guest from Paris inquired about Dali.", "Boutique stay in Lijiang reserved.", "New family itinerary created.", "Custom Meili Trek generated."];
  function showNotif() {
    notifText.innerText = activities[Math.floor(Math.random() * activities.length)];
    notif.style.opacity = "1"; notif.style.transform = "translateY(0)";
    setTimeout(() => { notif.style.opacity = "0"; notif.style.transform = "translateY(5px)"; }, 4500);
  }
  setInterval(showNotif, 12000);

  document.querySelectorAll('.tag-btn').forEach(btn => {
    btn.addEventListener('click', () => btn.classList.toggle('active'));
  });

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    const API_KEY = {{ settings.gemini_api_key | json }};
    display.classList.remove('hidden');
    loadingEl.classList.remove('hidden');
    resultEl.innerHTML = '';

    try {
      const fd = new FormData(form);
      const tags = Array.from(document.querySelectorAll('.tag-btn.active')).map(b => b.dataset.tag).join(', ');
      const prompt = `Luxury travel consultant persona. Output English only. Use elegant tone. Format as Professional Markdown. Duration: ${fd.get('duration')} days. Travelers: ${fd.get('travelers')}. Pace: ${fd.get('pace')}. Spots: ${fd.get('destinations')}. Interests: ${tags}. Include Daily Itinerary and Insider Tips.`;

      const res = await fetch(`https://generativelanguage.googleapis.com/v1beta/models/gemini-1.5-flash:generateContent?key=${API_KEY}`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ contents: [{ parts: [{ text: prompt }] }] })
      });
      
      const data = await res.json();
      loadingEl.classList.add('hidden');
      if (data.candidates) {
        let text = data.candidates[0].content.parts[0].text;
        resultEl.innerHTML = text.replace(/### (.*?)\n/g, '<h3>$1</h3>').replace(/\n/g, '<br>');
      }
    } catch (err) { resultEl.innerHTML = "System is refining its wisdom. Please try again."; }
  });
});
</script>

{% schema %}
{
  "name": "AI Dual Layout Pro",
  "settings": [
    { "type": "text", "id": "main_title", "label": "英文大标题", "default": "BESPOKE AI PLANNER" },
    { "type": "text", "id": "ai_pretitle", "label": "AI 小标题", "default": "AI CONCIERGE" },
    { "type": "text", "id": "ai_title", "label": "AI 名字", "default": "JADE GUIDE ALPHA" },
    { "type": "text", "id": "cta_title", "label": "联系标题", "default": "CONFIRM PLAN" }
  ],
  "presets": [{ "name": "AI Dual Layout Pro" }]
}
{% endschema %}