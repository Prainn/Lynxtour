<div class="customer-register-section" style="max-width: 400px; margin: 50px auto; text-align: center;">
  
  <h1>注册账户</h1>

  {% form 'create_customer', novalidate: 'novalidate' %}
    {%- if form.errors -%}
      <div class="form-errors" style="color: red;">
        {{ form.errors | default_errors }}
      </div>
    {%- endif -%}

    <div class="field" style="margin-bottom: 15px;">
      <label for="RegisterForm-FirstName" style="display:block; text-align:left;">名字</label>
      <input 
        type="text" 
        name="customer[first_name]" 
        id="RegisterForm-FirstName" 
        autocomplete="given-name"
        style="width: 100%; padding: 8px;"
      >
    </div>

    <div class="field" style="margin-bottom: 15px;">
      <label for="RegisterForm-LastName" style="display:block; text-align:left;">姓氏</label>
      <input 
        type="text" 
        name="customer[last_name]" 
        id="RegisterForm-LastName" 
        autocomplete="family-name"
        style="width: 100%; padding: 8px;"
      >
    </div>

    <div class="field" style="margin-bottom: 15px;">
      <label for="RegisterForm-email" style="display:block; text-align:left;">邮箱</label>
      <input 
        type="email" 
        name="customer[email]" 
        id="RegisterForm-email" 
        autocomplete="email"
        style="width: 100%; padding: 8px;"
        required
      >
    </div>

    <div class="field" style="margin-bottom: 15px;">
      <label for="RegisterForm-password" style="display:block; text-align:left;">密码</label>
      <input 
        type="password" 
        name="customer[password]" 
        id="RegisterForm-password" 
        style="width: 100%; padding: 8px;"
        required
      >
    </div>

    <div class="actions">
      <button type="submit" style="padding: 10px 20px; background: #000; color: #fff; cursor: pointer;">
        注册
      </button>
    </div>
    
    <div style="margin-top: 15px;">
      <a href="{{ routes.account_login_url }}">已有账户？去登录</a>
    </div>
  {% endform %}
</div>

{% schema %}
{
  "name": "Customer Register",
  "settings": []
}
{% endschema %}